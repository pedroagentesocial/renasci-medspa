    { "source": "/services/hair-restoration-prp", "destination": "/services/restauracion-capilar-prp", "permanent": true },
    { "source": "/services/hair-restoration-stem-cells", "destination": "/services/stem-cells-treatment", "permanent": true },
    { "source": "/services/vaginal-rejuvenation-prp", "destination": "/services/rejuvenecimiento-vaginal-prp", "permanent": true },
    { "source": "/services/vaginal-rejuvenation-stem-cells", "destination": "/services/rejuvenecimiento-vaginal-celulas-madre", "permanent": true },
    { "source": "/services/lab-draw", "destination": "/services/bhrt-monthly-support", "permanent": true },
    { "source": "/services/peptides-bpc-157", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-cjc1295-ipamorelin", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-sermorelin", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-nad", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-ghku", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-vitamin-d", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-hair-growth", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/peptides-take-home", "destination": "/services/therapy-peptide", "permanent": true },
    { "source": "/services/iv-drips", "destination": "/services/iv-therapy", "permanent": true },
    { "source": "/services/im-injections", "destination": "/services/inyeccion-energia-b12", "permanent": true },
    { "source": "/services/b12-energy-injection", "destination": "/services/inyeccion-energia-b12", "permanent": true },
    { "source": "/services/fat-blaster-injections", "destination": "/services/inyecciones-fat-blaster", "permanent": true },
    { "source": "/services/b12-fat-blaster-double-effect", "destination": "/services/b12-fat-blaster", "permanent": true },
