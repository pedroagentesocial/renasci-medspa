    { "source": "/services/medically-supervised-weight-loss-program", "destination": "/services/medically-supervised-weight-loss", "permanent": true },
    { "source": "/services/personalized-facial-contour", "destination": "/services/contorno-facial-personalizado", "permanent": true },
    { "source": "/services/cheekbone-lift", "destination": "/services/cheekbone-pop", "permanent": true },
    { "source": "/services/mini-chin-reduction", "destination": "/services/mini-chin-up", "permanent": true },
    { "source": "/services/mini-lip-enhancement", "destination": "/services/mini-aumento-labios", "permanent": true },
    { "source": "/services/full-lip-augmentation", "destination": "/services/relleno-labios", "permanent": true },
    { "source": "/services/mega-lip-augmentation", "destination": "/services/mega-aumento-labios", "permanent": true },
    { "source": "/services/collagen-stimulation-sculptra", "destination": "/services/sculptra-colageno", "permanent": true },
    { "source": "/services/renasci-prf-gel-therapy", "destination": "/services/ez-gel-prf", "permanent": true },
    { "source": "/services/bhrt-setup-labs-consult", "destination": "/services/bhrt-setup-labs-consult", "permanent": false },
    { "source": "/sitemap-index.xml", "destination": "/sitemap.xml", "permanent": false },
    { "source": "/medical-spa-salt-lake-city", "destination": "/services", "permanent": true },
    { "source": "/medical-spa-midvale", "destination": "/contact", "permanent": true },
    { "source": "/medical-spa-sandy-utah", "destination": "/services", "permanent": true },
    { "source": "/medical-spa-murray-utah", "destination": "/services", "permanent": true },
    { "source": "/medical-spa-south-jordan-utah", "destination": "/services", "permanent": true },
    { "source": "/medical-spa-draper-utah", "destination": "/services", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
