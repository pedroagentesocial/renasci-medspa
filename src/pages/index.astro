---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { categorias, serviciosDestacados, getServicioBySlug } from '../data/services';

// Obtener servicios destacados
const serviciosHome = serviciosDestacados.map(slug => getServicioBySlug(slug)).filter(Boolean);
---

<BaseLayout 
  title="Renasci Medical Spa - Renueva tu piel"
  description="Tratamientos estéticos avanzados en Renasci Medical Spa. Botox, rellenos, sculptra y más. Renueva tu piel con los mejores especialistas."
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-soft via-white to-soft overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, #E94594 0%, transparent 50%), radial-gradient(circle at 75% 75%, #C8A08C 0%, transparent 50%);"></div>
    </div>
    
    <div class="container mx-auto px-4 py-20 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Contenido Hero -->
        <div class="text-center lg:text-left">
          <h1 class="font-display font-bold text-5xl lg:text-6xl text-dark mb-6 leading-tight">
            Renueva tu 
            <span class="text-primary">piel</span>
          </h1>
          
          <p class="text-xl text-graytxt mb-8 leading-relaxed max-w-lg mx-auto lg:mx-0">
            Descubre tratamientos estéticos de vanguardia que realzan tu belleza natural. 
            En Renasci Medical Spa, transformamos tu piel con la más alta tecnología.
          </p>
          
          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <CTAButton 
              href="#agendar" 
              variant="primary" 
              size="lg"
              class="animate-pulse hover:animate-none"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Agendar Ahora
            </CTAButton>
            
            <CTAButton 
              href="/services" 
              variant="outline" 
              size="lg"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
              Ver Servicios
            </CTAButton>
          </div>
          
          <!-- Stats -->
          <div class="grid grid-cols-3 gap-8 mt-12 pt-8 border-t border-gray-100">
            <div class="text-center">
              <div class="font-display font-bold text-2xl text-primary mb-1">500+</div>
              <div class="text-sm text-graytxt">Clientes Satisfechos</div>
            </div>
            <div class="text-center">
              <div class="font-display font-bold text-2xl text-primary mb-1">50+</div>
              <div class="text-sm text-graytxt">Tratamientos</div>
            </div>
            <div class="text-center">
              <div class="font-display font-bold text-2xl text-primary mb-1">5★</div>
              <div class="text-sm text-graytxt">Calificación</div>
            </div>
          </div>
        </div>
        
        <!-- Imagen Hero -->
        <div class="relative">
          <div class="relative z-10">
            <img 
              src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=elegant%20medical%20spa%20treatment%20room%20with%20modern%20equipment%2C%20soft%20lighting%2C%20clean%20white%20and%20pink%20aesthetic%2C%20professional%20beauty%20clinic%20interior&image_size=portrait_4_3"
              alt="Renasci Medical Spa - Sala de tratamientos moderna"
              class="rounded-2xl shadow-2xl w-full h-auto"
              width="600"
              height="800"
            />
          </div>
          
          <!-- Elementos decorativos -->
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-primary/10 rounded-full blur-xl"></div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-logo/10 rounded-full blur-xl"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Destacados -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-4xl text-dark mb-4">
          Servicios Destacados
        </h2>
        <p class="text-xl text-graytxt max-w-2xl mx-auto">
          Descubre nuestros tratamientos más populares, diseñados para realzar tu belleza natural
        </p>
      </div>
      
      <!-- Grid de servicios -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        {serviciosHome.map((servicio) => (
          <ServiceCard servicio={servicio} />
        ))}
      </div>
      
      <!-- CTA Ver todos -->
      <div class="text-center">
        <CTAButton href="/services" variant="primary" size="lg">
          Ver Todos los Servicios
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </CTAButton>
      </div>
    </div>
  </section>

  <!-- Antes y Después -->
  <section class="py-20 bg-soft">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Contenido -->
        <div>
          <h2 class="font-display font-bold text-4xl text-dark mb-6">
            Resultados que 
            <span class="text-primary">Transforman</span>
          </h2>
          
          <p class="text-lg text-graytxt mb-8 leading-relaxed">
            Nuestros tratamientos están respaldados por años de experiencia y la más alta tecnología. 
            Cada procedimiento está diseñado para brindarte resultados naturales y duraderos.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="bg-primary/10 rounded-full p-2 mr-4 mt-1">
                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-2">Resultados Naturales</h3>
                <p class="text-graytxt">Técnicas avanzadas que realzan tu belleza sin comprometer tu expresión natural.</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="bg-primary/10 rounded-full p-2 mr-4 mt-1">
                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-2">Tecnología de Vanguardia</h3>
                <p class="text-graytxt">Equipos de última generación y productos de la más alta calidad.</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="bg-primary/10 rounded-full p-2 mr-4 mt-1">
                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-2">Atención Personalizada</h3>
                <p class="text-graytxt">Cada tratamiento es diseñado específicamente para tus necesidades únicas.</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Imagen -->
        <div class="relative">
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=before%20and%20after%20beauty%20treatment%20results%2C%20professional%20medical%20spa%20photography%2C%20natural%20skin%20improvement%2C%20elegant%20presentation&image_size=square_hd"
            alt="Resultados antes y después de tratamientos Renasci"
            class="rounded-2xl shadow-xl w-full h-auto"
            width="600"
            height="600"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Membresía CTA -->
  <section class="py-20 bg-gradient-to-r from-primary to-primary/80 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-4xl mb-6">
        Únete a Renasci Membership
      </h2>
      
      <p class="text-xl mb-8 max-w-2xl mx-auto opacity-90">
        Accede a descuentos exclusivos, tratamientos prioritarios y beneficios especiales 
        con nuestros planes de membresía diseñados para ti.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          href="/membership" 
          variant="secondary"
          size="lg"
          class="bg-white text-primary hover:bg-gray-50"
        >
          Ver Planes de Membresía
        </CTAButton>
        
        <CTAButton 
          href="#agendar" 
          variant="outline"
          size="lg"
          class="border-white text-white hover:bg-white hover:text-primary"
        >
          Agendar Consulta
        </CTAButton>
      </div>
    </div>
  </section>

  <!-- Contacto/Agendar -->
  <section id="agendar" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-display font-bold text-4xl text-dark mb-4">
            Agenda tu Cita
          </h2>
          <p class="text-xl text-graytxt">
            Estamos listos para ayudarte a alcanzar tus objetivos de belleza
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 gap-12">
          <!-- Información de contacto -->
          <div class="space-y-8">
            <div>
              <h3 class="font-display font-semibold text-xl text-dark mb-4">Información de Contacto</h3>
              
              <div class="space-y-4">
                <div class="flex items-center">
                  <div class="bg-primary/10 rounded-full p-3 mr-4">
                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="font-semibold text-dark">Teléfono</div>
                    <div class="text-graytxt">(555) 123-4567</div>
                  </div>
                </div>
                
                <div class="flex items-center">
                  <div class="bg-primary/10 rounded-full p-3 mr-4">
                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="font-semibold text-dark">Dirección</div>
                    <div class="text-graytxt">123 Beauty Ave, Ciudad, Estado 12345</div>
                  </div>
                </div>
                
                <div class="flex items-center">
                  <div class="bg-primary/10 rounded-full p-3 mr-4">
                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="font-semibold text-dark">Horarios</div>
                    <div class="text-graytxt">Lun-Vie: 9:00-18:00<br>Sáb: 9:00-16:00</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Formulario de contacto -->
          <div class="bg-soft rounded-2xl p-8">
            <form class="space-y-6">
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label for="nombre" class="block text-sm font-semibold text-dark mb-2">Nombre</label>
                  <input 
                    type="text" 
                    id="nombre" 
                    name="nombre"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                    required
                  />
                </div>
                <div>
                  <label for="telefono" class="block text-sm font-semibold text-dark mb-2">Teléfono</label>
                  <input 
                    type="tel" 
                    id="telefono" 
                    name="telefono"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                    required
                  />
                </div>
              </div>
              
              <div>
                <label for="email" class="block text-sm font-semibold text-dark mb-2">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                  required
                />
              </div>
              
              <div>
                <label for="servicio" class="block text-sm font-semibold text-dark mb-2">Servicio de Interés</label>
                <select 
                  id="servicio" 
                  name="servicio"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                >
                  <option value="">Selecciona un servicio</option>
                  {categorias.map((categoria) => (
                    <optgroup label={categoria.nombre}>
                      {categoria.servicios.map((servicio) => (
                        <option value={servicio.slug}>{servicio.t}</option>
                      ))}
                    </optgroup>
                  ))}
                </select>
              </div>
              
              <div>
                <label for="mensaje" class="block text-sm font-semibold text-dark mb-2">Mensaje</label>
                <textarea 
                  id="mensaje" 
                  name="mensaje"
                  rows="4"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors resize-none"
                  placeholder="Cuéntanos sobre tus objetivos y preferencias..."
                ></textarea>
              </div>
              
              <CTAButton 
                type="submit"
                variant="primary" 
                size="lg"
                class="w-full"
              >
                Enviar Solicitud
              </CTAButton>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>