---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { serviciosUnificados } from '../data/services-unified';

// Obtener servicios destacados (primeros 8 servicios)
const serviciosHome = serviciosUnificados.slice(0, 8);
---

<BaseLayout 
  title="Renasci Medical Spa - Renueva tu piel"
  description="Tratamientos estéticos avanzados en Renasci Medical Spa. Botox, rellenos, sculptra y más. Renueva tu piel con los mejores especialistas."
>
  <!-- Hero Section with Video -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <video 
      autoplay 
      muted 
      loop 
      playsinline 
      poster="/img/hero-fallback.jpg"
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/video/hero.mp4" type="video/mp4">
    </video>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative z-10 px-6 max-w-3xl">
      <h1 class="font-display text-white text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Renueva tu piel<br>
        <span class="text-primary">Renew your glow</span>
      </h1>
      <p class="mt-4 text-white/90 text-lg md:text-xl font-body mb-8">
        Tratamientos estéticos de vanguardia para realzar tu belleza natural
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/#booking" 
          class="inline-flex items-center justify-center px-8 py-4 rounded-2xl font-semibold bg-primary text-white hover:opacity-90 active:translate-y-[1px] transition-all duration-200 focus-visible:ring-2 ring-primary/50 min-h-[44px]"
        >
          Agendar Ahora
        </a>
        <a 
          href="tel:+13855550123" 
          id="callBtn" 
          class="relative inline-flex items-center justify-center px-8 py-4 rounded-2xl font-semibold bg-call text-white hover:opacity-90 active:translate-y-[1px] transition-all duration-200 focus-visible:ring-2 ring-call/50 animate-pulseSoft overflow-hidden min-h-[44px]"
        >
          📞 (385) 555-0123
        </a>
      </div>
    </div>
  </section>

  <!-- JavaScript para filtros -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const filterPills = document.querySelectorAll('.filter-pill');
      const serviceCards = document.querySelectorAll('.service-card');

      filterPills.forEach(pill => {
        pill.addEventListener('click', function() {
          const filter = this.dataset.filter;
          
          // Update active pill
          filterPills.forEach(p => {
            p.classList.remove('active', 'bg-primary', 'text-white');
            p.classList.add('bg-gray-100', 'text-gray-700');
          });
          
          this.classList.add('active', 'bg-primary', 'text-white');
          this.classList.remove('bg-gray-100', 'text-gray-700');
          
          // Filter cards
          serviceCards.forEach(card => {
            const category = card.dataset.category;
            if (filter === 'all' || category === filter) {
              card.style.display = 'block';
              card.classList.remove('hidden');
            } else {
              card.style.display = 'none';
              card.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>

  <!-- Nuestros Servicios Section -->
  <section class="py-16 md:py-24 bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Título Principal -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-dark mb-4 font-poppins">
          Nuestros Servicios
          <span class="block text-primary text-2xl md:text-3xl font-normal">Our Services</span>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto font-dm-sans">
          Tratamientos estéticos de vanguardia para realzar tu belleza natural
        </p>
      </div>

      <!-- 3 Bloques Destacados "Ways to Elevate" -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
        <!-- Inyectables -->
        <div class="group relative overflow-hidden rounded-2xl aspect-[16/10] hover:scale-[1.03] transition-transform duration-300">
          <img 
            src="/img/services/inyectables-hero.jpg" 
            alt="Tratamientos de inyectables - Botox y rellenos dérmicos"
            class="absolute inset-0 w-full h-full object-cover"
          >
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-6 text-white">
            <h3 class="text-2xl font-bold mb-2 font-poppins">Inyectables</h3>
            <p class="text-white/90 mb-4 font-dm-sans">Botox, rellenos dérmicos y tratamientos de rejuvenecimiento</p>
            <a href="/services?cat=inyectables" class="inline-flex items-center text-white font-semibold hover:text-primary transition-colors">
              Ver más →
            </a>
          </div>
        </div>

        <!-- Skin & Laser -->
        <div class="group relative overflow-hidden rounded-2xl aspect-[16/10] hover:scale-[1.03] transition-transform duration-300">
          <img 
            src="/img/services/skin-laser-hero.jpg" 
            alt="Tratamientos de piel y láser - Rejuvenecimiento facial"
            class="absolute inset-0 w-full h-full object-cover"
          >
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-6 text-white">
            <h3 class="text-2xl font-bold mb-2 font-poppins">Skin & Laser</h3>
            <p class="text-white/90 mb-4 font-dm-sans">Tratamientos láser, microneedling y cuidado facial avanzado</p>
            <a href="/services?cat=skin-laser" class="inline-flex items-center text-white font-semibold hover:text-primary transition-colors">
              Ver más →
            </a>
          </div>
        </div>

        <!-- Cuerpo & Íntimo -->
        <div class="group relative overflow-hidden rounded-2xl aspect-[16/10] hover:scale-[1.03] transition-transform duration-300">
          <img 
            src="/img/services/cuerpo-intimo-hero.jpg" 
            alt="Tratamientos corporales e íntimos - Contorno y bienestar"
            class="absolute inset-0 w-full h-full object-cover"
          >
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-6 text-white">
            <h3 class="text-2xl font-bold mb-2 font-poppins">Cuerpo & Íntimo</h3>
            <p class="text-white/90 mb-4 font-dm-sans">Contorno corporal y tratamientos íntimos especializados</p>
            <a href="/services?cat=cuerpo-intimo" class="inline-flex items-center text-white font-semibold hover:text-primary transition-colors">
              Ver más →
            </a>
          </div>
        </div>
      </div>

      <!-- Pills de Filtro -->
      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <button class="filter-pill active px-4 py-2 rounded-full bg-primary text-white text-sm font-medium transition-all duration-200" data-filter="all">
          Todos
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="neurotoxinas">
          Neurotoxinas
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="rellenos">
          Rellenos/Sculptra
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="skin-laser">
          Skin & Laser
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="contorno">
          Contorno
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="intimo">
          Íntimo
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="cabello-piel">
          Cabello&Piel
        </button>
        <button class="filter-pill px-4 py-2 rounded-full bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-all duration-200" data-filter="bienestar">
          Bienestar
        </button>
      </div>

      <!-- Mosaico de Servicios (4:5 ratio) -->
      <div id="servicesGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
        {serviciosHome.map((service) => (
          <ServiceCard 
            service={service}
            lang="es"
          />
        ))}
      </div>

      <!-- Banner Membresía -->
      <div class="bg-white rounded-2xl p-8 text-center shadow-card border border-gray-100">
        <h3 class="text-2xl md:text-3xl font-bold text-dark mb-4 font-poppins">
          ¿Nuevo aquí? Conoce la Membresía Glow Society
        </h3>
        <p class="text-gray-600 mb-6 font-dm-sans text-lg">
          Accede a descuentos exclusivos y tratamientos premium con beneficios únicos
        </p>
        <a href="/membership" class="inline-flex items-center justify-center px-8 py-4 rounded-2xl font-semibold bg-primary text-white hover:opacity-90 active:translate-y-[1px] transition-all duration-200 focus-visible:ring-2 ring-primary/50 min-h-[44px]">
          Conocer Membresía
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div class="order-2 lg:order-1">
          <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-text mb-6">
            Experiencia y 
            <span class="text-primary">Excelencia</span>
          </h2>
          <p class="text-lg text-text/80 mb-6 leading-relaxed">
            En Renasci Medical Spa, combinamos la más avanzada tecnología médica con un enfoque personalizado para cada cliente. Nuestro equipo de especialistas certificados se dedica a brindar resultados excepcionales en un ambiente seguro y profesional.
          </p>
          <p class="text-lg text-text/80 mb-8 leading-relaxed">
            Desde tratamientos de rejuvenecimiento facial hasta procedimientos corporales innovadores, cada servicio está diseñado para realzar tu belleza natural y aumentar tu confianza.
          </p>
          
          <!-- Stats -->
          <div class="grid grid-cols-2 gap-6 mb-8">
            <div class="text-center p-4 bg-background rounded-lg">
              <div class="font-display font-bold text-2xl text-primary mb-1">500+</div>
              <div class="text-sm text-text/70 uppercase tracking-wide">Clientes Satisfechos</div>
            </div>
            <div class="text-center p-4 bg-background rounded-lg">
              <div class="font-display font-bold text-2xl text-primary mb-1">5+</div>
              <div class="text-sm text-text/70 uppercase tracking-wide">Años de Experiencia</div>
            </div>
          </div>

          <CTAButton 
            href="/about"
            variant="ghost"
            className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200"
          >
            Conoce Más Sobre Nosotros
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </CTAButton>
        </div>

        <!-- Image -->
        <div class="order-1 lg:order-2">
          <div class="relative">
            <img 
              src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
              alt="Professional medical spa treatment room"
              class="w-full h-96 lg:h-[500px] object-cover rounded-2xl shadow-xl"
              loading="lazy"
            />
            <!-- Decorative element -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-primary/10 rounded-full blur-xl"></div>
            <div class="absolute -top-6 -left-6 w-32 h-32 bg-secondary/10 rounded-full blur-xl"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Membership CTA Section -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-primary/5 to-secondary/5">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-text mb-6">
          Únete a Nuestra
          <span class="text-primary">Membresía</span>
        </h2>
        <p class="text-lg md:text-xl text-text/80 mb-8 leading-relaxed">
          Accede a descuentos exclusivos, tratamientos prioritarios y beneficios especiales diseñados para nuestros miembros más valorados.
        </p>
        
        <!-- Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-card transition-all duration-200">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-lg text-text mb-2">Descuentos Exclusivos</h3>
            <p class="text-text/70">Hasta 20% de descuento en todos nuestros servicios</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-card transition-all duration-200">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-lg text-text mb-2">Acceso Prioritario</h3>
            <p class="text-text/70">Reserva tus citas con prioridad y flexibilidad</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm hover:shadow-card transition-all duration-200">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-lg text-text mb-2">Beneficios Especiales</h3>
            <p class="text-text/70">Tratamientos gratuitos y productos exclusivos</p>
          </div>
        </div>

        <CTAButton 
          href="/membership"
          variant="primary"
          className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200"
        >
          Conoce Nuestra Membresía
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </CTAButton>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="py-16 lg:py-24 bg-text text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl mb-6">
        ¿Listo para
        <span class="text-primary">Transformarte?</span>
      </h2>
      <p class="text-lg md:text-xl text-white/80 mb-8 max-w-3xl mx-auto leading-relaxed">
        Agenda tu consulta gratuita hoy y descubre cómo podemos ayudarte a alcanzar tus objetivos estéticos con tratamientos personalizados.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <CTAButton 
          href="/contact"
          variant="primary"
          className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200"
        >
          Agendar Consulta Gratuita
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </CTAButton>
        
        <a 
          href="tel:+13855550123"
          class="call-cta-button inline-flex items-center gap-3 px-8 py-4 bg-[#10B981] text-white rounded-2xl font-semibold text-lg transition-all duration-200 hover:opacity-90 hover:-translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#10B981]/50 animate-pulse-soft"
          aria-label="Llamar Renasci"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          (385) 555-0123
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Hero call button ripple effect
  function initHeroCallButtonRipple() {
    const heroCallButton = document.querySelector('.call-hero-button') as HTMLElement;
    
    if (heroCallButton) {
      heroCallButton.addEventListener('pointerdown', function(this: HTMLElement, e: PointerEvent) {
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;
        
        const ripple = document.createElement('span');
        ripple.style.cssText = `
          position: absolute;
          width: ${size}px;
          height: ${size}px;
          left: ${x}px;
          top: ${y}px;
          background: rgba(255, 255, 255, 0.3);
          border-radius: 50%;
          transform: scale(0);
          animation: ripple 600ms ease-out;
          pointer-events: none;
        `;
        
        this.style.position = 'relative';
        this.style.overflow = 'hidden';
        this.appendChild(ripple);
        
        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    }
  }

  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', initHeroCallButtonRipple);
</script>

<style>
  /* Pulse animation for call button */
  @keyframes pulse-soft {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
    }
  }

  .animate-pulse-soft {
    animation: pulse-soft 2s infinite;
  }

  /* Ripple animation */
  @keyframes ripple {
    to {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Hover effects for cards */
  .hover\:shadow-card:hover {
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  /* Micro-interactions for links */
  .nav-link {
    position: relative;
    transition: all 200ms ease-out;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: currentColor;
    transition: width 200ms ease-out;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Smooth transitions for all interactive elements */
  a, button, .service-card {
    transition: all 200ms ease-out;
  }

  /* Prevent layout shift on hover */
  .hover\:scale-\[1\.02\]:hover {
    transform: scale(1.02);
  }
</style>