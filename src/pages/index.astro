  <script>
    (function(){
      const el = document.getElementById('heroTitleText');
      const url = new URL(window.location.href);
      const script = (url.searchParams.get('script') || '').toLowerCase();
      if (!el) return;
      if (script === 'sacramento') {
        el.classList.remove('font-hero-elmatia');
        el.classList.add('font-hero-sacramento');
      } else {
        el.classList.remove('font-hero-sacramento');
        el.classList.add('font-hero-elmatia');
      }
    })();
  </script>
