---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
 
import HeroHotspots from '../components/HeroHotspots.astro';
import OurServices from '../components/ourservices.astro';
import MembershipCTA from '../components/MembershipCTA.astro';
import SimpleContactForm from '../components/SimpleContactForm.astro';
import FAQ from '../components/FAQ.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
---

<BaseLayout 
  title="Renasci Medical Spa - Renueva tu piel"
  description="Tratamientos estéticos avanzados en Renasci Medical Spa. Botox, rellenos, sculptra y más. Renueva tu piel con los mejores especialistas."
>
  <!-- Hero Section with Slider -->
  <section class="relative min-h-[85vh] md:min-h-screen flex items-center overflow-hidden">
    <!-- Slides -->
    <div id="heroSlides" class="absolute inset-0">
      <!-- Slide 0: Image -->
      <div class="hero-slide opacity-100 transition-opacity duration-700 ease-out">
        <div 
          class="absolute inset-0 w-full h-full bg-cover bg-center"
          style="background-image:url('/img/services/hero-index.jpeg?v=2')"
          aria-label="Renasci Hero"
        ></div>
        <div class="absolute inset-0 bg-black/40"></div>

        <!-- Hotspots SOLO para slide 0 -->
        <div class="hidden md:block">
        <HeroHotspots 
          hotspots={[
            {
              x: 51,
              y: 60,
              title: "Botox Lip Flip",
              titleEs: "Botox Lip Flip",
              titleEn: "Botox Lip Flip",
              line: "Define el labio superior naturalmente",
              lineEs: "Define el labio superior naturalmente",
              lineEn: "Naturally defines the upper lip",
              href: "/services/botox-lip-flip",
            },
            {
              x: 49,
              y: 30,
              title: "Botox",
              titleEs: "Botox",
              titleEn: "Botox",
              line: "Suaviza líneas del entrecejo",
              lineEs: "Suaviza líneas del entrecejo",
              lineEn: "Smooths glabella frown lines",
              href: "/services/botox"
            },
            {
              x: 56,
              y: 83,
              title: "Nefertiti Neck Lift",
              titleEs: "Lifting de Cuello Nefertiti",
              titleEn: "Nefertiti Neck Lift",
              line: "Define y rejuvenece el cuello",
              lineEs: "Define y rejuvenece el cuello",
              lineEn: "Defines and rejuvenates the neck",
              href: "/services/nefertiti-neck-lift"
            },
            {
              x: 49,
              y: 78,
              title: "ChinBella",
              titleEs: "ChinBella",
              titleEn: "ChinBella",
              line: "Reducción de papada y mentón",
              lineEs: "Reducción de papada y mentón",
              lineEn: "Chin and double-chin contouring",
              href: "/services/chinbella"
            },
            {
              x: 60,
              y: 40,
              title: "Neurotoxin Injections",
              titleEs: "Inyecciones de Neurotoxina",
              titleEn: "Neurotoxin Injections",
              line: "Trata líneas perioculares (contorno de ojos)",
              lineEs: "Trata líneas perioculares (contorno de ojos)",
              lineEn: "Treats periocular (eye contour) lines",
              href: "/services/neurotoxin-injections"
            },
            {
              x: 42,
              y: 46,
              title: "Botox en Pómulos",
              titleEs: "Botox en Pómulos",
              titleEn: "Cheekbone Lift",
              line: "Realce y definición del pómulo",
              lineEs: "Realce y definición del pómulo",
              lineEn: "Enhance and define cheekbones",
              href: "/services/cheekbone-lift"
            }
          ]}
        />
        </div>
      </div>
      <!-- Slide 1: Image -->
      <div class="hero-slide opacity-0 pointer-events-none transition-opacity duration-700 ease-out membership-slide">
        <div 
          class="absolute inset-0 w-full h-full bg-cover bg-center membership-bg"
          style="background-image:url('/img/services/banner.jpg')"
          aria-label="Renasci Membership"
        ></div>
        <div class="absolute inset-0 bg-black/40"></div>
      </div>
    </div>

    <!-- Título del hero (solo visible en slide 0) -->
    <div id="heroTitle" class="relative z-10 px-6 max-w-4xl mx-auto sm:ml-8 lg:ml-16">
      <h1 class="font-rougescript text-white text-5xl md:text-7xl lg:text-8xl font-normal tracking-tight mb-6 text-center md:text-left" id="heroTitleText">
        <span data-i18n="hero.renew_prefix">Renueva tu</span> <span data-i18n="hero.renew_highlight">Piel</span>
      </h1>
      <p class="text-white/80 text-base md:text-xl leading-relaxed mb-6 text-left max-w-md md:max-w-lg" style="text-align: justify;">
        Belleza que se tranforma contigo, guiada por medicina regenerativa y resultados que respetan tu esencia.
      </p>
      <div class="flex justify-center md:justify-start">
        <a 
          href="/services" 
          class="inline-flex items-center gap-2 px-6 md:px-8 py-3 md:py-4 rounded-[48px] font-semibold bg-[#F3A2A7] text-white text-sm md:text-base hover:opacity-90 active:translate-y-[1px] transition-all duración-200 focus-visible:ring-2 ring-[#F3A2A7]/50 min-h-[38px] md:min-h-[44px]"
        >
          <span data-i18n="cta.view_services">Conoce nuestros servicios</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Overlay de slide 1 (solo visible en imagen de membresía) -->
    <div id="heroMembershipOverlay" class="absolute inset-0 z-10" style="display:none">
      <div class="absolute left-0 right-0 top-20 sm:top-24 md:hidden px-6">
        <h2 class="font-rougescript text-white text-center text-3xl sm:text-4xl tracking-tight mb-4">
          <span data-i18n="hero.memberships_title_prefix">Conoce Nuestras</span> <span class="text-[#F3A2A7]" data-i18n="hero.memberships_title_highlight">Membresías</span>
        </h2>
      </div>
      <div class="absolute right-6 sm:right-10 lg:right-16 top-28 sm:top-32 lg:top-36 hidden md:block">
        <h2 class="font-rougescript text-white text-right text-6xl lg:text-7xl tracking-tight mb-4">
          <span data-i18n="hero.memberships_title_prefix">Conoce Nuestras</span> <span class="text-[#F3A2A7]" data-i18n="hero.memberships_title_highlight">Membresías</span>
        </h2>
      </div>
      <div class="absolute left-0 right-0 bottom-24 sm:bottom-28 md:hidden flex justify-center px-6">
        <a 
          href="/membership" 
          class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold text-sm bg-[#AABFA8] text-white hover:opacity-90 active:translate-y-[1px] transition-all duration-200 focus-visible:ring-2 ring-[#AABFA8]/50 min-h-[44px] w-full max-w-xs justify-center"
        >
          <span data-i18n="cta.go_membership">Ir a Membresía</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
      <div class="absolute right-6 sm:right-10 lg:right-16 bottom-12 sm:bottom-16 lg:bottom-20 hidden md:block">
        <a 
          href="/membership" 
          class="inline-flex items-center gap-2 px-8 py-4 rounded-[48px] font-semibold bg-[#AABFA8] text-white hover:opacity-90 active:translate-y-[1px] transition-all duration-200 focus-visible:ring-2 ring-[#AABFA8]/50 min-h-[44px]"
        >
          <span data-i18n="cta.go_membership">Ir a Membresía</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Slider Indicators (bar for activo, círculo para inactivo) -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2 md:gap-4 z-10">
      <button id="heroToggle" class="flex items-center justify-center w-8 h-8 md:w-9 md:h-9 rounded-full bg-white/20 text-white hover:bg-white/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50" aria-label="Pause slider">
        <svg id="heroToggleIcon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <rect x="6" y="5" width="4" height="14" rx="1" stroke-width="2" />
          <rect x="14" y="5" width="4" height="14" rx="1" stroke-width="2" />
        </svg>
      </button>
      <!-- Indicator for slide 0 -->
      <button class="indicator" data-slide="0" aria-label="Slide 1">
        <div class="bar w-28 md:w-40 h-1 bg-white/30 rounded-full overflow-hidden"><div class="fill h-full bg-[#F3A2A7] w-0"></div></div>
        <div class="circle w-6 h-6">
          <svg class="w-6 h-6" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9" stroke="rgba(255,255,255,0.3)" stroke-width="2" fill="none"/>
            <circle class="circle-progress" cx="12" cy="12" r="9" stroke="#F3A2A7" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="56.5" stroke-dashoffset="56.5"/>
          </svg>
        </div>
      </button>
      <!-- Indicator for slide 1 -->
      <button class="indicator" data-slide="1" aria-label="Slide 2">
        <div class="bar w-28 md:w-40 h-1 bg-white/30 rounded-full overflow-hidden"><div class="fill h-full bg-[#F3A2A7] w-0"></div></div>
        <div class="circle w-6 h-6">
          <svg class="w-6 h-6" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9" stroke="rgba(255,255,255,0.3)" stroke-width="2" fill="none"/>
            <circle class="circle-progress" cx="12" cy="12" r="9" stroke="#F3A2A7" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="56.5" stroke-dashoffset="56.5"/>
          </svg>
        </div>
      </button>
    </div>
  </section>

  <style>
    @font-face {
      font-family: 'Rouge Script';
      src: url('/src/styles/fonts/RougeScript-Regular.ttf') format('truetype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    .font-rougescript {
      font-family: 'Rouge Script', cursive;
      letter-spacing: -0.02em;
      font-style: italic;
    }
  </style>

  <OurServices />

  <!-- Announcement: IgniteRF -->
  <section class="py-6 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-black">
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-[#F3A2A7] text-black text-xs font-semibold mr-3">
            <span data-i18n="home.announce.igniterf_badge">Novedad</span>
          </span>
          <span class="font-display text-lg md:text-xl font-bold">
            <span data-i18n="home.announce.igniterf_title">IgniteRF by InMode</span>
          </span>
          <span class="ml-2 text-black/70">
            <span data-i18n="home.announce.igniterf_copy">Nueva plataforma RFAL para contracción de tejido — disponible en Renasci.</span>
          </span>
        </div>
        <a href="/services/igniterf" class="inline-flex items-center gap-2 px-5 py-2 rounded-[48px] bg-[#AABFA8] text-white font-semibold hover:opacity-90 transition-all">
          <span data-i18n="home.announce.igniterf_cta">Saber más</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <MembershipCTA />

  <!-- JavaScript para filtros -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const filterPills = document.querySelectorAll('.filter-pill');
      const serviceCards = document.querySelectorAll('.service-card');

      filterPills.forEach((pill) => {
        pill.addEventListener('click', (event) => {
          const pillEl = event.currentTarget as HTMLElement | null;
          if (!pillEl) return;
          const filter = pillEl.dataset.filter;
          
          filterPills.forEach((p) => {
            const pEl = p as HTMLElement;
            pEl.classList.remove('active', 'bg-primary', 'text-white');
            pEl.classList.add('bg-gray-100', 'text-gray-700');
          });
          
          pillEl.classList.add('active', 'bg-primary', 'text-white');
          pillEl.classList.remove('bg-gray-100', 'text-gray-700');
          
          serviceCards.forEach((card) => {
            const cardEl = card as HTMLElement;
            const category = cardEl.dataset.category;
            if (filter === 'all' || category === filter) {
              cardEl.style.display = 'block';
              cardEl.classList.remove('hidden');
            } else {
              cardEl.style.display = 'none';
              cardEl.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>

  

  <!-- About Section -->
  <section class="pt-12 lg:pt-16 pb-16 lg:pb-24 bg-white relative overflow-hidden text-black">
    <!-- Animated Background Patterns -->
      <div class="absolute inset-0 pointer-events-none">
      <!-- Floating Stars -->
      <div class="floating-star absolute top-20 left-10 w-2 h-2 bg-[#F3A2A7]/20 rounded-full animate-float-slow"></div>
      <div class="floating-star absolute top-32 right-20 w-1.5 h-1.5 bg-[#F3A2A7]/15 rounded-full animate-float-medium" style="animation-delay: 1s;"></div>
      <div class="floating-star absolute top-48 left-1/4 w-1 h-1 bg-[#F3A2A7]/25 rounded-full animate-float-fast" style="animation-delay: 2s;"></div>
      <div class="floating-star absolute bottom-32 right-1/3 w-2.5 h-2.5 bg-[#F3A2A7]/10 rounded-full animate-float-slow" style="animation-delay: 0.5s;"></div>
      <div class="floating-star absolute bottom-48 left-16 w-1.5 h-1.5 bg-[#F3A2A7]/20 rounded-full animate-float-medium" style="animation-delay: 1.5s;"></div>
      
      <!-- Floating Bubbles -->
      <div class="floating-bubble absolute top-16 right-32 w-8 h-8 bg-[#F3A2A7]/5 rounded-full animate-bubble-rise"></div>
      <div class="floating-bubble absolute top-40 left-20 w-12 h-12 bg-[#F3A2A7]/8 rounded-full animate-bubble-rise" style="animation-delay: 2s;"></div>
      <div class="floating-bubble absolute bottom-20 right-16 w-6 h-6 bg-[#F3A2A7]/6 rounded-full animate-bubble-rise" style="animation-delay: 1s;"></div>
      <div class="floating-bubble absolute bottom-40 left-1/3 w-10 h-10 bg-[#F3A2A7]/4 rounded-full animate-bubble-rise" style="animation-delay: 3s;"></div>
      
      <!-- Geometric Shapes -->
      <div class="geometric-shape absolute top-24 right-1/4 w-4 h-4 border border-[#F3A2A7]/15 rotate-45 animate-rotate-slow"></div>
      <div class="geometric-shape absolute bottom-28 left-1/4 w-6 h-6 border border-[#F3A2A7]/10 animate-rotate-reverse" style="animation-delay: 1s;"></div>
      
      <!-- Subtle Gradient Orbs -->
      <div class="gradient-orb absolute top-1/4 left-8 w-20 h-20 bg-gradient-to-br from-[#F3A2A7]/5 to-transparent rounded-full blur-sm animate-pulse-gentle"></div>
      <div class="gradient-orb absolute bottom-1/4 right-12 w-16 h-16 bg-gradient-to-br from-[#F3A2A7]/8 to-transparent rounded-full blur-sm animate-pulse-gentle" style="animation-delay: 2s;"></div>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[40%_60%] gap-12 lg:gap-16 items-start">
        <!-- Content -->
        <div class="order-2 lg:order-1 lg:mt-12 w-full lg:max-w-none">
          <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-black mb-6">
            Renasci® <span class="text-[#F3A2A7]">Experience</span>
          </h2>
          <p class="text-lg text-black/80 mb-6 leading-relaxed max-w-none">
            At Renasci Medical Spa, we combine advanced medical technology with a personalized approach for every client. Our certified specialists deliver exceptional results in a safe, professional environment.
          </p>
          <p class="text-lg text-black/80 mb-8 leading-relaxed max-w-none">
            From facial rejuvenation to innovative body treatments, every service is designed to enhance your natural beauty and boost your confidence.
          </p>

          <CTAButton 
            href="/about"
            variant="primary"
            className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200"
          >
            <span>More about us</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </CTAButton>
        </div>

        <!-- Image -->
        <div class="order-1 lg:order-2 -mx-4 sm:-mx-6 lg:mx-0 lg:-ml-6">
          <div class="relative">
            <img 
              src="/img/about.jpg"
              alt="Renasci Medical Spa"
              class="w-full h-80 sm:h-96 lg:h-[520px] object-contain"
              loading="lazy"
            />
            <!-- Enhanced Decorative elements -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-[#F3A2A7]/15 rounded-full blur-xl animate-pulse-gentle"></div>
            <div class="absolute -top-6 -left-6 w-32 h-32 bg-[#F3A2A7]/10 rounded-full blur-xl animate-pulse-gentle" style="animation-delay: 1s;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <TestimonialsSection />
  <SimpleContactForm />

  
  
  </BaseLayout>

<script>
  // Hero call button ripple effect
  function initHeroCallButtonRipple() {
    const heroCallButton = document.querySelector('.call-hero-button') as HTMLElement;
    
    if (heroCallButton) {
      heroCallButton.addEventListener('pointerdown', function(this: HTMLElement, e: PointerEvent) {
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;
        
        const ripple = document.createElement('span');
        ripple.style.cssText = `
          position: absolute;
          width: ${size}px;
          height: ${size}px;
          left: ${x}px;
          top: ${y}px;
          background: rgba(255, 255, 255, 0.3);
          border-radius: 50%;
          transform: scale(0);
          animation: ripple 600ms ease-out;
          pointer-events: none;
        `;
        
        this.style.position = 'relative';
        this.style.overflow = 'hidden';
        this.appendChild(ripple);
        
        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    }
  }

  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', initHeroCallButtonRipple);

  // Hero slider logic
  (function initHeroSlider() {
    const slideDuration = 20000; // 20s per slide
    const slides = Array.from(document.querySelectorAll('.hero-slide')) as HTMLElement[];
    const indicators = Array.from(document.querySelectorAll('.indicator')) as HTMLElement[];
    const toggleBtn = document.getElementById('heroToggle') as HTMLButtonElement | null;
    const toggleIcon = document.getElementById('heroToggleIcon') as SVGElement | null;
    let current = 0;
    let advanceTimer: number | null = null;
    let isPaused = false;
    let remainingMs = slideDuration;
    let lastProgress = 0;
    let pausedByVisibility = false;
    const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function freezeIndicators() {
      const activeInd = indicators[current];
      if (!activeInd) return;
      const bar = activeInd.querySelector('.bar') as HTMLElement | null;
      const fill = activeInd.querySelector('.bar .fill') as HTMLElement | null;
      if (bar && fill) {
        const bw = bar.getBoundingClientRect().width;
        const fw = fill.getBoundingClientRect().width;
        fill.style.transition = 'none';
        if (bw > 0) {
          lastProgress = Math.min(1, Math.max(0, fw / bw));
          fill.style.width = `${lastProgress * 100}%`;
          remainingMs = Math.max(1, Math.round(slideDuration * (1 - lastProgress)));
        } else {
          lastProgress = 0;
          remainingMs = slideDuration;
        }
      }
      const circle = activeInd.querySelector('.circle .circle-progress') as SVGCircleElement | null;
      if (circle) {
        const cs = window.getComputedStyle(circle);
        const dash = cs.getPropertyValue('stroke-dashoffset') || circle.style.strokeDashoffset || '0';
        circle.style.transition = 'none';
        circle.style.strokeDashoffset = dash;
      }
    }

    function animateIndicator(indEl: HTMLElement, active: boolean) {
      const barFill = indEl.querySelector('.bar .fill') as HTMLElement | null;
      const circleProg = indEl.querySelector('.circle .circle-progress') as SVGCircleElement | null;
      if (active) {
        indEl.classList.add('active');
        indEl.classList.remove('inactive');
        if (barFill) {
          barFill.style.transition = 'none';
          barFill.style.width = '0%';
          void barFill.offsetWidth;
          barFill.style.transition = `width ${slideDuration}ms linear`;
          barFill.style.width = '100%';
        }
        if (circleProg) {
          circleProg.style.transition = 'none';
          circleProg.style.strokeDashoffset = '56.5';
        }
      } else {
        indEl.classList.add('inactive');
        indEl.classList.remove('active');
        if (barFill) {
          barFill.style.transition = 'none';
          barFill.style.width = '0%';
        }
        if (circleProg) {
          circleProg.style.transition = 'none';
          circleProg.style.strokeDashoffset = '56.5';
          void circleProg.getBoundingClientRect();
          circleProg.style.transition = `stroke-dashoffset ${slideDuration}ms linear`;
          circleProg.style.strokeDashoffset = '0';
        }
      }
    }

    function setActive(index: number) {
      current = index;
      slides.forEach((s, i) => {
        if (i === index) {
          s.classList.remove('opacity-0', 'pointer-events-none');
          s.classList.add('opacity-100');
        } else {
          s.classList.remove('opacity-100');
          s.classList.add('opacity-0', 'pointer-events-none');
        }
      });
      const titleEl = document.getElementById('heroTitle');
      const membershipEl = document.getElementById('heroMembershipOverlay');
      if (titleEl) {
        titleEl.style.display = index === 0 ? '' : 'none';
      }
      if (membershipEl) {
        (membershipEl as HTMLElement).style.display = index === 1 ? '' : 'none';
      }
      indicators.forEach((ind, i) => animateIndicator(ind, i === index));
      try { localStorage.setItem('heroSliderCurrent', String(current)); } catch {}
      lastProgress = 0;
      remainingMs = slideDuration;
      if (advanceTimer) window.clearTimeout(advanceTimer);
      if (!isPaused) {
        advanceTimer = window.setTimeout(() => setActive((current + 1) % slides.length), remainingMs);
      } else {
        freezeIndicators();
      }
    }

    indicators.forEach(ind => {
      ind.addEventListener('click', () => {
        const target = parseInt(ind.getAttribute('data-slide') || '0', 10);
        if (target !== current) setActive(target);
      });
    });

    // Apply initial paused state from storage and reduced motion
    try {
      const stored = localStorage.getItem('heroSliderPaused');
      if (stored === 'true') {
        isPaused = true;
        if (toggleIcon) toggleIcon.innerHTML = '<polygon points="8,5 8,19 19,12" fill="currentColor" />';
        toggleBtn?.setAttribute('aria-label', 'Play slider');
      }
    } catch {}
    if (prefersReduced) {
      isPaused = true;
      try { localStorage.setItem('heroSliderPaused', 'true'); } catch {}
      if (toggleIcon) toggleIcon.innerHTML = '<polygon points="8,5 8,19 19,12" fill="currentColor" />';
      toggleBtn?.setAttribute('aria-label', 'Play slider');
    }
    let initialIndex = 0;
    try {
      const storedIdx = parseInt(localStorage.getItem('heroSliderCurrent') || '0', 10);
      if (!Number.isNaN(storedIdx)) initialIndex = Math.max(0, Math.min(storedIdx, slides.length - 1));
    } catch {}
    setActive(initialIndex);

    function setPlayState(paused: boolean) {
      isPaused = paused;
      if (advanceTimer) { window.clearTimeout(advanceTimer); advanceTimer = null; }
      if (paused) {
        freezeIndicators();
      } else {
        // Resume from the current progress without restarting
        const activeInd = indicators[current];
        if (activeInd) {
          const bar = activeInd.querySelector('.bar') as HTMLElement | null;
          const fill = activeInd.querySelector('.bar .fill') as HTMLElement | null;
          if (bar && fill) {
            fill.style.transition = 'none';
            void (fill as any).offsetWidth;
            fill.style.transition = `width ${remainingMs}ms linear`;
            fill.style.width = '100%';
          }
          const circle = activeInd.querySelector('.circle .circle-progress') as SVGCircleElement | null;
          if (circle) {
            circle.style.transition = 'none';
            void circle.getBoundingClientRect();
            circle.style.transition = `stroke-dashoffset ${remainingMs}ms linear`;
            circle.style.strokeDashoffset = '0';
          }
        }
        advanceTimer = window.setTimeout(() => setActive((current + 1) % slides.length), remainingMs);
      }
      if (toggleIcon) {
        // Update icon: pause when playing, play when paused
        toggleIcon.innerHTML = paused
          ? '<polygon points="8,5 8,19 19,12" fill="currentColor" />'
          : '<rect x="6" y="5" width="4" height="14" rx="1" stroke-width="2" /><rect x="14" y="5" width="4" height="14" rx="1" stroke-width="2" />';
      }
      if (toggleBtn) toggleBtn.setAttribute('aria-label', paused ? 'Play slider' : 'Pause slider');
    }

    toggleBtn?.addEventListener('click', () => {
      const next = !isPaused;
      try { localStorage.setItem('heroSliderPaused', String(next)); } catch {}
      setPlayState(next);
    });

    // Pause on tab hidden; resume on visible if not user-paused
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (!isPaused) {
          pausedByVisibility = true;
          setPlayState(true);
        }
      } else {
        let userPaused = false;
        try { userPaused = localStorage.getItem('heroSliderPaused') === 'true'; } catch {}
        if (pausedByVisibility && !userPaused) {
          pausedByVisibility = false;
          setPlayState(false);
        }
      }
    });
  })();
</script>

