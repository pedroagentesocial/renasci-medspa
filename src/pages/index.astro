---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
 
import HeroHotspots from '../components/HeroHotspots.astro';
import OurServices from '../components/ourservices.astro';
import MembershipCTA from '../components/MembershipCTA.astro';
import CarouselServices from '../components/CarouselServices.astro';
import SimpleContactForm from '../components/SimpleContactForm.astro';
import FAQ from '../components/FAQ.astro';
import { serviciosUnificados } from '../data/services-unified';

// Obtener servicios destacados (primeros 8 servicios)
const serviciosHome = serviciosUnificados.slice(0, 8);
