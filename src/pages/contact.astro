---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import ContactFormMembership from '../components/ContactFormMembership.astro';
import TransformCTA from '../components/TransformCTA.astro';
---

<BaseLayout 
  title="Contacto - Renasci Medical Spa"
  description="Contáctanos para agendar tu consulta gratuita. Estamos aquí para ayudarte en tu transformación de belleza y bienestar."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <h1 class="font-display font-bold text-5xl md:text-6xl mb-4"><span data-t-es="Contáctanos" data-t-en="Contact Us">Contáctanos</span></h1>
        <p class="text-lg md:text-xl text-white/80 mb-8" data-t-es="Tu transformación comienza con una consulta gratuita. Estamos listos para ayudarte." data-t-en="Your transformation begins with a free consultation. We are ready to help you.">Tu transformación comienza con una consulta gratuita. Estamos listos para ayudarte.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton href="tel:+13856092840" variant="mint" className="!px-6 !py-3 focus-visible:ring-[#AABFA8]/50">
            <span data-t-es="Llama Ahora" data-t-en="Call Now">Llama Ahora</span>
          </CTAButton>
          <CTAButton href="https://wa.me/13856092840" variant="call" className="!px-6 !py-3 focus-visible:ring-[#1DD1A1]/50">
            <span>WhatsApp</span>
          </CTAButton>
          <CTAButton href="#contacto" variant="primary" className="!px-6 !py-3 focus-visible:ring-[#F3A2A7]/50">
            <span data-t-es="Agenda Online" data-t-en="Book Online">Agenda Online</span>
          </CTAButton>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <span class="h-[2px] w-16 bg-[#F3A2A7]"></span>
          <span class="mx-3 w-10 h-10 rounded-full bg-[#F3A2A7] text-white flex items-center justify-center">•</span>
          <span class="h-[2px] w-16 bg-[#F3A2A7]"></span>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-[#F3A2A7]"><span data-t-es="Múltiples Formas de Conectar" data-t-en="Multiple Ways to Connect">Múltiples Formas de Conectar</span></h2>
        <p class="text-xl text-graytxt max-w-3xl mx-auto" data-t-es="Elige la forma más conveniente para ti: teléfono, email o visita." data-t-en="Choose the most convenient option for you: phone, email or visit.">Elige la forma más conveniente para ti: teléfono, email o visita.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="text-center p-8 bg-[#F3A2A7]/5 rounded-3xl hover:bg-[#F3A2A7]/10 transition-colors">
          <div class="w-16 h-16 bg-[#F3A2A7] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <h3 class="font-bold text-2xl text-text mb-2" data-t-es="Llámanos" data-t-en="Call Us">Llámanos</h3>
          <p class="text-graytxt mb-3" data-t-es="Habla directamente con nuestro equipo" data-t-en="Speak directly with our team">Habla directamente con nuestro equipo</p>
          <a href="tel:+13856092840" class="text-[#F3A2A7] font-bold text-xl">385 609 2840</a>
          <p class="text-sm text-graytxt mt-2" data-t-es="Lun - Vie: 9:00 AM - 7:00 PM" data-t-en="Mon - Fri: 9:00 AM - 7:00 PM">Lun - Vie: 9:00 AM - 7:00 PM</p>
        </div>
        <div class="text-center p-8 bg-[#AABFA8]/5 rounded-3xl hover:bg-[#AABFA8]/10 transition-colors">
          <div class="w-16 h-16 bg-[#AABFA8] rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-bold text-2xl text-text mb-2" data-t-es="Escríbenos" data-t-en="Write to Us">Escríbenos</h3>
          <p class="text-graytxt mb-3" data-t-es="Responderemos pronto tu mensaje" data-t-en="We'll reply to your message soon">Responderemos pronto tu mensaje</p>
          <a href="mailto:info@renascimedspa.com" class="text-[#AABFA8] font-bold text-xl">info@renascimedspa.com</a>
          <p class="text-sm text-graytxt mt-2" data-t-es="Respuesta en 24 horas" data-t-en="Response within 24 hours">Respuesta en 24 horas</p>
        </div>
        <div class="text-center p-8 bg-logo/5 rounded-3xl hover:bg-logo/10 transition-colors">
          <div class="w-16 h-16 bg-logo rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-bold text-2xl text-text mb-2" data-t-es="Visítanos" data-t-en="Visit Us">Visítanos</h3>
          <p class="text-graytxt mb-3" data-t-es="Conoce nuestras instalaciones" data-t-en="See our facilities">Conoce nuestras instalaciones</p>
          <p class="text-logo font-bold">6770 S 900 E, Midvale, UT 84047</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white text-black">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center mb-6">
            <span class="h-[2px] w-16 bg-[#F3A2A7]"></span>
            <span class="mx-3 w-10 h-10 rounded-full bg-[#F3A2A7] text-white flex items-center justify-center">•</span>
            <span class="h-[2px] w-16 bg-[#F3A2A7]"></span>
          </div>
          <h2 class="font-display font-bold text-4xl md:text-5xl text-[#F3A2A7]"><span data-t-es="Horarios de Atención" data-t-en="Opening Hours">Horarios de Atención</span></h2>
          <p class="text-xl text-gray-700" data-t-es="Estamos aquí cuando nos necesites." data-t-en="We are here when you need us.">Estamos aquí cuando nos necesites.</p>
        </div>
        <div class="bg-white rounded-3xl shadow-xl p-8 md:p-12 border border-gray-200">
          <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-6">
              <div class="flex justify-between items-center py-4 border-b border-gray-200"><span class="font-semibold text-black" data-t-es="Lunes - Viernes" data-t-en="Monday - Friday">Lunes - Viernes</span><span class="text-[#F3A2A7] font-bold">9:00 AM - 7:00 PM</span></div>
              <div class="flex justify-between items-center py-4 border-b border-gray-200"><span class="font-semibold text-black" data-t-es="Sábados" data-t-en="Saturdays">Sábados</span><span class="text-[#F3A2A7] font-bold">10:00 AM - 6:00 PM</span></div>
              <div class="flex justify-between items-center py-4 border-b border-gray-200"><span class="font-semibold text-black" data-t-es="Domingos" data-t-en="Sundays">Domingos</span><span class="text-[#F3A2A7] font-bold">10:00 AM - 4:00 PM</span></div>
              <div class="flex justify-between items-center py-4"><span class="font-semibold text-black" data-t-es="Días Festivos" data-t-en="Holidays">Días Festivos</span><span class="text-gray-500" data-t-es="Horarios especiales" data-t-en="Special hours">Horarios especiales</span></div>
            </div>
            <div class="bg-white rounded-2xl p-5 md:p-6 border border-gray-100">
              <h3 class="font-bold text-xl text-text mb-2" data-t-es="Citas de Emergencia" data-t-en="Emergency Appointments">Citas de Emergencia</h3>
              <p class="text-graytxt mb-3" data-t-es="Para consultas urgentes fuera del horario regular, contáctanos." data-t-en="For urgent inquiries outside regular hours, contact us.">Para consultas urgentes fuera del horario regular, contáctanos.</p>
              <CTAButton href="tel:+13856092840" variant="mint" className="!px-5 !py-2.5 focus-visible:ring-[#AABFA8]/50">
                <span data-t-es="Contacto de Emergencia" data-t-en="Emergency Contact">Contacto de Emergencia</span>
              </CTAButton>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactFormMembership />

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <span class="h-[2px] w-16 bg-[#F3A2A7]"></span>
          <span class="mx-3 w-10 h-10 rounded-full bg-[#F3A2A7] text-white flex items-center justify-center">•</span>
          <span class="h-[2px] w-16 bg-[#F3A2A7]"></span>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-[#F3A2A7]"><span data-t-es="Nuestra Ubicación" data-t-en="Our Location">Nuestra Ubicación</span></h2>
        <p class="text-xl text-graytxt" data-t-es="Fácil acceso y estacionamiento gratuito." data-t-en="Easy access and free parking.">Fácil acceso y estacionamiento gratuito.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto items-center">
        <div class="space-y-8">
          <div class="bg-gray-50 rounded-3xl p-8">
            <h3 class="font-bold text-2xl text-text mb-6"><span data-t-es="Cómo Llegar" data-t-en="How to Get Here">Cómo Llegar</span></h3>
            <div class="space-y-6">
              <div class="flex items-start space-x-4"><div class="w-8 h-8 bg-[#F3A2A7] rounded-full flex items-center justify-center"><span class="text-white font-bold text-sm">1</span></div><div><h4 class="font-semibold text-text mb-1" data-t-es="En Auto" data-t-en="By Car">En Auto</h4><p class="text-graytxt" data-t-es="Estacionamiento gratuito disponible." data-t-en="Free parking available.">Estacionamiento gratuito disponible.</p></div></div>
              <div class="flex items-start space-x-4"><div class="w-8 h-8 bg-[#AABFA8] rounded-full flex items-center justify-center"><span class="text-white font-bold text-sm">2</span></div><div><h4 class="font-semibold text-text mb-1" data-t-es="Transporte Público" data-t-en="Public Transport">Transporte Público</h4><p class="text-graytxt" data-t-es="Parada cercana." data-t-en="Nearby stop.">Parada cercana.</p></div></div>
              <div class="flex items-start space-x-4"><div class="w-8 h-8 bg-logo rounded-full flex items-center justify-center"><span class="text-white font-bold text-sm">3</span></div><div><h4 class="font-semibold text-text mb-1">Accesibilidad</h4><p class="text-graytxt">Instalaciones accesibles.</p></div></div>
            </div>
          </div>
        </div>
        <div class="rounded-3xl h-96 flex items-center justify-center relative overflow-hidden bg-cover bg-center" style="background-image: url('/img/services/transform.JPG')">
          <div class="absolute inset-0 bg-black/30"></div>
          <div class="relative z-10 text-center">
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
              <svg class="w-8 h-8 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="font-bold text-xl text-text mb-2">Renasci Medical Spa</h3>
            <p class="text-graytxt">6770 S 900 E, Midvale, UT 84047</p>
            <CTAButton href="https://maps.google.com/?q=6770+S+900+E,+Midvale,+UT+84047" variant="primary">
              <span data-t-es="Ver en Google Maps" data-t-en="View on Google Maps">Ver en Google Maps</span>
            </CTAButton>
          </div>
        </div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>

<script>
  function applyContactLang(){
    const params = new URLSearchParams(window.location.search)
    const urlLang = params.get('lang')
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language')
    const lang = urlLang === 'en' || urlLang === 'es' ? urlLang : (storedLang === 'en' ? 'en' : (window.i18nManager?.getCurrentLanguage?.() || document.documentElement.lang || 'es'))
    const nodes = Array.from(document.querySelectorAll('[data-t-es]'))
    nodes.forEach((n) => { const es = n.getAttribute('data-t-es')||''; const en = n.getAttribute('data-t-en')||es; n.textContent = (lang==='en')? en : es })
  }
  document.addEventListener('DOMContentLoaded', applyContactLang)
  window.addEventListener('languageChanged', (e) => { const lang = e.detail?.language || 'es'; const nodes = Array.from(document.querySelectorAll('[data-t-es]')); nodes.forEach((n) => { const es = n.getAttribute('data-t-es')||''; const en = n.getAttribute('data-t-en')||es; n.textContent = (lang==='en')? en : es }) })
</script>
