---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import ContactFormMembership from '../components/ContactFormMembership.astro';
import TransformCTA from '../components/TransformCTA.astro';
---

<BaseLayout 
  title="Contacto - Renasci Medical Spa"
  description="Contáctanos para agendar tu consulta gratuita. Estamos aquí para ayudarte en tu transformación de belleza y bienestar."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <h1 class="font-display font-bold text-5xl md:text-6xl mb-4">Contáctanos</h1>
        <p class="text-lg md:text-xl text-white/80 mb-8">Tu transformación comienza con una consulta gratuita. Estamos listos para ayudarte.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton label="Llama Ahora" href="tel:+13855550123" variant="primary" className="!bg-[#1DD1A1] hover:!bg-[#16C79A]" />
          <CTAButton label="WhatsApp" href="https://wa.me/13855550123" variant="primary" className="!bg-[#1DD1A1] hover:!bg-[#16C79A]" />
          <CTAButton label="Agenda Online" href="#contacto" variant="primary" className="bg-[#374151] hover:bg-[#1F2937]" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <span class="h-[2px] w-16 bg-black"></span>
          <span class="mx-3 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center">•</span>
          <span class="h-[2px] w-16 bg-black"></span>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-text">Múltiples Formas de Conectar</h2>
        <p class="text-xl text-graytxt max-w-3xl mx-auto">Elige la forma más conveniente para ti: teléfono, email o visita.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="text-center p-8 bg-primary/5 rounded-3xl hover:bg-primary/10 transition-colors">
          <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <h3 class="font-bold text-2xl text-text mb-2">Llámanos</h3>
          <p class="text-graytxt mb-3">Habla directamente con nuestro equipo</p>
          <a href="tel:+13855550123" class="text-primary font-bold text-xl">(385) 555-0123</a>
          <p class="text-sm text-graytxt mt-2">Lun - Vie: 9:00 AM - 7:00 PM</p>
        </div>
        <div class="text-center p-8 bg-call/5 rounded-3xl hover:bg-call/10 transition-colors">
          <div class="w-16 h-16 bg-call rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-bold text-2xl text-text mb-2">Escríbenos</h3>
          <p class="text-graytxt mb-3">Responderemos pronto tu mensaje</p>
          <a href="mailto:info@renascimedspa.com" class="text-call font-bold text-xl">info@renascimedspa.com</a>
          <p class="text-sm text-graytxt mt-2">Respuesta en 24 horas</p>
        </div>
        <div class="text-center p-8 bg-logo/5 rounded-3xl hover:bg-logo/10 transition-colors">
          <div class="w-16 h-16 bg-logo rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-bold text-2xl text-text mb-2">Visítanos</h3>
          <p class="text-graytxt mb-3">Conoce nuestras instalaciones</p>
          <p class="text-logo font-bold">123 Beauty Ave, Salt Lake City, UT</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-black text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center mb-6">
            <span class="h-[2px] w-16 bg-white"></span>
            <span class="mx-3 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center">•</span>
            <span class="h-[2px] w-16 bg-white"></span>
          </div>
          <h2 class="font-display font-bold text-4xl md:text-5xl text-white">Horarios de Atención</h2>
          <p class="text-xl text-white/80">Estamos aquí cuando nos necesites.</p>
        </div>
        <div class="bg-black rounded-3xl shadow-xl p-8 md:p-12 border border-white/10">
          <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-6">
              <div class="flex justify-between items-center py-4 border-b border-white/10"><span class="font-semibold text-white">Lunes - Viernes</span><span class="text-primary font-bold">9:00 AM - 7:00 PM</span></div>
              <div class="flex justify-between items-center py-4 border-b border-white/10"><span class="font-semibold text-white">Sábados</span><span class="text-primary font-bold">10:00 AM - 6:00 PM</span></div>
              <div class="flex justify-between items-center py-4 border-b border-white/10"><span class="font-semibold text-white">Domingos</span><span class="text-primary font-bold">10:00 AM - 4:00 PM</span></div>
              <div class="flex justify-between items-center py-4"><span class="font-semibold text-white">Días Festivos</span><span class="text-white/60">Horarios especiales</span></div>
            </div>
            <div class="bg-white rounded-2xl p-5 md:p-6 border border-gray-100">
              <h3 class="font-bold text-xl text-text mb-2">Citas de Emergencia</h3>
              <p class="text-graytxt mb-3">Para consultas urgentes fuera del horario regular, contáctanos.</p>
              <CTAButton label="Contacto de Emergencia" href="tel:+13855550123" variant="primary" className="!px-5 !py-2.5" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactFormMembership />

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <span class="h-[2px] w-16 bg-black"></span>
          <span class="mx-3 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center">•</span>
          <span class="h-[2px] w-16 bg-black"></span>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-text">Nuestra Ubicación</h2>
        <p class="text-xl text-graytxt">Fácil acceso y estacionamiento gratuito.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto items-center">
        <div class="space-y-8">
          <div class="bg-gray-50 rounded-3xl p-8">
            <h3 class="font-bold text-2xl text-text mb-6">Cómo Llegar</h3>
            <div class="space-y-6">
              <div class="flex items-start space-x-4"><div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center"><span class="text-white font-bold text-sm">1</span></div><div><h4 class="font-semibold text-text mb-1">En Auto</h4><p class="text-graytxt">Estacionamiento gratuito disponible.</p></div></div>
              <div class="flex items-start space-x-4"><div class="w-8 h-8 bg-call rounded-full flex items-center justify-center"><span class="text-white font-bold text-sm">2</span></div><div><h4 class="font-semibold text-text mb-1">Transporte Público</h4><p class="text-graytxt">Parada cercana.</p></div></div>
              <div class="flex items-start space-x-4"><div class="w-8 h-8 bg-logo rounded-full flex items-center justify-center"><span class="text-white font-bold text-sm">3</span></div><div><h4 class="font-semibold text-text mb-1">Accesibilidad</h4><p class="text-graytxt">Instalaciones accesibles.</p></div></div>
            </div>
          </div>
        </div>
        <div class="bg-gray-200 rounded-3xl h-96 flex items-center justify-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-call/20"></div>
          <div class="relative z-10 text-center">
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="font-bold text-xl text-text mb-2">Renasci Medical Spa</h3>
            <p class="text-graytxt">123 Beauty Ave, Salt Lake City, UT</p>
            <CTAButton label="Ver en Google Maps" href="https://maps.google.com/?q=123+Beauty+Ave+Salt+Lake+City+UT" variant="primary" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>