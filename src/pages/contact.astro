---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import ReviewCTA from '../components/ReviewCTA.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': 'https://renascimedspa.com/contact#contactpage',
  url: 'https://renascimedspa.com/contact',
  name: 'Contacto Renasci Medical Spa — Midvale, Utah',
  description: 'Agenda tu consulta gratuita en Renasci Medical Spa, ubicado en Midvale, Utah, atendiendo Salt Lake City, Sandy, Murray, South Jordan y Draper.',
  about: { '@id': 'https://renascimedspa.com/#business' },
  mainEntity: { '@id': 'https://renascimedspa.com/#business' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://renascimedspa.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contacto', item: 'https://renascimedspa.com/contact' }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Dónde está ubicado Renasci Medical Spa?',
      acceptedAnswer: { '@type': 'Answer', text: 'Nuestra clínica está en 6770 S 900 E, Suite 100, Midvale, UT 84047. Atendemos pacientes de Salt Lake City, Sandy, Murray, South Jordan, Draper y todo el Salt Lake Valley.' }
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo una cita?',
      acceptedAnswer: { '@type': 'Answer', text: 'Puedes agendar de tres formas: llamando al (385) 609-2840, completando el formulario de contacto, o reservando online desde Boulevard. Respondemos en menos de 24 horas.' }
    },
    {
      '@type': 'Question',
      name: '¿La consulta inicial tiene costo?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. La consulta inicial es completamente gratuita. Evaluamos tus objetivos, anatomía y diseñamos un plan personalizado sin compromiso.' }
    },
    {
      '@type': 'Question',
      name: '¿Hay estacionamiento gratuito?',
      acceptedAnswer: { '@type': 'Answer', text: 'Sí. Tenemos estacionamiento gratuito en sitio y acceso fácil desde la I-15 e I-215, además de parada UTA cercana.' }
    },
    {
      '@type': 'Question',
      name: '¿Atienden en español e inglés?',
      acceptedAnswer: { '@type': 'Answer', text: 'Sí. Todo nuestro equipo es bilingüe y te atendemos con la misma calidad profesional en español o inglés.' }
    },
    {
      '@type': 'Question',
      name: '¿Aceptan tarjetas de crédito y financiamiento?',
      acceptedAnswer: { '@type': 'Answer', text: 'Aceptamos efectivo, tarjetas de crédito y débito. Para tratamientos más extensos ofrecemos planes de pago y nuestra membresía con descuentos exclusivos.' }
    },
    {
      '@type': 'Question',
      name: '¿Cuál es su política de cancelación?',
      acceptedAnswer: { '@type': 'Answer', text: 'Te pedimos avisar con al menos 24 horas de anticipación para reagendar o cancelar sin cargo. Esto nos ayuda a atender mejor a todos nuestros pacientes.' }
    }
  ]
};
---

<BaseLayout
  title="Contacto Renasci Medical Spa | Salt Lake City, Midvale Utah"
  description="Agenda tu consulta gratuita en Renasci Medical Spa, Midvale Utah. Atendemos Salt Lake City, Sandy, Murray, South Jordan y Draper. (385) 609-2840 · orders@renascimedspa.com"
  seoKeywords="contacto medical spa Utah, agendar cita medspa Salt Lake City, Renasci Medical Spa Midvale, consulta gratuita medspa, medical spa Salt Lake Valley"
>
  <JsonLd schema={contactSchema} />
  <JsonLd schema={breadcrumbSchema} />
  <JsonLd schema={faqSchema} />
  <section class="relative min-h-[68vh] flex items-center overflow-hidden">
    <img
      src="/img/about.jpg"
      alt="Renasci Medical Spa"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/55 to-black/70"></div>

    <div class="relative z-10 container mx-auto px-6 py-24 text-white">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.22em] text-[#F3A2A7] font-semibold mb-4" data-t-es="Contacto" data-t-en="Get in Touch">Contacto</p>
        <h1 class="font-display font-bold text-4xl md:text-6xl leading-tight mb-5" data-t-es="Hablemos de tu próxima cita" data-t-en="Let's talk about your next visit">Hablemos de tu próxima cita</h1>
        <p class="text-base md:text-lg text-white/85 max-w-2xl mb-8" data-t-es="Agenda una consulta gratuita o escríbenos. Nuestro equipo te responde en menos de 24 horas para diseñar el plan que mejor se ajuste a ti." data-t-en="Book a free consultation or send us a message. Our team replies within 24 hours to craft the plan that best fits you.">Agenda una consulta gratuita o escríbenos. Nuestro equipo te responde en menos de 24 horas para diseñar el plan que mejor se ajuste a ti.</p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-7 py-3 rounded-full hover:brightness-105 transition" data-t-es="Agendar Online" data-t-en="Book Online">Agendar Online</a>
          <a href="tel:+13856092840" class="inline-flex items-center justify-center gap-2 bg-[#AABFA8] text-white font-semibold px-7 py-3 rounded-full hover:brightness-105 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span data-t-es="Llamar" data-t-en="Call">Llamar</span>
          </a>
          <a href="https://wa.me/13856092840" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 border-2 border-white/80 bg-white/10 text-white font-semibold px-7 py-3 rounded-full hover:bg-white/20 transition">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-6 right-6 hidden md:flex items-center gap-2 text-white/70 text-xs">
      <span class="w-8 h-px bg-white/40"></span>
      <span class="uppercase tracking-[0.18em]" data-t-es="Midvale, Utah" data-t-en="Midvale, Utah">Midvale, Utah</span>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-5 max-w-6xl mx-auto">
        <a href="tel:+13856092840" class="group rounded-3xl border border-gray-200 p-7 hover:border-[#F3A2A7] hover:shadow-card-hover transition flex flex-col">
          <div class="w-12 h-12 rounded-2xl bg-[#F3A2A7]/15 text-[#F3A2A7] flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-1" data-t-es="Llámanos" data-t-en="Call Us">Llámanos</p>
          <p class="font-display font-bold text-xl text-gray-900 mb-2 group-hover:text-[#F3A2A7] transition">(385) 609-2840</p>
          <p class="text-sm text-gray-600 mt-auto" data-t-es="Lun – Vie · 9 AM – 7 PM" data-t-en="Mon – Fri · 9 AM – 7 PM">Lun – Vie · 9 AM – 7 PM</p>
        </a>

        <a href="mailto:orders@renascimedspa.com" class="group rounded-3xl border border-gray-200 p-7 hover:border-[#AABFA8] hover:shadow-card-hover transition flex flex-col">
          <div class="w-12 h-12 rounded-2xl bg-[#AABFA8]/15 text-[#AABFA8] flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-1" data-t-es="Escríbenos" data-t-en="Email Us">Escríbenos</p>
          <p class="font-display font-bold text-xl text-gray-900 mb-2 group-hover:text-[#AABFA8] transition break-words">orders@renascimedspa.com</p>
          <p class="text-sm text-gray-600 mt-auto" data-t-es="Respuesta en menos de 24 hrs" data-t-en="Reply in under 24 hrs">Respuesta en menos de 24 hrs</p>
        </a>

        <a href="https://maps.google.com/?q=6770+S+900+E,+Midvale,+UT+84047" target="_blank" rel="noopener noreferrer" class="group rounded-3xl border border-gray-200 p-7 hover:border-[#C69C87] hover:shadow-card-hover transition flex flex-col">
          <div class="w-12 h-12 rounded-2xl bg-[#C69C87]/15 text-[#C69C87] flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-1" data-t-es="Visítanos" data-t-en="Visit Us">Visítanos</p>
          <p class="font-display font-bold text-xl text-gray-900 mb-2 group-hover:text-[#C69C87] transition">6770 S 900 E</p>
          <p class="text-sm text-gray-600 mt-auto">Midvale, UT 84047</p>
        </a>
      </div>
    </div>
  </section>

  <section id="contacto" class="py-16 lg:py-20 bg-gray-50 text-gray-900">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-8 lg:gap-10">
        <div class="lg:col-span-3 bg-white rounded-3xl border border-gray-200 p-7 lg:p-10">
          <p class="text-xs uppercase tracking-[0.16em] text-[#AABFA8] font-semibold mb-2" data-t-es="Envíanos un mensaje" data-t-en="Send us a message">Envíanos un mensaje</p>
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#C69C87] mb-2" data-t-es="Cuéntanos sobre ti" data-t-en="Tell us about you">Cuéntanos sobre ti</h2>
          <p class="text-sm text-gray-600 mb-7" data-t-es="Completa el formulario y te respondemos con un plan personalizado." data-t-en="Fill out the form and we'll reply with a personalized plan.">Completa el formulario y te respondemos con un plan personalizado.</p>

          <form id="contact-form" action="/api/contact" method="POST" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <label class="block">
                <span class="text-sm font-semibold text-gray-700 mb-1.5 block" data-t-es="Nombre" data-t-en="Name">Nombre</span>
                <input required type="text" name="name" autocomplete="name" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#F3A2A7]/40 focus:border-[#F3A2A7] transition" placeholder="Tu nombre" data-ph-es="Tu nombre" data-ph-en="Your name" />
              </label>
              <label class="block">
                <span class="text-sm font-semibold text-gray-700 mb-1.5 block" data-t-es="Teléfono" data-t-en="Phone">Teléfono</span>
                <input required type="tel" name="phone" autocomplete="tel" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#F3A2A7]/40 focus:border-[#F3A2A7] transition" placeholder="(385) 609-2840" data-ph-es="(385) 609-2840" data-ph-en="(385) 609-2840" />
              </label>
            </div>
            <label class="block">
              <span class="text-sm font-semibold text-gray-700 mb-1.5 block" data-t-es="Email" data-t-en="Email">Email</span>
              <input required type="email" name="email" autocomplete="email" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#F3A2A7]/40 focus:border-[#F3A2A7] transition" placeholder="tu@email.com" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-gray-700 mb-1.5 block" data-t-es="Servicio de interés" data-t-en="Service of interest">Servicio de interés</span>
              <select name="service" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#F3A2A7]/40 focus:border-[#F3A2A7] transition bg-white">
                <option value="" data-t-es="Selecciona un servicio" data-t-en="Select a service">Selecciona un servicio</option>
                <option value="neurotoxin-injections" data-t-es="Neurotoxinas" data-t-en="Neurotoxins">Neurotoxinas</option>
                <option value="dermal-fillers" data-t-es="Rellenos Dérmicos" data-t-en="Dermal Fillers">Rellenos Dérmicos</option>
                <option value="iv-therapy" data-t-es="Terapia IV" data-t-en="IV Therapy">Terapia IV</option>
                <option value="medically-supervised-weight-loss" data-t-es="Pérdida de Peso" data-t-en="Weight Loss">Pérdida de Peso</option>
                <option value="therapy-peptide" data-t-es="Terapia con Péptidos" data-t-en="Peptide Therapy">Terapia con Péptidos</option>
                <option value="biodentical-hormone-therapy" data-t-es="Terapia Hormonal" data-t-en="Hormone Therapy">Terapia Hormonal</option>
                <option value="membership" data-t-es="Membresía" data-t-en="Membership">Membresía</option>
                <option value="other" data-t-es="Otro" data-t-en="Other">Otro</option>
              </select>
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-gray-700 mb-1.5 block" data-t-es="Mensaje" data-t-en="Message">Mensaje</span>
              <textarea name="message" rows="4" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#F3A2A7]/40 focus:border-[#F3A2A7] transition resize-none" placeholder="Cuéntanos sobre tus objetivos..." data-ph-es="Cuéntanos sobre tus objetivos..." data-ph-en="Tell us about your goals..."></textarea>
            </label>

            <label class="flex items-start gap-3 text-xs text-gray-600">
              <input required type="checkbox" name="consent" class="mt-1 w-4 h-4 accent-[#F3A2A7]" />
              <span data-t-es="Acepto ser contactado por Renasci Medical Spa." data-t-en="I agree to be contacted by Renasci Medical Spa.">Acepto ser contactado por Renasci Medical Spa.</span>
            </label>

            <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-8 py-3 rounded-full hover:brightness-105 transition">
              <span data-t-es="Enviar Mensaje" data-t-en="Send Message">Enviar Mensaje</span>
            </button>

            <p id="form-status" class="text-sm hidden"></p>
          </form>
        </div>

        <aside class="lg:col-span-2 space-y-5">
          <div class="bg-white rounded-3xl border border-gray-200 p-7">
            <p class="text-xs uppercase tracking-[0.16em] text-[#F3A2A7] font-semibold mb-2" data-t-es="Horarios" data-t-en="Hours">Horarios</p>
            <h3 class="font-display font-bold text-2xl text-gray-900 mb-5" data-t-es="Cuándo encontrarnos" data-t-en="When we're open">Cuándo encontrarnos</h3>
            <ul class="divide-y divide-gray-100">
              <li class="flex justify-between py-3 text-sm">
                <span class="text-gray-700" data-t-es="Lunes – Viernes" data-t-en="Monday – Friday">Lunes – Viernes</span>
                <span class="font-semibold text-gray-900">9 AM – 7 PM</span>
              </li>
              <li class="flex justify-between py-3 text-sm">
                <span class="text-gray-700" data-t-es="Sábado" data-t-en="Saturday">Sábado</span>
                <span class="font-semibold text-gray-900">9 AM – 5 PM</span>
              </li>
              <li class="flex justify-between py-3 text-sm">
                <span class="text-gray-700" data-t-es="Domingo" data-t-en="Sunday">Domingo</span>
                <span class="font-semibold text-gray-500" data-t-es="Cerrado" data-t-en="Closed">Cerrado</span>
              </li>
              <li class="flex justify-between py-3 text-sm">
                <span class="text-gray-700" data-t-es="Festivos" data-t-en="Holidays">Festivos</span>
                <span class="text-gray-500" data-t-es="Horario especial" data-t-en="Special hours">Horario especial</span>
              </li>
            </ul>
          </div>

          <div class="bg-[#AABFA8] text-white rounded-3xl p-7">
            <p class="text-xs uppercase tracking-[0.16em] text-white/80 font-semibold mb-2" data-t-es="Atención prioritaria" data-t-en="Priority care">Atención prioritaria</p>
            <h3 class="font-display font-bold text-2xl mb-2" data-t-es="¿Necesitas algo urgente?" data-t-en="Need something urgent?">¿Necesitas algo urgente?</h3>
            <p class="text-sm text-white/90 mb-5" data-t-es="Llámanos directamente y te atendemos lo antes posible, incluso fuera de horario regular." data-t-en="Call us directly and we'll get back to you as soon as possible, even outside regular hours.">Llámanos directamente y te atendemos lo antes posible, incluso fuera de horario regular.</p>
            <a href="tel:+13856092840" class="inline-flex items-center justify-center gap-2 bg-white text-[#AABFA8] font-semibold px-5 py-2.5 rounded-full hover:brightness-95 transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span>(385) 609-2840</span>
            </a>
          </div>

          <ReviewCTA variant="card" />
        </aside>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-8 items-stretch">
        <div class="lg:col-span-2 flex flex-col justify-center">
          <p class="text-xs uppercase tracking-[0.16em] text-[#C69C87] font-semibold mb-2" data-t-es="Nuestra Ubicación" data-t-en="Our Location">Nuestra Ubicación</p>
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-t-es="Te esperamos en Midvale" data-t-en="We're waiting for you in Midvale">Te esperamos en Midvale</h2>
          <p class="text-base text-gray-700 mb-6" data-t-es="Espacio acogedor con estacionamiento gratuito y fácil acceso desde toda la zona del Salt Lake Valley." data-t-en="A welcoming space with free parking and easy access from the entire Salt Lake Valley area.">Espacio acogedor con estacionamiento gratuito y fácil acceso desde toda la zona del Salt Lake Valley.</p>

          <ul class="space-y-3 mb-6 text-sm">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#F3A2A7]/15 text-[#F3A2A7] flex items-center justify-center font-bold text-xs">1</span>
              <span class="text-gray-700"><strong class="text-gray-900" data-t-es="En auto:" data-t-en="By car:">En auto:</strong> <span data-t-es="Estacionamiento gratuito en sitio." data-t-en="Free parking on site.">Estacionamiento gratuito en sitio.</span></span>
            </li>
