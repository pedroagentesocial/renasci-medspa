<script>
  type Lang = 'en' | 'es';

  const getContactLang = (): Lang => {
    const html = document.documentElement.getAttribute('data-lang') || document.documentElement.lang;
    return html === 'en' ? 'en' : 'es';
  };

  const initContactForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    if (!form || !status) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      status.classList.remove('hidden', 'text-red-600', 'text-green-600');
      status.textContent = getContactLang() === 'en' ? 'Sending…' : 'Enviando…';
      status.classList.add('text-gray-600');

      try {
        const res = await fetch(form.action, { method: 'POST', body: data });
        if (!res.ok) throw new Error('Network error');
        form.reset();
        status.classList.remove('text-gray-600', 'text-red-600');
        status.classList.add('text-green-600');
        status.textContent = getContactLang() === 'en'
          ? 'Thanks — we\'ll get back to you shortly.'
          : 'Gracias — te responderemos pronto.';
      } catch {
        status.classList.remove('text-gray-600', 'text-green-600');
        status.classList.add('text-red-600');
        status.textContent = getContactLang() === 'en'
          ? 'Something went wrong. Please try again or call us.'
          : 'Hubo un problema. Inténtalo de nuevo o llámanos.';
      }
    });
  };

  document.addEventListener('DOMContentLoaded', initContactForm);
  document.addEventListener('astro:page-load', initContactForm);
</script>
