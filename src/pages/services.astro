function getService(h) {
  const s = byHref.get(h)
  if (s) {
    const oimg = imageOverrides.get(h)
    if (oimg) s.image = oimg
    const ot = titleOverrides.get(h)
    if (ot) s.title = ot
    if (!s.excerpt) {
      const be = briefExcerpts.get(h)
      if (be) s.excerpt = be
    }
    return s
  }
  const slug = (h || '').split('/').pop() || ''
  const ot = titleOverrides.get(h)
  const oimg = imageOverrides.get(h) || '/images/med-spa-room.jpg'
  const title = ot ? (ot.es || ot.en || slug) : slug.replace(/-/g,' ')
  const be = briefExcerpts.get(h) || ''
  return {
    id: slug,
    slug,
    title,
    image: oimg,
    href: h,
    excerpt: be,
    category: 'injections'
  }
}

