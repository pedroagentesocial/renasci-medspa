</style>

  <script>
    function setupCarousel(id){
      const el = document.getElementById(id)
      if (!el) return
      const items = Array.from(el.querySelectorAll('.carousel-item'))
      let index = 0
      function computeVisible(){
        const w = items[0]?.offsetWidth || 1
        const c = Math.floor(el.clientWidth / w)
        return c > 0 ? c : 1
      }
      function scrollToIndex(i){
        index = i
        const target = items[index]
        if (target) el.scrollTo({ left: target.offsetLeft, behavior: 'smooth' })
      }
      document.querySelectorAll(`.carousel-btn[data-target="${id}"]`).forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = parseInt(btn.getAttribute('data-dir') || '1', 10)
          const visible = computeVisible()
          if (dir > 0) {
            const next = index + 1
            const end = items.length - visible
            scrollToIndex(next > end ? 0 : next)
          } else {
            const prev = index - 1
            const end = items.length - visible
            scrollToIndex(prev < 0 ? (end >= 0 ? end : 0) : prev)
          }
        })
      })
    }
    document.addEventListener('DOMContentLoaded', () => {
      setupCarousel('carousel-injections')
      setupCarousel('carousel-contouring')
      setupCarousel('carousel-biostimulators')
      setupCarousel('carousel-wellness')
      setupCarousel('carousel-botox')
      setupCarousel('carousel-regenerative')
      setupCarousel('carousel-bhrt')
      setupCarousel('carousel-peptides')
    })
  </script>
  <script>
    (function(){
      const pageText = { es: { heroTitleLeft: 'Nuestros ', heroTitleRight: 'Servicios', heroSubtitle: 'Explora nuestras categorías y tratamientos profesionales. Selecciona una sección para ver todos los servicios disponibles.', prev: 'Anterior', next: 'Siguiente' }, en: { heroTitleLeft: 'Our ', heroTitleRight: 'Services', heroSubtitle: 'Explore our categories and professional treatments. Choose a section to see all available services.', prev: 'Previous', next: 'Next' } }
      const groupIdMap = {
        'neurotoxin-dermal-filler-injections': { es: 'Inyecciones de Neurotoxinas y Rellenos Dérmicos', en: 'Neurotoxin & Dermal Filler Injections' },
        'facial-body-contouring': { es: 'Contorno Facial y Corporal', en: 'Facial & Body Contouring' },
        'biostimulators': { es: 'Bioestimuladores', en: 'Biostimulators' },
        'specialized-treatments': { es: 'Tratamientos Especializados', en: 'Specialized Treatments' },
        'weight-loss-wellness': { es: 'Pérdida de Peso y Bienestar', en: 'Weight Loss & Wellness' },
        'botox-neuromodulators': { es: 'Botox y Neuromoduladores', en: 'Botox & Neuromodulators' },
        'regenerative-medicine-therapies': { es: 'Terapias de Medicina Regenerativa', en: 'Regenerative Medicine Therapies' },
        'hair-restoration-treatments': { es: 'Tratamientos de Restauración Capilar', en: 'Hair Restoration Treatments' },
        'advanced-treatments': { es: 'Tratamientos Avanzados', en: 'Advanced Treatments' },
        'intimate-rejuvenation': { es: 'Rejuvenecimiento Íntimo', en: 'Intimate Rejuvenation' },
        'microneedling': { es: 'Microneedling', en: 'Microneedling' },
        'platelet-rich-plasma-prp': { es: 'Plasma Rico en Plaquetas (PRP)', en: 'Platelet-Rich Plasma (PRP)' },
        'bioidentical-hormone-therapy-bhrt': { es: 'Terapia Hormonal Bioidéntica (BHRT)', en: 'Bioidentical Hormone Therapy (BHRT)' },
        'peptide-therapy': { es: 'Terapia con Péptidos', en: 'Peptide Therapy' },
        'iv-im-therapy': { es: 'Terapia IV/IM', en: 'IV/IM Therapy' }
      }
      function getCurrentLang(){
        const url = new URL(window.location.href)
        const qp = url.searchParams.get('lang')
        if (qp === 'es' || qp === 'en') return qp
        const saved = localStorage.getItem('renasci-language') || localStorage.getItem('language')
        if (saved === 'es' || saved === 'en') return saved
        return (document.documentElement.lang === 'en') ? 'en' : 'es'
      }
      function applyTexts(lang){
        const heroTitleEl = document.querySelector('.hero-inner h1')
        const heroSubtitleEl = document.querySelector('.hero-inner p')
        if (heroTitleEl) heroTitleEl.innerHTML = `${pageText[lang].heroTitleLeft}<span class="accent-pink">${pageText[lang].heroTitleRight}</span>`
        if (heroSubtitleEl) heroSubtitleEl.textContent = pageText[lang].heroSubtitle
        document.querySelectorAll('.services-group').forEach((groupEl) => {
          const id = groupEl.getAttribute('id') || ''
          const map = groupIdMap[id]
          const h2 = groupEl.querySelector('h2')
          if (h2 && map) h2.textContent = map[lang] || h2.textContent
        })
        document.querySelectorAll('.carousel-btn').forEach((btn) => {
          const dir = btn.getAttribute('data-dir')
          btn.setAttribute('aria-label', dir === '-1' ? pageText[lang].prev : pageText[lang].next)
        })
        document.querySelectorAll('.service-card').forEach((card) => {
          const root = card
          const h3 = card.querySelector('h3')
          const p = card.querySelector('p')
          const cta = card.querySelector('.p-4 a[href]')
          const title = lang === 'en' ? root.dataset.titleEn || root.dataset.titleEs : root.dataset.titleEs || root.dataset.titleEn
          const desc = lang === 'en' ? root.dataset.descEn || root.dataset.descEs : root.dataset.descEs || root.dataset.descEn
          if (h3 && title) h3.textContent = title
          if (p && typeof desc === 'string') p.textContent = desc
          if (cta) cta.textContent = (lang === 'es' ? 'Ver más →' : 'Learn more →')
        })
      }
      applyTexts(getCurrentLang())
      window.addEventListener('languageChanged', (e) => {
        const lang = (e && e.detail && e.detail.language) || getCurrentLang()
        applyTexts(lang)
      })
    })()
  </script>
