---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getLocaleFromUrl } from '../i18n/config'
const langParam = Astro.url.searchParams.get('lang')
const pathLocale = getLocaleFromUrl(Astro.url)
const lang = (langParam === 'es' || langParam === 'en') ? langParam : pathLocale
const pageText = {
  es: {
    title: 'Servicios',
    heroTitleLeft: 'Nuestros ',
    heroTitleRight: 'Servicios',
    heroSubtitle: 'Explora nuestras categorías y tratamientos profesionales. Selecciona una sección para ver todos los servicios disponibles.',
  },
  en: {
    title: 'Services',
    heroTitleLeft: 'Our ',
    heroTitleRight: 'Services',
    heroSubtitle: 'Explore our categories and professional treatments. Choose a section to see all available services.',
  }
}

const serviceCards = [
  { title: { es: 'Inyecciones de Neurotoxina', en: 'Neurotoxin Injections' }, href: '/services/neurotoxin-injections', image: '/img/services/hero-services.jpg' },
  { title: { es: 'Rellenos Dérmicos', en: 'Dermal Fillers' }, href: '/services/dermal-fillers', image: '/img/services/Lip-filler-image.jpg' },
  { title: { es: 'Tratamientos Faciales', en: 'Facial Treatments' }, href: '/services/facial-treatments', image: '/img/services/Cheekbone-lift.jpg' },
  { title: { es: 'Contorno Corporal', en: 'Body Contouring' }, href: '/services/body-contouring-treatments', image: '/img/services/mini-chin-bio.jpg' },
  { title: { es: 'Bioestimuladores', en: 'Biostimulators' }, href: '/services/biostimulators', image: '/img/services/Sculptra.jpg.avif' },
  { title: { es: 'Pérdida de Peso', en: 'Weight Loss' }, href: '/services/medically-supervised-weight-loss', image: '/img/services/Supervised.jpg' },
  { title: { es: 'Tratamientos Avanzados', en: 'Advanced Treatments' }, href: '/services/advanced-treatments', image: '/img/services/Cortisone.png' },
  { title: { es: 'Microneedling', en: 'Microneedling' }, href: '/services/microneedling', image: '/img/services/microneedling-face.jpg' },
  { title: { es: 'Inyecciones PRP', en: 'PRP Injections' }, href: '/services/prp-injections', image: '/img/services/PRP-face.jpg' },
  { title: { es: 'Tratamiento con Células Madre', en: 'Stem Cells Treatment' }, href: '/services/stem-cells-treatment', image: '/img/services/Hair-restoration-Cells.jpg' },
  { title: { es: 'Terapia Hormonal Bioidéntica', en: 'Bioidentical Hormone Therapy' }, href: '/services/biodentical-hormone-therapy', image: '/img/services/Hormone-her.jpg' },
  { title: { es: 'Terapia con Péptidos', en: 'Peptide Therapy' }, href: '/services/therapy-peptide', image: '/img/services/CJC-1295.jpg' },
  { title: { es: 'Terapia IV', en: 'IV Therapy' }, href: '/services/iv-therapy', image: '/img/services/Drips.jpeg' },
  { title: { es: 'IgniteRF by InMode', en: 'IgniteRF by InMode' }, href: '/services/igniterf', image: '/img/ignateRF.png' },
]
---

<BaseLayout title={pageText[lang].title} lang={lang}>
  <section class="hero-services">
    <div class="hero-inner text-center">
      <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl tracking-tight" data-hero-title>{pageText[lang].heroTitleLeft}<span class="accent-pink">{pageText[lang].heroTitleRight}</span></h1>
      <p class="mt-4 text-white/80 text-base sm:text-lg" data-hero-subtitle>{pageText[lang].heroSubtitle}</p>
    </div>
  </section>
  <section id="servicios" class="py-12 sm:py-16 lg:py-20 bg-white scroll-mt-28 md:scroll-mt-36">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="services-grid gap-6 lg:gap-8">
        {serviceCards.map((card) => (
          <a
            href={card.href}
            class="service-card group block rounded-2xl overflow-hidden bg-white transition-colors"
            data-service-card
            data-title-es={card.title.es}
            data-title-en={card.title.en}
          >
            <div class="h-44 sm:h-48 lg:h-52 w-full bg-gray-100">
              <img src={card.image} alt={card.title[lang] ?? card.title.en} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="px-4 py-4 text-center">
              <h3 class="text-base sm:text-lg font-semibold text-gray-900 transition-colors group-hover:text-[#E94594]" data-card-title>
                {card.title[lang] ?? card.title.en}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

<style is:global>
  .hero-services{ background:#000; color:#fff; min-height:40vh; display:flex; align-items:center; justify-content:center; padding-top:64px; padding-bottom:48px; position:relative; background-image:url('/img/services/hero-services.jpg'); background-size:cover; background-position:center }
  .hero-services::after{ content:""; position:absolute; inset:0; background:rgba(0,0,0,0.4) }
  .hero-services .hero-inner{ position:relative; z-index:1 }
  @media (min-width:640px){ .hero-services{ min-height:45vh; padding-top:80px; padding-bottom:64px } }
  @media (min-width:1024px){ .hero-services{ min-height:50vh; padding-top:96px; padding-bottom:80px } }
  .hero-inner{ max-width:1120px; margin:0 auto; padding:0 16px }
  .accent-pink{ color:#F3A2A7 }
  .services-grid{ display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); justify-items:center }
  .service-card{ width:100%; max-width:280px }
  @media (max-width:1024px){ .services-grid{ grid-template-columns:repeat(2, minmax(0, 1fr)) } }
  @media (max-width:640px){ .services-grid{ grid-template-columns:1fr } }
</style>
<script>
  (function () {
    type Lang = 'es' | 'en'
    const pageText: Record<Lang, { heroTitleLeft: string; heroTitleRight: string; heroSubtitle: string }> = {
      es: {
        heroTitleLeft: 'Nuestros ',
        heroTitleRight: 'Servicios',
        heroSubtitle: 'Explora nuestras categorías y tratamientos profesionales. Selecciona una sección para ver todos los servicios disponibles.',
      },
      en: {
        heroTitleLeft: 'Our ',
        heroTitleRight: 'Services',
        heroSubtitle: 'Explore our categories and professional treatments. Choose a section to see all available services.',
      }
    }

    function getCurrentLang(): Lang {
      const url = new URL(window.location.href)
      const qp = url.searchParams.get('lang')
      if (qp === 'es' || qp === 'en') return qp as Lang
      const saved = localStorage.getItem('renasci-language') || localStorage.getItem('language')
      if (saved === 'es' || saved === 'en') return saved as Lang
      return document.documentElement.lang === 'en' ? 'en' : 'es'
    }

    function apply(lang: Lang) {
      const heroTitleEl = document.querySelector('[data-hero-title]') as HTMLElement | null
      const heroSubtitleEl = document.querySelector('[data-hero-subtitle]') as HTMLElement | null
      if (heroTitleEl) heroTitleEl.innerHTML = `${pageText[lang].heroTitleLeft}<span class="accent-pink">${pageText[lang].heroTitleRight}</span>`
      if (heroSubtitleEl) heroSubtitleEl.textContent = pageText[lang].heroSubtitle
      document.querySelectorAll('[data-service-card]').forEach((card) => {
        const el = card as HTMLElement
        const titleEl = el.querySelector('[data-card-title]') as HTMLElement | null
        const title = lang === 'en' ? el.dataset.titleEn || el.dataset.titleEs : el.dataset.titleEs || el.dataset.titleEn
        if (titleEl && title) titleEl.textContent = title
      })
    }

    apply(getCurrentLang())
    window.addEventListener('languageChanged', (e) => {
      const detail = (e as CustomEvent).detail as { language?: Lang } | undefined
      const nextLang = detail?.language === 'es' || detail?.language === 'en' ? detail.language : getCurrentLang()
      apply(nextLang)
    })
  })()
</script>
</BaseLayout>
