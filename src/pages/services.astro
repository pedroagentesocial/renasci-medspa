function getBadgeFor(service){
  try {
    const t = String((service?.title && (service.title.en || service.title.es)) || service?.title || '')
    const s = String(service?.slug || ((service?.href || '').split('/').pop() || ''))
    const b = badgesBySlug.get(s.toLowerCase())
    if (b) return b
    if (/premier/i.test(t) || /premier/i.test(s)) return 'Premier'
    if (/(membresía|membership)/i.test(t)) return t.match(/membresía/i) ? 'Membresía' : 'Membership'
    return ''
  } catch { return '' }
}

function getBadgeClass(label){
  const v = String(label || '').toLowerCase()
  if (v.includes('premier')) return 'bg-[#FFD700] text-black'
  if (v.includes('membership') || v.includes('membresía')) return 'bg-[#10B981] text-white'
  return 'bg-[#F3A2A7] text-white'
}
