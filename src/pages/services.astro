    const oimg = imageOverrides.get(h)
    if (oimg) s.image = oimg
    const ot = titleOverrides.get(h)
    if (ot) s.title = ot
    const beEs = briefExcerpts.get(h)
    const beEn = briefExcerptsEn.get(h)
    if (!s.excerpt) {
      if (beEs || beEn) s.excerpt = { es: beEs || beEn || '', en: beEn || beEs || '' }
    } else if (typeof s.excerpt === 'string') {
      s.excerpt = { es: s.excerpt, en: beEn || s.excerpt }
    } else if (typeof s.excerpt === 'object') {
      const curEs = s.excerpt.es
      const curEn = s.excerpt.en
      s.excerpt = { es: curEs || beEs || curEn || '', en: curEn || beEn || curEs || '' }
    }
    if (typeof s.title === 'string') s.title = { es: s.title, en: s.title }
    return s
  }
  const slug = (h || '').split('/').pop() || ''
  const ot = titleOverrides.get(h)
  const oimg = imageOverrides.get(h) || '/images/med-spa-room.jpg'
  const titleObj = ot 
    ? { es: ot.es || ot.en || slug, en: ot.en || ot.es || slug }
    : (() => { const t = slug.replace(/-/g,' '); return { es: t, en: t } })()
  const beEs = briefExcerpts.get(h) || ''
  const beEn = briefExcerptsEn.get(h) || beEs
  return {
    id: slug,
    slug,
    title: titleObj,
    image: oimg,
    href: h,
    excerpt: { es: beEs, en: beEn },
    category: 'injections'
  }
}

