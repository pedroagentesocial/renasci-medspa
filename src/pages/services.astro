</style>

  <script>
    function setupCarousel(id){
      const el = document.getElementById(id)
      if (!el) return
      const items = Array.from(el.querySelectorAll('.carousel-item'))
      let index = 0
      function computeVisible(){
        const w = items[0]?.offsetWidth || 1
        const c = Math.floor(el.clientWidth / w)
        return c > 0 ? c : 1
      }
      function scrollToIndex(i){
        index = i
        const target = items[index]
        if (target) el.scrollTo({ left: target.offsetLeft, behavior: 'smooth' })
      }
      document.querySelectorAll(`.carousel-btn[data-target="${id}"]`).forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = parseInt(btn.getAttribute('data-dir') || '1', 10)
          const visible = computeVisible()
          if (dir > 0) {
            const next = index + 1
            const end = items.length - visible
            scrollToIndex(next > end ? 0 : next)
          } else {
            const prev = index - 1
            const end = items.length - visible
            scrollToIndex(prev < 0 ? (end >= 0 ? end : 0) : prev)
          }
        })
      })
    }
    document.addEventListener('DOMContentLoaded', () => {
      setupCarousel('carousel-injections')
      setupCarousel('carousel-contouring')
      setupCarousel('carousel-biostimulators')
      setupCarousel('carousel-wellness')
      setupCarousel('carousel-botox')
      setupCarousel('carousel-regenerative')
      setupCarousel('carousel-bhrt')
      setupCarousel('carousel-peptides')
    })
  </script>
