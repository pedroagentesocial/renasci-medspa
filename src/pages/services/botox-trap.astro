---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import MembershipCTA from '../../components/MembershipCTA.astro';
---

<BaseLayout 
  title="Botox Trap (Trapezius Slimming/Relief) - Renasci Medical Spa"
  description="Neurotoxin protocol to refine trapezius bulk for a longer neck line, shoulder slimming and tension relief. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-[#F3A2A7]/30"><span data-i18n="services.neurotoxins_title">Botox y Neuromoduladores</span></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4" data-i18n="botoxTrap.hero_title">Botox Trap (Trapezius)</h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto" data-i18n="botoxTrap.hero_subtitle">Shoulder contour refinement and tension relief with clinical neurotoxin mapping.</p>
      <div class="inline-flex gap-4 mb-6 justify-center items-center">
        <div class="bg-white/10 rounded-2xl p-6 inline-block border border-white/20 text-center">
          <div class="text-sm text-white/80 mb-1" data-i18n="botoxTrap.price_from_label">Starting at</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]" data-i18n="botoxTrap.price_value">$1000</div>
          <div class="text-sm text-white/80 mt-1" data-i18n="botoxTrap.duration_label">Duration: 45 min</div>
        </div>
        <div class="bg-transparent rounded-2xl p-6 inline-block border-2 border-[#1DD1A1] hover:ring-2 hover:ring-[#1DD1A1] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#1DD1A1]/20 text-black text-xs font-semibold mb-3 border border-[#1DD1A1]/40"><span class="w-2 h-2 rounded-full bg-[#1DD1A1]"></span>Renasci Vital</div>
          <div class="text-sm text-white/80 mb-1">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-[#1DD1A1]">20% OFF</div>
          <div class="text-sm text-white/80 mt-1">Now $800</div>
        </div>
        <div class="bg-transparent rounded-2xl p-6 inline-block border-2 border-[#C8A08C] hover:ring-2 hover:ring-[#C8A08C] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#C8A08C]/20 text-black text-xs font-semibold mb-3 border border-[#C8A08C]/40"><span class="w-2 h-2 rounded-full bg-[#C8A08C]"></span>Premier</div>
          <div class="text-sm text-white/80 mb-1">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-[#C8A08C]">30% OFF</div>
          <div class="text-sm text-white/80 mt-1">Now $700</div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-6">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50"><span data-i18n="cta.view_details">View Details</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13856092840" class="inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duración-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50" aria-label="Call Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 0 0 5.516 5.516l1.13-2.257a1 1 0 0 1 1.21-.502l 4.493 1.498a1 1 0 0 1 .684.949V19a2 2 0 0 1-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg> <span data-i18n="cta.call">Call</span> 385 609 2840</a>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-black text-sm font-semibold mt-4 mx-auto w-fit whitespace-nowrap"><span class="w-2.5 h-2.5 rounded-full bg-[#F3A2A7]"></span><span data-i18n="botoxTrap.membership_included_label">Included in Membership Plans</span><a href="/membership" class="underline underline-offset-2 hover:text-black ml-2"><span data-i18n="botoxTrap.membership_see_link">See Memberships</span></a></div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.home">Home</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.services">Services</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="botoxTrap.breadcrumb_label">Botox Trap (Trapezius)</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/Botox-trap.jpg.avif" alt="Botox Trap" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="rounded-3xl p-8 lg:p-10 h-full flex-1 border-2 border-[#F3A2A7] bg-white hover:ring-2 hover:ring-[#F3A2A7]/60">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6" data-i18n="botoxTrap.details.title">Botox Trap (Trapezius)</h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4" data-i18n="botoxTrap.details.p1">Precision neurotoxin mapping ...</p>
              <p class="mb-4" data-i18n="botoxTrap.details.p2">Ideal for aesthetic slimming and comfort; natural finish.</p>
              <p data-i18n="botoxTrap.details.p3">Onset in days; full effect ~2 weeks; minimal downtime.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-i18n="botoxTrap.benefits.title">Treatment Benefits</h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto" data-i18n="botoxTrap.benefits.subtitle">Why choose Botox Trap</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3" data-i18n="botoxTrap.benefits.items.0.title">Slimmer Shoulders</h3><p class="text-gray-700" data-i18n="botoxTrap.benefits.items.0.text">Refines trapezius bulk for contour.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3" data-i18n="botoxTrap.benefits.items.1.title">Tension Relief</h3><p class="text-gray-700" data-i18n="botoxTrap.benefits.items.1.text">Comfort boost in neck/shoulders.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3" data-i18n="botoxTrap.benefits.items.2.title">Natural Finish</h3><p class="text-gray-700" data-i18n="botoxTrap.benefits.items.2.text">Elegant results respecting proportions.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-i18n="botoxTrap.process.title">Treatment Process</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto" data-i18n="botoxTrap.process.subtitle">Consultation, trapezius mapping, precise neurotoxin and follow‑up</p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-[#F3A2A7] via-[#F3A2A7] to-transparent rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="flex items-center mb-4"><div class="w-10 h-10 rounded-full bg-[#F3A2A7] flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="botoxTrap.process.steps.0.title">Consultation</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="botoxTrap.process.steps.0.text">Goals, anatomy and suitability.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/first.jpg" alt="Consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white hover:ring-2 hover:ring-[#F3A2A7]/60 text-center"><div class="flex items-center mb-4"><div class="w-10 h-10 rounded-full bg-[#F3A2A7] flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="botoxTrap.process.steps.1.title">Mapping</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="botoxTrap.process.steps.1.text">Strategic trapezius dosing plan.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/second.jpg" alt="Mapping" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="flex items-center mb-4"><div class="w-10 h-10 rounded-full bg-[#F3A2A7] flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="botoxTrap.process.steps.2.title">Precise Application</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="botoxTrap.process.steps.2.text">Comfort‑focused technique and dosing.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/Botox-trap.jpg.avif" alt="Application" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="flex items-center mb-4"><div class="w-10 h-10 rounded-full bg-[#F3A2A7] flex items-center justify-center text-white font-bold mr-4">4</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="botoxTrap.process.steps.3.title">Follow‑up</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="botoxTrap.process.steps.3.text">Review comfort and contour; adjust.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/fourth.jpg" alt="Follow-up" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-i18n="botoxTrap.faq.title">Frequently Asked Questions</h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto" data-i18n="botoxTrap.faq.subtitle">Questions about trapezius slimming</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3" data-i18n="botoxTrap.faq.items.0.q">Is it natural?</h3><p class="text-gray-700 leading-relaxed" data-i18n="botoxTrap.faq.items.0.a">Yes; aims for elegant contour and comfort.</p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3" data-i18n="botoxTrap.faq.items.1.q">When do results appear?</h3><p class="text-gray-700 leading-relaxed" data-i18n="botoxTrap.faq.items.1.a">Initial effect in days; full ~2 weeks.</p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3" data-i18n="botoxTrap.faq.items.2.q">Downtime?</h3><p class="text-gray-700 leading-relaxed" data-i18n="botoxTrap.faq.items.2.a">Minimal; normal activities same day.</p></div>
      </div>
    </div>
  </section>

  <MembershipCTA />
  <TransformCTA />
</BaseLayout>
