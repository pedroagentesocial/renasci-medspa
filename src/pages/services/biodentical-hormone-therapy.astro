---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSchema from '../../components/PageSchema.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import SimpleContactForm from '../../components/SimpleContactForm.astro';
---

<BaseLayout
  title="Bioidentical Hormone Therapy - Renasci Medical Spa"
  description="Terapia hormonal bioidéntica personalizada para equilibrio, energía y bienestar. Agenda tu cita en Renasci Medical Spa."
>
  <PageSchema
    type="service"
    name="Bioidentical Hormone Therapy - Renasci Medical Spa"
    nameEs="Terapia Hormonal Bioidéntica"
    nameEn="Bioidentical Hormone Therapy"
    description="Terapia hormonal bioidéntica personalizada para restaurar el equilibrio, mejorar la energía y apoyar el bienestar integral."
    url="/services/biodentical-hormone-therapy"
    image="/img/services/Hormone-her.jpg"
    category="Hormone Therapy"
  />
  <section class="relative min-h-[45vh] flex items-center justify-center text-center overflow-hidden">
    <img
      src="/img/services/Hormone-him.jpg"
      alt="Bioidentical Hormone Therapy"
      data-alt-es="Terapia Hormonal Bioidéntica"
      data-alt-en="Bioidentical Hormone Therapy"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <h1 class="font-display font-bold text-4xl md:text-6xl text-white">
        <span data-t-es="Terapia Hormonal Bioidéntica" data-t-en="Bioidentical Hormone Therapy">Terapia Hormonal Bioidéntica</span>
      </h1>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-t-es="Inicio" data-t-en="Home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-t-es="Servicios" data-t-en="Services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-t-es="Terapia Hormonal Bioidéntica" data-t-en="Bioidentical Hormone Therapy">Terapia Hormonal Bioidéntica</span></li>
      </ol>
    </div>
  </nav>

  <section class="py-12 lg:py-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-stretch">
        <div class="relative bg-white rounded-3xl overflow-hidden min-h-[360px] lg:min-h-[520px]">
          <img 
            src="/img/services/Monthly.jpg"
            alt="Bioidentical Hormone Therapy"
            data-alt-es="Terapia Hormonal Bioidéntica"
            data-alt-en="Bioidentical Hormone Therapy"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex">
          <div class="bg-white rounded-3xl border border-gray-200 p-8 lg:p-10 w-full">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6" data-t-es="Terapia Hormonal Bioidéntica" data-t-en="Bioidentical Hormone Therapy">Terapia Hormonal Bioidéntica</h2>
            <p class="text-lg text-gray-700 leading-relaxed mb-6" data-t-es="La terapia hormonal bioidéntica ayuda a equilibrar niveles hormonales de forma personalizada para mejorar energía, estado de ánimo, metabolismo y bienestar integral. En Renasci diseñamos planes con seguimiento médico, laboratorios y ajustes de dosis según tu respuesta." data-t-en="Bioidentical hormone therapy helps restore hormonal balance with personalized plans to improve energy, mood, metabolism, and overall wellness. At Renasci we tailor dosing with medical supervision, labs, and ongoing adjustments based on your response.">La terapia hormonal bioidéntica ayuda a equilibrar niveles hormonales de forma personalizada para mejorar energía, estado de ánimo, metabolismo y bienestar integral. En Renasci diseñamos planes con seguimiento médico, laboratorios y ajustes de dosis según tu respuesta.</p>
            <h3 class="font-semibold text-lg text-gray-900 mb-3" data-t-es="Beneficios:" data-t-en="Benefits:">Beneficios:</h3>
            <ul class="list-disc pl-5 space-y-2 text-gray-700 mb-8">
              <li data-t-es="Mejora de energía y vitalidad" data-t-en="Improved energy and vitality">Mejora de energía y vitalidad</li>
              <li data-t-es="Equilibrio del estado de ánimo" data-t-en="Balanced mood">Equilibrio del estado de ánimo</li>
              <li data-t-es="Soporte metabólico y composición corporal" data-t-en="Metabolic and body composition support">Soporte metabólico y composición corporal</li>
              <li data-t-es="Plan personalizado con monitoreo clínico" data-t-en="Personalized plan with clinical monitoring">Plan personalizado con monitoreo clínico</li>
              <li data-t-es="Ajustes continuos para resultados sostenibles" data-t-en="Ongoing adjustments for sustainable results">Ajustes continuos para resultados sostenibles</li>
            </ul>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-6 py-3 rounded-full hover:opacity-90 transition" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-gray-50 text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-2" data-t-es="Opciones de Terapia" data-t-en="Treatment Options">Opciones de Terapia</h2>
        <p class="text-lg text-gray-700" data-t-es="Planes con soporte y seguimiento médico" data-t-en="Plans with medical support and follow-up">Planes con soporte y seguimiento médico</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-6">
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Monthly.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2" data-t-es="Hormone Membership for Her" data-t-en="Hormone Membership for Her">Hormone Membership for Her</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="Desde $250" data-t-en="Starting at $250">Desde $250</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Acompañamiento continuo, mensajería y visitas para afinar tu terapia hormonal." data-t-en="Ongoing guidance, messaging, and visits to fine-tune your hormone therapy.">Acompañamiento continuo, mensajería y visitas para afinar tu terapia hormonal.</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Hormone-him.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2" data-t-es="Hormone Replacement Therapy for Him" data-t-en="Hormone Replacement Therapy for Him">Hormone Replacement Therapy for Him</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="Desde $250" data-t-en="Starting at $250">Desde $250</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Evaluación y plan personalizado para optimizar energía, ánimo y desempeño físico." data-t-en="Evaluation and personalized plan to optimize energy, mood, and physical performance.">Evaluación y plan personalizado para optimizar energía, ánimo y desempeño físico.</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#AABFA8] text-white">
    <div class="container mx-auto px-6">
      <div class="h-[3px] w-28 bg-white/60 mb-6 mx-auto animate-in fade-in duration-500"></div>
      <h3 class="font-display font-bold text-4xl lg:text-5xl text-white text-center mb-10 animate-in fade-in slide-in-from-bottom-2 duration-500" data-t-es="Preguntas Frecuentes" data-t-en="FAQs">Preguntas Frecuentes</h3>
      <div class="max-w-4xl mx-auto divide-y divide-white/30">
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500" open>
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Qué es la terapia hormonal bioidéntica?" data-t-en="What is bioidentical hormone therapy?">¿Qué es la terapia hormonal bioidéntica?</span>
            <span class="faq-icon text-white">-</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Es un tratamiento médico personalizado que utiliza hormonas con estructura idéntica a las del cuerpo para apoyar el equilibrio hormonal y el bienestar general." data-t-en="It is a personalized medical treatment that uses hormones with the same structure as those in the body to support hormonal balance and overall wellness.">Es un tratamiento médico personalizado que utiliza hormonas con estructura idéntica a las del cuerpo para apoyar el equilibrio hormonal y el bienestar general.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-100">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Para quién es recomendable?" data-t-en="Who is it recommended for?">¿Para quién es recomendable?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Para personas con síntomas relacionados con desequilibrios hormonales como baja energía, cambios de ánimo, alteraciones del sueño o metabolismo." data-t-en="For people with symptoms related to hormonal imbalance such as low energy, mood changes, sleep issues, or metabolic changes.">Para personas con síntomas relacionados con desequilibrios hormonales como baja energía, cambios de ánimo, alteraciones del sueño o metabolismo.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-200">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Cómo es el proceso de inicio?" data-t-en="How does the process start?">¿Cómo es el proceso de inicio?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Inicia con evaluación clínica, revisión de historial y laboratorios para definir un plan y ajustar dosis según tu respuesta." data-t-en="It starts with a clinical evaluation, history review, and labs to define a plan and adjust dosing based on your response.">Inicia con evaluación clínica, revisión de historial y laboratorios para definir un plan y ajustar dosis según tu respuesta.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-300">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Cada cuánto se hacen ajustes?" data-t-en="How often are adjustments made?">¿Cada cuánto se hacen ajustes?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Los ajustes se realizan según síntomas, objetivos y resultados de laboratorio, con seguimiento médico continuo." data-t-en="Adjustments are made based on symptoms, goals, and lab results, with ongoing medical follow-up.">Los ajustes se realizan según síntomas, objetivos y resultados de laboratorio, con seguimiento médico continuo.</p>
        </details>
      </div>
    </div>
  </section>

  <TransformCTA />
  <SimpleContactForm />
</BaseLayout>

<script>
  const initBhrtFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item: Element) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current: Element) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  document.addEventListener('DOMContentLoaded', initBhrtFaq);
  document.addEventListener('astro:page-load', initBhrtFaq);
</script>
