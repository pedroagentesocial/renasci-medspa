    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 px-6 max-w-4xl mx-auto">
      <h1 class="font-display font-bold text-4xl md:text-6xl text-white" data-t-es="PÉRDIDA DE PESO MÉDICAMENTE SUPERVISADA" data-t-en="MEDICAL WEIGHT LOSS">PÉRDIDA DE PESO MÉDICAMENTE SUPERVISADA</h1>
    </div>
  </section>

  <nav class="bg-white py-3">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-[#F3A2A7] transition-colors" data-t-es="Inicio" data-t-en="Home">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-[#F3A2A7] transition-colors" data-t-es="Servicios" data-t-en="Services">Servicios</a></li>
        <li class="text-gray-400">/</li>
