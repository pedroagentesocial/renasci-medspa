      </ol>
    </div>
  </nav>

  <section class="pt-4 pb-12 lg:pt-8 lg:pb-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
