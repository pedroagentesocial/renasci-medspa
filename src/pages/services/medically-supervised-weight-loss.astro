        </div>
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/hero-services.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Tirzepatide</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span>$580</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4">30mg / 2ml</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
