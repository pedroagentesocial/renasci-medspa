<script>
  const initWeightLossFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item: Element) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current: Element) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  const getWeightLossLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    const managerLang = (window as Window & { i18nManager?: { getCurrentLanguage?: () => string } }).i18nManager?.getCurrentLanguage?.();
    if (managerLang === 'en' || managerLang === 'es') return managerLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyWeightLossLang = (lang: 'en' | 'es') => {
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('[data-alt-es]').forEach((el) => {
      const es = el.getAttribute('data-alt-es') || '';
      const en = el.getAttribute('data-alt-en') || es;
      el.setAttribute('alt', lang === 'en' ? en : es);
    });
  };

  const initWeightLossLang = () => applyWeightLossLang(getWeightLossLang());

  document.addEventListener('DOMContentLoaded', initWeightLossFaq);
  document.addEventListener('astro:page-load', initWeightLossFaq);
  document.addEventListener('DOMContentLoaded', initWeightLossLang);
  document.addEventListener('astro:page-load', initWeightLossLang);
  window.addEventListener('languageChanged', (e: Event) => {
    const lang = (e as CustomEvent<{ language?: 'en' | 'es' }>).detail?.language || getWeightLossLang();
    applyWeightLossLang(lang === 'en' ? 'en' : 'es');
  });
</script>
