              <li data-t-es="Ayuda a controlar el apetito y promover la saciedad" data-t-en="Helps control appetite and promote fullness">Ayuda a controlar el apetito y promover la saciedad</li>
              <li data-t-es="Seguimiento clínico para ajustar dosis y tolerancia" data-t-en="Clinical follow-ups to adjust dosing and tolerance">Seguimiento clínico para ajustar dosis y tolerancia</li>
              <li data-t-es="Enfoque en resultados seguros, constantes y sostenibles" data-t-en="Focus on safe, steady, and sustainable results">Enfoque en resultados seguros, constantes y sostenibles</li>
            </ul>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="inline-flex items-center gap-2 px-8 py-3 bg-[#F3A2A7] text-white rounded-full font-semibold text-base transition-all duration-200 hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
      <div class="mt-6 rounded-3xl bg-white p-8 lg:p-10 text-center">
        <h3 class="font-display font-bold text-2xl lg:text-3xl text-[#F3A2A7] mb-4" data-t-es="Precios y Consultas" data-t-en="Pricing & Consults">Precios y Consultas</h3>
        <p class="text-lg text-gray-700" data-t-es="1 cita al mes incluida en el precio del tratamiento" data-t-en="1 appointment per month included in treatment price">1 cita al mes incluida en el precio del tratamiento</p>
        <p class="text-lg text-gray-700" data-t-es="Citas adicionales: $50 cada una" data-t-en="Additional appointments: $50 each">Citas adicionales: $50 cada una</p>
