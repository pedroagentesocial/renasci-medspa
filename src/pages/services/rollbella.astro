---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="RollBella (Bra Roll) - Renasci Medical Spa"
  description="Body contouring targeting bra roll area to refine silhouette with natural-looking results. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30">Body Contouring</div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4">RollBella (Bra Roll)</h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto">Refines the bra roll area for a smoother, balanced silhouette.</p>
      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20">
        <div class="text-sm text-white/80 mb-1">Starting at</div>
        <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">$1,100</div>
        <div class="text-sm text-white/80 mt-1">Duration: 60 min</div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50">View Details<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50" aria-label="Call Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Services</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">RollBella (Bra Roll)</li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/images/med-spa-room.jpg" alt="RollBella" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-6">RollBella (Bra Roll)</h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4">Refines the <strong>bra roll</strong> area using precise body contouring to smooth and balance the silhouette.</p>
              <p class="mb-4">Designed for a natural finish that respects your proportions.</p>
              <p>Visible refinement over days; tailored to your anatomy and goals.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Treatment Benefits</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Key advantages of RollBella</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Smoother Silhouette</h3><p class="text-white/80">Refines bra roll area for balanced contour.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Natural Finish</h3><p class="text-white/80">Maintains soft, proportionate look.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Precision</h3><p class="text-white/80">Strategic application tailored to anatomy.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Proceso del Tratamiento</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Consulta, mapeo y aplicación precisa para contorno equilibrado</p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-primary via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900">Consulta Inicial</h3></div><p class="text-gray-600 leading-relaxed">Evaluación del área bra roll y objetivos de contorno.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Consulta" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900">Mapeo</h3></div><p class="text-gray-600 leading-relaxed">Plan preciso para suavizar y equilibrar la silueta.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/images/inyeccion-botox.jpg" alt="Mapeo" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900">Aplicación Precisa</h3></div><p class="text-gray-600 leading-relaxed">Microinyecciones estratégicas para acabado natural.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/inyeccion-botox.jpg" alt="Aplicación" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div><h3 class="font-display font-bold text-xl text-gray-900">Cuidados y Seguimiento</h3></div><p class="text-gray-600 leading-relaxed">Recomendaciones posteriores y evaluación de resultados.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/images/med-spa-room.jpg" alt="Seguimiento" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Preguntas Frecuentes</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Resolvemos dudas comunes sobre RollBella</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">¿Cuánto tiempo duran los resultados?</h3><p class="text-white/80 leading-relaxed">Generalmente meses; varía según metabolismo y cuidados.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">¿Se ve natural?</h3><p class="text-white/80 leading-relaxed">Sí; el acabado busca mantener proporciones suaves.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">¿Es doloroso?</h3><p class="text-white/80 leading-relaxed">Molestias mínimas con anestesia tópica y técnica precisa.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Lo Que Dicen Nuestros Pacientes</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Experiencias reales con resultados naturales</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-gray-900 hover:ring-2 hover:ring-primary/60"><p class="text-gray-700 italic">"Silueta más suave y natural; muy contenta con el cambio."</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-gray-900 hover:ring-2 hover:ring-primary/60"><p class="text-gray-700 italic">“Se siente equilibrado y no exagerado; procedimiento cómodo.”</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-gray-900 hover:ring-2 hover:ring-primary/60"><p class="text-gray-700 italic">“Acabado natural y proporciones mejor definidas.”</p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>