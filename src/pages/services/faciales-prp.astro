---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'faciales-prp',
  slug: 'faciales-prp',
  title: { es: 'Faciales con PRP', en: 'PRP Facials' },
  description: { es: 'Tratamiento facial regenerativo avanzado con plasma rico en plaquetas (PRP) que estimula la renovación celular, mejora la textura de la piel y proporciona un rejuvenecimiento natural desde adentro.', en: 'Advanced regenerative facial treatment with platelet-rich plasma (PRP) that stimulates cellular renewal, improves skin texture and provides natural rejuvenation from within.' },
  excerpt: { es: 'Rejuvenecimiento facial natural con plasma rico en plaquetas para una piel radiante.', en: 'Natural facial rejuvenation with platelet-rich plasma for radiant skin.' },
  category: 'faciales-especializados',
  precio: 'Por definir',
  image: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400&h=300&fit=crop&crop=center',
  benefits: ['Estimula renovación celular', 'Mejora textura de la piel', 'Rejuvenecimiento natural', 'Resultados progresivos'],
  duracion: '75 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'faciales-especializados' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-pink-500/20 backdrop-blur-sm border border-pink-300/30 mb-6">
        <span class="text-pink-200 text-sm font-medium uppercase tracking-wider">Faciales Especializados</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        <span class="bg-gradient-to-r from-pink-200 via-white to-pink-200 bg-clip-text text-transparent">
          {servicio.title.es}
        </span>
      </h1>
      
      <!-- Description -->
      <p class="text-xl md:text-2xl text-pink-100 mb-8 max-w-3xl mx-auto leading-relaxed">
        {servicio.description.es}
      </p>
      
      <!-- Price Highlight -->
      <div class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl shadow-2xl mb-8 transform hover:scale-105 transition-all duration-300">
        <span class="text-2xl md:text-3xl font-bold text-white">{servicio.precio}</span>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <CTAButton 
          href="/contact" 
          variant="primary"
          class="bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        >
          Agenda tu Cita
        </CTAButton>
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white/10 backdrop-blur-sm text-white border border-white/30 hover:bg-white/20 px-8 py-4 rounded-xl font-semibold text-lg transform hover:scale-105 transition-all duration-300"
        >
          Más Información
        </CTAButton>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-20 bg-gradient-to-r from-pink-50 to-rose-50 relative overflow-hidden">
    <!-- Decorative Elements -->
    <div class="absolute top-0 left-0 w-72 h-72 bg-pink-200/30 rounded-full blur-3xl -translate-x-36 -translate-y-36"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-200/20 rounded-full blur-3xl translate-x-48 translate-y-48"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Beneficios de los <span class="text-pink-600">Faciales con PRP</span>
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Descubre cómo este tratamiento regenerativo puede transformar tu piel de manera natural
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {servicio.benefits.map((benefit, index) => (
          <div class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transform hover:-translate-y-2 transition-all duration-300 border border-pink-100">
            <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
              <span class="text-2xl font-bold text-white">{index + 1}</span>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{benefit}</h3>
            <p class="text-gray-600">Experimenta los beneficios únicos de este tratamiento facial especializado.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-gray-600">
          Un proceso cuidadoso y profesional para obtener los mejores resultados
        </p>
      </div>
      
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Consulta Inicial</h3>
          <p class="text-gray-600">Evaluamos tu piel y diseñamos un plan de tratamiento personalizado para tus necesidades específicas.</p>
        </div>
        
        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Extracción de PRP</h3>
          <p class="text-gray-600">Realizamos una pequeña extracción de sangre y procesamos tu plasma rico en plaquetas.</p>
        </div>
        
        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Aplicación Facial</h3>
          <p class="text-gray-600">Aplicamos el PRP en tu rostro mediante técnicas especializadas para maximizar la absorción y efectividad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-r from-gray-50 to-pink-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
        <p class="text-xl text-gray-600">
          Resolvemos tus dudas sobre los faciales con PRP
        </p>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-pink-100">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Qué es el PRP y cómo funciona en tratamientos faciales?</h3>
          <p class="text-gray-600">El PRP (Plasma Rico en Plaquetas) es un concentrado de tus propias plaquetas que contiene factores de crecimiento naturales. Cuando se aplica en el rostro, estimula la regeneración celular y la producción de colágeno.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-pink-100">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Cuánto tiempo duran los resultados?</h3>
          <p class="text-gray-600">Los resultados de los faciales con PRP pueden durar entre 6 a 12 meses, dependiendo de tu tipo de piel y cuidados posteriores. Se recomienda un mantenimiento regular para resultados óptimos.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-pink-100">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Es seguro el tratamiento con PRP?</h3>
          <p class="text-gray-600">Sí, es muy seguro ya que utilizamos tu propia sangre, eliminando el riesgo de reacciones alérgicas. Es un tratamiento natural y biocompatible con efectos secundarios mínimos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gradient-to-r from-pink-50 to-rose-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
            Servicios <span class="text-pink-600">Relacionados</span>
          </h2>
          <p class="text-xl text-gray-600">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-pink-600 to-rose-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full -translate-x-48 -translate-y-48"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full translate-x-48 translate-y-48"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        ¿Lista para Rejuvenecer tu Piel?
      </h2>
      <p class="text-xl text-pink-100 mb-8 max-w-2xl mx-auto">
        Agenda tu cita hoy y descubre cómo los faciales con PRP pueden transformar tu piel de manera natural y efectiva.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          href="/contact" 
          variant="primary"
          class="bg-white text-pink-600 hover:bg-pink-50 px-8 py-4 rounded-xl font-semibold text-lg shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        >
          Agenda tu Cita
        </CTAButton>
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white/10 backdrop-blur-sm text-white border border-white/30 hover:bg-white/20 px-8 py-4 rounded-xl font-semibold text-lg transform hover:scale-105 transition-all duration-300"
        >
          Consulta Gratuita
        </CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>