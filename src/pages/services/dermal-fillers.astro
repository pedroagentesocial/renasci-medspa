  <section class="py-16 bg-[#AABFA8] text-white">
    <div class="container mx-auto px-6">
      <div class="h-[3px] w-28 bg-white/60 mb-6 mx-auto animate-in fade-in duration-500"></div>
      <h3 class="font-display font-bold text-4xl lg:text-5xl text-white text-center mb-10 animate-in fade-in slide-in-from-bottom-2 duration-500" data-t-es="Preguntas Frecuentes" data-t-en="FAQs">Preguntas Frecuentes</h3>
      <div class="max-w-4xl mx-auto divide-y divide-white/30">
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500" open>
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Qué son los rellenos dérmicos?" data-t-en="What are dermal fillers?">¿Qué son los rellenos dérmicos?</span>
            <span class="faq-icon text-white">-</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Son geles inyectables que restauran volumen, suavizan líneas y mejoran el contorno facial con resultados naturales." data-t-en="They are injectable gels that restore volume, smooth lines, and enhance facial contour with natural-looking results.">Son geles inyectables que restauran volumen, suavizan líneas y mejoran el contorno facial con resultados naturales.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-100">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Cuánto duran los resultados?" data-t-en="How long do results last?">¿Cuánto duran los resultados?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Por lo general, duran de 6 a 18 meses según el tipo de relleno, el área tratada y tu metabolismo." data-t-en="Typically 6 to 18 months depending on the filler type, treatment area, and your metabolism.">Por lo general, duran de 6 a 18 meses según el tipo de relleno, el área tratada y tu metabolismo.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-200">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Hay tiempo de recuperación?" data-t-en="Is there any downtime?">¿Hay tiempo de recuperación?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="El tiempo de inactividad es mínimo. Puede haber ligera inflamación o moretones que suelen resolverse rápidamente." data-t-en="Downtime is minimal. Mild swelling or bruising may occur and usually resolves quickly.">El tiempo de inactividad es mínimo. Puede haber ligera inflamación o moretones que suelen resolverse rápidamente.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-300">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Cuándo se ven los resultados?" data-t-en="When will I see results?">¿Cuándo se ven los resultados?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Los resultados se notan de inmediato y se perfeccionan en los días siguientes." data-t-en="Results are visible immediately and refine over the next several days.">Los resultados se notan de inmediato y se perfeccionan en los días siguientes.</p>
        </details>
      </div>
    </div>
  </section>
  <TransformCTA />
  <SimpleContactForm />
</BaseLayout>

<script>
  const initDermalFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  document.addEventListener('DOMContentLoaded', initDermalFaq);
  document.addEventListener('astro:page-load', initDermalFaq);

  const getDermalLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyDermalLang = (lang) => {
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('[data-alt-es]').forEach((el) => {
      const es = el.getAttribute('data-alt-es') || '';
      const en = el.getAttribute('data-alt-en') || es;
      el.setAttribute('alt', lang === 'en' ? en : es);
    });
  };

  const initDermalLang = () => applyDermalLang(getDermalLang());

  document.addEventListener('DOMContentLoaded', initDermalLang);
  document.addEventListener('astro:page-load', initDermalLang);
  window.addEventListener('languageChanged', () => {
    initDermalLang();
  });
</script>
