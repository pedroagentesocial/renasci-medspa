---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import SimpleContactForm from '../../components/SimpleContactForm.astro';
---

<BaseLayout
  title="Dermal Fillers - Renasci Med Spa"
  description="Rellenos dérmicos para restaurar volumen, suavizar arrugas y realzar rasgos faciales. Agenda tu cita en Renasci Med Spa."
>
  <section class="py-28 md:py-36 text-white text-center relative overflow-hidden">
