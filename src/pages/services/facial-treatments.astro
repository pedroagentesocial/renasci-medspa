---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSchema from '../../components/PageSchema.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import SimpleContactForm from '../../components/SimpleContactForm.astro';
---

<BaseLayout
  title="Facial Treatments - Renasci Medical Spa"
  description="Tratamientos faciales avanzados para contorno, definición y rejuvenecimiento. Agenda tu cita en Renasci Medical Spa."
>
  <PageSchema
    type="collection"
    name="Tratamientos Faciales - Renasci Medical Spa"
    nameEs="Tratamientos Faciales"
    nameEn="Facial Treatments"
    description="Tratamientos faciales avanzados para contorno, definición y rejuvenecimiento."
    url="/services/facial-treatments"
    image="/img/services/Cheekbone-lift.jpg"
  />
  <section class="py-28 md:py-36 text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 w-full h-full bg-cover bg-center" style="background-image:url('/img/services/Cheekbone-lift.jpg')"></div>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative px-6 max-w-4xl mx-auto">
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white">
        <span data-t-es="Tratamientos Faciales" data-t-en="Facial Treatments">Tratamientos Faciales</span>
      </h1>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-t-es="Inicio" data-t-en="Home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-t-es="Servicios" data-t-en="Services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-t-es="Tratamientos Faciales" data-t-en="Facial Treatments">Tratamientos Faciales</span></li>
      </ol>
    </div>
  </nav>

  <section class="py-12 lg:py-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-stretch">
        <div class="relative bg-white rounded-3xl overflow-hidden min-h-[360px] lg:min-h-[520px]">
          <img 
            src="/img/services/no-more-bags.jpg"
            alt="Tratamientos Faciales"
            data-alt-es="Tratamientos Faciales"
            data-alt-en="Facial Treatments"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex">
          <div class="bg-white rounded-3xl border border-gray-200 p-8 lg:p-10 w-full">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6" data-t-es="Tratamientos Faciales" data-t-en="Facial Treatments">Tratamientos Faciales</h2>
            <p class="text-lg text-gray-700 leading-relaxed mb-6" data-t-es="Nuestros tratamientos faciales se enfocan en definir contornos, reducir signos visibles de fatiga y lograr un aspecto equilibrado. Cada protocolo se diseña según tu anatomía, metas estéticas y evaluación clínica." data-t-en="Our facial treatments focus on contour definition, reducing visible signs of fatigue, and achieving a balanced appearance. Each protocol is designed around your anatomy, aesthetic goals, and clinical evaluation.">Nuestros tratamientos faciales se enfocan en definir contornos, reducir signos visibles de fatiga y lograr un aspecto equilibrado. Cada protocolo se diseña según tu anatomía, metas estéticas y evaluación clínica.</p>
            <h3 class="font-semibold text-lg text-gray-900 mb-3" data-t-es="Beneficios:" data-t-en="Benefits:">Beneficios:</h3>
            <ul class="list-disc pl-5 space-y-2 text-gray-700 mb-8">
              <li data-t-es="Definición precisa de pómulos y contorno" data-t-en="Precise cheekbone and contour definition">Definición precisa de pómulos y contorno</li>
              <li data-t-es="Reducción de bolsas y signos de cansancio" data-t-en="Reduced under-eye bags and fatigue signs">Reducción de bolsas y signos de cansancio</li>
              <li data-t-es="Resultados naturales y personalizados" data-t-en="Natural, personalized results">Resultados naturales y personalizados</li>
              <li data-t-es="Procedimientos de enfoque médico" data-t-en="Medically guided procedures">Procedimientos de enfoque médico</li>
              <li data-t-es="Mejora visible con mínima recuperación" data-t-en="Visible improvement with minimal downtime">Mejora visible con mínima recuperación</li>
            </ul>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-6 py-3 rounded-full hover:opacity-90 transition" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-gray-50 text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-2" data-t-es="Tratamientos" data-t-en="Treatments">Tratamientos</h2>
        <p class="text-lg text-gray-700" data-t-es="Faciales diseñados para renovar, equilibrar e iluminar la piel" data-t-en="Facials designed to renew, balance, and brighten the skin">Faciales diseñados para renovar, equilibrar e iluminar la piel</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-6">
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Cheekbone-lift.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Microdermabrasion Facial</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="$100" data-t-en="$100">$100</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Exfolia, alisa la textura y aporta luminosidad con recuperación mínima." data-t-en="Exfoliates, smooths texture, and boosts radiance with minimal downtime.">Exfolia, alisa la textura y aporta luminosidad con recuperación mínima.</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/no-more-bags.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Renasci Signature Facial</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="$120" data-t-en="$120">$120</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Limpieza profunda, exfoliación suave y masaje relajante para un glow saludable." data-t-en="Deep cleanse, gentle exfoliation, and relaxing massage for a healthy glow.">Limpieza profunda, exfoliación suave y masaje relajante para un glow saludable.</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/no-more-bags.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Hydrating Glow Facial</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="$150" data-t-en="$150">$150</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Repara la barrera, mejora elasticidad y deja la piel suave y luminosa." data-t-en="Repairs the barrier, improves elasticity, and leaves skin soft and glowing.">Repara la barrera, mejora elasticidad y deja la piel suave y luminosa.</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Cheekbone-lift.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Clarifying Acne Facial</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="$150" data-t-en="$150">$150</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Limpieza profunda, control de grasa y calma del enrojecimiento." data-t-en="Deep pore cleanse, oil control, and calming of redness.">Limpieza profunda, control de grasa y calma del enrojecimiento.</p>
            </div>
            <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#AABFA8] text-white">
    <div class="container mx-auto px-6">
      <div class="h-[3px] w-28 bg-white/60 mb-6 mx-auto animate-in fade-in duration-500"></div>
      <h3 class="font-display font-bold text-4xl lg:text-5xl text-white text-center mb-10 animate-in fade-in slide-in-from-bottom-2 duration-500" data-t-es="Preguntas Frecuentes" data-t-en="FAQs">Preguntas Frecuentes</h3>
      <div class="max-w-4xl mx-auto divide-y divide-white/30">
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500" open>
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Qué zonas se pueden tratar?" data-t-en="What areas can be treated?">¿Qué zonas se pueden tratar?</span>
            <span class="faq-icon text-white">-</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Se pueden tratar pómulos y zona de ojeras para mejorar contorno y apariencia descansada." data-t-en="Cheekbones and under-eye areas can be treated to improve contour and a rested appearance.">Se pueden tratar pómulos y zona de ojeras para mejorar contorno y apariencia descansada.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-100">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Los resultados son naturales?" data-t-en="Are the results natural?">¿Los resultados son naturales?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Sí, se prioriza un resultado armónico y de apariencia natural." data-t-en="Yes, the focus is on harmonious, natural-looking results.">Sí, se prioriza un resultado armónico y de apariencia natural.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-200">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Necesito evaluación previa?" data-t-en="Do I need an evaluation first?">¿Necesito evaluación previa?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Sí, la evaluación ayuda a definir el tratamiento ideal para tu rostro." data-t-en="Yes, evaluation helps define the best treatment for your face.">Sí, la evaluación ayuda a definir el tratamiento ideal para tu rostro.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-300">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Hay tiempo de recuperación?" data-t-en="Is there downtime?">¿Hay tiempo de recuperación?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="La recuperación suele ser mínima y depende del tratamiento." data-t-en="Downtime is usually minimal and depends on the treatment.">La recuperación suele ser mínima y depende del tratamiento.</p>
        </details>
      </div>
    </div>
  </section>

  <TransformCTA />
  <SimpleContactForm />
</BaseLayout>

<script>
  const initFacialFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item: Element) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current: Element) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  document.addEventListener('DOMContentLoaded', initFacialFaq);
  document.addEventListener('astro:page-load', initFacialFaq);

  const getFacialLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyFacialLang = (lang: 'en' | 'es') => {
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('[data-alt-es]').forEach((el) => {
      const es = el.getAttribute('data-alt-es') || '';
      const en = el.getAttribute('data-alt-en') || es;
      el.setAttribute('alt', lang === 'en' ? en : es);
    });
  };

  const initFacialLang = () => applyFacialLang(getFacialLang());

  document.addEventListener('DOMContentLoaded', initFacialLang);
  document.addEventListener('astro:page-load', initFacialLang);
  window.addEventListener('languageChanged', () => {
    initFacialLang();
  });
</script>
