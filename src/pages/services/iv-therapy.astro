<script>
  const initIvTherapyFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  document.addEventListener('DOMContentLoaded', initIvTherapyFaq);
  document.addEventListener('astro:page-load', initIvTherapyFaq);

  const getIvTherapyLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyIvTherapyLang = (lang) => {
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('[data-alt-es]').forEach((el) => {
      const es = el.getAttribute('data-alt-es') || '';
      const en = el.getAttribute('data-alt-en') || es;
      el.setAttribute('alt', lang === 'en' ? en : es);
    });
  };

  const initIvTherapyBookingButtons = () => {
    const boulevardUrl = 'https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget';
    const sections = Array.from(document.querySelectorAll('section'));
    const treatmentsSection = sections.find((section) => section.querySelector('[data-t-en="Treatments"]'));
    if (!treatmentsSection) return;

    treatmentsSection.querySelectorAll('.relative.rounded-2xl.overflow-hidden').forEach((card) => {
      const title = card.querySelector('h3');
      if (!title) return;
      const titleEn = (title.getAttribute('data-t-en') || title.textContent || '').toLowerCase();
      if (titleEn.includes('add-ons')) return;
      if (card.querySelector('[data-iv-book-now]')) return;

      const content = card.querySelector('.relative.z-10.p-6.flex.flex-col.h-full.text-center');
      if (!content) return;

      content.classList.add('justify-between');

      const button = document.createElement('a');
      button.setAttribute('href', boulevardUrl);
      button.setAttribute('data-booking-trigger', 'boulevard');
      button.setAttribute('data-iv-book-now', 'true');
      button.setAttribute('data-t-es', 'Agendar Ahora');
      button.setAttribute('data-t-en', 'Book Now');
      button.className = 'inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-5 py-2.5 rounded-full hover:opacity-90 transition mt-4 self-center';
      button.textContent = 'Book Now';

      content.appendChild(button);
    });
  };

  const initIvTherapyLang = () => applyIvTherapyLang(getIvTherapyLang());

  document.addEventListener('DOMContentLoaded', initIvTherapyBookingButtons);
  document.addEventListener('astro:page-load', initIvTherapyBookingButtons);
  document.addEventListener('DOMContentLoaded', initIvTherapyLang);
  document.addEventListener('astro:page-load', initIvTherapyLang);
  window.addEventListener('languageChanged', () => {
    initIvTherapyLang();
  });
</script>
