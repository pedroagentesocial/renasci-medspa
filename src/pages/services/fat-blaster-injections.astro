---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="Fat Blaster Injections - Renasci Medical Spa"
  description="Lipotropic injections to accelerate metabolism and support natural fat burning. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30">Wellness & Weight Loss</div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4">Fat Blaster Injections</h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto">Aids fat metabolism and energy with targeted lipotropics.</p>
      <div class="inline-flex gap-4 mb-6 justify-center items-center">
        <div class="bg-white/10 rounded-2xl p-6 inline-block border border-white/20 text-center">
          <div class="text-sm text-white/80 mb-1">Starting at</div>
          <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">$40</div>
          <div class="text-sm text-white/80 mt-1">Duration: 15 min</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 inline-block border-2 border-[#1DD1A1] hover:border-[#22E9AB] hover:ring-2 hover:ring-[#1DD1A1] hover:shadow-[0_0_32px_rgba(29,209,161,0.35)] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#1DD1A1]/20 text-white text-xs font-semibold mb-3 border border-[#1DD1A1]/40">
            <span class="w-2 h-2 rounded-full bg-[#1DD1A1]"></span>
            Membership Benefit
          </div>
          <div class="text-sm text-white/80 mb-1">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-call">Free</div>
          <div class="text-xs text-white/70 mt-2">Includes 1 complimentary per month</div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50">View Details<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50" aria-label="Call Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-sm font-semibold mt-4 mx-auto w-fit whitespace-nowrap">
        <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
        Included in Membership Plans
        <a href="/membership" class="underline underline-offset-2 hover:text-white ml-2">See Memberships</a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Services</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">Fat Blaster Injections</li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/Fat-blaster.jpg.webp" alt="Fat Blaster Injections" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-6">Fat Blaster Injections</h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4">Lipotropic blend designed to <strong>support fat metabolism</strong>, energy and wellness.</p>
              <p class="mb-4">Works well alongside nutrition and activity plans.</p>
              <p>Minimal downtime; progressive results over weeks.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Treatment Benefits</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Key advantages of Fat Blaster</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Metabolic Support</h3><p class="text-white/80">Aids fat processing efficiency.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Energy</h3><p class="text-white/80">Helps daily vitality.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Natural Blend</h3><p class="text-white/80">Strategic lipotropics for support.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Treatment Process</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Consultation, injection series and progressive refinement</p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-primary via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900">Consultation</h3></div><p class="text-gray-600 leading-relaxed">Goals, plan and schedule.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900">Injection Series</h3></div><p class="text-gray-600 leading-relaxed">Strategic dosing over weeks.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/inyeccion-botox.jpg" alt="Injection" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900">Progress Review</h3></div><p class="text-gray-600 leading-relaxed">Adjustments to optimize results.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Review" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Frequently Asked Questions</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Common questions about Fat Blaster</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">How long to see results?</h3><p class="text-white/80 leading-relaxed">Energy often improves quickly; fat metabolism effects build over weeks.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">Is it combined with B12?</h3><p class="text-white/80 leading-relaxed">Often paired with B12 shots for synergy.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">Downtime?</h3><p class="text-white/80 leading-relaxed">Minimal; resume normal activities immediately.</p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>
