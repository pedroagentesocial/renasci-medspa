---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';

// Datos específicos del servicio
const servicio = {
  id: 'chinbella',
  slug: 'chinbella',
  title: { es: 'ChinBella (papada/doble mentón)', en: 'ChinBella (double chin treatment)' },
  description: { es: 'Tratamiento especializado para reducir la papada y definir el contorno del mentón, creando un perfil más estilizado y juvenil.', en: 'Specialized treatment to reduce double chin and define chin contour, creating a more stylized and youthful profile.' },
  excerpt: { es: 'Elimina la papada y define tu mentón para un perfil más estilizado.', en: 'Eliminate double chin and define your chin for a more stylized profile.' },
  category: 'contorno',
  precio: '$1200',
  image: 'https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?w=400&h=300&fit=crop&crop=center',
  benefits: ['Reducción de papada', 'Mentón más definido', 'Perfil estilizado', 'Resultados duraderos'],
  duracion: '60 minutos'
};

// Estructura estandarizada; sin sección de relacionados
---

<BaseLayout 
  title="ChinBella (Papada/Doble Mentón) - Renasci Medical Spa"
  description="Tratamiento especializado para reducir la papada y definir el contorno del mentón, logrando un perfil más estilizado y juvenil. Agenda tu cita en Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30">Body Contouring</div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4">ChinBella — Papada/Doble Mentón</h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto">Reduce papada y define el contorno del mentón para un perfil estilizado y juvenil.</p>
      <div class="inline-flex gap-4 mb-6 justify-center items-center">
        <div class="bg-white/10 rounded-2xl p-6 inline-block border border-white/20 text-center">
          <div class="text-sm text-white/80 mb-1">Precio desde</div>
          <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">$1100</div>
          <div class="text-sm text-white/80 mt-1">Duración: 60 min</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 inline-block border-2 border-[#C8A08C] hover:border-[#D9B9A0] hover:ring-2 hover:ring-[#C8A08C] hover:shadow-[0_0_32px_rgba(200,160,140,0.35)] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#C8A08C]/20 text-white text-xs font-semibold mb-3 border border-[#C8A08C]/40"><span class="w-2 h-2 rounded-full bg-[#C8A08C]"></span>Premier</div>
          <div class="text-sm text-white/80 mb-1">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-logo">15% OFF</div>
          <div class="text-sm text-white/80 mt-1">Now $935</div>
          <div class="text-xs text-white/70 mt-2">Exclusive savings and follow-up</div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#detalles" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duración-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50">Ver Detalles<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duración-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50" aria-label="Llamar Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-sm font-semibold mt-4 mx-auto w-fit whitespace-nowrap"><span class="w-2.5 h-2.5 rounded-full bg-primary"></span>Included in Membership Plans<a href="/membership" class="underline underline-offset-2 hover:text-white ml-2">See Memberships</a></div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">ChinBella — Papada/Doble Mentón</li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <section id="detalles" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/Mini-Chin-Reduction.webp" alt="ChinBella" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-6">ChinBella — Papada/Doble Mentón</h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4">Tratamiento preciso para reducir papada y definir el contorno del mentón con resultados naturales.</p>
              <p class="mb-4">Técnica enfocada con guía post‑tratamiento para un perfil armónico.</p>
              <p>Resultados progresivos; opción de sesiones de refuerzo según objetivos.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Beneficios del Tratamiento</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Ventajas clave de ChinBella</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Reducción de Papada</h3><p class="text-white/80">Perfil más estilizado.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Mentón Definido</h3><p class="text-white/80">Contorno claro y armónico.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-xl text-white mb-3">Resultados Naturales</h3><p class="text-white/80">Sin apariencia artificial.</p></div>
      </div>
    </div>
  </section>

    <!-- FAQ Section -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
            Preguntas <span class="text-pink-600">Frecuentes</span>
          </h2>
        </div>
        
        <div class="space-y-8">
          <div class="bg-gray-50 rounded-2xl p-8 hover:bg-pink-50 transition-colors duration-300">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Cuánto duran los resultados?</h3>
            <p class="text-gray-600">Los resultados del ChinBella pueden durar entre 18-24 meses, dependiendo del tipo de tratamiento y las características individuales.</p>
          </div>
          
          <div class="bg-gray-50 rounded-2xl p-8 hover:bg-pink-50 transition-colors duration-300">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Es permanente el tratamiento?</h3>
            <p class="text-gray-600">Los resultados son de larga duración pero no permanentes. Se pueden realizar sesiones de mantenimiento según sea necesario.</p>
          </div>
          
          <div class="bg-gray-50 rounded-2xl p-8 hover:bg-pink-50 transition-colors duration-300">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Cuándo veré los resultados?</h3>
            <p class="text-gray-600">Los resultados iniciales son visibles inmediatamente, con mejoras progresivas durante las primeras 4-6 semanas.</p>
          </div>
        </div>
      </div>
    </section>


  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Proceso del Tratamiento</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Evaluación, aplicación precisa y seguimiento</p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-primary via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900">Evaluación Inicial</h3></div><p class="text-gray-600 leading-relaxed">Diagnóstico del contorno y plan personalizado.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Evaluación" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900">Marcado y Preparación</h3></div><p class="text-gray-600 leading-relaxed">Puntos y parámetros adecuados.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/inyeccion-botox.jpg" alt="Preparación" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900">Aplicación Precisa</h3></div><p class="text-gray-600 leading-relaxed">Técnica enfocada y confortable.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/inyeccion-botox.jpg" alt="Aplicación" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div><h3 class="font-display font-bold text-xl text-gray-900">Seguimiento</h3></div><p class="text-gray-600 leading-relaxed">Revisión de progreso y ajustes.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/images/med-spa-room.jpg" alt="Seguimiento" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Preguntas Frecuentes</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Resolvemos dudas comunes sobre ChinBella</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">¿Cuánto duran los resultados?</h3><p class="text-white/80 leading-relaxed">Larga duración; sesiones de refuerzo opcionales.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">¿Es permanente?</h3><p class="text-white/80 leading-relaxed">No permanente; estabilidad con mantenimiento.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3">¿Cuándo veré resultados?</h3><p class="text-white/80 leading-relaxed">Mejora progresiva en 4–6 semanas.</p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>
