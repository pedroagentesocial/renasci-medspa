---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
---

<BaseLayout 
  title="Rejuvenecimiento Vaginal con PRP - Renasci Medical Spa"
  description="Tratamiento de rejuvenecimiento vaginal con PRP para mejorar la salud íntima femenina. Resultados naturales y seguros. Agenda tu cita en Renasci Medical Spa."
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt="Rejuvenecimiento vaginal con PRP en spa médico"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/45"></div>
    
    <!-- Floating decorative elements -->
    <div class="absolute top-20 left-10 w-20 h-20 bg-gradient-to-br from-primary/30 to-secondary/30 rounded-full blur-xl animate-float-slow"></div>
    <div class="absolute bottom-32 right-16 w-32 h-32 bg-gradient-to-br from-secondary/20 to-primary/20 rounded-full blur-2xl animate-float-slow" style="animation-delay: -2s;"></div>
    <div class="absolute top-1/3 right-20 w-16 h-16 bg-gradient-to-br from-primary/40 to-pink-400/40 rounded-full blur-lg animate-pulse-gentle"></div>
    
    <!-- Content -->
    <div class="relative z-10 px-6 max-w-4xl mx-auto">
      <!-- Category Badge -->
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30 animate-fade-in-up">
        Rejuvenecimiento Intimo
      </div>
      
      <h1 class="font-display font-bold text-4xl md:text-6xl text-white mb-6 text-shadow-lg animate-fade-in-up" style="animation-delay: 0.2s;">
        Rejuvenecimiento Vaginal con PRP
      </h1>
      
      <p class="text-lg md:text-xl text-white/90 mb-8 leading-relaxed text-shadow max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
        Tratamiento innovador que utiliza plasma rico en plaquetas para mejorar la salud íntima femenina de forma natural y segura
      </p>
      
      <!-- Precio destacado -->
      <div class="bg-gradient-to-r from-white/15 to-pink-100/15 backdrop-blur-sm rounded-2xl p-6 shadow-card mb-8 inline-block border border-white/30 animate-scale-in" style="animation-delay: 0.6s;">
        <div class="text-sm text-white/80 mb-1">Precio</div>
        <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">Por definir</div>
        <div class="text-sm text-white/80 mt-1">Duración: 45-60 min</div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.8s;">
        <a 
          href="#detalles"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 animate-pulse-gentle"
        >
          Ver Detalles
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
        
        <a 
          href="tel:+13855550123"
          class="call-hero-button inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50 animate-bounce-subtle"
          aria-label="Llamar Renasci"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          (385) 555-0123
        </a>
      </div>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="bg-background py-6 border-b border-gray-100">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">Rejuvenecimiento Vaginal con PRP</li>
      </ol>
    </div>
  </nav>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-16 lg:py-24 bg-background">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Imagen -->
        <div class="relative group animate-slide-in-left">
          <img 
            src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt="Rejuvenecimiento vaginal con PRP procedimiento"
            class="w-full h-[400px] lg:h-[500px] object-cover rounded-3xl shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]"
            loading="lazy"
          />
          <!-- Floating card -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-6 shadow-2xl border border-gray-100 animate-float-gentle">
            <div class="text-sm text-gray-600 mb-1">Resultados visibles</div>
            <div class="font-bold text-xl text-primary">2-4 semanas</div>
          </div>
        </div>
        
        <!-- Contenido -->
        <div class="animate-slide-in-right">
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-gray-900 mb-6">
            Rejuvenecimiento Natural con PRP
          </h2>
          
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            El rejuvenecimiento vaginal con PRP utiliza las propias plaquetas de la paciente para estimular la regeneración celular y mejorar la salud íntima de forma completamente natural.
          </p>
          
          <!-- Beneficios -->
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-6 h-6 bg-gradient-to-r from-primary to-pink-500 rounded-full flex items-center justify-center mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Mejora la lubricación natural</h3>
                <p class="text-gray-600">Estimula la producción natural de colágeno y elastina</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-6 h-6 bg-gradient-to-r from-primary to-pink-500 rounded-full flex items-center justify-center mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Aumenta la sensibilidad</h3>
                <p class="text-gray-600">Mejora la respuesta y el bienestar íntimo</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-6 h-6 bg-gradient-to-r from-primary to-pink-500 rounded-full flex items-center justify-center mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Tratamiento natural</h3>
                <p class="text-gray-600">Utiliza los factores de crecimiento propios del cuerpo</p>
              </div>
            </div>
          </div>
          
          <CTAButton 
            href="tel:+13855550123"
            text="Agendar Consulta"
            variant="primary"
            size="lg"
            class="animate-pulse-gentle"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-gray-900 mb-6">
          Proceso del Tratamiento
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Un procedimiento seguro y mínimamente invasivo realizado en ambiente médico profesional
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-primary to-pink-500 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-white font-bold text-xl">1</span>
          </div>
          <h3 class="font-semibold text-xl text-gray-900 mb-4">Consulta Inicial</h3>
          <p class="text-gray-600">Evaluación médica completa y explicación detallada del procedimiento</p>
        </div>
        
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-primary to-pink-500 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-white font-bold text-xl">2</span>
          </div>
          <h3 class="font-semibold text-xl text-gray-900 mb-4">Extracción de Sangre</h3>
          <p class="text-gray-600">Toma de muestra sanguínea para preparar el plasma rico en plaquetas</p>
        </div>
        
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-primary to-pink-500 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-white font-bold text-xl">3</span>
          </div>
          <h3 class="font-semibold text-xl text-gray-900 mb-4">Aplicación del PRP</h3>
          <p class="text-gray-600">Inyección precisa del PRP en las áreas específicas para estimular la regeneración</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-24 bg-background">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-gray-900 mb-6">
            Preguntas Frecuentes
          </h2>
          <p class="text-lg text-gray-600">
            Resolvemos las dudas más comunes sobre el rejuvenecimiento vaginal con PRP
          </p>
        </div>
        
        <div class="space-y-6">
          <div class="bg-white rounded-2xl p-6 shadow-card border border-gray-100">
            <h3 class="font-semibold text-lg text-gray-900 mb-3">¿Es seguro el tratamiento con PRP?</h3>
            <p class="text-gray-600">Sí, es completamente seguro ya que utiliza las propias plaquetas de la paciente, eliminando el riesgo de reacciones alérgicas o rechazo.</p>
          </div>
          
          <div class="bg-white rounded-2xl p-6 shadow-card border border-gray-100">
            <h3 class="font-semibold text-lg text-gray-900 mb-3">¿Cuándo se ven los resultados?</h3>
            <p class="text-gray-600">Los primeros resultados se pueden notar entre 2-4 semanas después del tratamiento, con mejoras continuas durante los siguientes meses.</p>
          </div>
          
          <div class="bg-white rounded-2xl p-6 shadow-card border border-gray-100">
            <h3 class="font-semibold text-lg text-gray-900 mb-3">¿Cuánto dura el efecto?</h3>
            <p class="text-gray-600">Los efectos pueden durar entre 12-18 meses, dependiendo de cada paciente. Se pueden realizar sesiones de mantenimiento según sea necesario.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-16 lg:py-24 bg-gradient-to-r from-primary to-pink-500 text-white">
    <div class="container mx-auto px-6 text-center">
      <h2 class="font-display font-bold text-3xl lg:text-4xl mb-6">
        ¿Lista para Mejorar tu Bienestar Íntimo?
      </h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">
        Agenda tu consulta personalizada y descubre cómo el rejuvenecimiento vaginal con PRP puede mejorar tu calidad de vida
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="tel:+13855550123"
          class="inline-flex items-center gap-3 px-8 py-4 bg-white text-primary rounded-2xl font-semibold text-lg transition-all duration-300 hover:bg-gray-50 hover:-translate-y-[2px] hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          Llamar Ahora
        </a>
        
        <a 
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:bg-white hover:text-primary hover:-translate-y-[2px] hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
        >
          Agendar Consulta
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0h6m-6 0l-2 2m8-2l2 2m-2-2v10a2 2 0 01-2 2H10a2 2 0 01-2-2V9"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>