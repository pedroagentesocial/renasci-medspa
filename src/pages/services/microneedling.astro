---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout title="Microneedling - Renasci Medical Spa" description="Microneedling para estimular colágeno y mejorar textura de la piel.">
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <h1 class="font-display font-bold text-5xl md:text-6xl mb-4">Microneedling</h1>
        <p class="text-lg md:text-xl text-white/80 mb-8">Rejuvenecimiento facial que estimula la producción natural de colágeno y mejora la textura de la piel.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton label="Agenda Online" href="/contact" variant="ghost" />
          <CTAButton label="Llama Ahora" href="tel:+13855550123" variant="primary" className="!bg-[#1DD1A1] hover:!bg-[#16C79A]" />
          <CTAButton label="Ver Detalles" href="#detalles" variant="ghost" />
        </div>
        <div class="mt-10 flex items-center justify-center">
          <span class="h-[2px] w-20 bg-white/60"></span>
          <span class="mx-3 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center">•</span>
          <span class="h-[2px] w-20 bg-white/60"></span>
        </div>
      </div>
    </div>
  </section>

  <nav class="bg-white py-6 border-b border-gray-100">
    <div class="container mx-auto px-4">
      <ol class="flex items-center space-x-2 text-sm text-text/70">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li>/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li>/</li>
        <li class="text-text font-medium">Microneedling</li>
      </ol>
    </div>
  </nav>

  <section id="detalles" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-start">
        <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=1200&h=900&fit=crop&crop=center" alt="Microneedling" class="w-full h-96 lg:h-[500px] object-cover rounded-3xl shadow" loading="lazy" />
        <div class="space-y-6">
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-text">Renueva tu piel con Microneedling</h2>
          <p class="text-text/80">El microneedling utiliza microagujas para estimular colágeno y elastina, reduciendo poros, líneas finas y cicatrices para una piel más firme y suave.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="rounded-2xl border border-gray-200 p-6">
              <p class="text-sm text-text/60">Precio desde</p>
              <p class="text-2xl font-bold text-primary">Por definir</p>
            </div>
            <div class="rounded-2xl border border-gray-200 p-6">
              <p class="text-sm text-text/60">Duración</p>
              <p class="text-2xl font-bold text-primary">45 minutos</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h3 class="font-display font-bold text-3xl text-text">Beneficios</h3>
        <p class="text-text/70">Resultados visibles con mínima recuperación</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Estimula colágeno</h4><p class="text-text/70 text-sm">Mejora firmeza y elasticidad.</p></div>
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Suaviza textura</h4><p class="text-text/70 text-sm">Reduce poros y líneas finas.</p></div>
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Mejora cicatrices</h4><p class="text-text/70 text-sm">Atenúa cicatrices de acné.</p></div>
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Recuperación rápida</h4><p class="text-text/70 text-sm">Vuelta a actividades en horas.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12"><h3 class="font-display font-bold text-3xl text-text">Proceso</h3></div>
      <div class="grid lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
        <div class="text-center"><div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"><span class="font-bold text-primary text-2xl">1</span></div><h4 class="font-bold text-xl text-text mb-2">Evaluación</h4><p class="text-text/70">Diagnóstico y plan personalizado.</p></div>
        <div class="text-center"><div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"><span class="font-bold text-primary text-2xl">2</span></div><h4 class="font-bold text-xl text-text mb-2">Aplicación</h4><p class="text-text/70">Microagujas con precisión controlada.</p></div>
        <div class="text-center"><div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"><span class="font-bold text-primary text-2xl">3</span></div><h4 class="font-bold text-xl text-text mb-2">Recuperación</h4><p class="text-text/70">Mejora progresiva en 1–2 semanas.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-10"><h3 class="font-display font-bold text-3xl text-text">Preguntas Frecuentes</h3></div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 p-6"><h4 class="font-semibold text-lg text-text mb-2">¿Es doloroso?</h4><p class="text-text/70">Molestia mínima con crema anestésica.</p></div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6"><h4 class="font-semibold text-lg text-text mb-2">¿Cuántas sesiones?</h4><p class="text-text/70">Usualmente 3–4 sesiones según objetivos.</p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>