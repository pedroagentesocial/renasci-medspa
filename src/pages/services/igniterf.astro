---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="IgniteRF by InMode — Plataforma RFAL Avanzada"
  description="IgniteRF es una solución avanzada para contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con penetración de hasta 60mm."
>
  <section class="relative min-h-[32vh] sm:min-h-[40vh] bg-black text-white text-center flex items-center overflow-hidden">
    <video class="absolute inset-0 w-full h-full object-cover" src="/video/igniteRF.mp4" autoplay muted loop playsinline></video>
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight mb-4">
        <span data-i18n="igniterf.hero_title">IgniteRF</span>
      </h1>
      <p class="text-white/85 text-lg md:text-xl">
        <span data-i18n="igniterf.hero_subtitle">RFAL</span>
      </p>
      <div class="mt-6">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold bg-[#F3A2A7] text-white hover:opacity-90 transition-all">
          <span data-i18n="igniterf.cta">Agenda</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section class="py-12 lg:py-16 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div>
          <h2 class="font-display font-bold text-2xl md:text-3xl text-dark mb-4"><span data-i18n="igniterf.what_is_title">¿Qué es IgniteRF?</span></h2>
          <p class="text-graytxt leading-relaxed mb-4">
            <span data-i18n="igniterf.what_is_p1">p1</span>
          </p>
          <p class="text-graytxt leading-relaxed">
            <span data-i18n="igniterf.what_is_p2">p2</span>
          </p>
        </div>
        <div class="bg-[#F3A2A7]/10 rounded-2xl p-6">
          <h3 class="font-semibold text-xl text-dark mb-3"><span data-i18n="igniterf.key_benefits_title">Beneficios</span></h3>
          <ul class="space-y-3 text-graytxt list-none">
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span data-i18n="igniterf.key_benefits.b1">b1</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span data-i18n="igniterf.key_benefits.b2">b2</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span data-i18n="igniterf.key_benefits.b3">b3</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span data-i18n="igniterf.key_benefits.b4">b4</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span data-i18n="igniterf.key_benefits.b5">b5</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-8 lg:py-12 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h3 class="font-display font-bold text-2xl text-dark mb-4"><span data-i18n="igniterf.tech_title">Tecnologías</span></h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.bodytite_turbo.title">BodyTite Turbo</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.bodytite_turbo.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.facetite_turbo.title">FaceTite Turbo</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.facetite_turbo.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.quantumrf_25.title">QuantumRF 25</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.quantumrf_25.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.quantumrf_10.title">QuantumRF 10</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.quantumrf_10.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.bodytite_ignite.title">BodyTite IgniteRF</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.bodytite_ignite.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.facetite_ignite.title">FaceTite IgniteRF</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.facetite_ignite.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.accutite_ignite.title">AccuTite IgniteRF</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.accutite_ignite.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.morpheus8.title">Morpheus8</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.morpheus8.desc">desc</p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2" data-i18n="igniterf.tech.morpheus8_deep.title">Morpheus8 Deep</h4>
          <p class="text-graytxt" data-i18n="igniterf.tech.morpheus8_deep.desc">desc</p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold bg-[#AABFA8] text-white hover:opacity-90 transition-all">
          <span data-i18n="igniterf.cta">Agenda</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .text-dark { color: #1A1A1A; }
  .text-graytxt { color: #4B5563; }
</style>
