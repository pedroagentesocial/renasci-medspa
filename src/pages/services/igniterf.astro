---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="IgniteRF by InMode — Plataforma RFAL Avanzada"
  description="IgniteRF es una solución avanzada para contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con penetración de hasta 60mm."
>
  <section class="relative min-h-[40vh] sm:min-h-[48vh] bg-black text-white text-center flex items-center overflow-hidden">
    <video class="absolute inset-0 w-full h-full object-cover opacity-60" src="/video/igniteRF.mp4" autoplay muted loop playsinline></video>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight mb-4">
        <span class="menu-item-label" data-label-es="IgniteRF by InMode" data-label-en="IgniteRF by InMode">IgniteRF by InMode</span>
      </h1>
      <p class="text-white/85 text-lg md:text-xl">
        <span class="menu-item-label" data-label-es="Plataforma RFAL con modalidades sinérgicas para contracción de tejido y resultados naturales en rostro y cuerpo." data-label-en="RFAL platform with synergistic modalities for tissue contraction and natural-looking results on face and body.">Plataforma RFAL con modalidades sinérgicas para contracción de tejido y resultados naturales en rostro y cuerpo.</span>
      </p>
      <div class="mt-6">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold bg-[#F3A2A7] text-white hover:opacity-90 transition-all">
          <span class="menu-item-label" data-label-es="Agenda una consulta" data-label-en="Schedule a consult">Agenda una consulta</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section class="py-12 lg:py-16 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div>
          <h2 class="font-display font-bold text-2xl md:text-3xl text-dark mb-4"><span class="menu-item-label" data-label-es="¿Qué es IgniteRF?" data-label-en="What is IgniteRF?">¿Qué es IgniteRF?</span></h2>
          <p class="text-graytxt leading-relaxed mb-4">
            <span class="menu-item-label" data-label-es="IgniteRF es una plataforma integral indicada para procedimientos que requieren contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con niveles de penetración de hasta 60mm. Integra modalidades sinérgicas y parámetros de energía preestablecidos que optimizan la dispersión térmica para obtener resultados consistentes y naturales." data-label-en="IgniteRF is a comprehensive platform indicated for procedures requiring soft tissue contraction, electrocoagulation, hemostasis, and fractional treatments with penetration levels up to 60mm. It integrates synergistic modalities and preset energy parameters to optimize heat dispersion for consistent, natural results.">IgniteRF es una plataforma integral indicada para procedimientos que requieren contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con niveles de penetración de hasta 60mm. Integra modalidades sinérgicas y parámetros de energía preestablecidos que optimizan la dispersión térmica para obtener resultados consistentes y naturales.</span>
          </p>
          <p class="text-graytxt leading-relaxed">
            <span class="menu-item-label" data-label-es="Incorpora mecanismos de retroalimentación de temperatura e impedancia para monitorizar el tejido en tiempo real, maximizando la seguridad y los resultados clínicos." data-label-en="It incorporates temperature and impedance feedback mechanisms to monitor tissue in real time, maximizing safety and clinical outcomes.">Incorpora mecanismos de retroalimentación de temperatura e impedancia para monitorizar el tejido en tiempo real, maximizando la seguridad y los resultados clínicos.</span>
          </p>
        </div>
        <div class="bg-[#F3A2A7]/10 rounded-2xl p-6">
          <h3 class="font-semibold text-xl text-dark mb-3"><span class="menu-item-label" data-label-es="Beneficios Clave" data-label-en="Key Benefits">Beneficios Clave</span></h3>
          <ul class="space-y-2 text-graytxt list-disc pl-6">
            <li><span class="menu-item-label" data-label-es="Plataforma con rango de tratamiento de 0.5mm a 60mm." data-label-en="Comprehensive platform with treatment range from 0.5mm to 60mm.">Plataforma con rango de tratamiento de 0.5mm a 60mm.</span></li>
            <li><span class="menu-item-label" data-label-es="Enfoque multimodal para precisión y contracción de tejido." data-label-en="Multi-modality approach for precision and tissue contraction.">Enfoque multimodal para precisión y contracción de tejido.</span></li>
            <li><span class="menu-item-label" data-label-es="Radiofrecuencia bipolar (RF) clínicamente probada." data-label-en="Clinically proven bipolar radiofrequency (RF).">Radiofrecuencia bipolar (RF) clínicamente probada.</span></li>
            <li><span class="menu-item-label" data-label-es="Parámetros preestablecidos que controlan la dispersión de calor." data-label-en="Preset parameters controlling heat dispersion.">Parámetros preestablecidos que controlan la dispersión de calor.</span></li>
            <li><span class="menu-item-label" data-label-es="Retroalimentación de temperatura e impedancia continua." data-label-en="Continuous temperature and impedance feedback.">Retroalimentación de temperatura e impedancia continua.</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-8 lg:py-12 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h3 class="font-display font-bold text-2xl text-dark mb-4"><span class="menu-item-label" data-label-es="Tecnologías en la estación" data-label-en="Technologies on the workstation">Tecnologías en la estación</span></h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-es="BodyTite Turbo" data-label-en="BodyTite Turbo">BodyTite Turbo</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-es="Contracción de tejido corporal con profundidad elevada y control térmico avanzado." data-label-en="Body tissue contraction with elevated depth and advanced thermal control.">Contracción de tejido corporal con profundidad elevada y control térmico avanzado.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-es="FaceTite Turbo" data-label-en="FaceTite Turbo">FaceTite Turbo</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-es="Contorno facial mínimamente invasivo con contracción de tejido subcutáneo." data-label-en="Minimally invasive facial contouring with subcutaneous tissue contraction.">Contorno facial mínimamente invasivo con contracción de tejido subcutáneo.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-es="AccuTite" data-label-en="AccuTite">AccuTite</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-es="Aplicación de precisión en zonas pequeñas y delicadas." data-label-en="Precision application on small and delicate areas.">Aplicación de precisión en zonas pequeñas y delicadas.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-es="Morpheus8 Body Turbo" data-label-en="Morpheus8 Body Turbo">Morpheus8 Body Turbo</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-es="RF fraccionada para remodelación y mejora de la apariencia de tejidos." data-label-en="Fractional RF for remodeling and improved tissue appearance.">RF fraccionada para remodelación y mejora de la apariencia de tejidos.</span></p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold bg-[#AABFA8] text-white hover:opacity-90 transition-all">
          <span class="menu-item-label" data-label-es="Solicitar evaluación" data-label-en="Request evaluation">Solicitar evaluación</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .text-dark { color: #1A1A1A; }
  .text-graytxt { color: #4B5563; }
</style>
