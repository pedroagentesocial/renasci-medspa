---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="IgniteRF by InMode — Plataforma RFAL Avanzada"
  description="IgniteRF es una solución avanzada para contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con penetración de hasta 60mm."
>
  <section class="relative h-screen md:h-[80vh] bg-black text-white overflow-hidden">
    <video 
      class="absolute inset-0 w-full h-full object-cover z-0" 
      src="/video/igniteRF.mp4" 
      autoplay 
      muted 
      playsinline 
      loop
      preload="auto" 
      aria-hidden="true"
    ></video>
    <div class="absolute inset-0 z-10 flex items-center justify-center">
      <div class="text-center px-4">
        <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight mb-2" style="text-shadow: 0 2px 8px rgba(0,0,0,.6);">
          <span data-i18n="igniterf.hero_title">IGNITERF</span>
        </h1>
        <p class="uppercase tracking-widest text-sm md:text-base text-white/90" style="text-shadow: 0 2px 8px rgba(0,0,0,.6);">
          <span data-i18n="igniterf.hero_subtitle">ADVANCED MINIMALLY INVASIVE CONTRACTION TREATMENTS</span>
        </p>
      </div>
    </div>
  </section>

  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section class="py-12 lg:py-16 bg-white">
