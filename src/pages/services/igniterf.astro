---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="IgniteRF by InMode — Plataforma RFAL Avanzada"
  description="IgniteRF es una solución avanzada para contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con penetración de hasta 60mm."
>
  <section class="relative min-h-[32vh] sm:min-h-[40vh] bg-black text-white text-center flex items-center overflow-hidden">
    <video class="absolute inset-0 w-full h-full object-cover" src="/video/igniteRF.mp4" autoplay muted loop playsinline></video>
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight mb-4">
        <span class="menu-item-label" data-label-en="IgniteRF by InMode" data-label-es="IgniteRF de InMode">IgniteRF by InMode</span>
      </h1>
      <p class="text-white/85 text-lg md:text-xl">
        <span class="menu-item-label" data-label-en="RFAL platform for precise soft tissue contraction and natural-looking results — face & body" data-label-es="Plataforma RFAL para contracción precisa de tejido blando y resultados naturales — rostro y cuerpo">RFAL platform for precise soft tissue contraction and natural-looking results — face & body</span>
      </p>
      <div class="mt-6">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold bg-[#F3A2A7] text-white hover:opacity-90 transition-all">
          <span class="menu-item-label" data-label-en="Schedule a consult" data-label-es="Agenda una consulta">Schedule a consult</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section class="py-12 lg:py-16 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div>
          <h2 class="font-display font-bold text-2xl md:text-3xl text-dark mb-4"><span class="menu-item-label" data-label-en="What is IgniteRF?" data-label-es="¿Qué es IgniteRF?">What is IgniteRF?</span></h2>
          <p class="text-graytxt leading-relaxed mb-4">
            <span class="menu-item-label" data-label-en="IgniteRF is an advanced body and facial solution indicated for procedures requiring soft tissue contraction, electrocoagulation, hemostasis, and fractional treatments up to 60mm depth. It blends multiple synergistic modalities to deliver speed and efficacy with natural-looking results." data-label-es="IgniteRF es una solución corporal y facial avanzada indicada para procedimientos que requieren contracción de tejidos blandos, electrocoagulación, hemostasia y tratamientos fraccionados con niveles de penetración de hasta 60mm. Combina modalidades sinérgicas para brindar rapidez, eficacia y resultados de aspecto natural.">IgniteRF is an advanced body and facial solution indicated for procedures requiring soft tissue contraction, electrocoagulation, hemostasis, and fractional treatments up to 60mm depth. It blends multiple synergistic modalities to deliver speed and efficacy with natural-looking results.</span>
          </p>
          <p class="text-graytxt leading-relaxed">
            <span class="menu-item-label" data-label-en="It incorporates temperature and impedance feedback mechanisms to monitor tissue in real time, maximizing safety and clinical outcomes." data-label-es="Incorpora mecanismos de retroalimentación de temperatura e impedancia para monitorizar el tejido en tiempo real, maximizando la seguridad y los resultados clínicos.">It incorporates temperature and impedance feedback mechanisms to monitor tissue in real time, maximizing safety and clinical outcomes.</span>
          </p>
        </div>
        <div class="bg-[#F3A2A7]/10 rounded-2xl p-6">
          <h3 class="font-semibold text-xl text-dark mb-3"><span class="menu-item-label" data-label-en="Key Benefits" data-label-es="Beneficios Clave">Key Benefits</span></h3>
          <ul class="space-y-3 text-graytxt list-none">
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span class="menu-item-label" data-label-en="A comprehensive platform providing a full range of treatment depths from 0.5mm to 60mm." data-label-es="Una plataforma integral que ofrece una gama completa de profundidades de tratamiento de 0,5 mm a 60 mm.">A comprehensive platform providing a full range of treatment depths from 0.5mm to 60mm.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span class="menu-item-label" data-label-en="Multi-modality approach for precision procedures to contract and improve soft tissue appearance." data-label-es="Enfoque multimodal para procedimientos de precisión que contraen y mejoran la apariencia de los tejidos blandos.">Multi-modality approach for precision procedures to contract and improve soft tissue appearance.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span class="menu-item-label" data-label-en="Leverages the power of clinically proven bipolar radiofrequency (RF) energy." data-label-es="Aprovecha el poder de la energía de radiofrecuencia (RF) bipolar clínicamente probada.">Leverages the power of clinically proven bipolar radiofrequency (RF) energy.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span class="menu-item-label" data-label-en="Preset energy parameters control heat dispersion for optimal treatment results." data-label-es="Los parámetros de energía preestablecidos controlan la dispersión del calor para obtener resultados óptimos del tratamiento.">Preset energy parameters control heat dispersion for optimal treatment results.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[#F3A2A7] mt-[2px]">•</span>
              <span class="menu-item-label" data-label-en="Built-in temperature and impedance feedback mechanisms constantly monitor tissue to maximize outcomes." data-label-es="Los mecanismos de retroalimentación de temperatura e impedancia incorporados monitorean constantemente el tejido para maximizar los resultados.">Built-in temperature and impedance feedback mechanisms constantly monitor tissue to maximize outcomes.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-8 lg:py-12 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h3 class="font-display font-bold text-2xl text-dark mb-4"><span class="menu-item-label" data-label-en="Technologies on the Workstation" data-label-es="Tecnologías en la Estación">Technologies on the Workstation</span></h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="BodyTite Turbo" data-label-es="BodyTite Turbo">BodyTite Turbo</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="50% more power and 40% longer rigid cannula for precision and faster results." data-label-es="50% más potencia y una cánula rígida 40% más larga para mayor precisión y resultados más rápidos.">50% more power and 40% longer rigid cannula for precision and faster results.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="FaceTite Turbo" data-label-es="FaceTite Turbo">FaceTite Turbo</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Minimally invasive handpiece with rigid cannula for control, precision and safety in delicate zones." data-label-es="Pieza de mano mínimamente invasiva con cánula rígida para control, precisión y seguridad en zonas delicadas.">Minimally invasive handpiece with rigid cannula for control, precision and safety in delicate zones.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="QuantumRF 25" data-label-es="QuantumRF 25">QuantumRF 25</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Advanced minimally invasive FRF to maximal depths on larger areas with pulsed bipolar RF." data-label-es="RF fraccionada mínimamente invasiva a profundidades máximas en áreas grandes con RF bipolar pulsada.">Advanced minimally invasive FRF to maximal depths on larger areas with pulsed bipolar RF.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="QuantumRF 10" data-label-es="QuantumRF 10">QuantumRF 10</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Innovative minimally invasive FRF for precise soft tissue contraction in small zones." data-label-es="RF fraccionada mínimamente invasiva para contracción precisa de tejido en zonas pequeñas.">Innovative minimally invasive FRF for precise soft tissue contraction in small zones.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="BodyTite IgniteRF" data-label-es="BodyTite IgniteRF">BodyTite IgniteRF</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Clinically proven RFAL for larger body areas; unprecedented contraction in a single treatment." data-label-es="RFAL clínicamente probada para áreas corporales grandes; contracción sin precedentes en una sola sesión.">Clinically proven RFAL for larger body areas; unprecedented contraction in a single treatment.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="FaceTite IgniteRF" data-label-es="FaceTite IgniteRF">FaceTite IgniteRF</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Advanced RFAL for small areas; non-aspirating cannula enables safe subdermal work." data-label-es="RFAL avanzada para áreas pequeñas; la cánula no aspirante permite trabajo subdérmico seguro.">Advanced RFAL for small areas; non-aspirating cannula enables safe subdermal work.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="AccuTite IgniteRF" data-label-es="AccuTite IgniteRF">AccuTite IgniteRF</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Smallest minimally invasive RF device with real-time temperature and impedance safeguards." data-label-es="El dispositivo RF mínimamente invasivo más pequeño, con salvaguardas de temperatura e impedancia en tiempo real.">Smallest minimally invasive RF device with real-time temperature and impedance safeguards.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="Morpheus8" data-label-es="Morpheus8">Morpheus8</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Fractional bipolar RF microneedling for dermal and subdermal remodeling." data-label-es="RF bipolar fraccionada con microneedling para remodelación dérmica y subdérmica.">Fractional bipolar RF microneedling for dermal and subdermal remodeling.</span></p>
        </div>
        <div class="rounded-2xl border border-gray-200 p-6">
          <h4 class="font-semibold text-lg text-dark mb-2"><span class="menu-item-label" data-label-en="Morpheus8 Deep" data-label-es="Morpheus8 Deep">Morpheus8 Deep</span></h4>
          <p class="text-graytxt"><span class="menu-item-label" data-label-en="Deepest targeted RF deposition with multi-level subdermal and dermal contraction." data-label-es="El depósito de RF más profundo con contracción subdérmica multinivel y dérmica.">Deepest targeted RF deposition with multi-level subdermal and dermal contraction.</span></p>
        </div>
      </div>
      <div class="mt-8">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-[48px] font-semibold bg-[#AABFA8] text-white hover:opacity-90 transition-all">
          <span class="menu-item-label" data-label-en="Learn more" data-label-es="Solicitar evaluación">Learn more</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .text-dark { color: #1A1A1A; }
  .text-graytxt { color: #4B5563; }
</style>
