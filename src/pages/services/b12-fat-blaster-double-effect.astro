---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="B12 + Fat Blaster Double Effect - Renasci Medical Spa"
  description="Combined B12 energy and lipotropic support to boost vitality and enhance fat metabolism. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30"><span data-i18n="b12double.category">Wellness & Weight Loss</span></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4"><span data-i18n="b12double.hero_title">B12 + Fat Blaster Double Effect</span></h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto"><span data-i18n="b12double.hero_subtitle">Synergistic protocol for energy and metabolism support in one session.</span></p>
      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20">
        <div class="text-sm text-white/80 mb-1"><span data-i18n="b12double.price_from_label">Starting at</span></div>
        <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]"><span data-i18n="b12double.price_value">$65</span></div>
        <div class="text-sm text-white/80 mt-1"><span data-i18n="b12double.duration_label">Duration: 20 min</span></div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50"><span data-i18n="cta.view_details">View Details</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50" aria-label="Call Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.home">Home</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.services">Services</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="b12double.breadcrumb_label">B12 + Fat Blaster Double Effect</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/images/inyeccion-botox.jpg" alt="B12 + Fat Blaster" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6"><span data-i18n="b12double.details.title">Double Effect Protocol</span></h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4"><span data-i18n="b12double.details.p1"><strong>B12</strong> supports energy and focus while <strong>lipotropics</strong> aid fat metabolism — combined for synergy.</span></p>
              <p class="mb-4"><span data-i18n="b12double.details.p2">Convenient session with minimal downtime; designed to complement healthy habits.</span></p>
              <p><span data-i18n="b12double.details.p3">Refinement develops over days to weeks; schedule personalized.</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="b12double.benefits.title">Treatment Benefits</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="b12double.benefits.subtitle">Synergy in energy and metabolism</span></p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="b12double.benefits.items.0.title">Energy + Focus</span></h3><p class="text-gray-700"><span data-i18n="b12double.benefits.items.0.text">B12 support for daily vitality.</span></p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="b12double.benefits.items.1.title">Fat Metabolism</span></h3><p class="text-gray-700"><span data-i18n="b12double.benefits.items.1.text">Lipotropics aid processing efficiency.</span></p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="b12double.benefits.items.2.title">Convenient Combo</span></h3><p class="text-gray-700"><span data-i18n="b12double.benefits.items.2.text">One visit; minimal downtime.</span></p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="b12double.process.title">Treatment Process</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto"><span data-i18n="b12double.process.subtitle">Consultation, combined injections and follow‑up scheduling</span></p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-[#F3A2A7] via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900">Consultation</h3></div><p class="text-gray-600 leading-relaxed">Suitability and synergy plan.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900">Combined Injections</h3></div><p class="text-gray-600 leading-relaxed">B12 and lipotropics in one visit.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/images/inyeccion-botox.jpg" alt="Combined" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900">Follow‑up</h3></div><p class="text-gray-600 leading-relaxed">Weekly or biweekly schedule.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Follow-up" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="b12double.faq.title">Frequently Asked Questions</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="b12double.faq.subtitle">Common questions about the double effect protocol</span></p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3"><span data-i18n="b12double.faq.items.0.q">Why combine them?</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="b12double.faq.items.0.a">Energy and metabolism support together enhances overall effect.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3"><span data-i18n="b12double.faq.items.1.q">How often?</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="b12double.faq.items.1.a">Weekly or biweekly, personalized per goals.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3"><span data-i18n="b12double.faq.items.2.q">Downtime?</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="b12double.faq.items.2.a">Minimal; resume normal activities immediately.</span></p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>
