---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'lifting-nefertiti',
  slug: 'lifting-nefertiti',
  title: { es: 'Lifting de Cuello Nefertiti', en: 'Nefertiti Neck Lift' },
  description: { es: 'Tratamiento especializado con neurotoxina para definir y estilizar el cuello, creando una línea jawline más definida y elegante, inspirado en la belleza de la reina Nefertiti.', en: 'Specialized neurotoxin treatment to define and stylize the neck, creating a more defined and elegant jawline, inspired by the beauty of Queen Nefertiti.' },
  excerpt: { es: 'Define y estiliza el cuello para una línea jawline más elegante.', en: 'Defines and stylizes the neck for a more elegant jawline.' },
  category: 'especializados',
  precio: '$480',
  image: 'https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=400&h=300&fit=crop&crop=center',
  benefits: ['Jawline definida', 'Cuello estilizado', 'Efecto lifting', 'Resultados naturales'],
  duracion: '30 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'especializados' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <!-- Floating Card -->
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-white/20 shadow-2xl transform hover:scale-105 transition-all duration-500">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          {servicio.title.es}
        </h1>
        
        <p class="text-xl md:text-2xl text-pink-100 mb-8 leading-relaxed">
          {servicio.description.es}
        </p>
        
        <!-- Price Badge -->
        <div class="inline-flex items-center bg-gradient-to-r from-pink-500 to-purple-600 text-white px-8 py-4 rounded-full text-2xl font-bold mb-8 shadow-lg">
          <span class="mr-2">💎</span>
          {servicio.precio}
        </div>
        
        <!-- CTA Button -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton 
            text="Agenda tu Cita" 
            href="/contacto"
            variant="primary"
            class="transform hover:scale-105 transition-all duration-300"
          />
          <CTAButton 
            text="Más Información" 
            href="#detalles"
            variant="secondary"
            class="transform hover:scale-105 transition-all duration-300"
          />
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/50 rounded-full flex justify-center">
        <div class="w-1 h-3 bg-white/70 rounded-full mt-2 animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Información del Servicio -->
        <div class="space-y-8">
          <div class="bg-white rounded-3xl p-8 shadow-xl border border-pink-100">
            <h3 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-3 rounded-full mr-4">
                🌟
              </span>
              Beneficios
            </h3>
            
            <div class="grid gap-4">
              {servicio.benefits.map((benefit, index) => (
                <div class="flex items-center p-4 bg-gradient-to-r from-pink-50 to-purple-50 rounded-xl transform hover:scale-105 transition-all duration-300">
                  <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-2 rounded-full mr-4 flex-shrink-0">
                    ✓
                  </div>
                  <span class="text-gray-700 font-medium">{benefit}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Imagen del Servicio -->
        <div class="relative">
          <div class="bg-gradient-to-br from-pink-400 to-purple-600 rounded-3xl p-1 transform hover:scale-105 transition-all duration-500">
            <img 
              src={servicio.image}
              alt={`${servicio.title.es} treatment`}
              class="w-full h-96 object-cover rounded-3xl shadow-2xl"
              loading="lazy"
            />
          </div>
          
          <!-- Floating Badge -->
          <div class="absolute -top-4 -right-4 bg-gradient-to-r from-pink-500 to-purple-600 text-white p-4 rounded-full shadow-lg transform rotate-12">
            <span class="text-2xl">💫</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-gray-600">
          Técnica elegante y refinada
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl transform hover:scale-105 transition-all duration-300">
          <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            1
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Evaluación</h3>
          <p class="text-gray-600">Análisis de la anatomía del cuello y jawline</p>
        </div>
        
        <div class="text-center p-8 bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl transform hover:scale-105 transition-all duration-300">
          <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            2
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Marcado Estratégico</h3>
          <p class="text-gray-600">Identificación de puntos clave para el efecto Nefertiti</p>
        </div>
        
        <div class="text-center p-8 bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl transform hover:scale-105 transition-all duration-300">
          <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            3
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Aplicación Precisa</h3>
          <p class="text-gray-600">Inyección estratégica para crear el lifting natural</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Qué es el efecto Nefertiti?</h3>
          <p class="text-gray-600">Es una técnica que define la línea del cuello y jawline, creando un perfil más elegante y estilizado.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Cuándo veré los resultados?</h3>
          <p class="text-gray-600">Los resultados comienzan a notarse después de 3-5 días y alcanzan su máximo efecto en 2 semanas.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Es doloroso el procedimiento?</h3>
          <p class="text-gray-600">Es mínimamente invasivo con molestias muy leves. Se puede aplicar anestesia tópica si es necesario.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gradient-to-r from-pink-50 to-rose-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
            Servicios <span class="text-pink-600">Relacionados</span>
          </h2>
          <p class="text-xl text-gray-600">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-pink-600 to-rose-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full -translate-x-48 -translate-y-48"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full translate-x-48 translate-y-48"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        ¿Lista para un Cuello de Reina?
      </h2>
      <p class="text-xl text-pink-100 mb-8 max-w-2xl mx-auto">
        Agenda tu cita hoy y descubre cómo el Lifting Nefertiti puede transformar tu perfil con elegancia y naturalidad.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agenda Consulta" 
          href="/contacto"
          variant="secondary"
          class="bg-white text-pink-600 hover:bg-pink-50 transform hover:scale-105 transition-all duration-300"
        />
        <CTAButton 
          text="Llama Ahora" 
          href="tel:+1234567890"
          variant="outline"
          class="border-white text-white hover:bg-white hover:text-pink-600 transform hover:scale-105 transition-all duration-300"
        />
      </div>
    </div>
  </section>
</BaseLayout>