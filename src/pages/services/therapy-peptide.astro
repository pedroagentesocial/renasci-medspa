          <p class="text-lg text-gray-700 leading-relaxed" data-t-es={pageText.es.whatAreP2} data-t-en={pageText.en.whatAreP2}>{pageText[lang].whatAreP2}</p>
        </div>
        <div>
          <h2 class="font-display font-bold text-3xl md:text-4xl text-[#F3A2A7] mb-6" data-t-es={pageText.es.benefitsTitle} data-t-en={pageText.en.benefitsTitle}>{pageText[lang].benefitsTitle}</h2>
          <ul class="list-disc pl-5 space-y-3 text-gray-700 leading-relaxed">
            <li data-t-es={pageText.es.benefits[0]} data-t-en={pageText.en.benefits[0]}>{pageText[lang].benefits[0]}</li>
            <li data-t-es={pageText.es.benefits[1]} data-t-en={pageText.en.benefits[1]}>{pageText[lang].benefits[1]}</li>
            <li data-t-es={pageText.es.benefits[2]} data-t-en={pageText.en.benefits[2]}>{pageText[lang].benefits[2]}</li>
            <li data-t-es={pageText.es.benefits[3]} data-t-en={pageText.en.benefits[3]}>{pageText[lang].benefits[3]}</li>
            <li data-t-es={pageText.es.benefits[4]} data-t-en={pageText.en.benefits[4]}>{pageText[lang].benefits[4]}</li>
            <li data-t-es={pageText.es.benefits[5]} data-t-en={pageText.en.benefits[5]}>{pageText[lang].benefits[5]}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-[#F3A2A7] mb-6" data-t-es={pageText.es.pricingTitle} data-t-en={pageText.en.pricingTitle}>{pageText[lang].pricingTitle}</h2>
