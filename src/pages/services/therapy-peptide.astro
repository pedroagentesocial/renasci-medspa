---

<BaseLayout 
  title={pageText[lang].metaTitle}
  description={pageText[lang].metaDescription}
  lang={lang}
>
  <section class="relative min-h-[45vh] flex items-center justify-center text-center overflow-hidden">
    <img 
      src="/img/services/peptide-therapy.jpg"
      alt={pageText[lang].heroAlt}
      data-alt-es={pageText.es.heroAlt}
      data-alt-en={pageText.en.heroAlt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <h1 class="font-display font-bold text-4xl md:text-6xl text-white mb-4" data-t-es={pageText.es.heroTitle} data-t-en={pageText.en.heroTitle}>{pageText[lang].heroTitle}</h1>
      <p class="text-lg md:text-xl text-white/90 leading-relaxed" data-t-es={pageText.es.introText} data-t-en={pageText.en.introText}>{pageText[lang].introText}</p>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50 text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10 max-w-6xl mx-auto">
