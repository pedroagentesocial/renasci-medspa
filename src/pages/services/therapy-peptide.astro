      bpcTitle: 'BPC-157',
      bpcDesc: 'Supports tissue recovery and regenerative balance.',
      cjcTitle: 'CJC 1295 / Ipamorelin',
      cjcDesc: 'Helps with recovery, sleep quality, and body composition goals.',
      sermorelinTitle: 'Sermorelin',
      sermorelinDesc: 'Encourages natural hormone signaling for recovery and vitality.',
      nadTitle: 'NAD+',
      nadDesc: 'Supports energy, cellular repair, and mental clarity.',
      ghkuTitle: 'GhKu',
      ghkuDesc: 'Supports skin renewal and recovery-focused care.',
      vitaminTitle: 'Vitamin D',
      vitaminDesc: 'Helps maintain immune balance and overall wellness support.',
      hairTitle: 'Hair Growth',
      hairDesc: 'Supports fuller, healthier-looking hair with regenerative focus.'
    },
    cta: 'Book Now'
