import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout title="Microneedling con PRP - Renasci Medical Spa" description="Microneedling potenciado con PRP para máxima regeneración celular y resultados superiores.">
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <h1 class="font-display font-bold text-5xl md:text-6xl mb-4">Microneedling con PRP</h1>
        <p class="text-lg md:text-xl text-white/80 mb-8">Combinación avanzada que acelera la regeneración celular y mejora notablemente la calidad de la piel.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton label="Agenda Online" href="/contact" variant="ghost" />
          <CTAButton label="Llama Ahora" href="tel:+13855550123" variant="primary" className="!bg-[#1DD1A1] hover:!bg-[#16C79A]" />
          <CTAButton label="Ver Detalles" href="#detalles" variant="ghost" />
        </div>
        <div class="mt-10 flex items-center justify-center"><span class="h-[2px] w-20 bg-white/60"></span><span class="mx-3 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center">•</span><span class="h-[2px] w-20 bg-white/60"></span></div>
      </div>
    </div>
  </section>

  <section id="detalles" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-start">
        <img src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=1200&h=900&fit=crop&crop=center" alt="Microneedling con PRP" class="w-full h-96 lg:h-[500px] object-cover rounded-3xl shadow" loading="lazy" />
        <div class="space-y-6">
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-text">Máxima regeneración con PRP</h2>
          <p class="text-text/80">El PRP potencia el microneedling al aportar factores de crecimiento, optimizando la regeneración celular y mejorando textura, firmeza y luminosidad.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="rounded-2xl border border-gray-200 p-6"><p class="text-sm text-text/60">Precio desde</p><p class="text-2xl font-bold text-primary">Por definir</p></div>
            <div class="rounded-2xl border border-gray-200 p-6"><p class="text-sm text-text/60">Duración</p><p class="text-2xl font-bold text-primary">60 minutos</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12"><h3 class="font-display font-bold text-3xl text-text">Beneficios</h3><p class="text-text/70">Regeneración superior y resultados duraderos</p></div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Acelera regeneración</h4><p class="text-text/70 text-sm">Factores de crecimiento del PRP.</p></div>
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Mejora textura</h4><p class="text-text/70 text-sm">Mayor luminosidad y suavidad.</p></div>
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Estimula colágeno</h4><p class="text-text/70 text-sm">Firmeza y elasticidad.</p></div>
        <div class="bg-white rounded-2xl p-6 shadow"><h4 class="font-semibold text-lg text-text mb-2">Resultados superiores</h4><p class="text-text/70 text-sm">Sinergia PRP + microagujas.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12"><h3 class="font-display font-bold text-3xl text-text">Proceso</h3></div>
      <div class="grid lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
        <div class="text-center"><div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"><span class="font-bold text-primary text-2xl">1</span></div><h4 class="font-bold text-xl text-text mb-2">Extracción</h4><p class="text-text/70">Obtención del PRP.</p></div>
        <div class="text-center"><div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"><span class="font-bold text-primary text-2xl">2</span></div><h4 class="font-bold text-xl text-text mb-2">Microneedling</h4><p class="text-text/70">Microcanales controlados.</p></div>
        <div class="text-center"><div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6"><span class="font-bold text-primary text-2xl">3</span></div><h4 class="font-bold text-xl text-text mb-2">Aplicación PRP</h4><p class="text-text/70">Máxima absorción.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-10"><h3 class="font-display font-bold text-3xl text-text">Preguntas Frecuentes</h3></div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 p-6"><h4 class="font-semibold text-lg text-text mb-2">¿Qué es el PRP?</h4><p class="text-text/70">Plasma rico en plaquetas con factores de crecimiento.</p></div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6"><h4 class="font-semibold text-lg text-text mb-2">¿Cuándo veré resultados?</h4><p class="text-text/70">A partir de 2–3 semanas y de forma progresiva.</p></div>
      </div>
    </div>
  </section>
  <TransformCTA />
</BaseLayout>