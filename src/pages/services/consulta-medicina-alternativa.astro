---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'consulta-medicina-alternativa',
  slug: 'consulta-medicina-alternativa',
  title: { es: 'Consulta de Medicina Alternativa Get Carded', en: 'Alternative Medicine Consultation Get Carded' },
  description: { es: 'Consulta especializada en medicina alternativa para obtener la certificación médica necesaria para tratamientos de bienestar y pérdida de peso.', en: 'Specialized alternative medicine consultation to obtain the necessary medical certification for wellness and weight loss treatments.' },
  excerpt: { es: 'Certificación médica para tratamientos de bienestar.', en: 'Medical certification for wellness treatments.' },
  category: 'bienestar',
  precio: '$250 (+$15 tarifa estatal)',
  image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?w=400&h=300&fit=crop&crop=center',
  benefits: ['Certificación médica', 'Evaluación integral', 'Plan personalizado', 'Seguimiento profesional'],
  duracion: '45 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'bienestar' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1f?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} consultation at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="mb-8">
        <span class="inline-block px-4 py-2 bg-pink-500/20 backdrop-blur-sm rounded-full text-pink-200 text-sm font-medium mb-4">
          📋 Pérdida de Peso y Bienestar
        </span>
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
          {servicio.title.es}
        </h1>
        <p class="text-xl md:text-2xl text-pink-100 mb-8 max-w-3xl mx-auto leading-relaxed">
          {servicio.description.es}
        </p>
      </div>

      <!-- Precio y Duración -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-4 border border-white/20">
          <div class="text-pink-200 text-sm font-medium">Precio</div>
          <div class="text-white text-2xl font-bold">{servicio.precio}</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-4 border border-white/20">
          <div class="text-pink-200 text-sm font-medium">Duración</div>
          <div class="text-white text-2xl font-bold">{servicio.duracion}</div>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agendar Consulta" 
          href="https://calendly.com/renasci-medical-spa" 
          variant="primary"
          class="text-lg px-8 py-4"
        />
        <CTAButton 
          text="Más Información" 
          href="tel:+1234567890" 
          variant="secondary"
          class="text-lg px-8 py-4"
        />
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center">
        <div class="w-1 h-3 bg-white/50 rounded-full mt-2 animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Beneficios de la Consulta
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Obtén la certificación médica necesaria para acceder a tratamientos especializados de bienestar y pérdida de peso.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {servicio.benefits.map((benefit, index) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 mx-auto">
              <span class="text-2xl text-white font-bold">{index + 1}</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">{benefit}</h3>
            <p class="text-gray-600 text-center">
              {index === 0 && "Obtén la documentación médica requerida para tratamientos especializados."}
              {index === 1 && "Evaluación completa de tu estado de salud y necesidades específicas."}
              {index === 2 && "Plan de tratamiento diseñado especialmente para tus objetivos."}
              {index === 3 && "Acompañamiento médico continuo durante todo el proceso."}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Proceso de Consulta -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Proceso de Consulta
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Un proceso simple y profesional para obtener tu certificación médica.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-3xl">📋</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">1. Evaluación Inicial</h3>
          <p class="text-gray-600">
            Revisión completa de tu historial médico y evaluación de tus objetivos de bienestar.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-3xl">🔍</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">2. Análisis Médico</h3>
          <p class="text-gray-600">
            Examen médico detallado para determinar la elegibilidad para tratamientos específicos.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-3xl">✅</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">3. Certificación</h3>
          <p class="text-gray-600">
            Emisión de la certificación médica y plan de tratamiento personalizado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Relacionados -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Servicios Relacionados
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Descubre otros tratamientos de bienestar que pueden complementar tu plan.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-br from-pink-600 to-purple-700 text-white">
    <div class="max-w-4xl mx-auto text-center px-6">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        ¿Listo para Comenzar tu Consulta?
      </h2>
      <p class="text-xl mb-8 text-pink-100">
        Agenda tu consulta de medicina alternativa y obtén la certificación necesaria para tus tratamientos de bienestar.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agendar Ahora" 
          href="https://calendly.com/renasci-medical-spa" 
          variant="secondary"
          class="text-lg px-8 py-4"
        />
        <CTAButton 
          text="Llamar Ahora" 
          href="tel:+1234567890" 
          variant="outline"
          class="text-lg px-8 py-4 border-white text-white hover:bg-white hover:text-pink-600"
        />
      </div>
    </div>
  </section>
</BaseLayout>