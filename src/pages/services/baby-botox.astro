---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'baby-botox',
  slug: 'baby-botox',
  title: { es: 'Baby Botox', en: 'Baby Botox' },
  description: { es: 'Tratamiento suave con dosis menores de neurotoxina para resultados naturales y sutiles, manteniendo la expresión facial natural.', en: 'Gentle treatment with smaller doses of neurotoxin for natural and subtle results, maintaining natural facial expression.' },
  excerpt: { es: 'Tratamiento suave para resultados naturales y sutiles.', en: 'Gentle treatment for natural and subtle results.' },
  category: 'inyecciones-neurotoxinas',
  precio: 'Por definir',
  image: 'https://images.unsplash.com/photo-1616391182219-e080b4d1043a?w=400&h=300&fit=crop&crop=center',
  benefits: ['Resultados naturales', 'Expresión preservada', 'Menos riesgo', 'Efecto sutil'],
  duracion: '20 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'neurotoxinas' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1616391182219-e080b4d1043a?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-white/20 shadow-2xl">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          {servicio.title.es}
        </h1>
        
        <p class="text-xl md:text-2xl text-pink-100 mb-8 max-w-3xl mx-auto leading-relaxed">
          {servicio.description.es}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
          <div class="bg-pink-500/20 backdrop-blur-sm rounded-2xl px-6 py-3 border border-pink-300/30">
            <span class="text-pink-100 text-sm font-medium">Precio:</span>
            <span class="text-white text-lg font-bold ml-2">{servicio.precio}</span>
          </div>
          <div class="bg-purple-500/20 backdrop-blur-sm rounded-2xl px-6 py-3 border border-purple-300/30">
            <span class="text-purple-100 text-sm font-medium">Duración:</span>
            <span class="text-white text-lg font-bold ml-2">{servicio.duracion}</span>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton 
            text="Agenda tu Cita" 
            href="/contacto"
            variant="primary"
            class="bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 transform hover:scale-105 transition-all duration-300"
          />
          <CTAButton 
            text="Más Información" 
            href="#detalles"
            variant="secondary"
            class="bg-white/20 backdrop-blur-sm border-white/30 text-white hover:bg-white/30 transform hover:scale-105 transition-all duration-300"
          />
        </div>
      </div>
      
      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center text-white/70">
        <span class="text-sm mb-2">Desliza para más</span>
        <div class="w-1 h-8 bg-white/30 rounded-full overflow-hidden">
          <div class="w-1 h-3 bg-white/70 rounded-full mt-2 animate-pulse"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Información del Servicio -->
        <div class="space-y-8">
          <div class="bg-white rounded-3xl p-8 shadow-xl border border-pink-100">
            <h3 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-3 rounded-full mr-4">
                🌟
              </span>
              Beneficios
            </h3>
            
            <div class="grid gap-4">
              {servicio.benefits.map((benefit, index) => (
                <div class="flex items-center p-4 bg-gradient-to-r from-pink-50 to-purple-50 rounded-xl transform hover:scale-105 transition-all duration-300">
                  <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-2 rounded-full mr-4 flex-shrink-0">
                    ✓
                  </div>
                  <span class="text-gray-700 font-medium">{benefit}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Imagen del Servicio -->
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-pink-400/20 to-purple-600/20 rounded-3xl transform rotate-3"></div>
          <img 
            src={servicio.image}
            alt={servicio.title.es}
            class="relative w-full h-96 object-cover rounded-3xl shadow-2xl transform -rotate-1 hover:rotate-0 transition-transform duration-500"
            loading="lazy"
          />
          
          <!-- Floating Card -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-6 shadow-xl border border-pink-100 transform hover:scale-105 transition-all duration-300">
            <div class="text-center">
              <div class="text-2xl font-bold text-pink-600 mb-1">{servicio.precio}</div>
              <div class="text-sm text-gray-600">Precio del tratamiento</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Conoce paso a paso cómo realizamos este tratamiento especializado
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            1
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Consulta Personalizada</h3>
          <p class="text-gray-600">Evaluamos tu rostro y determinamos las dosis mínimas necesarias para resultados naturales.</p>
        </div>
        
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            2
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Aplicación Suave</h3>
          <p class="text-gray-600">Aplicamos dosis menores de neurotoxina con técnica precisa para mantener la expresión natural.</p>
        </div>
        
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            3
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Seguimiento Cuidadoso</h3>
          <p class="text-gray-600">Monitoreamos los resultados para asegurar el efecto deseado sin comprometer la naturalidad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
        <p class="text-xl text-gray-600">
          Resolvemos tus dudas sobre el Baby Botox
        </p>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Qué diferencia al Baby Botox del Botox tradicional?</h3>
          <p class="text-gray-600">El Baby Botox utiliza dosis menores de neurotoxina para lograr resultados más sutiles y naturales, preservando la expresión facial mientras suaviza las líneas.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Para quién es ideal este tratamiento?</h3>
          <p class="text-gray-600">Es perfecto para personas que buscan prevenir arrugas, quieren resultados sutiles, o es su primera vez con neurotoxinas.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Cuánto duran los efectos?</h3>
          <p class="text-gray-600">Los resultados del Baby Botox duran típicamente entre 2-3 meses, siendo más cortos que el Botox tradicional debido a las dosis menores.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gradient-to-r from-pink-50 to-rose-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
            Servicios <span class="text-pink-600">Relacionados</span>
          </h2>
          <p class="text-xl text-gray-600">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-pink-600 to-rose-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full -translate-x-48 -translate-y-48"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full translate-x-48 translate-y-48"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        ¿Lista para Probar Baby Botox?
      </h2>
      <p class="text-xl text-pink-100 mb-8 max-w-2xl mx-auto">
        Agenda tu consulta hoy y descubre los beneficios de este tratamiento suave para resultados naturales y sutiles.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agenda tu Consulta" 
          href="/contacto"
          variant="secondary"
          class="bg-white text-pink-600 hover:bg-pink-50 transform hover:scale-105 transition-all duration-300"
        />
        <CTAButton 
          text="Llama Ahora" 
          href="tel:+13856092840"
          variant="outline"
          class="border-white text-white hover:bg-white hover:text-pink-600 transform hover:scale-105 transition-all duration-300"
        />
      </div>
    </div>
  </section>
</BaseLayout>