---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'botox-lip-flip-especializado',
  slug: 'botox-lip-flip-especializado',
  title: { es: 'Tratamiento Botox Lip Flip (giro de labio)', en: 'Botox Lip Flip Treatment' },
  description: { es: 'Técnica especializada de Botox para crear un efecto de labios más voluminosos y definidos mediante el relajamiento del músculo orbicular, logrando un giro sutil del labio superior.', en: 'Specialized Botox technique to create fuller and more defined lips by relaxing the orbicular muscle, achieving a subtle flip of the upper lip.' },
  excerpt: { es: 'Crea labios más voluminosos con técnica especializada de Botox.', en: 'Creates fuller lips with specialized Botox technique.' },
  category: 'especializados',
  precio: '$75',
  image: 'https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=400&h=300&fit=crop&crop=center',
  benefits: ['Labios más definidos', 'Efecto natural', 'Procedimiento rápido', 'Sin tiempo de recuperación'],
  duracion: '15 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'especializados' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <!-- Floating Card -->
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-white/20 shadow-2xl transform hover:scale-105 transition-all duration-500">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          {servicio.title.es}
        </h1>
        
        <p class="text-xl md:text-2xl text-pink-100 mb-8 leading-relaxed">
          {servicio.description.es}
        </p>
        
        <!-- Price Badge -->
        <div class="inline-flex items-center bg-gradient-to-r from-pink-500 to-purple-600 text-white px-8 py-4 rounded-full text-2xl font-bold mb-8 shadow-lg">
          <span class="mr-2">💎</span>
          {servicio.precio}
        </div>
        
        <!-- CTA Button -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton 
            href="/contacto"
            variant="primary"
            className="transform hover:scale-105 transition-all duration-300"
          >
            Agenda tu Cita
          </CTAButton>
          <CTAButton 
            href="#detalles"
            variant="ghost"
            className="transform hover:scale-105 transition-all duration-300"
          >
            Más Información
          </CTAButton>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/50 rounded-full flex justify-center">
        <div class="w-1 h-3 bg-white/70 rounded-full mt-2 animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Información del Servicio -->
        <div class="space-y-8">
          <div class="bg-white rounded-3xl p-8 shadow-xl border border-pink-100">
            <h3 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-3 rounded-full mr-4">
                🌟
              </span>
              Beneficios
            </h3>
            
            <div class="grid gap-4">
              {servicio.benefits.map((benefit, index) => (
                <div class="flex items-center p-4 bg-gradient-to-r from-pink-50 to-purple-50 rounded-xl transform hover:scale-105 transition-all duration-300">
                  <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-2 rounded-full mr-4 flex-shrink-0">
                    ✓
                  </div>
                  <span class="text-gray-700 font-medium">{benefit}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Imagen del Servicio -->
        <div class="relative">
          <div class="bg-gradient-to-br from-pink-400 to-purple-600 rounded-3xl p-1 transform hover:scale-105 transition-all duration-500">
            <img 
              src={servicio.image}
              alt={`${servicio.title.es} treatment`}
              class="w-full h-96 object-cover rounded-3xl shadow-2xl"
              loading="lazy"
            />
          </div>
          
          <!-- Floating Badge -->
          <div class="absolute -top-4 -right-4 bg-gradient-to-r from-pink-500 to-purple-600 text-white p-4 rounded-full shadow-lg transform rotate-12">
            <span class="text-2xl">💫</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-gray-600">
          Procedimiento rápido y efectivo
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl transform hover:scale-105 transition-all duration-300">
          <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            1
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Consulta</h3>
          <p class="text-gray-600">Evaluación de la forma y estructura de tus labios</p>
        </div>
        
        <div class="text-center p-8 bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl transform hover:scale-105 transition-all duration-300">
          <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            2
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Marcado</h3>
          <p class="text-gray-600">Identificación precisa de los puntos de inyección</p>
        </div>
        
        <div class="text-center p-8 bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl transform hover:scale-105 transition-all duration-300">
          <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            3
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Aplicación Lip Flip</h3>
          <p class="text-gray-600">Inyección precisa para crear el efecto de giro</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Qué diferencia hay con los rellenos labiales?</h3>
          <p class="text-gray-600">El Lip Flip usa Botox para relajar el músculo y crear volumen natural, mientras que los rellenos añaden volumen físico.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Cuánto duran los resultados?</h3>
          <p class="text-gray-600">Los efectos del Lip Flip duran aproximadamente 2-3 meses.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Puedo combinar con otros tratamientos?</h3>
          <p class="text-gray-600">Sí, se puede combinar con rellenos labiales para un resultado más completo y personalizado.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Lo que dicen sobre Renasci</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Experiencias reales con resultados sutiles y naturales</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-gray-900 hover:ring-2 hover:ring-primary/60"><div class="flex items-center mb-4"><img src="https://images.unsplash.com/photo-1494790108755-2616b612b786?q=80&w=1887&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Laura Martínez" class="w-12 h-12 rounded-full object-cover mr-4" loading="lazy" /><div><h4 class="font-semibold text-gray-900">Laura Martínez</h4></div></div><p class="text-gray-700 mb-4 italic">"Definición sutil y natural; me encantó el resultado desde la primera semana."</p></div>
        <div class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-gray-900 hover:ring-2 hover:ring-primary/60"><div class="flex items-center mb-4"><div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center mr-4 text-white font-semibold">AM</div><div><h4 class="font-semibold text-gray-900">Ana Morales</h4></div></div><p class="text-gray-700 mb-4 italic">“Proceso rápido y sin molestias. Superó mis expectativas.”</p></div>
        <div class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-gray-900 hover:ring-2 hover:ring-primary/60"><div class="flex items-center mb-4"><div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center mr-4 text-white font-semibold">JP</div><div><h4 class="font-semibold text-gray-900">Javier Pérez</h4></div></div><p class="text-gray-700 mb-4 italic">“Resultados naturales, sin apariencia de relleno. Muy satisfecho.”</p></div>
      </div>
    </div>
  </section>
  <TransformCTA />
</BaseLayout>
