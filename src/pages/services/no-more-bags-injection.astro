---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="No More Bags Injection (Under-eye) - Renasci Medical Spa"
  description="Target under-eye bags with precise injections to refine contour and achieve a rested, natural look. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30"><span data-i18n="nobags.category">Facial Contouring</span></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4"><span data-i18n="nobags.hero_title">No More Bags Injection</span></h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto"><span data-i18n="nobags.hero_subtitle">Reduce under-eye puffiness and refine contour for a rested, natural look.</span></p>
      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20">
        <div class="text-sm text-white/80 mb-1"><span data-i18n="nobags.price_from_label">Starting at</span></div>
        <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]"><span data-i18n="nobags.price_value">$750</span></div>
        <div class="text-sm text-white/80 mt-1"><span data-i18n="nobags.duration_label">Duration: 45 min</span></div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50"><span data-i18n="cta.view_details">Ver Detalles</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50" aria-label="Llamar Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg> <span data-i18n="cta.call">Llamar</span> (385) 555-0123</a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="nobags.breadcrumb_label">No More Bags Injection</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/no-more-bags.jpg" alt="Under-eye injection" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6"><span data-i18n="nobags.details.title">No More Bags Injection</span></h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4"><span data-i18n="nobags.details.p1">Targets <strong>under-eye puffiness</strong> with precise, natural-looking refinement of the lower eyelid contour.</span></p>
              <p class="mb-4"><span data-i18n="nobags.details.p2">Designed to achieve a rested, balanced appearance while preserving your expressiveness.</span></p>
              <p><span data-i18n="nobags.details.p3">Visible refinement over days; tailored to your anatomy and goals.</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="nobags.benefits.title">Treatment Benefits</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="nobags.benefits.subtitle">Key advantages of No More Bags Injection</span></p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 000-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 000-6.364 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="nobags.benefits.items.0.title">Reduces Puffiness</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="nobags.benefits.items.0.text">Targets under-eye bags for a rested appearance.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke_width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="nobags.benefits.items.1.title">Natural Finish</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="nobags.benefits.items.1.text">Refines contour without overcorrecting.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duración-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duración-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke_width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="nobags.benefits.items.2.title">Precision</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="nobags.benefits.items.2.text">Strategic application tailored to the lower eyelid.</span></p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="nobags.process.title">Treatment Process</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto"><span data-i18n="nobags.process.subtitle">Consultation, mapping and precise under-eye injections</span></p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-[#F3A2A7] via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-[#F3A2A7]/10 to-pink-500/10 rounded-2xl p-6 border border-[#F3A2A7]/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-[#F3A2A7] to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="nobags.process.steps.0.title">Initial Consultation</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="nobags.process.steps.0.text">Assessment of under-eye contour and goals.</span></p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/first.jpg" alt="Initial consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="nobags.process.steps.1.title">Mapping</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="nobags.process.steps.1.text">Precise plan to achieve refined lower eyelid contour.</span></p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/second.jpg" alt="Mapping" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="nobags.process.steps.2.title">Precise Application</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="nobags.process.steps.2.text">Strategic injections for a rested, natural finish.</span></p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/no-more-bags.jpg" alt="Application" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="nobags.process.steps.3.title">Care & Follow-up</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="nobags.process.steps.3.text">Post-care and evaluation to refine results.</span></p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/fourth.jpg" alt="Follow-up" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="nobags.faq.title">Frequently Asked Questions</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="nobags.faq.subtitle">Common questions about No More Bags Injection</span></p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7]"><svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><span data-i18n="nobags.faq.items.0.q">Is it tailored to my anatomy?</span></h3><p class="text-gray-700 leading-relaxed pl-11"><span data-i18n="nobags.faq.items.0.a">Yes; mapping and technique are customized to your contour.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7]"><svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke_width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><span data-i18n="nobags.faq.items.1.q">How long do results last?</span></h3><p class="text-gray-700 leading-relaxed pl-11"><span data-i18n="nobags.faq.items.1.a">Visible immediately; refinement over days; longevity varies.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items_center justify_center mr-3 border-2 border-[#F3A2A7]"><svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke_width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg></div><span data-i18n="nobags.faq.items.2.q">Is it painful?</span></h3><p class="text-gray-700 leading-relaxed pl-11"><span data-i18n="nobags.faq.items.2.a">Minimal discomfort; topical anesthesia and precise technique.</span></p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="nobags.testimonials.title">What Our Patients Say</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto"><span data-i18n="nobags.testimonials.subtitle">Real experiences with natural, rested results</span></p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="flex items-center mb-4"><img src="https://images.unsplash.com/photo-1494790108755-2616b612b786?q=80&w=1887&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Laura M." class="w-12 h-12 rounded-full object-cover mr-4" loading="lazy" /><div><h4 class="font-semibold text-gray-900">Laura M.</h4></div></div><p class="text-gray-700 mb-4 italic"><span data-i18n="nobags.testimonials.items.0">"Under-eye looks rested and natural; very satisfied."</span></p></div>
        <div class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="flex items-center mb-4"><div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center mr-4 text-white font-semibold">AM</div><div><h4 class="font-semibold text-gray-900">Ana M.</h4></div></div><p class="text-gray-700 mb-4 italic"><span data-i18n="nobags.testimonials.items.1">“Refined contour without looking overdone; quick and comfortable.”</span></p></div>
        <div class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="flex items-center mb-4"><div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center mr-4 text-white font-semibold">JP</div><div><h4 class="font-semibold text-gray-900">Javier P.</h4></div></div><p class="text-gray-700 mb-4 italic"><span data-i18n="nobags.testimonials.items.2">“Natural, rested finish; contour looks balanced.”</span></p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>
