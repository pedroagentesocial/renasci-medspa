---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'botox-no-sweat',
  slug: 'botox-no-sweat',
  title: { es: 'Tratamiento Botox No-Sweat (sudoración)', en: 'Botox No-Sweat Treatment' },
  description: { es: 'Tratamiento especializado para hiperhidrosis axilar con resultados duraderos que elimina la sudoración excesiva.', en: 'Specialized treatment for axillary hyperhidrosis with lasting results that eliminates excessive sweating.' },
  excerpt: { es: 'Elimina la sudoración excesiva de axilas de forma efectiva y duradera.', en: 'Effectively and lastingly eliminates excessive underarm sweating.' },
  category: 'neurotoxinas',
  precio: '$850',
  image: 'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&h=300&fit=crop&crop=center',
  benefits: ['Elimina sudoración excesiva', 'Resultados hasta 6 meses', 'Mejora confianza', 'Procedimiento rápido'],
  duracion: '45 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'neurotoxinas' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-pink-500/20 backdrop-blur-sm border border-pink-300/30 mb-6">
        <span class="text-pink-200 text-sm font-medium uppercase tracking-wider">Neurotoxinas</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        <span class="bg-gradient-to-r from-pink-200 via-white to-pink-200 bg-clip-text text-transparent">
          {servicio.title.es}
        </span>
      </h1>
      
      <!-- Description -->
      <p class="text-xl md:text-2xl text-gray-700 mb-8 max-w-3xl mx-auto leading-relaxed">
        {servicio.description.es}
      </p>
      
      <!-- Price Highlight -->
      <div class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl shadow-2xl mb-8 transform hover:scale-105 transition-all duration-300">
        <span class="text-2xl md:text-3xl font-bold text-white">{servicio.precio}</span>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <CTAButton 
          href="/contact" 
          variant="primary"
          class="bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        >
          Agenda tu Cita
        </CTAButton>
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/20 transition-all duration-300"
        >
          Consulta Gratuita
        </CTAButton>
      </div>
    </div>
  </section>

  <!-- Breadcrumbs -->
  <nav class="bg-gray-50 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-pink-600 transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-pink-600 transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">{servicio.title.es}</li>
      </ol>
    </div>
  </nav>

  <!-- Service Details -->
  <section class="py-20 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Content -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">
              ¿Qué es el <span class="text-pink-600">Botox No-Sweat</span>?
            </h2>
            <p class="text-lg text-text/80 leading-relaxed">
              El tratamiento Botox No-Sweat es una solución especializada para la hiperhidrosis axilar (sudoración excesiva en las axilas). 
              Utilizamos neurotoxina botulínica para bloquear temporalmente las señales nerviosas que estimulan las glándulas sudoríparas, 
              proporcionando alivio duradero de la sudoración excesiva.
            </p>
          </div>
          
          <!-- Benefits -->
          <div>
            <h3 class="text-2xl font-bold text-text mb-4">Beneficios del Tratamiento</h3>
            <ul class="space-y-3">
              {servicio.benefits.map((benefit) => (
                <li class="flex items-center text-text/80">
                  <svg class="w-5 h-5 text-pink-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  {benefit}
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Right: Image -->
        <div class="relative">
          <div class="aspect-w-4 aspect-h-3 rounded-3xl overflow-hidden shadow-2xl">
            <img 
              src={servicio.image}
              alt={`${servicio.title.es} procedure`}
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Floating card -->
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-6 shadow-xl border border-gray-100">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-pink-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-600">Duración</p>
                <p class="font-semibold text-gray-900">{servicio.duracion}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-text/70 max-w-3xl mx-auto">
          Un procedimiento simple y efectivo que te dará confianza y comodidad
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-text mb-4">Consulta Inicial</h3>
          <p class="text-text/70">
            Evaluamos tu caso específico y determinamos las áreas de tratamiento para obtener los mejores resultados.
          </p>
        </div>
        
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-text mb-4">Aplicación</h3>
          <p class="text-text/70">
            Realizamos múltiples microinyecciones de neurotoxina en las áreas afectadas con técnica especializada.
          </p>
        </div>
        
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-text mb-4">Resultados</h3>
          <p class="text-text/70">
            Los efectos comienzan a notarse en 3-7 días y duran hasta 6 meses, brindándote confianza y comodidad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
          <h3 class="text-xl font-bold text-text mb-3">¿Es doloroso el tratamiento?</h3>
          <p class="text-text/70">
            El procedimiento causa molestias mínimas. Utilizamos agujas muy finas y técnicas que minimizan cualquier incomodidad.
          </p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
          <h3 class="text-xl font-bold text-text mb-3">¿Cuánto duran los resultados?</h3>
          <p class="text-text/70">
            Los resultados típicamente duran entre 4-6 meses, después de los cuales el tratamiento puede repetirse para mantener los beneficios.
          </p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
          <h3 class="text-xl font-bold text-text mb-3">¿Hay efectos secundarios?</h3>
          <p class="text-text/70">
            Los efectos secundarios son mínimos y temporales, pudiendo incluir ligero enrojecimiento o sensibilidad en el área tratada.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
            Servicios <span class="text-pink-600">Relacionados</span>
          </h2>
          <p class="text-xl text-text/70">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-r from-pink-600 to-purple-700">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        ¿Listo para eliminar la sudoración excesiva?
      </h2>
      <p class="text-xl text-pink-100 mb-8 max-w-2xl mx-auto">
        Agenda tu consulta gratuita y descubre cómo el Botox No-Sweat puede mejorar tu calidad de vida
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white text-pink-600 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-gray-100 transition-all duration-300 shadow-xl"
        >
          Agenda tu Consulta
        </CTAButton>
        <CTAButton 
          href="tel:+1234567890" 
          variant="outline"
          class="border-2 border-white text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white hover:text-pink-600 transition-all duration-300"
        >
          Llama Ahora
        </CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Custom animations */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-delay {
    animation: float 6s ease-in-out infinite;
    animation-delay: 2s;
  }
  
  /* Gradient text animation */
  @keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  
  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }
  
  /* Hover effects */
  .group:hover .group-hover\:scale-110 {
    transform: scale(1.1);
  }
  
  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }
</style>