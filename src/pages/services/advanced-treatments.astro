---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import SimpleContactForm from '../../components/SimpleContactForm.astro';
---

<BaseLayout 
  title="Advanced Treatments - Renasci Medical Spa"
  description="Tratamientos avanzados para cuidado de piel, inflamación localizada y brotes quísticos. Agenda tu cita en Renasci Medical Spa."
>
  <section class="py-28 md:py-36 text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 w-full h-full bg-cover bg-center" style="background-image:url('/img/services/hero-services.jpg')"></div>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative px-6 max-w-4xl mx-auto">
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white">
        <span data-t-es="Tratamientos Avanzados" data-t-en="Advanced Treatments">Tratamientos Avanzados</span>
      </h1>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-t-es="Inicio" data-t-en="Home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-t-es="Servicios" data-t-en="Services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-t-es="Tratamientos Avanzados" data-t-en="Advanced Treatments">Tratamientos Avanzados</span></li>
      </ol>
    </div>
  </nav>

  <section class="py-12 lg:py-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-stretch">
        <div class="relative bg-white rounded-3xl overflow-hidden min-h-[360px] lg:min-h-[520px]">
          <img 
            src="/img/services/Cortisone.png"
            alt="Tratamientos Avanzados"
            data-alt-es="Tratamientos Avanzados"
            data-alt-en="Advanced Treatments"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex">
          <div class="bg-white rounded-3xl border border-gray-200 p-8 lg:p-10 w-full">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6" data-t-es="Tratamientos Avanzados" data-t-en="Advanced Treatments">Tratamientos Avanzados</h2>
            <p class="text-lg text-gray-700 leading-relaxed mb-6" data-t-es="Los tratamientos avanzados están diseñados para atender necesidades específicas como inflamación localizada, brotes quísticos y lesiones que requieren intervención rápida y precisa. En Renasci combinamos evaluación clínica, procedimientos focalizados y seguimiento para lograr resultados visibles con un enfoque médico y seguro." data-t-en="Advanced treatments are designed for specific needs such as localized inflammation, cystic flare-ups, and lesions that require fast, targeted care. At Renasci we combine clinical evaluation, focused procedures, and follow-up to deliver visible results with a safe, medical approach.">Los tratamientos avanzados están diseñados para atender necesidades específicas como inflamación localizada, brotes quísticos y lesiones que requieren intervención rápida y precisa. En Renasci combinamos evaluación clínica, procedimientos focalizados y seguimiento para lograr resultados visibles con un enfoque médico y seguro.</p>
            <h3 class="font-semibold text-lg text-gray-900 mb-3" data-t-es="Beneficios:" data-t-en="Benefits:">Beneficios:</h3>
            <ul class="list-disc pl-5 space-y-2 text-gray-700 mb-8">
              <li data-t-es="Atención rápida a brotes e inflamación" data-t-en="Fast care for flare-ups and inflammation">Atención rápida a brotes e inflamación</li>
              <li data-t-es="Procedimientos localizados con mínima incomodidad" data-t-en="Targeted procedures with minimal discomfort">Procedimientos localizados con mínima incomodidad</li>
              <li data-t-es="Seguimiento clínico para resultados sostenibles" data-t-en="Clinical follow-up for sustained results">Seguimiento clínico para resultados sostenibles</li>
              <li data-t-es="Opciones personalizadas según tu piel" data-t-en="Personalized options based on your skin">Opciones personalizadas según tu piel</li>
              <li data-t-es="Mejoría visible en corto plazo" data-t-en="Visible improvement in a short time">Mejoría visible en corto plazo</li>
            </ul>
            <a href="https://link.msgsndr.com/widget/booking/ZIYe8XGFfENxqvZHGTBD" target="_blank" rel="noopener" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-6 py-3 rounded-full hover:opacity-90 transition" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-gray-50 text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-2" data-t-es="Tratamientos" data-t-en="Treatments">Tratamientos</h2>
        <p class="text-lg text-gray-700" data-t-es="Opciones avanzadas con enfoque clínico" data-t-en="Advanced options with clinical focus">Opciones avanzadas con enfoque clínico</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-6">
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Cortisone.png');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Cortisone Injection</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="Inflamación localizada" data-t-en="Localized inflammation">Inflamación localizada</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Inyección precisa para reducir inflamación y aliviar brotes quísticos de forma rápida." data-t-en="Precise injection to reduce inflammation and quickly relieve cystic flare-ups.">Inyección precisa para reducir inflamación y aliviar brotes quísticos de forma rápida.</p>
            </div>
            <a href="https://link.msgsndr.com/widget/booking/ZIYe8XGFfENxqvZHGTBD" target="_blank" rel="noopener" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="AGENDAR AHORA" data-t-en="BOOK NOW">AGENDAR AHORA</a>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Acne.jpeg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">Cystic Acne</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span data-t-es="Plan clínico" data-t-en="Clinical plan">Plan clínico</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
              <p class="text-sm text-white/90 mb-4" data-t-es="Tratamiento integral para brotes severos con evaluación, manejo y seguimiento." data-t-en="Comprehensive care for severe breakouts with evaluation, management, and follow-up.">Tratamiento integral para brotes severos con evaluación, manejo y seguimiento.</p>
            </div>
            <a href="https://link.msgsndr.com/widget/booking/ZIYe8XGFfENxqvZHGTBD" target="_blank" rel="noopener" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="AGENDAR AHORA" data-t-en="BOOK NOW">AGENDAR AHORA</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#AABFA8] text-white">
    <div class="container mx-auto px-6">
      <div class="h-[3px] w-28 bg-white/60 mb-6 mx-auto animate-in fade-in duration-500"></div>
      <h3 class="font-display font-bold text-4xl lg:text-5xl text-white text-center mb-10 animate-in fade-in slide-in-from-bottom-2 duration-500" data-t-es="Preguntas Frecuentes" data-t-en="FAQs">Preguntas Frecuentes</h3>
      <div class="max-w-4xl mx-auto divide-y divide-white/30">
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500" open>
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Qué problemas atienden los tratamientos avanzados?" data-t-en="What concerns do advanced treatments address?">¿Qué problemas atienden los tratamientos avanzados?</span>
            <span class="faq-icon text-white">-</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Atienden inflamación localizada, brotes quísticos y necesidades de intervención rápida con enfoque médico." data-t-en="They address localized inflammation, cystic flare-ups, and needs that require fast, medically guided care.">Atienden inflamación localizada, brotes quísticos y necesidades de intervención rápida con enfoque médico.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-100">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Necesito evaluación previa?" data-t-en="Do I need an evaluation first?">¿Necesito evaluación previa?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Sí. La evaluación permite definir el protocolo ideal y descartar contraindicaciones." data-t-en="Yes. The evaluation helps define the right protocol and rule out contraindications.">Sí. La evaluación permite definir el protocolo ideal y descartar contraindicaciones.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-200">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Hay tiempo de recuperación?" data-t-en="Is there downtime?">¿Hay tiempo de recuperación?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="La mayoría de los tratamientos tienen mínima recuperación y permiten continuar actividades normales." data-t-en="Most treatments have minimal downtime and allow you to resume normal activities.">La mayoría de los tratamientos tienen mínima recuperación y permiten continuar actividades normales.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-300">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿En cuánto tiempo se ven resultados?" data-t-en="How soon are results visible?">¿En cuánto tiempo se ven resultados?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Depende del tratamiento; en cortisona la mejoría puede verse en 24–48 horas." data-t-en="It depends on the treatment; with cortisone, improvement can be seen in 24–48 hours.">Depende del tratamiento; en cortisona la mejoría puede verse en 24–48 horas.</p>
        </details>
      </div>
    </div>
  </section>

  <TransformCTA />
  <SimpleContactForm />
</BaseLayout>

<script>
  const initAdvancedFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item: Element) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current: Element) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  document.addEventListener('DOMContentLoaded', initAdvancedFaq);
  document.addEventListener('astro:page-load', initAdvancedFaq);

  const getAdvancedLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyAdvancedLang = (lang: 'en' | 'es') => {
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('[data-alt-es]').forEach((el) => {
      const es = el.getAttribute('data-alt-es') || '';
      const en = el.getAttribute('data-alt-en') || es;
      el.setAttribute('alt', lang === 'en' ? en : es);
    });
  };

  const initAdvancedLang = () => applyAdvancedLang(getAdvancedLang());

  document.addEventListener('DOMContentLoaded', initAdvancedLang);
  document.addEventListener('astro:page-load', initAdvancedLang);
  window.addEventListener('languageChanged', () => {
    initAdvancedLang();
  });
</script>
