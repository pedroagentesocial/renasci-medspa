---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="Inyecciones de Neurotoxina Tox - Renasci Medical Spa"
  description="Tratamientos con Neurotoxina Tox para reducir líneas de expresión y prevenir la formación de nuevas arrugas. Resultados naturales y duraderos. Agenda tu cita en Renasci Medical Spa."
>
  <!-- Hero del Servicio -->
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    
    
    <!-- Content -->
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <!-- Category Badge -->
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30 animate-fade-in-up">
        Inyecciones
      </div>
      
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4 animate-fade-in-up" style="animation-delay: 0.2s;">
        Inyecciones de Neurotoxina Tox
      </h1>
      
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
        Tratamiento con neurotoxina para reducir líneas de expresión y prevenir la formación de nuevas arrugas con resultados naturales
      </p>
      
      <!-- Precio destacado -->
      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20 animate-scale-in" style="animation-delay: 0.6s;">
        <div class="text-sm text-white/80 mb-1">Precio desde</div>
        <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">$12 / unidad</div>
        <div class="text-sm text-white/80 mt-1">Duración: 30 min</div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.8s;">
        <a 
          href="#detalles"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 animate-pulse-gentle"
        >
          Ver Detalles
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
        
        <a 
          href="tel:+13856092840"
          class="call-hero-button inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50 animate-bounce-subtle"
          aria-label="Llamar Renasci"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          385 609 2840
        </a>
      </div>
    </div>
  </section>


  

  <!-- Breadcrumb -->
  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">Inyecciones de Neurotoxina Tox</li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <!-- Imagen -->
        <div class="relative group animate-slide-in-left bg-white rounded-3xl shadow-2xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img 
            src="/images/inyeccion-botox.jpg"
            alt="Inyección de Botox"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
            loading="lazy"
          />
          
        </div>

        <!-- Contenido -->
        <div class="animate-slide-in-right min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-6">
              Inyecciones de Neurotoxina Tox
            </h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4">
                Las <strong>Inyecciones de Neurotoxina Tox</strong> son un tratamiento avanzado y efectivo para reducir las arrugas dinámicas y prevenir la formación de nuevas líneas de expresión. Esta neurotoxina purificada actúa relajando temporalmente los músculos faciales responsables de las arrugas.
              </p>
              <p class="mb-4">
                Nuestros especialistas certificados se enfocan en áreas específicas como las líneas de expresión alrededor de los ojos, frente, entrecejo y otras zonas donde las contracciones musculares repetitivas han formado arrugas visibles, logrando resultados naturales y armoniosos.
              </p>
              <p>
                La Neurotoxina Tox ha demostrado ser segura y efectiva cuando es aplicada por profesionales certificados, ofreciendo una alternativa confiable para el rejuvenecimiento facial no invasivo.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- Beneficios -->
  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-primary"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </span>
          <div class="flex-1 h-[2px] bg-primary"></div>
        </div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">
          Beneficios del Tratamiento
        </h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">
          Descubre las ventajas de las Inyecciones de Neurotoxina Tox
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Beneficio 1 -->
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.1s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">Reduce Arrugas Dinámicas</h3>
          <p class="text-white/80 leading-relaxed">Elimina efectivamente las líneas de expresión causadas por movimientos musculares repetitivos para un aspecto más joven.</p>
        </div>

        <!-- Beneficio 2 -->
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.2s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">Previene Nuevas Líneas</h3>
          <p class="text-white/80 leading-relaxed">Actúa de manera preventiva, evitando la formación de nuevas arrugas y manteniendo la piel suave por más tiempo.</p>
        </div>

        <!-- Beneficio 3 -->
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.3s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">Resultados Naturales</h3>
          <p class="text-white/80 leading-relaxed">Mantiene la expresividad facial natural mientras suaviza las líneas no deseadas de manera sutil y armoniosa.</p>
        </div>

        <!-- Beneficio 4 -->
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.4s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">Mínimo Tiempo de Recuperación</h3>
          <p class="text-white/80 leading-relaxed">Procedimiento rápido y cómodo sin tiempo de recuperación significativo, permitiendo retomar actividades normales inmediatamente.</p>
        </div>

        <!-- Beneficio 5 -->
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.5s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">Efectos Duraderos</h3>
          <p class="text-white/80 leading-relaxed">Los efectos duran entre 3-4 meses, manteniendo una apariencia rejuvenecida y fresca por períodos prolongados.</p>
        </div>

        <!-- Beneficio 6 -->
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.6s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-3">Tratamiento Seguro</h3>
          <p class="text-white/80 leading-relaxed">Neurotoxina purificada y segura cuando es aplicada por profesionales certificados con amplia experiencia clínica.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- Proceso del Tratamiento -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-primary"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
            </svg>
          </span>
          <div class="flex-1 h-[2px] bg-primary"></div>
        </div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">
          Proceso del Tratamiento
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Un proceso simple y profesional para obtener los mejores resultados con Neurotoxina Tox
        </p>
      </div>

      <div class="relative">
        <!-- Línea conectora -->
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-primary via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        
        <div class="space-y-12">
          <!-- Paso 1 -->
          <div class="flex flex-col lg:flex-row items-center gap-8 animate-slide-in-left">
            <div class="lg:w-1/2 lg:pr-8">
              <div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div>
                  <h3 class="font-display font-bold text-xl text-gray-900">Consulta Inicial</h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  Evaluación completa de tu rostro y análisis de tus objetivos estéticos. Nuestro especialista determinará las áreas de tratamiento y la cantidad de Neurotoxina Tox necesaria para lograr resultados óptimos.
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pl-8">
              <img 
                src="/images/med-spa-room.jpg"
                alt="Consulta inicial Neurotoxina Tox"
                class="w-full h-64 object-cover rounded-2xl"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Paso 2 -->
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8 animate-slide-in-right">
            <div class="lg:w-1/2 lg:pl-8">
              <div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div>
                  <h3 class="font-display font-bold text-xl text-gray-900">Preparación del Área</h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  Limpieza y desinfección del área de tratamiento. Marcado preciso de los puntos de inyección para asegurar la aplicación óptima de la Neurotoxina Tox en cada músculo objetivo.
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pr-8">
              <img 
                src="/images/inyeccion-botox.jpg"
                alt="Preparación tratamiento Tox"
                class="w-full h-64 object-cover rounded-2xl"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Paso 3 -->
          <div class="flex flex-col lg:flex-row items-center gap-8 animate-slide-in-left">
            <div class="lg:w-1/2 lg:pr-8">
              <div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div>
                  <h3 class="font-display font-bold text-xl text-gray-900">Aplicación de Tox</h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  Inyección precisa de la Neurotoxina Tox en los músculos objetivo utilizando técnicas avanzadas. El procedimiento es rápido y prácticamente indoloro, durando aproximadamente 30 minutos.
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pl-8">
              <img 
                src="/images/inyeccion-botox.jpg"
                alt="Aplicación Neurotoxina Tox"
                class="w-full h-64 object-cover rounded-2xl"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Paso 4 -->
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8 animate-slide-in-right">
            <div class="lg:w-1/2 lg:pl-8">
              <div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div>
                  <h3 class="font-display font-bold text-xl text-gray-900">Cuidados Post-Tratamiento</h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  Instrucciones detalladas para el cuidado posterior y seguimiento personalizado. Los resultados comienzan a verse en 3-5 días y alcanzan su máximo efecto en 2 semanas.
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pr-8">
              <img 
                src="/images/med-spa-room.jpg"
                alt="Cuidados post-tratamiento Tox"
                class="w-full h-64 object-cover rounded-2xl"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="flex items-center justify-center my-10">
    <div class="flex-1 h-[2px] bg-primary"></div>
    <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </span>
    <div class="flex-1 h-[2px] bg-primary"></div>
  </div>

  <!-- Preguntas Frecuentes -->
  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">
          Preguntas Frecuentes
        </h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">
          Resolvemos las dudas más comunes sobre las Inyecciones de Neurotoxina Tox
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-6">
        <!-- FAQ 1 -->
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white animate-fade-in-up hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.1s;">
          <h3 class="font-display font-bold text-lg text-white mb-3 flex items-center">
            <div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-primary hover:bg-primary/15">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            ¿Qué es la Neurotoxina Tox y cómo funciona?
          </h3>
          <p class="text-white/80 leading-relaxed pl-11">
            La Neurotoxina Tox es una proteína purificada que bloquea temporalmente las señales nerviosas a los músculos, relajándolos y reduciendo las arrugas dinámicas. Es especialmente efectiva para líneas de expresión y prevención de nuevas arrugas.
          </p>
        </div>

        <!-- FAQ 2 -->
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white animate-fade-in-up hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.2s;">
          <h3 class="font-display font-bold text-lg text-white mb-3 flex items-center">
            <div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-primary hover:bg-primary/15">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
