---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
---

<BaseLayout 
  title="Inyección de Cortisona / Acné Quístico - Renasci Medical Spa"
  description="Tratamiento de cortisona para acné quístico. Reduce la inflamación y acelera la curación. Agenda tu cita en Renasci Medical Spa."
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt="Cortisone injection treatment at medical spa"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/45"></div>
    
    <!-- Floating decorative elements -->
    <div class="absolute top-20 left-10 w-20 h-20 bg-gradient-to-br from-primary/30 to-secondary/30 rounded-full blur-xl animate-float-slow"></div>
    <div class="absolute bottom-32 right-16 w-32 h-32 bg-gradient-to-br from-secondary/20 to-primary/20 rounded-full blur-2xl animate-float-slow" style="animation-delay: -2s;"></div>
    <div class="absolute top-1/3 right-20 w-16 h-16 bg-gradient-to-br from-primary/40 to-pink-400/40 rounded-full blur-lg animate-pulse-gentle"></div>
    
    <!-- Content -->
    <div class="relative z-10 px-6 max-w-4xl mx-auto">
      <!-- Category Badge -->
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30 animate-fade-in-up">
        Tratamientos Avanzados
      </div>
      
      <h1 class="font-display font-bold text-4xl md:text-6xl text-white mb-6 text-shadow-lg animate-fade-in-up" style="animation-delay: 0.2s;">
        Inyección de Cortisona / Acné Quístico
      </h1>
      
      <p class="text-lg md:text-xl text-white/90 mb-8 leading-relaxed text-shadow max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
        Tratamiento especializado para reducir la inflamación del acné quístico y acelerar la curación de lesiones severas
      </p>
      
      <!-- Precio destacado -->
      <div class="bg-gradient-to-r from-white/15 to-pink-100/15 backdrop-blur-sm rounded-2xl p-6 shadow-card mb-8 inline-block border border-white/30 animate-scale-in" style="animation-delay: 0.6s;">
        <div class="text-sm text-white/80 mb-1">Precio</div>
        <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">Por definir</div>
        <div class="text-sm text-white/80 mt-1">Duración: 15-30 min</div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.8s;">
        <a 
          href="#detalles"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 animate-pulse-gentle"
        >
          Ver Detalles
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
        
        <a 
          href="tel:+13856092840"
          class="call-hero-button inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50 animate-bounce-subtle"
          aria-label="Llamar Renasci"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          385 609 2840
        </a>
      </div>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="bg-background py-6 border-b border-gray-100">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">Inyección de Cortisona / Acné Quístico</li>
      </ol>
    </div>
  </nav>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-16 lg:py-24 bg-background">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Imagen -->
        <div class="relative group animate-slide-in-left">
          <img 
            src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            alt="Cortisone injection treatment procedure"
            class="w-full h-[400px] lg:h-[500px] object-cover rounded-3xl shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]"
            loading="lazy"
          />
          
          <!-- Floating card -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-6 shadow-2xl border border-gray-100 animate-float-gentle">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-gradient-to-br from-primary to-pink-500 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900">Alivio Rápido</div>
                <div class="text-sm text-gray-600">24-48 horas</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Contenido -->
        <div class="space-y-8 animate-slide-in-right">
          <div>
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-text mb-6">
              Cortisona: Tratamiento Especializado para Acné Severo
            </h2>
            
            <div class="prose prose-lg text-gray-700 space-y-4">
              <p>
                Las <strong>inyecciones de cortisona</strong> son un tratamiento médico especializado para el acné quístico severo que no responde a tratamientos tópicos convencionales. Utilizamos corticosteroides para reducir rápidamente la inflamación.
              </p>
              <p>
                Este procedimiento es especialmente efectivo para quistes grandes, dolorosos e inflamados que pueden dejar cicatrices permanentes si no se tratan adecuadamente y a tiempo.
              </p>
              <p>
                Ideal para casos de acné quístico agudo, nódulos inflamatorios severos y lesiones que requieren intervención médica inmediata para prevenir cicatrices.
              </p>
            </div>
          </div>

          <!-- Precio destacado -->
          <div class="bg-gradient-to-r from-primary/5 to-secondary/5 rounded-2xl p-6 border border-primary/10">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="font-display font-bold text-xl text-text mb-2">Precio del Tratamiento</h3>
                <p class="text-text/70">Inversión en tu salud dermatológica</p>
              </div>
              <div class="text-right">
                <div class="font-display font-bold text-3xl text-primary">Por definir</div>
                <p class="text-sm text-text/70 mt-1">Consulta incluida</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Beneficios del Tratamiento -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-text mb-4">
          Beneficios de las Inyecciones de Cortisona
        </h2>
        <p class="text-lg text-text/70 max-w-2xl mx-auto">
          Descubre las ventajas de este tratamiento médico especializado
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-2xl p-6 shadow-card hover:shadow-lg transition-all duration-300 card-hover">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-lg text-text mb-2">Alivio Rápido</h3>
          <p class="text-gray-600">Reducción de inflamación en 24-48 horas</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-card hover:shadow-lg transition-all duration-300 card-hover">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-lg text-text mb-2">Previene Cicatrices</h3>
          <p class="text-gray-600">Evita la formación de cicatrices permanentes</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-card hover:shadow-lg transition-all duration-300 card-hover">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-lg text-text mb-2">Procedimiento Rápido</h3>
          <p class="text-gray-600">Tratamiento de 15-30 minutos</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-card hover:shadow-lg transition-all duration-300 card-hover">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-lg text-text mb-2">Reduce Dolor</h3>
          <p class="text-gray-600">Alivia el dolor asociado con quistes inflamados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-16 lg:py-20 bg-background">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-text mb-4">
          Proceso del Tratamiento
        </h2>
        <p class="text-lg text-text/70 max-w-2xl mx-auto">
          Conoce paso a paso cómo realizamos las inyecciones de cortisona
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-primary to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="font-semibold text-xl text-text mb-4">Evaluación Médica</h3>
          <p class="text-gray-600">Examinamos las lesiones y determinamos el tratamiento adecuado</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-primary to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="font-semibold text-xl text-text mb-4">Preparación del Área</h3>
          <p class="text-gray-600">Limpiamos y desinfectamos el área a tratar</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-primary to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="font-semibold text-xl text-text mb-4">Inyección Precisa</h3>
          <p class="text-gray-600">Aplicamos la cortisona directamente en la lesión inflamada</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-text mb-4">
          Preguntas Frecuentes
        </h2>
        <p class="text-lg text-text/70 max-w-2xl mx-auto">
          Resolvemos tus dudas sobre las inyecciones de cortisona
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-card">
          <h3 class="font-semibold text-lg text-text mb-3">¿Para qué tipo de acné es efectivo?</h3>
          <p class="text-gray-600">Es especialmente efectivo para acné quístico, nódulos inflamatorios grandes y lesiones dolorosas que no responden a otros tratamientos.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-card">
          <h3 class="font-semibold text-lg text-text mb-3">¿Cuánto tiempo tarda en hacer efecto?</h3>
          <p class="text-gray-600">Los resultados se notan típicamente dentro de 24-48 horas, con reducción significativa de la inflamación y el dolor.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-card">
          <h3 class="font-semibold text-lg text-text mb-3">¿Es doloroso el procedimiento?</h3>
          <p class="text-gray-600">Puede haber molestia mínima durante la inyección, pero es generalmente bien tolerado y muy rápido.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-card">
          <h3 class="font-semibold text-lg text-text mb-3">¿Hay efectos secundarios?</h3>
          <p class="text-gray-600">Los efectos secundarios son raros, pero pueden incluir ligera atrofia temporal en el sitio de inyección.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-br from-primary to-pink-600 text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full -translate-x-48 -translate-y-48"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full translate-x-48 translate-y-48"></div>
    
    <div class="relative container mx-auto px-6">
      <h2 class="font-display font-bold text-3xl lg:text-4xl mb-6">
        ¿Necesitas Tratamiento para Acné Severo?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Agenda tu consulta médica especializada y obtén alivio rápido para tu acné quístico.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agenda tu Consulta" 
          href="/contacto"
          variant="secondary"
          class="bg-white text-primary hover:bg-gray-50 transform hover:scale-105 transition-all duration-300"
        />
        <CTAButton 
          text="Llama Ahora" 
          href="tel:+13856092840"
          variant="outline"
          class="border-white text-white hover:bg-white hover:text-primary transform hover:scale-105 transition-all duration-300"
        />
      </div>
    </div>
  </section>
</BaseLayout>