---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="BananaRoll (Bikini Area) - Renasci Medical Spa"
  description="Body contouring for the banana roll (bikini area) to refine and balance the silhouette with natural-looking results. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30"><span data-i18n="bananaroll.category">Body Contouring</span></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4"><span data-i18n="bananaroll.hero_title">BananaRoll (Bikini Area)</span></h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto"><span data-i18n="bananaroll.hero_subtitle">Refines the banana roll area for a smoother, proportionate silhouette.</span></p>
      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20">
        <div class="text-sm text-white/80 mb-1"><span data-i18n="bananaroll.price_from_label">Starting at</span></div>
        <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]"><span data-i18n="bananaroll.price_value">$1,200</span></div>
        <div class="text-sm text-white/80 mt-1"><span data-i18n="bananaroll.duration_label">Duration: 60 min</span></div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"><span data-i18n="cta.view_details">Ver Detalles</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50" aria-label="Llamar Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 0 1 2-2h3.28a1 1 0 0 1 .948.684l1.498 4.493a1 1 0 0 1-.502 1.21l-2.257 1.13a11.042 11.042 0 0 0 5.516 5.516l1.13-2.257a1 1 0 0 1 1.21-.502l4.493 1.498a1 1 0 0 1 .684.949V19a2 2 0 0 1-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg> <span data-i18n="cta.call">Llamar</span> (385) 555-0123</a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-i18n="nav.home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-i18n="nav.services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="bananaroll.breadcrumb_label">BananaRoll (Bikini Area)</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/Tratamiento-Coolsculpting-Banana-Roll-en-Barcelona.jpg" alt="BananaRoll" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6"><span data-i18n="bananaroll.details.title">BananaRoll (Bikini Area)</span></h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4"><span data-i18n="bananaroll.details.p1">Refines the <strong>banana roll</strong> at the bikini area with precise contouring to smooth and balance the silhouette.</span></p>
              <p class="mb-4"><span data-i18n="bananaroll.details.p2">Designed for a natural finish that respects your proportions.</span></p>
              <p><span data-i18n="bananaroll.details.p3">Visible refinement over days; tailored to your anatomy and goals.</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="bananaroll.benefits.title">Treatment Benefits</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="bananaroll.benefits.subtitle">Key advantages of BananaRoll</span></p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="bananaroll.benefits.items.0.title">Smoother Silhouette</span></h3><p class="text-gray-700"><span data-i18n="bananaroll.benefits.items.0.text">Refines bikini area contour for balance.</span></p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="bananaroll.benefits.items.1.title">Natural Finish</span></h3><p class="text-gray-700"><span data-i18n="bananaroll.benefits.items.1.text">Maintains soft, proportionate look.</span></p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="bananaroll.benefits.items.2.title">Precision</span></h3><p class="text-gray-700"><span data-i18n="bananaroll.benefits.items.2.text">Strategic application tailored to anatomy.</span></p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="bananaroll.process.title">Treatment Process</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto"><span data-i18n="bananaroll.process.subtitle">Consultation, mapping and precise application for balanced contour</span></p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-[#F3A2A7] via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="bananaroll.process.steps.0.title">Initial Consultation</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="bananaroll.process.steps.0.text">Assessment of banana roll area and contour goals.</span></p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/first.jpg" alt="Consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="bananaroll.process.steps.1.title">Mapping</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="bananaroll.process.steps.1.text">Precise plan to smooth and balance the silhouette.</span></p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/second.jpg" alt="Mapping" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="bananaroll.process.steps.2.title">Precise Application</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="bananaroll.process.steps.2.text">Strategic microinjections for a natural finish.</span></p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/bananaroll-aplication.jpg" alt="Application" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="bananaroll.process.steps.3.title">Aftercare & Follow‑up</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="bananaroll.process.steps.3.text">Post‑care guidance and results evaluation.</span></p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/fourth.jpg" alt="Follow-up" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="bananaroll.faq.title">Frequently Asked Questions</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="bananaroll.faq.subtitle">Common questions about BananaRoll treatment</span></p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3"><span data-i18n="bananaroll.faq.items.0.q">How long do results last?</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="bananaroll.faq.items.0.a">Typically months; varies by metabolism and aftercare.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3"><span data-i18n="bananaroll.faq.items.1.q">Will it look natural?</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="bananaroll.faq.items.1.a">Yes; the finish aims to maintain soft proportions.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3"><span data-i18n="bananaroll.faq.items.2.q">Is it painful?</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="bananaroll.faq.items.2.a">Minimal discomfort with topical anesthesia and precise technique.</span></p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>
