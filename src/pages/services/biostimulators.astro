---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import SimpleContactForm from '../../components/SimpleContactForm.astro';
---

<BaseLayout
  title="Biostimulators - Renasci Med Spa"
  description="Bioestimuladores para estimular colágeno, restaurar volumen y mejorar la textura de la piel. Agenda tu cita en Renasci Med Spa."
>
  <section class="py-28 md:py-36 text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 w-full h-full bg-cover bg-center" style="background-image:url('/img/services/hero-services.jpg')"></div>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative px-6 max-w-4xl mx-auto">
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white">
        <span data-t-es="Bioestimuladores" data-t-en="Biostimulators">Bioestimuladores</span>
      </h1>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-t-es="Inicio" data-t-en="Home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-t-es="Servicios" data-t-en="Services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-t-es="Bioestimuladores" data-t-en="Biostimulators">Bioestimuladores</span></li>
      </ol>
    </div>
  </nav>

  <section class="py-12 lg:py-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-stretch">
        <div class="relative bg-white rounded-3xl overflow-hidden min-h-[360px] lg:min-h-[520px]">
          <img
            src="/img/services/Lip-filler-image.jpg"
            alt="Bioestimuladores"
            data-alt-es="Bioestimuladores"
            data-alt-en="Biostimulators"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex">
          <div class="bg-white rounded-3xl border border-gray-200 p-8 lg:p-10 w-full">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6" data-t-es="Bioestimuladores" data-t-en="Biostimulators">Bioestimuladores</h2>
            <p class="text-lg text-gray-700 leading-relaxed mb-6" data-t-es="Tu piel mantiene su textura suave y juvenil gracias al colágeno producido de forma natural en el cuerpo. Con el tiempo, los niveles de colágeno disminuyen y, con ello, los signos visibles del envejecimiento. Los bioestimuladores como Sculptra® y Radiesse® funcionan estimulando los procesos naturales de reparación de la piel para producir más colágeno, reemplazando las proteínas que se pierden y devolviendo esa apariencia fresca y joven que mereces." data-t-en="Your skin’s smooth, youthful texture is maintained by collagen produced naturally in the body. Over time, collagen levels decline, and with it, the visible signs of aging. Biostimulators such as Sculptra® and Radiesse® work by stimulating your skin’s natural healing processes to produce more collagen, replacing your skin’s lost proteins and restoring the fresher, younger-looking appearance that you deserve.">Tu piel mantiene su textura suave y juvenil gracias al colágeno producido de forma natural en el cuerpo. Con el tiempo, los niveles de colágeno disminuyen y, con ello, los signos visibles del envejecimiento. Los bioestimuladores como Sculptra® y Radiesse® funcionan estimulando los procesos naturales de reparación de la piel para producir más colágeno, reemplazando las proteínas que se pierden y devolviendo esa apariencia fresca y joven que mereces.</p>
            <p class="text-lg text-gray-700 leading-relaxed mb-6" data-t-es="Renasci Med Spa ofrece dos de los mejores bioestimuladores disponibles: Radiesse® y Sculptra®. Nuestro equipo con experiencia evaluará la condición y el tipo de tu piel, considerará tus objetivos estéticos y desarrollará un plan de tratamiento personalizado para ayudarte a lograrlos rápidamente. Si buscas recuperar tu brillo juvenil, suavizar líneas finas o arrugas, o simplemente mantener una piel saludable, los bioestimuladores pueden ser la solución que has estado buscando." data-t-en="Renasci Med Spa offers two of the best biostimulators available – Radiesse® and Sculptra®. Our experienced staff will assess your skin’s condition and type, consider your cosmetic goals, and develop a customized treatment plan to help you quickly achieve them. If you’re looking to restore your youthful glow, smooth out any fine lines or wrinkles in your skin, or simply maintain a healthy complexion, biostimulators may be the solution you’ve been searching for.">Renasci Med Spa ofrece dos de los mejores bioestimuladores disponibles: Radiesse® y Sculptra®. Nuestro equipo con experiencia evaluará la condición y el tipo de tu piel, considerará tus objetivos estéticos y desarrollará un plan de tratamiento personalizado para ayudarte a lograrlos rápidamente. Si buscas recuperar tu brillo juvenil, suavizar líneas finas o arrugas, o simplemente mantener una piel saludable, los bioestimuladores pueden ser la solución que has estado buscando.</p>
            <p class="text-lg text-gray-700 leading-relaxed mb-6" data-t-es="Nuestros clientes son la prueba de los resultados increíbles que pueden lograr los bioestimuladores. Agenda tu cita con Renasci Med Spa en Cottonwood Heights, UT, hoy mismo y trabajemos juntos para restaurar el volumen natural de tu piel y ayudarte a lograr el brillo radiante que mereces." data-t-en="Our clients are proof of the incredible results that biostimulators can achieve. Book your appointment with Renasci Med Spa Cottonwood Heights, UT, today, and let’s work together to restore your skin’s natural volume and help you achieve the radiant glow that you deserve.">Nuestros clientes son la prueba de los resultados increíbles que pueden lograr los bioestimuladores. Agenda tu cita con Renasci Med Spa en Cottonwood Heights, UT, hoy mismo y trabajemos juntos para restaurar el volumen natural de tu piel y ayudarte a lograr el brillo radiante que mereces.</p>
            <h3 class="font-semibold text-lg text-gray-900 mb-3" data-t-es="Beneficios de los Bioestimuladores:" data-t-en="Benefits of Biostimulators:">Beneficios de los Bioestimuladores:</h3>
            <ul class="list-disc pl-5 space-y-2 text-gray-700 mb-8">
              <li data-t-es="Aumenta la producción de colágeno y elastina" data-t-en="Increase collagen and elastin production">Aumenta la producción de colágeno y elastina</li>
              <li data-t-es="Tratamiento no quirúrgico" data-t-en="Non-surgical treatment">Tratamiento no quirúrgico</li>
              <li data-t-es="Mejora la textura y el tono de la piel" data-t-en="Improve skin texture and tone">Mejora la textura y el tono de la piel</li>
              <li data-t-es="Restaura el volumen facial" data-t-en="Restore facial volume">Restaura el volumen facial</li>
              <li data-t-es="Reduce la apariencia de arrugas y líneas finas" data-t-en="Reduce the appearance of wrinkles and fine lines">Reduce la apariencia de arrugas y líneas finas</li>
              <li data-t-es="Personalizado y adaptado a tus necesidades únicas" data-t-en="Customized and tailored to your unique needs">Personalizado y adaptado a tus necesidades únicas</li>
              <li data-t-es="Resultados duraderos" data-t-en="Long-lasting results">Resultados duraderos</li>
            </ul>
            <a href="https://link.msgsndr.com/widget/booking/ZIYe8XGFfENxqvZHGTBD" target="_blank" rel="noopener" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-6 py-3 rounded-full hover:opacity-90 transition" data-t-es="Agendar Ahora" data-t-en="Book Now">Agendar Ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-gray-50 text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-2" data-t-es="Biostimulators Treatments" data-t-en="Biostimulators Treatments">Biostimulators Treatments</h2>
      </div>
      <div class="flex justify-center">
        <div class="relative rounded-2xl overflow-hidden min-h-[260px] text-white w-full max-w-md">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/img/services/Cheekbone-lift.jpg');"></div>
          <div class="absolute inset-0 bg-black/55"></div>
          <div class="relative z-10 p-6 flex flex-col h-full text-center">
            <div>
              <h3 class="font-display font-bold text-xl mb-2">SCULPTRA/RADIESSE</h3>
              <div class="flex items-center gap-3 text-sm text-white/90 mb-4">
                <span class="flex-1 h-px bg-white/70"></span>
                <span>$800 PER VIAL/SYRINGE</span>
                <span class="flex-1 h-px bg-white/70"></span>
              </div>
            </div>
            <a href="https://link.msgsndr.com/widget/booking/ZIYe8XGFfENxqvZHGTBD" target="_blank" rel="noopener" class="mt-auto inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-4 py-2 rounded-full hover:opacity-90 transition self-center" data-t-es="BOOK NOW" data-t-en="BOOK NOW">BOOK NOW</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#AABFA8] text-white">
    <div class="container mx-auto px-6">
      <div class="h-[3px] w-28 bg-white/60 mb-6 mx-auto animate-in fade-in duration-500"></div>
      <h3 class="font-display font-bold text-4xl lg:text-5xl text-white text-center mb-10 animate-in fade-in slide-in-from-bottom-2 duration-500" data-t-es="Preguntas Frecuentes" data-t-en="FAQs">Preguntas Frecuentes</h3>
      <div class="max-w-4xl mx-auto divide-y divide-white/30">
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500" open>
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Qué son los bioestimuladores?" data-t-en="What are biostimulators?">¿Qué son los bioestimuladores?</span>
            <span class="faq-icon text-white">-</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Son tratamientos que estimulan los procesos naturales de la piel para producir más colágeno, ayudando a restaurar una apariencia más fresca y juvenil." data-t-en="They are treatments that stimulate your skin’s natural processes to produce more collagen, helping restore a fresher, younger-looking appearance.">Son tratamientos que estimulan los procesos naturales de la piel para producir más colágeno, ayudando a restaurar una apariencia más fresca y juvenil.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-100">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Cómo funcionan Radiesse® y Sculptra®?" data-t-en="How do Radiesse® and Sculptra® work?">¿Cómo funcionan Radiesse® y Sculptra®?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Estimulan la producción de colágeno para reemplazar proteínas perdidas y mejorar la textura, el volumen y la elasticidad de la piel." data-t-en="They stimulate collagen production to replace lost proteins and improve skin texture, volume, and elasticity.">Estimulan la producción de colágeno para reemplazar proteínas perdidas y mejorar la textura, el volumen y la elasticidad de la piel.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-200">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Qué beneficios ofrecen?" data-t-en="What benefits do they offer?">¿Qué beneficios ofrecen?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Aumentan la producción de colágeno y elastina, mejoran la textura y el tono de la piel, restauran volumen y reducen líneas finas." data-t-en="They increase collagen and elastin production, improve skin texture and tone, restore volume, and reduce fine lines.">Aumentan la producción de colágeno y elastina, mejoran la textura y el tono de la piel, restauran volumen y reducen líneas finas.</p>
        </details>
        <details class="faq-item group py-6 animate-in fade-in slide-in-from-bottom-2 duration-500 delay-300">
          <summary class="faq-question cursor-pointer text-white font-semibold text-xl lg:text-2xl flex items-center justify-between transition-all duration-300 hover:translate-x-1">
            <span data-t-es="¿Para quiénes son ideales?" data-t-en="Who are they ideal for?">¿Para quiénes son ideales?</span>
            <span class="faq-icon text-white">+</span>
          </summary>
          <p class="mt-4 text-white/85 text-base lg:text-lg leading-relaxed group-open:animate-in group-open:fade-in group-open:slide-in-from-top-2 group-open:duration-300" data-t-es="Para quienes desean recuperar un brillo juvenil, suavizar líneas finas y mantener una piel saludable con un plan personalizado." data-t-en="For those who want to restore a youthful glow, smooth fine lines, and maintain healthy skin with a customized plan.">Para quienes desean recuperar un brillo juvenil, suavizar líneas finas y mantener una piel saludable con un plan personalizado.</p>
        </details>
      </div>
    </div>
  </section>
  <TransformCTA />
  <SimpleContactForm />
</BaseLayout>

<script>
  const initBiostimulatorsFaq = () => {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    const updateItem = (item) => {
      const summary = item.querySelector('.faq-question');
      const icon = item.querySelector('.faq-icon');
      if (!summary || !icon) return;
      const isOpen = item.hasAttribute('open');
      icon.textContent = isOpen ? '-' : '+';
    };

    const closeOthers = (current) => {
      items.forEach((item) => {
        if (item !== current) item.removeAttribute('open');
      });
    };

    const updateAll = () => {
      items.forEach(updateItem);
    };

    items.forEach((item) => {
      const summary = item.querySelector('summary');
      if (!summary) return;
      summary.addEventListener('click', () => {
        requestAnimationFrame(() => {
          if (item.hasAttribute('open')) {
            closeOthers(item);
          }
          updateAll();
        });
      });
    });

    updateAll();
  };

  document.addEventListener('DOMContentLoaded', initBiostimulatorsFaq);
  document.addEventListener('astro:page-load', initBiostimulatorsFaq);

  const getBiostimulatorsLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyBiostimulatorsLang = (lang) => {
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('[data-alt-es]').forEach((el) => {
      const es = el.getAttribute('data-alt-es') || '';
      const en = el.getAttribute('data-alt-en') || es;
      el.setAttribute('alt', lang === 'en' ? en : es);
    });
  };

  const initBiostimulatorsLang = () => applyBiostimulatorsLang(getBiostimulatorsLang());

  document.addEventListener('DOMContentLoaded', initBiostimulatorsLang);
  document.addEventListener('astro:page-load', initBiostimulatorsLang);
  window.addEventListener('languageChanged', () => {
    initBiostimulatorsLang();
  });
</script>
