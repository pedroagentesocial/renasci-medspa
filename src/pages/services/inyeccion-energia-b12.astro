---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'inyeccion-energia-b12',
  slug: 'inyeccion-energia-b12',
  title: { es: 'Inyección de Energía B12', en: 'B12 Energy Injection' },
  description: { es: 'Inyección de vitamina B12 para aumentar los niveles de energía, mejorar el estado de ánimo y optimizar el funcionamiento del sistema nervioso.', en: 'Vitamin B12 injection to increase energy levels, improve mood and optimize nervous system function.' },
  excerpt: { es: 'Aumenta energía y mejora el estado de ánimo.', en: 'Increase energy and improve mood.' },
  category: 'bienestar',
  precio: 'Por definir',
  image: 'https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=400&h=300&fit=crop&crop=center',
  benefits: ['Aumenta energía', 'Mejora estado de ánimo', 'Optimiza sistema nervioso', 'Combate fatiga'],
  duracion: '10 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'bienestar' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="mb-8">
        <span class="inline-block px-4 py-2 bg-pink-500/20 backdrop-blur-sm rounded-full text-pink-200 text-sm font-medium mb-4">
          ⚡ Pérdida de Peso y Bienestar
        </span>
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
          {servicio.title.es}
        </h1>
        <p class="text-xl md:text-2xl text-pink-100 mb-8 max-w-3xl mx-auto leading-relaxed">
          {servicio.description.es}
        </p>
      </div>

      <!-- Precio y Duración -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-4 border border-white/20">
          <div class="text-pink-200 text-sm font-medium">Precio</div>
          <div class="text-white text-2xl font-bold">{servicio.precio}</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-4 border border-white/20">
          <div class="text-pink-200 text-sm font-medium">Duración</div>
          <div class="text-white text-2xl font-bold">{servicio.duracion}</div>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agendar Cita" 
          href="https://calendly.com/renasci-medical-spa" 
          variant="primary"
          class="text-lg px-8 py-4"
        />
        <CTAButton 
          text="Más Información" 
          href="tel:+1234567890" 
          variant="secondary"
          class="text-lg px-8 py-4"
        />
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center">
        <div class="w-1 h-3 bg-white/50 rounded-full mt-2 animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Beneficios de la Vitamina B12
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          La vitamina B12 es esencial para el funcionamiento óptimo de tu cuerpo y mente. Descubre cómo puede transformar tu bienestar.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {servicio.benefits.map((benefit, index) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 mx-auto">
              <span class="text-2xl">
                {index === 0 && "⚡"}
                {index === 1 && "😊"}
                {index === 2 && "🧠"}
                {index === 3 && "💪"}
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">{benefit}</h3>
            <p class="text-gray-600 text-center">
              {index === 0 && "Incrementa significativamente tus niveles de energía natural."}
              {index === 1 && "Mejora el estado de ánimo y reduce la sensación de depresión."}
              {index === 2 && "Optimiza la función del sistema nervioso y la concentración."}
              {index === 3 && "Combate la fatiga crónica y el cansancio persistente."}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ¿Quién Necesita B12? -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          ¿Quién Necesita Vitamina B12?
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          La deficiencia de B12 es más común de lo que piensas. Conoce si podrías beneficiarte de nuestras inyecciones.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-2xl text-white">🌱</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Vegetarianos y Veganos</h3>
          <p class="text-gray-600">
            Las dietas basadas en plantas pueden carecer de B12, ya que se encuentra principalmente en productos animales.
          </p>
        </div>

        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-2xl text-white">👥</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Adultos Mayores</h3>
          <p class="text-gray-600">
            Con la edad, la absorción de B12 disminuye, haciendo necesaria la suplementación directa.
          </p>
        </div>

        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-2xl text-white">😴</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Personas con Fatiga</h3>
          <p class="text-gray-600">
            Si experimentas cansancio constante, la B12 puede ser la solución para recuperar tu energía.
          </p>
        </div>

        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-2xl text-white">🏃</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Atletas y Deportistas</h3>
          <p class="text-gray-600">
            La B12 mejora el rendimiento físico y acelera la recuperación muscular.
          </p>
        </div>

        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-2xl text-white">💼</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Profesionales Estresados</h3>
          <p class="text-gray-600">
            El estrés laboral puede agotar las reservas de B12, afectando tu rendimiento mental.
          </p>
        </div>

        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
            <span class="text-2xl text-white">🧬</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Problemas de Absorción</h3>
          <p class="text-gray-600">
            Condiciones digestivas pueden impedir la absorción oral, haciendo las inyecciones más efectivas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Relacionados -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Servicios Relacionados
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Combina la inyección de B12 con otros tratamientos para maximizar tu bienestar.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-br from-pink-600 to-purple-700 text-white">
    <div class="max-w-4xl mx-auto text-center px-6">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        ¿Listo para Recuperar tu Energía?
      </h2>
      <p class="text-xl mb-8 text-pink-100">
        Agenda tu inyección de vitamina B12 y siente la diferencia desde el primer día.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agendar Ahora" 
          href="https://calendly.com/renasci-medical-spa" 
          variant="secondary"
          class="text-lg px-8 py-4"
        />
        <CTAButton 
          text="Llamar Ahora" 
          href="tel:+1234567890" 
          variant="outline"
          class="text-lg px-8 py-4 border-white text-white hover:bg-white hover:text-pink-600"
        />
      </div>
    </div>
  </section>
</BaseLayout>