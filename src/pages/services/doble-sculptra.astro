---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'doble-sculptra',
  slug: 'doble-sculptra',
  title: { es: 'Doble Sculptra', en: 'Double Sculptra' },
  description: { es: 'Tratamiento intensivo con doble aplicación de Sculptra para resultados más dramáticos en la estimulación de colágeno y rejuvenecimiento facial.', en: 'Intensive treatment with double Sculptra application for more dramatic results in collagen stimulation and facial rejuvenation.' },
  excerpt: { es: 'Tratamiento intensivo con doble Sculptra para resultados más dramáticos.', en: 'Intensive treatment with double Sculptra for more dramatic results.' },
  category: 'sculptra-rellenos',
  precio: '$1600',
  image: 'https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?w=400&h=300&fit=crop&crop=center',
  benefits: ['Resultados más dramáticos', 'Estimulación intensa de colágeno', 'Rejuvenecimiento profundo', 'Duración extendida'],
  duracion: '90 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'sculptra-rellenos' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <!-- Floating Card -->
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-white/20 shadow-2xl transform hover:scale-105 transition-all duration-500">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          {servicio.title.es}
        </h1>
        
        <p class="text-xl md:text-2xl text-pink-100 mb-8 leading-relaxed">
          {servicio.description.es}
        </p>
        
        <!-- Price Badge -->
        <div class="inline-flex items-center bg-gradient-to-r from-pink-500 to-purple-600 text-white px-8 py-4 rounded-full text-2xl font-bold mb-8 shadow-lg">
          <span class="mr-2">⚡</span>
          {servicio.precio}
        </div>
        
        <!-- CTA Button -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton 
            text="Agenda tu Cita" 
            href="/contacto"
            variant="primary"
            class="transform hover:scale-105 transition-all duration-300"
          />
          <CTAButton 
            text="Más Información" 
            href="#detalles"
            variant="secondary"
            class="transform hover:scale-105 transition-all duration-300"
          />
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-white/50 rounded-full flex justify-center">
        <div class="w-1 h-3 bg-white/70 rounded-full mt-2 animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Información del Servicio -->
        <div class="space-y-8">
          <div class="bg-white rounded-3xl p-8 shadow-xl border border-pink-100 transform hover:scale-105 transition-all duration-500">
            <h2 class="text-3xl font-bold text-gray-800 mb-6 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-3 rounded-full mr-4">
                ⚡
              </span>
              Detalles del Tratamiento
            </h2>
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-pink-50 rounded-2xl p-6">
                <h3 class="font-semibold text-pink-800 mb-2">Duración</h3>
                <p class="text-gray-700">{servicio.duracion}</p>
              </div>
              
              <div class="bg-purple-50 rounded-2xl p-6">
                <h3 class="font-semibold text-purple-800 mb-2">Precio</h3>
                <p class="text-gray-700 font-bold text-xl">{servicio.precio}</p>
              </div>
            </div>
          </div>

          <!-- Beneficios -->
          <div class="bg-white rounded-3xl p-8 shadow-xl border border-pink-100">
            <h3 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-3 rounded-full mr-4">
                🌟
              </span>
              Beneficios
            </h3>
            
            <div class="grid gap-4">
              {servicio.benefits.map((benefit, index) => (
                <div class="flex items-center p-4 bg-gradient-to-r from-pink-50 to-purple-50 rounded-xl transform hover:scale-105 transition-all duration-300">
                  <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-2 rounded-full mr-4 flex-shrink-0">
                    ✓
                  </div>
                  <span class="text-gray-700 font-medium">{benefit}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Imagen del Servicio -->
        <div class="relative">
          <div class="bg-gradient-to-br from-pink-400 to-purple-600 rounded-3xl p-1 transform hover:scale-105 transition-all duration-500">
            <img 
              src={servicio.image}
              alt={`${servicio.title.es} treatment`}
              class="w-full h-96 object-cover rounded-3xl shadow-2xl"
              loading="lazy"
            />
          </div>
          
          <!-- Floating Badge -->
          <div class="absolute -top-4 -right-4 bg-white rounded-full p-4 shadow-xl border-4 border-pink-200 animate-pulse">
            <span class="text-2xl">⚡</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-800 mb-6">
          Proceso del Tratamiento
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Nuestro proceso está diseñado para brindarte la mejor experiencia y resultados óptimos
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            step: "01",
            title: "Evaluación Completa",
            description: "Análisis exhaustivo de tu piel y diseño personalizado del protocolo de doble Sculptra."
          },
          {
            step: "02", 
            title: "Doble Aplicación",
            description: "Aplicación intensiva de Sculptra en dos fases para maximizar la estimulación de colágeno."
          },
          {
            step: "03",
            title: "Seguimiento Intensivo",
            description: "Monitoreo especializado de los resultados dramáticos y citas de seguimiento personalizadas."
          }
        ].map((proceso, index) => (
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 text-center transform hover:scale-105 transition-all duration-500 border border-pink-100">
            <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
              {proceso.step}
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-4">{proceso.title}</h3>
            <p class="text-gray-600 leading-relaxed">{proceso.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-purple-50 to-pink-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-800 mb-6">
          Preguntas Frecuentes
        </h2>
        <p class="text-xl text-gray-600">
          Resolvemos tus dudas sobre el tratamiento Doble Sculptra
        </p>
      </div>

      <div class="space-y-6">
        {[
          {
            question: "¿Qué hace diferente al Doble Sculptra?",
            answer: "El Doble Sculptra utiliza una aplicación intensiva en dos fases para maximizar la estimulación de colágeno, proporcionando resultados más dramáticos y duraderos que el tratamiento estándar."
          },
          {
            question: "¿Cuánto duran los resultados?",
            answer: "Los resultados del Doble Sculptra pueden durar hasta 3 años o más, siendo significativamente más duraderos que otros tratamientos debido a la estimulación intensa de colágeno."
          },
          {
            question: "¿Es seguro el tratamiento intensivo?",
            answer: "Sí, el Doble Sculptra es completamente seguro cuando es realizado por profesionales certificados. El protocolo está diseñado para maximizar resultados manteniendo la seguridad."
          },
          {
            question: "¿Cuándo se ven los resultados?",
            answer: "Los resultados comienzan a notarse después de 6-8 semanas, con mejoras dramáticas y continuas durante los siguientes 6-12 meses."
          }
        ].map((faq, index) => (
          <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100 transform hover:scale-105 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-800 mb-3 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-2 rounded-full mr-3 text-sm">
                ?
              </span>
              {faq.question}
            </h3>
            <p class="text-gray-600 leading-relaxed ml-11">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Servicios Relacionados -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-800 mb-6">
            Servicios Relacionados
          </h2>
          <p class="text-xl text-gray-600">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-br from-pink-600 to-purple-700 text-white text-center">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-4xl font-bold mb-6">
        ¿Lista para resultados dramáticos?
      </h2>
      <p class="text-xl mb-8 opacity-90">
        Agenda tu consulta personalizada y descubre cómo el Doble Sculptra puede transformar tu piel con resultados intensivos.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agenda tu Consulta" 
          href="/contacto"
          variant="secondary"
          class="bg-white text-pink-600 hover:bg-pink-50 transform hover:scale-105 transition-all duration-300"
        />
        <CTAButton 
          text="Llama Ahora" 
          href="tel:+1234567890"
          variant="outline"
          class="border-white text-white hover:bg-white hover:text-pink-600 transform hover:scale-105 transition-all duration-300"
        />
      </div>
    </div>
  </section>
</BaseLayout>