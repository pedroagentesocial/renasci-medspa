---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'mini-aumento-labios',
  slug: 'mini-aumento-labios',
  title: { es: 'Mini Aumento de Labios', en: 'Mini Lip Enhancement' },
  description: { es: 'Tratamiento sutil con ácido hialurónico para dar volumen y definición natural a tus labios sin exagerar.', en: 'Subtle hyaluronic acid treatment to give natural volume and definition to your lips without exaggeration.' },
  excerpt: { es: 'Volumen sutil y natural para labios más definidos.', en: 'Subtle and natural volume for more defined lips.' },
  category: 'neurotoxinas',
  precio: '$375',
  image: 'https://images.unsplash.com/photo-1616391182219-e080b4d1043a?w=400&h=300&fit=crop&crop=face',
  benefits: ['Volumen natural', 'Hidratación profunda', 'Resultados inmediatos', 'Aspecto juvenil'],
  duracion: '30 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'neurotoxinas' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1616391182219-e080b4d1043a?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-pink-500/20 backdrop-blur-sm border border-pink-300/30 mb-6">
        <span class="text-pink-200 text-sm font-medium uppercase tracking-wider">Rellenos Dérmicos</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        <span class="bg-gradient-to-r from-pink-200 via-white to-pink-200 bg-clip-text text-transparent">
          {servicio.title.es}
        </span>
      </h1>
      
      <!-- Description -->
      <p class="text-xl md:text-2xl text-gray-700 mb-8 max-w-3xl mx-auto leading-relaxed">
        {servicio.description.es}
      </p>
      
      <!-- Price Highlight -->
      <div class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl shadow-2xl mb-8 transform hover:scale-105 transition-all duration-300">
        <span class="text-2xl md:text-3xl font-bold text-white">{servicio.precio}</span>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <CTAButton 
          href="/contact" 
          variant="primary"
          class="bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        >
          Agenda tu Cita
        </CTAButton>
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/20 transition-all duration-300"
        >
          Consulta Gratuita
        </CTAButton>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Beneficios del Tratamiento</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Ventajas clave del Mini Aumento de Labios</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-white mb-3">Volumen Natural</h3><p class="text-white/80 leading-relaxed">Resultados discretos y armoniosos sin exagerar el tamaño.</p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-primary hover:bg-primary/15"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg></div><h3 class="font-display font-bold text-xl text-white mb-3">Hidratación Profunda</h3><p class="text-white/80 leading-relaxed">El ácido hialurónico aporta hidratación y suavidad al labio.</p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duración-300 border-2 border-primary hover:bg-primary/15"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-white mb-3">Resultados Inmediatos</h3><p class="text-white/80 leading-relaxed">Definición y mejora visibles al instante y en los siguientes días.</p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duración-300 border-2 border-primary hover:bg-primary/15"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></div><h3 class="font-display font-bold text-xl text-white mb-3">Aspecto Juvenil</h3><p class="text-white/80 leading-relaxed">Mejora el contorno y suaviza líneas para una apariencia fresca.</p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duración-300 border-2 border-primary hover:bg-primary/15"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-white mb-3">Alta Precisión</h3><p class="text-white/80 leading-relaxed">Aplicación en puntos estratégicos para simetría y equilibrio.</p></div>
        <div class="group rounded-2xl p-6 transition-all duración-300 hover:-translate-y-2 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duración-300 border-2 border-primary hover:bg-primary/15"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-white mb-3">Definición Sutil</h3><p class="text-white/80 leading-relaxed">Realce del borde del labio manteniendo proporciones naturales.</p></div>
      </div>
    </div>
  </section>

  <!-- Breadcrumbs -->
  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">Mini Aumento de Labios</li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <!-- Service Details -->
  <section class="py-20 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Content -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">
              ¿Qué es el <span class="text-pink-600">Mini Aumento de Labios</span>?
            </h2>
            <p class="text-lg text-text/80 leading-relaxed">
              El Mini Aumento de Labios es un tratamiento conservador con ácido hialurónico que proporciona 
              un volumen sutil y natural. Perfecto para quienes desean mejorar la forma y definición de sus 
              labios sin cambios dramáticos, manteniendo una apariencia completamente natural.
            </p>
          </div>
          
          <!-- Benefits -->
          <div>
            <h3 class="text-2xl font-bold text-text mb-4">Beneficios del Tratamiento</h3>
            <ul class="space-y-3">
              {servicio.benefits.map((benefit) => (
                <li class="flex items-center text-text/80">
                  <svg class="w-5 h-5 text-pink-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  {benefit}
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Right: Image -->
        <div class="relative">
          <div class="aspect-w-4 aspect-h-3 rounded-3xl overflow-hidden shadow-2xl">
            <img 
              src={servicio.image}
              alt={`${servicio.title.es} procedure`}
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Floating card -->
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-6 shadow-xl border border-gray-100">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-pink-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-600">Duración</p>
                <p class="font-semibold text-gray-900">{servicio.duracion}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-text/70 max-w-3xl mx-auto">
          Un procedimiento seguro y preciso para labios naturalmente hermosos
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-text mb-4">Consulta</h3>
          <p class="text-text/70">
            Evaluamos la forma natural de tus labios y diseñamos un plan personalizado para lograr el resultado deseado.
          </p>
        </div>
        
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-text mb-4">Aplicación</h3>
          <p class="text-text/70">
            Inyectamos cuidadosamente pequeñas cantidades de ácido hialurónico en puntos estratégicos para crear volumen natural.
          </p>
        </div>
        
        <div class="text-center group">
          <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-text mb-4">Resultados</h3>
          <p class="text-text/70">
            Los resultados son inmediatos y mejoran en los siguientes días, durando entre 6-9 meses.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 lg:py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Preguntas Frecuentes</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Resolvemos dudas comunes sobre el Mini Aumento de Labios</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-primary"><svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>¿Qué diferencia hay con el aumento completo?</h3><p class="text-white/80 leading-relaxed pl-11">Usa menos producto y busca definición sutil y natural.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-primary"><svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>¿Cuánto tiempo dura el efecto?</h3><p class="text-white/80 leading-relaxed pl-11">Aproximadamente 6–9 meses según metabolismo y cuidado.</p></div>
        <div class="rounded-2xl p-6 border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60"><h3 class="font-display font-bold text-lg text-white mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-primary"><svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg></div>¿Es doloroso?</h3><p class="text-white/80 leading-relaxed pl-11">Molestias mínimas con anestesia tópica y técnica precisa.</p></div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">
            Servicios <span class="text-pink-600">Relacionados</span>
          </h2>
          <p class="text-xl text-text/70">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-r from-pink-600 to-purple-700">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        ¿Listo para labios naturalmente hermosos?
      </h2>
      <p class="text-xl text-pink-100 mb-8 max-w-2xl mx-auto">
        Agenda tu consulta gratuita y descubre cómo el mini aumento puede realzar tu belleza natural
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white text-pink-600 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-gray-100 transition-all duration-300 shadow-xl"
        >
          Agenda tu Consulta
        </CTAButton>
        <CTAButton 
          href="tel:+1234567890" 
          variant="outline"
          class="border-2 border-white text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white hover:text-pink-600 transition-all duration-300"
        >
          Llama Ahora
        </CTAButton>
      </div>
    </div>
  </section>
  
  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-primary"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></span><div class="flex-1 h-[2px] bg-primary"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-4">Lo Que Dicen Nuestros Pacientes</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Experiencias reales con resultados sutiles y naturales</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
