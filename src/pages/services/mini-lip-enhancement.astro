---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="Mini Lip Enhancement - Renasci Medical Spa"
  description="Subtle hyaluronic acid enhancement for natural volume and definition without exaggeration. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30"><span data-i18n="services.injectables_title">Neurotoxin & Dermal Filler Injections</span></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4"><span data-i18n="minilip.hero_title">Mini Lip Enhancement</span></h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto"><span data-i18n="minilip.hero_subtitle">Subtle volume and natural definition using premium hyaluronic acid.</span></p>
      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20">
        <div class="text-sm text-white/80 mb-1"><span data-i18n="minilip.price_from_label">Starting at</span></div>
        <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]"><span data-i18n="minilip.price_value">$375</span></div>
        <div class="text-sm text-white/80 mt-1"><span data-i18n="minilip.duration_label">Duration: 30 min</span></div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"><span data-i18n="cta.view_details">View Details</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50" aria-label="Call Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-i18n="nav.home">Home</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-i18n="nav.services">Services</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="minilip.breadcrumb_label">Mini Lip Enhancement</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/Lip-filler-image.jpg" alt="Mini Lip Enhancement" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6"><span data-i18n="minilip.details.title">Mini Lip Enhancement</span></h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4"><span data-i18n="minilip.details.p1">Uses <strong>small doses of hyaluronic acid</strong> to achieve <strong>subtle volume</strong> and <strong>natural edge definition</strong>.</span></p>
              <p class="mb-4"><span data-i18n="minilip.details.p2">Ideal for a discreet, harmonious change while maintaining facial balance and expressiveness.</span></p>
              <p><span data-i18n="minilip.details.p3">Immediate visible results that refine over days; typical duration is 6–9 months.</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="minilip.benefits.title">Treatment Benefits</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="minilip.benefits.subtitle">Key advantages of Mini Lip Enhancement</span></p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="minilip.benefits.items.0.title">Natural Volume</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="minilip.benefits.items.0.text">Discreet, balanced results without exaggeration.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="minilip.benefits.items.1.title">Deep Hydration</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="minilip.benefits.items.1.text">Hyaluronic acid adds softness and hydration.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="minilip.benefits.items.2.title">Immediate Results</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="minilip.benefits.items.2.text">Visible definition immediately and refined over days.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="minilip.benefits.items.3.title">Youthful Look</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="minilip.benefits.items.3.text">Enhances contour and softens lines for a fresh look.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="minilip.benefits.items.4.title">High Precision</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="minilip.benefits.items.4.text">Strategic points for symmetry and balance.</span></p></div>
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg></div><h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="minilip.benefits.items.5.title">Subtle Definition</span></h3><p class="text-gray-700 leading-relaxed"><span data-i18n="minilip.benefits.items.5.text">Enhances the lip border while keeping natural proportions.</span></p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="minilip.process.title">Treatment Process</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto"><span data-i18n="minilip.process.subtitle">Safe, precise and with immediate results</span></p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-[#F3A2A7] via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-[#F3A2A7]/10 to-pink-500/10 rounded-2xl p-6 border border-[#F3A2A7]/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-[#F3A2A7] to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="minilip.process.steps.0.title">Initial Consultation</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="minilip.process.steps.0.text">Evaluation of lip contour and natural proportions.</span></p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/first.jpg" alt="Initial consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="minilip.process.steps.1.title">Area Preparation</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="minilip.process.steps.1.text">Cleaning, disinfection and precise marking.</span></p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/inyeccion-botox.jpg" alt="Preparation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="minilip.process.steps.2.title">Precise Application</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="minilip.process.steps.2.text">Microinjections of hyaluronic acid for subtle definition.</span></p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/img/services/inyeccion-botox.jpg" alt="Precise application" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div><h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="minilip.process.steps.3.title">Care & Follow-up</span></h3></div><p class="text-gray-600 leading-relaxed"><span data-i18n="minilip.process.steps.3.text">Post-treatment recommendations and results evaluation.</span></p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/images/med-spa-room.jpg" alt="Follow-up" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
            </svg>
          </span>
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        </div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="minilip.faq.title">Frequently Asked Questions</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto"><span data-i18n="minilip.faq.subtitle">Common questions about Mini Lip Enhancement</span></p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><span data-i18n="minilip.faq.items.0.q">What’s the difference from full augmentation?</span></h3><p class="text-gray-700 leading-relaxed pl-11"><span data-i18n="minilip.faq.items.0.a">Uses less product focused on subtle, natural definition.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><span data-i18n="minilip.faq.items.1.q">How long does it last?</span></h3><p class="text-gray-700 leading-relaxed pl-11"><span data-i18n="minilip.faq.items.1.a">Typically 6–9 months, depending on metabolism and care.</span></p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center"><div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15"><svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke_width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg></div><span data-i18n="minilip.faq.items.2.q">Is it painful?</span></h3><p class="text-gray-700 leading-relaxed pl-11"><span data-i18n="minilip.faq.items.2.a">Minimal discomfort; topical anesthesia and precise technique.</span></p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="minilip.testimonials.title">What Our Patients Say</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto"><span data-i18n="minilip.testimonials.subtitle">Real experiences with subtle, natural results</span></p>
