---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'contorno-facial-personalizado',
  slug: 'contorno-facial-personalizado',
  title: { es: 'Contorno Facial Personalizado', en: 'Personalized Facial Contouring' },
  description: { es: 'Tratamiento personalizado para realzar y definir la estructura facial natural con técnicas avanzadas de contorno.', en: 'Personalized treatment to enhance and define natural facial structure with advanced contouring techniques.' },
  excerpt: { es: 'Esculpe y define los rasgos faciales de forma personalizada.', en: 'Sculpt and define facial features in a personalized way.' },
  category: 'contorno',
  precio: '$850',
  image: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400&h=300&fit=crop&crop=center',
  benefits: ['Rostro más definido', 'Armonía facial', 'Resultados naturales', 'Técnica personalizada'],
  duracion: '60 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'contorno' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8 animate-fade-in-up">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 bg-pink-500/20 backdrop-blur-sm border border-pink-300/30 rounded-full text-pink-100 text-sm font-medium">
          <span class="w-2 h-2 bg-pink-400 rounded-full mr-2 animate-pulse"></span>
          Tratamiento de Contorno Facial
        </div>

        <!-- Title -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight">
          <span class="bg-gradient-to-r from-pink-200 via-white to-pink-200 bg-clip-text text-transparent">
            {servicio.title.es}
          </span>
        </h1>

        <!-- Description -->
        <p class="text-xl md:text-2xl text-pink-100 max-w-3xl mx-auto leading-relaxed">
          {servicio.description.es}
        </p>

        <!-- Price & Duration -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-white">
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-6 py-3 rounded-full border border-white/20">
            <svg class="w-5 h-5 text-pink-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
            <span class="font-semibold">{servicio.precio}</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-6 py-3 rounded-full border border-white/20">
            <svg class="w-5 h-5 text-pink-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-semibold">{servicio.duracion}</span>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="pt-4">
          <CTAButton 
            text="Agenda tu Cita" 
            href="https://calendly.com/renasci-medical-spa" 
            variant="primary"
            class="transform hover:scale-105 transition-all duration-300 shadow-2xl hover:shadow-pink-500/25"
          />
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- Beneficios Section -->
  <section class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Beneficios del <span class="text-pink-600">Contorno Facial Personalizado</span>
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Descubre cómo este tratamiento puede transformar y realzar tu belleza natural
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {servicio.benefits.map((benefit, index) => (
          <div class="group">
            <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-pink-100 hover:border-pink-200">
              <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3">{benefit}</h3>
              <p class="text-gray-600">Resultados visibles y duraderos que realzan tu belleza natural.</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Proceso Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Nuestro <span class="text-pink-600">Proceso</span>
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Un enfoque personalizado para obtener los mejores resultados
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Consulta Personalizada</h3>
          <p class="text-gray-600">Evaluamos tu estructura facial y diseñamos un plan personalizado.</p>
        </div>

        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Aplicación Precisa</h3>
          <p class="text-gray-600">Utilizamos técnicas avanzadas para lograr el contorno deseado.</p>
        </div>

        <div class="text-center group">
          <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Resultados Naturales</h3>
          <p class="text-gray-600">Disfruta de un rostro más definido y armonioso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-purple-50 to-pink-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
      </div>

      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-pink-100">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Cuánto duran los resultados?</h3>
          <p class="text-gray-600">Los resultados del contorno facial personalizado pueden durar entre 12-18 meses, dependiendo del tipo de producto utilizado y las características individuales.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg border border-pink-100">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Es doloroso el procedimiento?</h3>
          <p class="text-gray-600">El procedimiento es mínimamente invasivo. Utilizamos técnicas de anestesia local para garantizar tu comodidad durante el tratamiento.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg border border-pink-100">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">¿Cuándo veré los resultados?</h3>
          <p class="text-gray-600">Los resultados son visibles inmediatamente después del tratamiento, con mejoras continuas durante las siguientes 2-4 semanas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Relacionados -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Servicios <span class="text-pink-600">Relacionados</span>
          </h2>
          <p class="text-xl text-gray-600">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <section class="py-20 bg-gradient-to-br from-pink-600 to-purple-700 text-white">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        ¿Listo para transformar tu rostro?
      </h2>
      <p class="text-xl mb-8 text-pink-100">
        Agenda tu consulta personalizada y descubre cómo podemos realzar tu belleza natural
      </p>
      <CTAButton 
        text="Agenda tu Consulta" 
        href="https://calendly.com/renasci-medical-spa" 
        variant="secondary"
        class="transform hover:scale-105 transition-all duration-300"
      />
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 1s ease-out;
  }
</style>