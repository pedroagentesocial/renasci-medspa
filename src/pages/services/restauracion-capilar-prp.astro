---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { serviciosUnificados } from '../../data/services-unified';

// Datos específicos del servicio
const servicio = {
  id: 'restauracion-capilar-prp',
  slug: 'restauracion-capilar-prp',
  title: { es: 'Tratamiento de Restauración Capilar con PRP', en: 'Hair Restoration Treatment with PRP' },
  description: { es: 'Tratamiento regenerativo avanzado con plasma rico en plaquetas para estimular el crecimiento capilar natural y fortalecer el cabello existente.', en: 'Advanced regenerative treatment with platelet-rich plasma to stimulate natural hair growth and strengthen existing hair.' },
  excerpt: { es: 'Restauración capilar natural con plasma rico en plaquetas.', en: 'Natural hair restoration with platelet-rich plasma.' },
  category: 'cabello-piel',
  precio: 'Por definir',
  image: 'https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=400&h=300&fit=crop&crop=center',
  benefits: ['Estimula crecimiento capilar', 'Fortalece cabello existente', 'Tratamiento natural', 'Resultados progresivos'],
  duracion: '60 minutos'
};

// Servicios relacionados
const serviciosRelacionados = serviciosUnificados
  .filter(s => s.category === 'cabello-piel' && s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <!-- Hero del Servicio -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt={`${servicio.title.es} treatment at medical spa`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-pink-900/40 via-purple-900/30 to-pink-800/40"></div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Animated circles -->
      <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-pink-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-24 h-24 bg-purple-400/20 rounded-full blur-lg animate-bounce"></div>
      <div class="absolute bottom-1/4 left-1/3 w-40 h-40 bg-pink-300/10 rounded-full blur-2xl animate-pulse delay-1000"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-pink-500/20 backdrop-blur-sm border border-pink-300/30 mb-6">
        <span class="text-pink-200 text-sm font-medium uppercase tracking-wider">Cabello y Piel</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        <span class="bg-gradient-to-r from-pink-200 via-white to-pink-200 bg-clip-text text-transparent">
          {servicio.title.es}
        </span>
      </h1>
      
      <!-- Description -->
      <p class="text-xl md:text-2xl text-gray-700 mb-8 max-w-3xl mx-auto leading-relaxed">
        {servicio.description.es}
      </p>
      
      <!-- Price Highlight -->
      <div class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl shadow-2xl mb-8 transform hover:scale-105 transition-all duration-300">
        <span class="text-2xl md:text-3xl font-bold text-white">{servicio.precio}</span>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <CTAButton 
          href="/contact" 
          variant="primary"
          class="bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        >
          Agenda tu Cita
        </CTAButton>
        <CTAButton 
          href="/contact" 
          variant="secondary"
          class="bg-white/10 backdrop-blur-sm border border-white/20 text-white hover:bg-white/20 px-8 py-4 rounded-xl font-semibold text-lg shadow-xl hover:shadow-2xl transform hover:scale-105 transition-all duration-300"
        >
          Más Información
        </CTAButton>
      </div>
    </div>
  </section>

  <!-- Beneficios del Tratamiento -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-800 mb-6">
          Beneficios del Tratamiento
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Descubre cómo nuestro tratamiento de restauración capilar puede transformar tu cabello
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {servicio.benefits.map((benefit, index) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 group">
            <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
              <span class="text-2xl font-bold text-white">{index + 1}</span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-4 text-center">{benefit}</h3>
            <p class="text-gray-600 text-center">
              {benefit === 'Estimula crecimiento capilar' && 'Activa los folículos pilosos para promover el crecimiento natural del cabello.'}
              {benefit === 'Fortalece cabello existente' && 'Mejora la calidad y resistencia del cabello actual.'}
              {benefit === 'Tratamiento natural' && 'Utiliza tus propias plaquetas para resultados seguros y naturales.'}
              {benefit === 'Resultados progresivos' && 'Mejoras visibles que se desarrollan gradualmente con el tiempo.'}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-800 mb-6">
          Proceso del Tratamiento
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Conoce paso a paso cómo realizamos este tratamiento especializado
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            1
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Evaluación Capilar</h3>
          <p class="text-gray-600">Analizamos el estado de tu cuero cabelludo y determinamos el plan de tratamiento más efectivo.</p>
        </div>
        
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            2
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Extracción de PRP</h3>
          <p class="text-gray-600">Extraemos una pequeña muestra de sangre y procesamos el plasma rico en plaquetas.</p>
        </div>
        
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            3
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Aplicación Precisa</h3>
          <p class="text-gray-600">Inyectamos el PRP en las áreas afectadas para estimular el crecimiento capilar natural.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-pink-50/30 to-purple-50/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-800 mb-6">
          Preguntas Frecuentes
        </h2>
        <p class="text-xl text-gray-600">
          Resolvemos tus dudas sobre el tratamiento de restauración capilar
        </p>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-xl font-bold text-gray-800 mb-3">¿Cuántas sesiones necesito?</h3>
          <p class="text-gray-600">Generalmente se recomiendan 3-4 sesiones espaciadas cada 4-6 semanas para obtener resultados óptimos.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-xl font-bold text-gray-800 mb-3">¿Cuándo veré los resultados?</h3>
          <p class="text-gray-600">Los primeros resultados pueden notarse después de 2-3 meses, con mejoras continuas durante 6-12 meses.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-xl font-bold text-gray-800 mb-3">¿Es doloroso el tratamiento?</h3>
          <p class="text-gray-600">El procedimiento es mínimamente invasivo. Aplicamos anestesia tópica para mayor comodidad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Relacionados -->
  {serviciosRelacionados.length > 0 && (
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-800 mb-6">
            Otros Tratamientos de Cabello y Piel
          </h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Descubre otros tratamientos que podrían interesarte
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {serviciosRelacionados.map((servicio) => (
            <ServiceCard servicio={servicio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-r from-pink-600 to-rose-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/10 rounded-full -translate-x-48 -translate-y-48"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/10 rounded-full translate-x-48 translate-y-48"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        ¿Lista para Restaurar tu Cabello?
      </h2>
      <p class="text-xl text-pink-100 mb-8 max-w-2xl mx-auto">
        Agenda tu consulta especializada y descubre cómo el PRP puede ayudarte a recuperar la densidad y vitalidad de tu cabello.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton 
          text="Agenda tu Consulta" 
          href="/contacto"
          variant="secondary"
          class="bg-white text-pink-600 hover:bg-pink-50 transform hover:scale-105 transition-all duration-300"
        />
        <CTAButton 
          text="Llama Ahora" 
          href="tel:+1234567890"
          variant="outline"
          class="border-white text-white hover:bg-white hover:text-pink-600 transform hover:scale-105 transition-all duration-300"
        />
      </div>
    </div>
  </section>
</BaseLayout>