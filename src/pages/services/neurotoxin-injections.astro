---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="Neurotoxin Injections - Renasci Medical Spa"
  description="Inyecciones de neurotoxina para suavizar líneas de expresión, prevenir nuevas arrugas y lograr resultados naturales y duraderos. Agenda tu cita en Renasci Medical Spa."
>
  <!-- Hero del Servicio -->
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30 animate-fade-in-up">
        <span data-i18n="services.injectables_title">Neurotoxin & Dermal Filler Injections</span>
      </div>

      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4 animate-fade-in-up" style="animation-delay: 0.2s;">
        <span data-i18n="neurotoxins.hero_title">Neurotoxin Injections</span>
      </h1>

      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.4s;">
        <span data-i18n="neurotoxins.hero_subtitle">Tratamiento con neurotoxina para suavizar arrugas dinámicas y prevenir nuevas líneas de expresión, manteniendo resultados naturales y armoniosos.</span>
      </p>

      <div class="bg-white/10 rounded-2xl p-6 mb-6 inline-block border border-white/20 animate-scale-in" style="animation-delay: 0.6s;">
        <div class="text-sm text-white/80 mb-1"><span data-i18n="neurotoxins.price_from_label">Precio desde</span></div>
        <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]"><span data-i18n="neurotoxins.price_value">$12 / unidad</span></div>
        <div class="text-sm text-white/80 mt-1"><span data-i18n="neurotoxins.duration_label">Duración: 30 min</span></div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.8s;">
        <a 
          href="#detalles"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text_white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline_none focus_visible:ring-2 focus_visible:ring_white/50 animate_pulse_gentle"
          >
          <span data-i18n="cta.view_details">Ver Detalles</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke_linecap="round" stroke_linejoin="round" stroke_width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>

        <a 
          href="tel:+13855550123"
          class="call-hero-button inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50 animate-bounce-subtle"
          aria-label="Llamar Renasci"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          <span data-i18n="cta.call">Llamar</span>
          (385) 555-0123
        </a>
      </div>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors"><span data-i18n="nav.home">Inicio</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors"><span data-i18n="nav.services">Servicios</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="neurotoxins.breadcrumb_label">Neurotoxin Injections</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <!-- Imagen -->
        <div class="relative group animate-slide-in-left bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img 
            src="/img/services/neurotoxins.jpg"
            alt="Neurotoxin Injections"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
            loading="lazy"
          />
        </div>

        <!-- Contenido -->
        <div class="animate-slide-in-right min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent mb-6">
              <span data-i18n="neurotoxins.details.title">Neurotoxin Injections</span>
            </h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4">
                <span data-i18n="neurotoxins.details.p1">Las <strong>Neurotoxin Injections</strong> son un tratamiento efectivo para suavizar arrugas dinámicas y prevenir nuevas líneas de expresión. Actúan relajando temporalmente los músculos responsables de las arrugas.</span>
              </p>
              <p class="mb-4">
                <span data-i18n="neurotoxins.details.p2">Nuestros especialistas aplican dosis precisas en áreas como frente, entrecejo y patas de gallo, logrando resultados naturales sin perder tu expresividad.</span>
              </p>
              <p>
                <span data-i18n="neurotoxins.details.p3">Es un procedimiento seguro y rápido, ideal para quienes buscan rejuvenecimiento facial no invasivo y resultados consistentes.</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
            </svg>
          </span>
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        </div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="neurotoxins.benefits.title">Beneficios del Tratamiento</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">
          <span data-i18n="neurotoxins.benefits.subtitle">Ventajas clave de las Inyecciones de Neurotoxina</span>
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60" style="animation-delay: 0.1s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15">
            <svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="neurotoxins.benefits.item1.title">Reduce Arrugas Dinámicas</span></h3>
          <p class="text-gray-700 leading-relaxed"><span data-i18n="neurotoxins.benefits.item1.text">Suaviza líneas de expresión causadas por movimientos repetitivos para un aspecto más joven.</span></p>
        </div>

        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-primary bg-transparent text-white hover:ring-2 hover:ring-primary/60" style="animation-delay: 0.2s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15">
            <svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="neurotoxins.benefits.item2.title">Previene Nuevas Líneas</span></h3>
          <p class="text-gray-700 leading-relaxed"><span data-i18n="neurotoxins.benefits.item2.text">Prevención efectiva para mantener la piel suave por más tiempo.</span></p>
        </div>

        <div class="group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-2 animate-fade-in-up border-2 border-[#F3A2A7] bg-transparent text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60" style="animation-delay: 0.3s;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15">
            <svg class="w-6 h-6 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-gray-900 mb-3"><span data-i18n="neurotoxins.benefits.item3.title">Resultados Naturales</span></h3>
          <p class="text-gray-700 leading-relaxed"><span data-i18n="neurotoxins.benefits.item3.text">Mantiene tu expresividad mientras suaviza líneas no deseadas.</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso del Tratamiento -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
            </svg>
          </span>
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        </div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="neurotoxins.process.title">Proceso del Tratamiento</span></h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          <span data-i18n="neurotoxins.process.subtitle">Un proceso simple y profesional para obtener los mejores resultados</span>
        </p>
      </div>

      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-primary via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8 animate-slide-in-left">
            <div class="lg:w-1/2 lg:pr-8">
              <div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div>
                  <h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="neurotoxins.process.step1.title">Consulta Inicial</span></h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  <span data-i18n="neurotoxins.process.step1.text">Evaluación de áreas a tratar y objetivos estéticos. Se define el plan y la cantidad de producto.</span>
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pl-8">
              <img src="/img/services/first.jpg" alt="Consulta inicial" class="w-full h-64 object-cover rounded-2xl" loading="lazy" />
            </div>
          </div>

          <div class="flex flex-col lg:flex-row-reverse items-center gap-8 animate-slide-in-right">
            <div class="lg:w-1/2 lg:pl-8">
              <div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div>
                  <h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="neurotoxins.process.step2.title">Preparación del Área</span></h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  <span data-i18n="neurotoxins.process.step2.text">Limpieza, desinfección y marcado preciso de puntos de inyección.</span>
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pr-8">
              <img src="/img/services/second.jpg" alt="Preparación" class="w-full h-64 object-cover rounded-2xl" loading="lazy" />
            </div>
          </div>

          <div class="flex flex-col lg:flex-row items-center gap-8 animate-slide-in-left">
            <div class="lg:w-1/2 lg:pr-8">
              <div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div>
                  <h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="neurotoxins.process.step3.title">Aplicación de Neurotoxina</span></h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  <span data-i18n="neurotoxins.process.step3.text">Inyección precisa y rápida en músculos objetivo. Procedimiento cómodo de ~30 minutos.</span>
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pl-8">
              <img src="/img/services/third.jpg" alt="Aplicación" class="w-full h-64 object-cover rounded-2xl" loading="lazy" />
            </div>
          </div>

          <div class="flex flex-col lg:flex-row-reverse items-center gap-8 animate-slide-in-right">
            <div class="lg:w-1/2 lg:pl-8">
              <div class="bg-gradient-to-br from-rose-500/10 to-pink-500/10 rounded-2xl p-6 border border-rose-500/20">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">4</div>
                  <h3 class="font-display font-bold text-xl text-gray-900"><span data-i18n="neurotoxins.process.step4.title">Cuidados Post-Tratamiento</span></h3>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  <span data-i18n="neurotoxins.process.step4.text">Recomendaciones de cuidado y seguimiento. Resultados visibles en 3–5 días; máximo en 2 semanas.</span>
                </p>
              </div>
            </div>
            <div class="lg:w-1/2 lg:pr-8">
              <img src="/img/services/fourth.jpg" alt="Cuidados post-tratamiento" class="w-full h-64 object-cover rounded-2xl" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Preguntas Frecuentes -->
  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        </div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4"><span data-i18n="neurotoxins.faq.title">Preguntas Frecuentes</span></h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">
          <span data-i18n="neurotoxins.faq.subtitle">Resolvemos dudas comunes sobre Neurotoxin Injections</span>
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 animate-fade-in-up hover:ring-2 hover:ring-[#F3A2A7]/60" style="animation-delay: 0.1s;">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center">
            <div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15">
              <svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <span data-i18n="neurotoxins.faq.q1">¿Qué es la neurotoxina y cómo funciona?</span>
          </h3>
          <p class="text-gray-700 leading-relaxed pl-11">
            <span data-i18n="neurotoxins.faq.a1">Bloquea temporalmente señales nerviosas en músculos específicos, suavizando las arrugas dinámicas de forma segura y controlada.</span>
          </p>
        </div>

        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 animate-fade-in-up hover:ring-2 hover:ring-[#F3A2A7]/60" style="animation-delay: 0.2s;">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center">
            <div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15">
              <svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <span data-i18n="neurotoxins.faq.q2">¿Cuánto duran los resultados?</span>
          </h3>
          <p class="text-gray-700 leading-relaxed pl-11">
            <span data-i18n="neurotoxins.faq.a2">Usualmente 3–4 meses, variando por área, dosis y metabolismo. Con constancia, la duración puede optimizarse.</span>
          </p>
        </div>

        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-transparent text-gray-900 animate-fade-in-up hover:ring-2 hover:ring-[#F3A2A7]/60" style="animation-delay: 0.3s;">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-3 flex items-center">
            <div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 border-2 border-[#F3A2A7] hover:bg-[#F3A2A7]/15">
              <svg class="w-4 h-4 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
            </div>
            <span data-i18n="neurotoxins.faq.q3">¿Es doloroso?</span>
          </h3>
          <p class="text-gray-700 leading-relaxed pl-11">
            <span data-i18n="neurotoxins.faq.a3">Es bien tolerado; se siente como pequeños pinchazos con agujas finas y técnica precisa.</span>
          </p>
        </div>
      </div>
    </div>
