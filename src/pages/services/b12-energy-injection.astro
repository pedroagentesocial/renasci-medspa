---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
---

<BaseLayout 
  title="B12 Energy Injection - Renasci Medical Spa"
  description="Vitamin B12 injection to increase energy, improve mood and support nervous system function. Book your appointment at Renasci Medical Spa."
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-[#F3A2A7]/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-3 border border-[#F3A2A7]/30"><span data-i18n="services.wellness_title">Wellness & Weight Loss</span></div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4" data-i18n="b12energy.hero_title">B12 Energy Injection</h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto" data-i18n="b12energy.hero_subtitle">Boosts natural energy, mood and focus with quick, comfortable intramuscular application.</p>
      <div class="inline-flex gap-4 mb-6 justify-center items-center">
        <div class="bg-white/10 rounded-2xl p-6 inline-block border border-white/20 text-center">
          <div class="text-sm text-white/80 mb-1"><span data-i18n="b12energy.price_from_label">Starting at</span></div>
          <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]" data-i18n="b12energy.price_value">$20</div>
          <div class="text-sm text-white/80 mt-1" data-i18n="b12energy.duration_label">Duration: 10 min</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 inline-block border-2 border-[#F3A2A7] hover:ring-2 hover:ring-[#F3A2A7] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#F3A2A7]/20 text-white text-xs font-semibold mb-3 border border-[#F3A2A7]/40">
            <span class="w-2 h-2 rounded-full bg-[#F3A2A7]"></span>
            <span data-i18n="b12energy.membership_badge_label">Membership Benefit</span>
          </div>
          <div class="text-sm text-white/80 mb-1" data-i18n="b12energy.members_label">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-[#F3A2A7]" data-i18n="b12energy.membership_free_value">Free</div>
          <div class="text-xs text-white/70 mt-2" data-i18n="b12energy.membership_includes_text">Includes 1 complimentary per month</div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-[#F3A2A7] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50"><span data-i18n="cta.view_details">View Details</span><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-[#AABFA8] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#AABFA8]/50" aria-label="Call Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 0 0 5.516 5.516l1.13-2.257a1 1 0 0 1 1.21-.502l4.493 1.498a1 1 0 0 1 .684.949V19a2 2 0 0 1-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-sm font-semibold mt-4 mx-auto w-fit whitespace-nowrap">
        <span class="w-2.5 h-2.5 rounded-full bg-[#F3A2A7]"></span>
        <span data-i18n="b12energy.membership_included_label">Included in Membership Plans</span>
        <a href="/membership" class="underline underline-offset-2 hover:text-white ml-2"><span data-i18n="b12energy.membership_see_link">See Memberships</span></a>
      </div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.home">Home</span></a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-[#F3A2A7] transition-colors"><span data-i18n="nav.services">Services</span></a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium"><span data-i18n="b12energy.breadcrumb_label">B12 Energy Injection</span></li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-[#F3A2A7]"></div>

  <section id="details" class="py-16 lg:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
        <div class="relative group bg-white rounded-3xl overflow-hidden h-full min-h-[420px] lg:min-h-[520px]">
          <img src="/img/services/B12.jpg" alt="B12 Energy Injection" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
        </div>
        <div class="min-h-[420px] lg:min-h-[520px] flex">
          <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-3xl p-8 lg:p-10 h-full flex-1">
            <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-6" data-i18n="b12energy.details.title">B12 Energy Injection</h2>
            <div class="prose prose-lg text-gray-700 leading-relaxed">
              <p class="mb-4" data-i18n="b12energy.details.p1">A quick intramuscular vitamin B12 shot to support <strong>energy, mood and focus</strong> throughout the day.</p>
              <p class="mb-4" data-i18n="b12energy.details.p2">Commonly paired with wellness plans or metabolism boosters.</p>
              <p data-i18n="b12energy.details.p3">Results can be felt quickly; minimal downtime.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-i18n="b12energy.benefits.title">Treatment Benefits</h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto" data-i18n="b12energy.benefits.subtitle">What B12 Energy Injection can do for you</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3" data-i18n="b12energy.benefits.items.0.title">Energy Boost</h3><p class="text-gray-700" data-i18n="b12energy.benefits.items.0.text">Supports natural daily energy.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3" data-i18n="b12energy.benefits.items.1.title">Mood & Focus</h3><p class="text-gray-700" data-i18n="b12energy.benefits.items.1.text">Helps clarity and balanced mood.</p></div>
        <div class="group rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-xl text-gray-900 mb-3" data-i18n="b12energy.benefits.items.2.title">Convenient</h3><p class="text-gray-700" data-i18n="b12energy.benefits.items.2.text">Quick application; minimal downtime.</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <div class="flex items-center justify-center mb-6"><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div><span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" /></svg></span><div class="flex-1 h-[2px] bg-[#F3A2A7]"></div></div>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-i18n="b12energy.process.title">Treatment Process</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto" data-i18n="b12energy.process.subtitle">Consultation, quick injection and optional follow‑up schedule</p>
      </div>
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-[#F3A2A7] via-pink-400 to-purple-500 rounded-full opacity-30 hidden lg:block"></div>
        <div class="space-y-12">
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-primary/10 to-pink-500/10 rounded-2xl p-6 border border-primary/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-primary to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">1</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="b12energy.process.steps.0.title">Consultation</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="b12energy.process.steps.0.text">Suitability, goals and schedule.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Consultation" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row-reverse items-center gap-8"><div class="lg:w-1/2 lg:pl-8"><div class="bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-2xl p-6 border border-purple-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold mr-4">2</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="b12energy.process.steps.1.title">Injection</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="b12energy.process.steps.1.text">Quick intramuscular application.</p></div></div><div class="lg:w-1/2 lg:pr-8"><img src="/img/services/inyeccion-botox.jpg" alt="Injection" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
          <div class="flex flex-col lg:flex-row items-center gap-8"><div class="lg:w-1/2 lg:pr-8"><div class="bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-2xl p-6 border border-emerald-500/20"><div class="flex items-center mb-4"><div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold mr-4">3</div><h3 class="font-display font-bold text-xl text-gray-900" data-i18n="b12energy.process.steps.2.title">Follow‑up</h3></div><p class="text-gray-600 leading-relaxed" data-i18n="b12energy.process.steps.2.text">Optional weekly/biweekly schedule.</p></div></div><div class="lg:w-1/2 lg:pl-8"><img src="/images/med-spa-room.jpg" alt="Follow-up" class="w-full h-64 object-cover rounded-2xl" loading="lazy" /></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#F3A2A7] mb-4" data-i18n="b12energy.faq.title">Frequently Asked Questions</h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto" data-i18n="b12energy.faq.subtitle">Common questions about B12 injections</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3" data-i18n="b12energy.faq.items.0.q">How often?</h3><p class="text-gray-700 leading-relaxed" data-i18n="b12energy.faq.items.0.a">Weekly or biweekly depending on goals; personalized schedule.</p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3" data-i18n="b12energy.faq.items.1.q">Is it natural?</h3><p class="text-gray-700 leading-relaxed" data-i18n="b12energy.faq.items.1.a">Supports your body with essential vitamin B12.</p></div>
        <div class="rounded-2xl p-6 border-2 border-[#F3A2A7] bg-white text-gray-900 hover:ring-2 hover:ring-[#F3A2A7]/60"><h3 class="font-display font-bold text-lg text-gray-900 mb-3" data-i18n="b12energy.faq.items.2.q">Downtime?</h3><p class="text-gray-700 leading-relaxed" data-i18n="b12energy.faq.items.2.a">Minimal; return to normal activities immediately.</p></div>
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>
