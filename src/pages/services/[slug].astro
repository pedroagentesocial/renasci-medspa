---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { getServicioUnificadoBySlug, serviciosUnificados, categoriasUnificadas } from '../../data/services-unified';

export async function getStaticPaths() {
  const paths: Array<{
    params: { slug: string };
    props: { servicio: any; categoria: any };
  }> = [];
  
  const staticSlugs = new Set([
    'tox-neurotoxina',
    'botox-no-sweat',
    'botox-lip-flip',
    'mini-aumento-labios',
    'aumento-completo-labios',
    'mega-aumento-labios',
    'mini-lip-enhancement',
    'full-lip-augmentation',
    'mega-lip-augmentation',
    'personalized-facial-contour',
    'cheekbone-lift',
    'no-more-bags-injection',
    'rollbella',
    'bananaroll',
    'puppet-lines-injections',
    'nefertiti-neck-lift',
    'brazilian-butt-lift',
    'chinbella',
    'xeomin',
    'dysport',
    'botox-trap',
    'migraine-botox',
    'collagen-stimulation-sculptra',
    'mega-collagen-stimulation-sculptra',
    'mini-chin-reduction',
    'renasci-prf-gel-therapy',
    'b12-energy-injection',
    'fat-blaster-injections',
    'b12-fat-blaster-double-effect',
    'alternative-medicine-consultation',
    'medically-supervised-weight-loss',
    'ozempic-mounjaro',
    'ozone-therapy',
    'exosomes',
    'hair-restoration-prp',
    'hair-restoration-stem-cells',
    'vaginal-rejuvenation-prp',
    'vaginal-rejuvenation-stem-cells',
    'cortisone-injection',
    'cystic-acne',
    'microneedling-face-neck',
    'microneedling-face-neck-decollete',
    'microneedling-stretch-marks',
    'prp-face-neck',
    'prp-face-neck-decollete',
    'prp-stretch-marks',
    'bhrt-setup-labs-consult',
    'bhrt-monthly-support',
    'hormone-replacement-therapy-him',
    'lab-draw',
    'peptides-bpc-157',
    'peptides-cjc1295-ipamorelin',
    'peptides-sermorelin',
    'peptides-nad',
    'peptides-ghku',
    'peptides-vitamin-d',
    'peptides-hair-growth',
    'peptides-take-home',
    'iv-drips',
    'im-injections'
  ]);

  categoriasUnificadas.forEach(categoria => {
    categoria.servicios.forEach((servicio: any) => {
      if (!staticSlugs.has(servicio.slug)) {
        paths.push({
          params: { slug: servicio.slug },
          props: { servicio, categoria }
        });
        const aliases = [
          `${servicio.slug}-treatment`
        ];
        aliases.forEach((alias) => {
          paths.push({
            params: { slug: alias },
            props: { servicio, categoria }
          });
        });
      }
    });
  });
  
  return paths;
}

const { slug } = Astro.params;
const { servicio, categoria } = Astro.props;

if (!servicio) {
  return Astro.redirect('/services');
}

// Servicios relacionados (misma categoría, excluyendo el actual)
const serviciosRelacionados = categoria.servicios
  .filter((s: any) => s.slug !== servicio.slug)
  .slice(0, 3);
---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
