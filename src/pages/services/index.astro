---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTAButton from '../../components/CTAButton.astro';
import { serviciosUnificados, categoriasUnificadas } from '../../data/services-unified';
---

<BaseLayout 
  title="Servicios - Renasci Medical Spa"
  description="Descubre todos nuestros tratamientos estéticos: Botox, rellenos, sculptra, contorno facial y más. Encuentra el tratamiento perfecto para ti."
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <!-- Background Image -->
    <img 
      src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
      alt="Professional medical spa services"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/45"></div>
    
    <!-- Content -->
    <div class="relative z-10 px-6 max-w-4xl mx-auto">
      <h1 class="font-display font-bold text-4xl md:text-6xl text-white mb-6 text-shadow-lg">
        Nuestros <span class="text-primary">Servicios</span>
      </h1>
      
      <p class="text-lg md:text-xl text-white/90 mb-8 leading-relaxed text-shadow max-w-3xl mx-auto">
        Explora nuestra amplia gama de tratamientos estéticos diseñados para realzar tu belleza natural. 
        Cada servicio está respaldado por la más alta tecnología y años de experiencia.
      </p>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="#servicios"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#E94594] text-white rounded-2xl font-semibold text-lg transition-all duration-200 hover:opacity-90 hover:-translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
        >
          Explorar Servicios
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
        
        <a 
          href="tel:+13855550123"
          class="call-hero-button inline-flex items-center gap-3 px-8 py-4 bg-[#10B981] text-white rounded-2xl font-semibold text-lg transition-all duration-200 hover:opacity-90 hover:-translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#10B981]/50 animate-pulse-soft"
          aria-label="Llamar Renasci"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          (385) 555-0123
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="servicios" class="py-16 lg:py-24 bg-background">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Filtros rápidos -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <button 
          class="filter-btn active px-4 md:px-6 py-3 rounded-full border-2 border-primary bg-primary text-white font-medium smooth-transition hover:shadow-card min-h-[44px]"
          data-filter="all"
        >
          Todos
        </button>
        <button 
          class="filter-btn px-4 md:px-6 py-3 rounded-full border-2 border-gray-200 bg-white text-text/70 font-medium smooth-transition hover:border-primary hover:text-primary min-h-[44px]"
          data-filter="popular"
        >
          Más Populares
        </button>
        <button 
          class="filter-btn px-4 md:px-6 py-3 rounded-full border-2 border-gray-200 bg-white text-text/70 font-medium smooth-transition hover:border-primary hover:text-primary min-h-[44px]"
          data-filter="facial"
        >
          Faciales
        </button>
        <button 
          class="filter-btn px-4 md:px-6 py-3 rounded-full border-2 border-gray-200 bg-white text-text/70 font-medium smooth-transition hover:border-primary hover:text-primary min-h-[44px]"
          data-filter="body"
        >
          Corporales
        </button>
      </div>

  <!-- Servicios por Categorías -->
  <section class="py-12 sm:py-16 lg:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {categoriasUnificadas.map((categoria, index) => (
        <div class="mb-16 lg:mb-20 last:mb-0" data-category={categoria.slug}>
          <!-- Header de categoría -->
          <div class="text-center mb-12">
            <h2 class="font-display font-bold text-2xl md:text-3xl lg:text-4xl text-dark mb-4 tracking-tight">
              {categoria.nombre.es}
            </h2>
            <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
          </div>
          
          <!-- Grid de servicios -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
            {categoria.servicios.map((servicio) => (
              <ServiceCard 
                service={servicio} 
                class="service-item"
                data-tags={`${categoria.slug} ${servicio.slug}`}
              />
            ))}
          </div>
          
          <!-- Separador -->
          {index < categoriasUnificadas.length - 1 && (
            <div class="border-t border-gray-100 pt-8"></div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 sm:py-16 lg:py-20 bg-soft">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display font-bold text-2xl md:text-3xl lg:text-4xl text-dark mb-6 tracking-tight">
          ¿No encuentras lo que buscas?
        </h2>
        
        <p class="text-base md:text-lg text-graytxt mb-8 leading-relaxed">
          Nuestro equipo de especialistas está aquí para ayudarte a encontrar el tratamiento perfecto 
          para tus necesidades específicas.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <CTAButton 
            href="#agendar" 
            variant="primary" 
            size="lg"
            class="min-h-[44px] px-4 md:px-6"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Agendar Consulta
          </CTAButton>
          
          <CTAButton 
            href="tel:+1234567890" 
            variant="outline" 
            size="lg"
            class="min-h-[44px] px-4 md:px-6"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Llamar Ahora
          </CTAButton>
        </div>
      </div>
    </div>
  </section>

  <!-- Contacto/Agendar -->
  <section id="agendar" class="py-12 sm:py-16 lg:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-display font-bold text-2xl md:text-3xl lg:text-4xl text-dark mb-4 tracking-tight">
            Agenda tu Consulta
          </h2>
          <p class="text-base md:text-lg text-graytxt leading-relaxed">
            Completa el formulario y nos pondremos en contacto contigo
          </p>
        </div>
        
        <!-- Formulario de contacto -->
        <div class="bg-soft rounded-2xl p-8">
          <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="nombre" class="block text-sm font-semibold text-dark mb-2">Nombre Completo</label>
                <input 
                  type="text" 
                  id="nombre" 
                  name="nombre"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors min-h-[44px]"
                  required
                />
              </div>
              <div>
                <label for="telefono" class="block text-sm font-semibold text-dark mb-2">Teléfono</label>
                <input 
                  type="tel" 
                  id="telefono" 
                  name="telefono"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors min-h-[44px]"
                  required
                />
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-semibold text-dark mb-2">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors min-h-[44px]"
                required
              />
            </div>
            
            <div>
              <label for="servicio" class="block text-sm font-semibold text-dark mb-2">Servicio de Interés</label>
              <select 
                id="servicio" 
                name="servicio"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors min-h-[44px]"
              >
                <option value="">Selecciona un servicio</option>
                {categoriasUnificadas.map((categoria) => (
                  <optgroup label={categoria.nombre.es}>
                    {categoria.servicios.map((servicio) => (
                      <option value={servicio.slug}>{servicio.title.es}</option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </div>
            
            <div>
              <label for="mensaje" class="block text-sm font-semibold text-dark mb-2">Mensaje Adicional</label>
              <textarea 
                id="mensaje" 
                name="mensaje"
                rows="4"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors resize-none"
                placeholder="Cuéntanos sobre tus objetivos, experiencias previas o cualquier pregunta específica..."
              ></textarea>
            </div>
            
            <CTAButton 
              type="submit"
              variant="primary" 
              size="lg"
              class="w-full min-h-[44px] px-4 md:px-6"
            >
              Enviar Solicitud de Consulta
            </CTAButton>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Flotante Móvil -->
  <a 
    href="#agendar" 
    class="fixed bottom-4 right-4 z-50 md:hidden bg-primary text-white px-5 py-3 rounded-2xl shadow-card min-h-[44px] flex items-center justify-center font-medium"
  >
    Agendar
  </a>
</BaseLayout>

<script>
  // Ripple effect for hero call button
  function initHeroCallButtonRipple() {
    const heroCallButton = document.querySelector('.call-hero-button') as HTMLElement;
    if (!heroCallButton) return;

    heroCallButton.addEventListener('pointerdown', function(this: HTMLElement, e: PointerEvent) {
      const rect = this.getBoundingClientRect();
      const size = Math.max(rect.width, rect.height);
      const x = e.clientX - rect.left - size / 2;
      const y = e.clientY - rect.top - size / 2;
      
      const ripple = document.createElement('span');
      ripple.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        left: ${x}px;
        top: ${y}px;
        background: rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        transform: scale(0);
        animation: ripple 0.6s ease-out;
        pointer-events: none;
      `;
      
      this.appendChild(ripple);
      
      setTimeout(() => {
        ripple.remove();
      }, 600);
    });
  }

  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', initHeroCallButtonRipple);
</script>

<style>
  @keyframes ripple {
    to {
      transform: scale(2);
      opacity: 0;
    }
  }

  @keyframes pulse-soft {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
    }
  }

  .animate-pulse-soft {
    animation: pulse-soft 2s infinite;
  }

  /* Micro-interactions */
  .link-underline {
    position: relative;
  }

  .link-underline::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -2px;
    left: 0;
    background-color: currentColor;
    transition: width 200ms ease-out;
  }

  .link-underline:hover::after {
    width: 100%;
  }

  .smooth-transition {
    transition: all 180ms ease-out;
  }

  .card-hover {
    transition: all 200ms ease-out;
  }

  .card-hover:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .btn-hover {
    transition: all 200ms ease-out;
  }

  .btn-hover:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
</style>

<script>
  // Filtrado de servicios
  function setupServiceFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const serviceItems = document.querySelectorAll('.service-item');
    
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        
        // Actualizar botones activos
        filterButtons.forEach(btn => {
          btn.classList.remove('active', 'bg-primary', 'text-white');
          btn.classList.add('bg-white', 'text-graytxt', 'border-gray-200');
        });
        
        button.classList.add('active', 'bg-primary', 'text-white');
        button.classList.remove('bg-white', 'text-graytxt', 'border-gray-200');
        
        // Filtrar servicios
        serviceItems.forEach(item => {
          const tags = item.getAttribute('data-tags') || '';
          
          if (filter === 'all') {
            item.style.display = 'block';
            item.classList.remove('hidden');
          } else if (filter === 'popular') {
            // Mostrar servicios populares (puedes definir cuáles son)
            const popularServices = ['tox-neurotoxina', 'sculptra-colageno', 'relleno-labios', 'cheekbone-pop'];
            const isPopular = popularServices.some(service => tags.includes(service));
            
            if (isPopular) {
              item.style.display = 'block';
              item.classList.remove('hidden');
            } else {
              item.style.display = 'none';
              item.classList.add('hidden');
            }
          } else if (filter === 'facial') {
            // Servicios faciales
            const facialCategories = ['inyecciones-neurotoxinas', 'contorno-facial-corporal', 'sculptra-y-rellenos', 'especializados'];
            const isFacial = facialCategories.some(cat => tags.includes(cat));
            
            if (isFacial) {
              item.style.display = 'block';
              item.classList.remove('hidden');
            } else {
              item.style.display = 'none';
              item.classList.add('hidden');
            }
          } else if (filter === 'body') {
            // Servicios corporales
            const bodyCategories = ['peso-bienestar', 'avanzados-corporales'];
            const isBody = bodyCategories.some(cat => tags.includes(cat)) || tags.includes('bella');
            
            if (isBody) {
              item.style.display = 'block';
              item.classList.remove('hidden');
            } else {
              item.style.display = 'none';
              item.classList.add('hidden');
            }
          }
        });
        
        // Animación suave
        serviceItems.forEach((item, index) => {
          if (!item.classList.contains('hidden')) {
            setTimeout(() => {
              item.style.opacity = '0';
              item.style.transform = 'translateY(20px)';
              
              setTimeout(() => {
                item.style.opacity = '1';
                item.style.transform = 'translateY(0)';
              }, 50);
            }, index * 50);
          }
        });
      });
    });
  }
  
  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', setupServiceFilters);
  
  // Re-inicializar si se cargan nuevos servicios dinámicamente
  document.addEventListener('astro:page-load', setupServiceFilters);
</script>

<style>
  .service-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  .filter-btn {
    transition: all 0.3s ease;
  }
  
  .filter-btn:hover {
    transform: translateY(-2px);
  }
  
  .filter-btn.active {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(233, 69, 148, 0.3);
  }
</style>