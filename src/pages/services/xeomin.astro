---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransformCTA from '../../components/TransformCTA.astro';
import MembershipCTA from '../../components/MembershipCTA.astro';

// Datos específicos del servicio
const servicio = {
  id: 'xeomin',
  slug: 'xeomin',
  title: { es: 'Xeomin', en: 'Xeomin' },
  description: { es: 'Neurotoxina pura sin proteínas complejas para resultados precisos y naturales en el tratamiento de arrugas y líneas de expresión.', en: 'Pure neurotoxin without complex proteins for precise and natural results in treating wrinkles and expression lines.' },
  excerpt: { es: 'Neurotoxina pura para resultados precisos y naturales.', en: 'Pure neurotoxin for precise and natural results.' },
  category: 'inyecciones-neurotoxinas',
  precio: 'Por definir',
  image: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400&h=300&fit=crop&crop=center',
  benefits: ['Neurotoxina pura', 'Sin proteínas complejas', 'Resultados naturales', 'Menor riesgo de resistencia'],
  duracion: '30 minutos',
  image: '/img/services/Xeomin-botox.jpg.webp'
};

---

<BaseLayout 
  title={`${servicio.title.es} - Renasci Medical Spa`}
  description={`${servicio.excerpt.es} Precio: ${servicio.precio}. Agenda tu cita en Renasci Medical Spa y descubre los beneficios de este tratamiento.`}
>
  <section class="pt-24 pb-16 md:pt-32 bg-black text-white text-center">
    <div class="px-6 max-w-4xl mx-auto mt-0 md:mt-4">
      <div class="inline-block bg-gradient-to-r from-primary/30 to-pink-500/30 backdrop-blur-sm text-white px-6 py-3 rounded-full text-sm font-semibold mb-6 border border-white/30">Inyecciones de Neurotoxina</div>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white mb-4">{servicio.title.es}</h1>
      <p class="text-lg md:text-xl text-white/80 mb-6 leading-relaxed max-w-3xl mx-auto">{servicio.description.es}</p>
      <div class="inline-flex gap-4 mb-6 justify-center items-center">
        <div class="bg-white/10 rounded-2xl p-6 inline-block border border-white/20 text-center">
          <div class="text-sm text-white/80 mb-1">Starting at</div>
          <div class="font-display font-bold text-2xl md:text-3xl bg-gradient-to-r from-primary to-pink-400 bg-clip-text text-transparent">$11/unit</div>
          <div class="text-sm text-white/80 mt-1">Duración: {servicio.duracion.replace(' minutos',' min')}</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 inline-block border-2 border-[#1DD1A1] hover:border-[#22E9AB] hover:ring-2 hover:ring-[#1DD1A1] hover:shadow-[0_0_32px_rgba(29,209,161,0.35)] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#1DD1A1]/20 text-white text-xs font-semibold mb-3 border border-[#1DD1A1]/40"><span class="w-2 h-2 rounded-full bg-[#1DD1A1]"></span>Renasci Vital</div>
          <div class="text-sm text-white/80 mb-1">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-call">20% OFF</div>
          <div class="text-sm text-white/80 mt-1">Now $8.80/unit</div>
        </div>
        <div class="bg-white/10 rounded-2xl p-6 inline-block border-2 border-[#C8A08C] hover:border-[#D9B9A0] hover:ring-2 hover:ring-[#C8A08C] hover:shadow-[0_0_32px_rgba(200,160,140,0.35)] transition-all duration-200">
          <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-[#C8A08C]/20 text-white text-xs font-semibold mb-3 border border-[#C8A08C]/40"><span class="w-2 h-2 rounded-full bg-[#C8A08C]"></span>Premier</div>
          <div class="text-sm text-white/80 mb-1">Members</div>
          <div class="font-display font-bold text-2xl md:text-3xl text-logo">30% OFF</div>
          <div class="text-sm text-white/80 mt-1">Now $7.70/unit</div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-6">
        <a href="#details" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary to-pink-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50">Ver Detalles<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg></a>
        <a href="tel:+13855550123" class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-call to-emerald-500 text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:opacity-90 hover:-translate-y-[2px] focus:outline-none focus-visible:ring-2 focus-visible:ring-call/50" aria-label="Llamar Renasci"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>(385) 555-0123</a>
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-sm font-semibold mt-4 mx-auto w-fit whitespace-nowrap"><span class="w-2.5 h-2.5 rounded-full bg-primary"></span>Included in Membership Plans<a href="/membership" class="underline underline-offset-2 hover:text-white ml-2">See Memberships</a></div>
    </div>
  </section>

  <nav class="bg-background py-6">
    <div class="container mx-auto px-6">
      <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-primary transition-colors">Inicio</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/services" class="hover:text-primary transition-colors">Servicios</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">{servicio.title.es}</li>
      </ol>
    </div>
  </nav>
  <div class="h-[2px] w-full bg-primary"></div>

  <!-- Detalles del Servicio -->
  <section id="detalles" class="py-20 bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Información del Servicio -->
        <div class="space-y-8">
          <div class="bg-white rounded-3xl p-8 shadow-xl border border-pink-100">
            <h3 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
              <span class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-3 rounded-full mr-4">
                🌟
              </span>
              Beneficios
            </h3>
            
            <div class="grid gap-4">
              {servicio.benefits.map((benefit, index) => (
                <div class="flex items-center p-4 bg-gradient-to-r from-pink-50 to-purple-50 rounded-xl transform hover:scale-105 transition-all duration-300">
                  <div class="bg-gradient-to-r from-pink-500 to-purple-600 text-white p-2 rounded-full mr-4 flex-shrink-0">
                    ✓
                  </div>
                  <span class="text-gray-700 font-medium">{benefit}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Imagen del Servicio -->
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-pink-400/20 to-purple-600/20 rounded-3xl transform rotate-3"></div>
          <img 
            src={servicio.image}
            alt={servicio.title.es}
            class="relative w-full h-96 object-cover rounded-3xl shadow-2xl transform -rotate-1 hover:rotate-0 transition-transform duration-500"
            loading="lazy"
          />
          
          <!-- Floating Card -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-6 shadow-xl border border-pink-100 transform hover:scale-105 transition-all duration-300">
            <div class="text-center">
              <div class="text-2xl font-bold text-pink-600 mb-1">{servicio.precio}</div>
              <div class="text-sm text-gray-600">Precio del tratamiento</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Proceso del <span class="text-pink-600">Tratamiento</span>
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Conoce paso a paso cómo realizamos este tratamiento especializado
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            1
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Consulta Inicial</h3>
          <p class="text-gray-600">Evaluamos tu piel y determinamos el plan de tratamiento personalizado con Xeomin.</p>
        </div>
        
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            2
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Aplicación Precisa</h3>
          <p class="text-gray-600">Inyectamos Xeomin en las áreas específicas con técnica avanzada para resultados óptimos.</p>
        </div>
        
        <div class="text-center group">
          <div class="bg-gradient-to-br from-pink-500 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            3
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">Seguimiento</h3>
          <p class="text-gray-600">Monitoreamos tu progreso y ajustamos el tratamiento según sea necesario.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gradient-to-br from-gray-50 to-pink-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Preguntas <span class="text-pink-600">Frecuentes</span>
        </h2>
        <p class="text-xl text-gray-600">
          Resolvemos tus dudas sobre el tratamiento con Xeomin
        </p>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Qué hace diferente a Xeomin de otras neurotoxinas?</h3>
          <p class="text-gray-600">Xeomin es una neurotoxina pura sin proteínas complejas, lo que reduce el riesgo de desarrollar resistencia al tratamiento y proporciona resultados más consistentes.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Cuánto duran los resultados?</h3>
          <p class="text-gray-600">Los efectos de Xeomin típicamente duran entre 3-4 meses, similar a otras neurotoxinas, pero algunos pacientes experimentan resultados más duraderos.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-pink-100">
          <h3 class="text-lg font-bold text-gray-800 mb-3">¿Es seguro el tratamiento con Xeomin?</h3>
          <p class="text-gray-600">Sí, Xeomin está aprobado por la FDA y tiene un excelente perfil de seguridad cuando es administrado por profesionales calificados.</p>
        </div>
      </div>
    </div>
  </section>

  <MembershipCTA />
  <TransformCTA />
</BaseLayout>
