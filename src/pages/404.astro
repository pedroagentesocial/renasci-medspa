---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada - Renasci Medical Spa"
  description="La página que buscas no existe. Regresa al inicio y descubre nuestros tratamientos estéticos en Renasci Medical Spa."
  seoTitle="404 - Página no encontrada | Renasci Medical Spa"
>
  <section class="relative min-h-[78vh] flex items-center justify-center overflow-hidden">
    <img
      src="/img/about.jpg"
      alt="Renasci Medical Spa"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center text-white">
      <p class="font-display font-bold text-7xl md:text-9xl text-[#F3A2A7] leading-none mb-2 animate-[pulse-gentle_3s_ease-in-out_infinite]">404</p>
      <p class="text-xs uppercase tracking-[0.18em] text-white/80 font-semibold mb-6" data-t-es="Página No Encontrada" data-t-en="Page Not Found">Página No Encontrada</p>

      <h1 class="font-display font-bold text-3xl md:text-5xl leading-tight mb-5" data-t-es="Esta ruta se perdió en el spa" data-t-en="This page got lost on its way to the spa">Esta ruta se perdió en el spa</h1>

      <p class="text-base md:text-lg text-white/90 max-w-xl mx-auto mb-8" data-t-es="La página que buscas no existe o fue movida. Te invitamos a regresar al inicio o explorar nuestros tratamientos estéticos personalizados." data-t-en="The page you're looking for doesn't exist or has been moved. Head back home or explore our personalized aesthetic treatments.">La página que buscas no existe o fue movida. Te invitamos a regresar al inicio o explorar nuestros tratamientos estéticos personalizados.</p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-7 py-3 rounded-full hover:brightness-105 transition" data-t-es="Volver al Inicio" data-t-en="Back to Home">Volver al Inicio</a>
        <a href="/services" class="inline-flex items-center justify-center border-2 border-white/80 bg-white/10 text-white font-semibold px-7 py-3 rounded-full hover:bg-white/20 transition" data-t-es="Ver Servicios" data-t-en="View Services">Ver Servicios</a>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-10">
        <p class="text-xs uppercase tracking-[0.16em] text-[#AABFA8] font-semibold mb-2" data-t-es="Tal Vez Te Interese" data-t-en="You Might Be Looking For">Tal Vez Te Interese</p>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#C69C87]" data-t-es="Tratamientos destacados" data-t-en="Featured Treatments">Tratamientos destacados</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
        <a href="/services/neurotoxin-injections" class="group block rounded-2xl border border-gray-200 p-6 hover:border-[#F3A2A7] hover:shadow-card-hover transition">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-1" data-t-es="Neurotoxinas" data-t-en="Neurotoxins">Neurotoxinas</h3>
          <p class="text-sm text-gray-600 mb-3" data-t-es="Suaviza líneas de expresión con resultados naturales." data-t-en="Soften expression lines with natural-looking results.">Suaviza líneas de expresión con resultados naturales.</p>
          <span class="text-sm font-semibold text-[#F3A2A7] group-hover:underline" data-t-es="Ver Detalles →" data-t-en="View Details →">Ver Detalles →</span>
        </a>

        <a href="/services/dermal-fillers" class="group block rounded-2xl border border-gray-200 p-6 hover:border-[#F3A2A7] hover:shadow-card-hover transition">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-1" data-t-es="Rellenos Dérmicos" data-t-en="Dermal Fillers">Rellenos Dérmicos</h3>
          <p class="text-sm text-gray-600 mb-3" data-t-es="Volumen y contorno con productos de alta calidad." data-t-en="Volume and contour with high-quality products.">Volumen y contorno con productos de alta calidad.</p>
          <span class="text-sm font-semibold text-[#F3A2A7] group-hover:underline" data-t-es="Ver Detalles →" data-t-en="View Details →">Ver Detalles →</span>
        </a>

        <a href="/services/iv-therapy" class="group block rounded-2xl border border-gray-200 p-6 hover:border-[#F3A2A7] hover:shadow-card-hover transition">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-1" data-t-es="Terapia IV" data-t-en="IV Therapy">Terapia IV</h3>
          <p class="text-sm text-gray-600 mb-3" data-t-es="Hidratación, energía y recuperación a nivel celular." data-t-en="Hydration, energy, and recovery at the cellular level.">Hidratación, energía y recuperación a nivel celular.</p>
          <span class="text-sm font-semibold text-[#F3A2A7] group-hover:underline" data-t-es="Ver Detalles →" data-t-en="View Details →">Ver Detalles →</span>
        </a>

        <a href="/services/medically-supervised-weight-loss" class="group block rounded-2xl border border-gray-200 p-6 hover:border-[#F3A2A7] hover:shadow-card-hover transition">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-1" data-t-es="Pérdida de Peso" data-t-en="Weight Loss">Pérdida de Peso</h3>
          <p class="text-sm text-gray-600 mb-3" data-t-es="Programas médicamente supervisados con resultados sostenibles." data-t-en="Medically supervised programs with sustainable results.">Programas médicamente supervisados con resultados sostenibles.</p>
          <span class="text-sm font-semibold text-[#F3A2A7] group-hover:underline" data-t-es="Ver Detalles →" data-t-en="View Details →">Ver Detalles →</span>
        </a>

        <a href="/services/therapy-peptide" class="group block rounded-2xl border border-gray-200 p-6 hover:border-[#F3A2A7] hover:shadow-card-hover transition">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-1" data-t-es="Terapia con Péptidos" data-t-en="Peptide Therapy">Terapia con Péptidos</h3>
          <p class="text-sm text-gray-600 mb-3" data-t-es="Energía, recuperación y bienestar hormonal personalizado." data-t-en="Energy, recovery, and personalized hormonal wellness.">Energía, recuperación y bienestar hormonal personalizado.</p>
          <span class="text-sm font-semibold text-[#F3A2A7] group-hover:underline" data-t-es="Ver Detalles →" data-t-en="View Details →">Ver Detalles →</span>
        </a>

        <a href="/membership" class="group block rounded-2xl border border-gray-200 p-6 hover:border-[#F3A2A7] hover:shadow-card-hover transition">
          <h3 class="font-display font-bold text-lg text-gray-900 mb-1" data-t-es="Membresía" data-t-en="Membership">Membresía</h3>
          <p class="text-sm text-gray-600 mb-3" data-t-es="Beneficios exclusivos y acceso prioritario a tratamientos." data-t-en="Exclusive benefits and priority access to treatments.">Beneficios exclusivos y acceso prioritario a tratamientos.</p>
          <span class="text-sm font-semibold text-[#F3A2A7] group-hover:underline" data-t-es="Ver Detalles →" data-t-en="View Details →">Ver Detalles →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="py-14 bg-[#DDEAF6]">
    <div class="container mx-auto px-6 text-center">
      <h2 class="font-display font-bold text-2xl lg:text-3xl text-[#2F4E6F] mb-2" data-t-es="¿Necesitas ayuda?" data-t-en="Need help?">¿Necesitas ayuda?</h2>
      <p class="text-[#2F4E6F]/80 mb-6" data-t-es="Estamos para guiarte en tu próximo paso." data-t-en="We're here to guide your next step.">Estamos para guiarte en tu próximo paso.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="tel:+13856092840" class="inline-flex items-center justify-center bg-[#AABFA8] text-white font-semibold px-6 py-3 rounded-full hover:brightness-105 transition" data-t-es="Llamar (385) 609-2840" data-t-en="Call (385) 609-2840">Llamar (385) 609-2840</a>
        <a href="/contact" class="inline-flex items-center justify-center border-2 border-[#2F4E6F] text-[#2F4E6F] font-semibold px-6 py-3 rounded-full hover:bg-[#2F4E6F] hover:text-white transition" data-t-es="Ir a Contacto" data-t-en="Go to Contact">Ir a Contacto</a>
      </div>
    </div>
  </section>
</BaseLayout>

