---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { t } from '../i18n/config';
import { dict } from '../i18n/dict';
import { getLocaleFromUrl } from '../i18n/config';

const currentLocale = getLocaleFromUrl(Astro.url);

const title = t(currentLocale, "pages.server_error", dict);
const description = currentLocale === "es" 
  ? "Error interno del servidor. Nuestro equipo está trabajando para solucionarlo."
  : "Internal server error. Our team is working to fix it.";
---

<BaseLayout 
  title={title}
  description={description}
  seoTitle={`500 - ${title} | Renasci Medical Spa`}
  seoDescription={description}
  lang={currentLocale}
>
  <div class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="max-w-md mx-auto text-center">
      <!-- 500 Illustration -->
      <div class="mb-8">
        <div class="text-8xl font-bold text-primary/20 mb-4">500</div>
        <div class="w-24 h-24 mx-auto bg-soft rounded-full flex items-center justify-center">
          <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
      </div>

      <!-- Content -->
      <div class="space-y-4 mb-8">
        <h1 class="text-2xl font-heading font-bold text-dark">
          {currentLocale === "es" ? "Error del servidor" : "Server error"}
        </h1>
        
        <p class="text-dark/70 leading-relaxed">
          {currentLocale === "es" 
            ? "Algo salió mal en nuestros servidores. Nuestro equipo técnico ya está trabajando para solucionarlo. Por favor, inténtalo de nuevo en unos minutos."
            : "Something went wrong on our servers. Our technical team is already working to fix it. Please try again in a few minutes."
          }
        </p>
      </div>

      <!-- Actions -->
      <div class="space-y-4">
        <CTAButton 
          href="/"
          variant="primary"
          size="lg"
          className="w-full"
        >
          {t(currentLocale, "cta.back_home", dict)}
        </CTAButton>

        <button 
          onclick="window.location.reload()"
          class="w-full px-6 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white rounded-2xl font-semibold transition-all duration-200 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          aria-label={currentLocale === "es" ? "Recargar página" : "Reload page"}
        >
          {currentLocale === "es" ? "Intentar de nuevo" : "Try again"}
        </button>
      </div>

      <!-- Contact Support -->
      <div class="mt-8 pt-6 border-t border-soft">
        <p class="text-sm text-dark/60 mb-3">
          {currentLocale === "es" ? "¿El problema persiste?" : "Problem persists?"}
        </p>
        
        <div class="space-y-2">
          <p class="text-sm text-dark/70">
            {currentLocale === "es" 
              ? "Contáctanos directamente:"
              : "Contact us directly:"
            }
          </p>
          
          <div class="flex flex-col sm:flex-row justify-center items-center space-y-2 sm:space-y-0 sm:space-x-6 text-sm">
            <a 
              href="tel:+1-000-000-0000" 
              class="text-primary hover:text-primary/80 transition-colors flex items-center space-x-1"
              aria-label={currentLocale === "es" ? "Llamar por teléfono" : "Call by phone"}
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <span>+1 (000) 000-0000</span>
            </a>
            
            <a 
              href="mailto:info@renasci.com" 
              class="text-primary hover:text-primary/80 transition-colors flex items-center space-x-1"
              aria-label={currentLocale === "es" ? "Enviar email" : "Send email"}
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <span>info@renasci.com</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Add subtle animation to the illustration */
  .text-8xl {
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }
  
  /* Ensure proper focus states */
  a:focus-visible,
  button:focus-visible {
    outline: 2px solid #E94594;
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>