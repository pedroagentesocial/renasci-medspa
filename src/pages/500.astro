---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Error del Servidor - Renasci Medical Spa"
  description="Ocurrió un error temporal. Nuestro equipo ya está trabajando para resolverlo. Vuelve a intentarlo en unos minutos."
  seoTitle="500 - Error del Servidor | Renasci Medical Spa"
>
  <section class="relative min-h-[78vh] flex items-center justify-center overflow-hidden">
    <img
      src="/img/about.jpg"
      alt="Renasci Medical Spa"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/65"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center text-white">
      <p class="font-display font-bold text-7xl md:text-9xl text-[#F3A2A7] leading-none mb-2 animate-[pulse-gentle_3s_ease-in-out_infinite]">500</p>
      <p class="text-xs uppercase tracking-[0.18em] text-white/80 font-semibold mb-6" data-t-es="Error del Servidor" data-t-en="Server Error">Error del Servidor</p>

      <h1 class="font-display font-bold text-3xl md:text-5xl leading-tight mb-5" data-t-es="Algo salió mal por aquí" data-t-en="Something went wrong on our end">Algo salió mal por aquí</h1>

      <p class="text-base md:text-lg text-white/90 max-w-xl mx-auto mb-8" data-t-es="Tuvimos un problema temporal. Nuestro equipo ya está trabajando para solucionarlo. Por favor, intenta de nuevo en unos minutos." data-t-en="We had a temporary issue. Our team is already working to fix it. Please try again in a few minutes.">Tuvimos un problema temporal. Nuestro equipo ya está trabajando para solucionarlo. Por favor, intenta de nuevo en unos minutos.</p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <button id="retry-btn" type="button" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-7 py-3 rounded-full hover:brightness-105 transition" data-t-es="Intentar de Nuevo" data-t-en="Try Again">Intentar de Nuevo</button>
        <a href="/" class="inline-flex items-center justify-center border-2 border-white/80 bg-white/10 text-white font-semibold px-7 py-3 rounded-full hover:bg-white/20 transition" data-t-es="Volver al Inicio" data-t-en="Back to Home">Volver al Inicio</a>
      </div>
    </div>
  </section>

  <section class="py-14 lg:py-16 bg-white text-gray-900">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.16em] text-[#AABFA8] font-semibold mb-2" data-t-es="¿El Problema Persiste?" data-t-en="Still Not Working?">¿El Problema Persiste?</p>
        <h2 class="font-display font-bold text-3xl lg:text-4xl text-[#C69C87] mb-4" data-t-es="Estamos para ayudarte" data-t-en="We're here to help">Estamos para ayudarte</h2>
        <p class="text-base text-gray-700 mb-10" data-t-es="Si necesitas asistencia inmediata, contáctanos directamente y con gusto te atendemos." data-t-en="If you need immediate assistance, reach out directly and we'll gladly help.">Si necesitas asistencia inmediata, contáctanos directamente y con gusto te atendemos.</p>

        <div class="grid sm:grid-cols-2 gap-5">
          <a href="tel:+13856092840" class="group flex items-center gap-4 rounded-2xl border border-gray-200 p-5 hover:border-[#F3A2A7] hover:shadow-card-hover transition text-left">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#AABFA8]/15 text-[#AABFA8] flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-0.5" data-t-es="Llámanos" data-t-en="Call Us">Llámanos</p>
              <p class="font-display font-bold text-lg text-gray-900 group-hover:text-[#F3A2A7] transition">(385) 609-2840</p>
            </div>
          </a>

          <a href="mailto:info@renascimedspa.com" class="group flex items-center gap-4 rounded-2xl border border-gray-200 p-5 hover:border-[#F3A2A7] hover:shadow-card-hover transition text-left">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#F3A2A7]/15 text-[#F3A2A7] flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-0.5" data-t-es="Escríbenos" data-t-en="Email Us">Escríbenos</p>
              <p class="font-display font-bold text-lg text-gray-900 group-hover:text-[#F3A2A7] transition">info@renascimedspa.com</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const initRetry = () => {
    const btn = document.getElementById('retry-btn');
    btn?.addEventListener('click', () => window.location.reload());
  };
  document.addEventListener('DOMContentLoaded', initRetry);
  document.addEventListener('astro:page-load', initRetry);
</script>
