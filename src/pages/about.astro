---
import BaseLayout from '../layouts/BaseLayout.astro';
import TransformCTA from '../components/TransformCTA.astro';

const stats = [
  {
    target: 15,
    start: 12,
    suffix: '+',
    label: { es: 'Años de experiencia', en: 'Years of experience' },
  },
  {
    target: 5000,
    start: 4500,
    suffix: '+',
    label: { es: 'Pacientes felices', en: 'Happy patients' },
  },
  {
    target: 98,
    start: 90,
    suffix: '%',
    label: { es: 'Tasa de satisfacción', en: 'Satisfaction rate' },
  },
]

const values = [
  {
    accent: 'pink',
    title: { es: 'Excelencia', en: 'Excellence' },
    text: {
      es: 'Estándares clínicos altos en cada tratamiento, sin atajos ni concesiones.',
      en: 'High clinical standards on every treatment — no shortcuts, no compromises.'
    },
    icon: 'sparkle',
  },
  {
    accent: 'mint',
    title: { es: 'Seguridad', en: 'Safety' },
    text: {
      es: 'Protocolos médicos rigurosos y tecnología certificada en cada paso.',
      en: 'Rigorous medical protocols and certified technology at every step.'
    },
    icon: 'shield',
  },
  {
    accent: 'tan',
    title: { es: 'Personalización', en: 'Personalization' },
    text: {
      es: 'Planes únicos para tus objetivos y tu estilo, respetando tu esencia.',
      en: 'Unique plans for your goals and style, honoring your essence.'
    },
    icon: 'user',
  },
]

const method = [
  {
    accent: 'mint',
    title: { es: 'Atención personalizada', en: 'Personalized care' },
    text: {
      es: 'Plan a tu medida tras una consulta detallada de tus objetivos.',
      en: 'A plan tailored to you after a detailed consultation of your goals.'
    },
    icon: 'compass',
  },
  {
    accent: 'tan',
    title: { es: 'Seguridad médica', en: 'Medical safety' },
    text: {
      es: 'Protocolos clínicos verificados y seguimiento continuo para tu tranquilidad.',
      en: 'Verified clinical protocols and ongoing follow-up for your peace of mind.'
    },
    icon: 'shield',
  },
  {
    accent: 'pink',
    title: { es: 'Tecnología avanzada', en: 'Advanced technology' },
    text: {
      es: 'Equipos y técnicas de última generación para resultados naturales.',
      en: 'State-of-the-art equipment and techniques for natural results.'
    },
    icon: 'spark',
  },
]

const iconPaths: Record<string, string> = {
  sparkle: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z',
  shield: 'M9 12.75 11.25 15 15 9.75M9 4.5h6m-6 0a3 3 0 0 0-3 3v9.75a2.25 2.25 0 0 0 2.25 2.25h7.5a2.25 2.25 0 0 0 2.25-2.25V7.5a3 3 0 0 0-3-3',
  user: 'M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
  compass: 'M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z',
  spark: 'M3.75 13.5 10.5 4.5l3.75 5.25 3-3.75 3 9-3 4.5-13.5-6Z',
}
---

<BaseLayout
  title="Sobre Nosotros - Renasci Medical Spa"
  description="Conoce la historia de Renasci Medical Spa, nuestros valores y el método que respalda cada tratamiento en Salt Lake City."
>
  <!-- HERO Editorial -->
  <section class="about-hero relative flex min-h-[88vh] items-center justify-center overflow-hidden md:min-h-screen">
    <img
      src="/img/about.jpg"
      alt="Renasci Medical Spa"
      class="absolute inset-0 h-full w-full object-cover"
      style="object-position: center 25%;"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/55 to-black/80"></div>

    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="hero-orb absolute -top-24 -left-16 h-80 w-80 rounded-full bg-[#F3A2A7]/15 blur-3xl"></div>
      <div class="hero-orb-delayed absolute -bottom-24 right-1/4 h-96 w-96 rounded-full bg-[#AABFA8]/15 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center text-white">
      <span class="reveal mb-7 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-white/85">
        <span class="h-px w-10 bg-white/45"></span>
        <span data-t-es="Sobre nosotros" data-t-en="About us">Sobre nosotros</span>
        <span class="h-px w-10 bg-white/45"></span>
      </span>

      <h1 class="hero-headline">
        <span
          class="reveal hero-word hero-word-1 font-display font-bold tracking-tight"
          style="--reveal-delay: 80ms;"
          data-t-es="Sobre"
          data-t-en="About"
        >Sobre</span>
        <span
          class="reveal hero-word hero-word-2 font-hero-elmatia text-[#F3A2A7]"
          style="--reveal-delay: 240ms;"
          data-t-es="Renasci"
          data-t-en="Renasci"
        >Renasci</span>
      </h1>

      <p
        class="reveal mx-auto mt-7 max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg md:text-xl"
        style="--reveal-delay: 380ms;"
        data-t-es="Donde la medicina estética avanzada se encuentra con el cuidado personalizado y resultados que respetan tu esencia."
        data-t-en="Where advanced aesthetic medicine meets personalized care and results that honor your essence."
      >Donde la medicina estética avanzada se encuentra con el cuidado personalizado y resultados que respetan tu esencia.</p>

      <div class="reveal mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4" style="--reveal-delay: 520ms;">
        <a
          href="#nuestra-historia"
          class="hero-cta-primary group inline-flex items-center gap-2 rounded-full bg-[#F3A2A7] px-8 py-4 font-semibold text-white shadow-[0_18px_36px_-12px_rgba(243,162,167,0.7)] transition-all duration-300 hover:gap-3 hover:opacity-95"
          style="-webkit-tap-highlight-color: transparent;"
        >
          <span data-t-es="Conoce nuestra historia" data-t-en="Read our story">Conoce nuestra historia</span>
          <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="/contact"
          class="hero-cta-secondary group inline-flex items-center gap-2 rounded-full border border-white/40 bg-white/5 px-8 py-4 font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white hover:bg-white/15"
          style="-webkit-tap-highlight-color: transparent;"
        >
          <span data-t-es="Agenda tu consulta" data-t-en="Book a consultation">Agenda tu consulta</span>
        </a>
      </div>
    </div>

    <a href="#nuestra-historia" class="hero-scroll group absolute bottom-8 left-1/2 -translate-x-1/2 text-white/70 hover:text-white transition-colors" aria-label="Scroll">
      <span class="block text-[10px] font-semibold uppercase tracking-[0.42em] mb-2 text-center" data-t-es="Explorar" data-t-en="Explore">Explorar</span>
      <span class="hero-scroll-arrow mx-auto block h-10 w-[2px] bg-gradient-to-b from-white/0 via-white/70 to-white/0"></span>
    </a>
  </section>

  <!-- HISTORIA -->
  <section id="nuestra-historia" class="about-history relative overflow-hidden bg-white py-20 text-black lg:py-28">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-16 left-1/4 h-72 w-72 rounded-full bg-[#F3A2A7]/10 blur-3xl"></div>
      <div class="absolute -bottom-20 right-1/4 h-80 w-80 rounded-full bg-[#AABFA8]/10 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center lg:mb-16">
        <span class="reveal mb-6 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-[#B76B71]">
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
          <span data-t-es="Desde el día uno" data-t-en="From day one">Desde el día uno</span>
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
        </span>
        <h2 class="section-headline">
          <span
            class="reveal headline-word headline-word-1 font-display font-bold tracking-tight text-black"
            style="--reveal-delay: 80ms;"
            data-t-es="Nuestra"
            data-t-en="Our"
          >Nuestra</span>
          <span
            class="reveal headline-word headline-word-2 font-hero-elmatia text-[#F3A2A7]"
            style="--reveal-delay: 220ms;"
            data-t-es="Historia"
            data-t-en="Story"
          >Historia</span>
        </h2>
      </div>

      <div class="story-content mx-auto max-w-3xl space-y-6">
        <p
          class="reveal text-lg leading-relaxed text-black/80 md:text-xl"
          style="--reveal-delay: 280ms;"
          data-t-es="Renasci Medical Spa nació de una visión: crear un espacio donde la medicina estética de vanguardia se encuentra con el cuidado personalizado y la excelencia en el servicio."
          data-t-en="Renasci Medical Spa was born from a vision: to create a space where cutting-edge aesthetic medicine meets personalized care and service excellence."
        >Renasci Medical Spa nació de una visión: crear un espacio donde la medicina estética de vanguardia se encuentra con el cuidado personalizado y la excelencia en el servicio.</p>
        <p
          class="reveal text-lg leading-relaxed text-black/80 md:text-xl"
          style="--reveal-delay: 380ms;"
          data-t-es="Fundado por profesionales con más de 15 años de experiencia, somos el destino preferido para quienes buscan resultados excepcionales en un ambiente de confianza."
          data-t-en="Founded by professionals with over 15 years of experience, we are the preferred destination for those seeking exceptional results in a trusted environment."
        >Fundado por profesionales con más de 15 años de experiencia, somos el destino preferido para quienes buscan resultados excepcionales en un ambiente de confianza.</p>
        <p
          class="reveal text-lg leading-relaxed text-black/80 md:text-xl"
          style="--reveal-delay: 480ms;"
          data-t-es="Cada tratamiento está respaldado por tecnología de punta y técnicas avanzadas, con un enfoque que respeta tu belleza natural y realza lo que te hace única."
          data-t-en="Every treatment is backed by cutting-edge technology and advanced techniques, with an approach that respects your natural beauty and enhances what makes you unique."
        >Cada tratamiento está respaldado por tecnología de punta y técnicas avanzadas, con un enfoque que respeta tu belleza natural y realza lo que te hace única.</p>
      </div>

      <div class="stats-grid mt-14 grid grid-cols-1 gap-5 sm:grid-cols-3 lg:mt-16 lg:gap-6">
        {stats.map((stat, i) => (
          <div class="reveal stat-card" style={`--reveal-delay: ${600 + i * 120}ms;`}>
            <div class="stat-rule"></div>
            <div class="stat-value">
              <span class="counter" data-target={stat.target} data-start={stat.start}>{stat.target}</span><span class="stat-suffix">{stat.suffix}</span>
            </div>
            <div class="stat-label" data-t-es={stat.label.es} data-t-en={stat.label.en}>{stat.label.es}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALORES -->
  <section class="about-values relative overflow-hidden bg-white py-20 text-black lg:py-24">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-12 right-1/4 h-72 w-72 rounded-full bg-[#1DD1A1]/8 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center lg:mb-16">
        <span class="reveal mb-6 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-[#B76B71]">
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
          <span data-t-es="Lo que nos define" data-t-en="What defines us">Lo que nos define</span>
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
        </span>
        <h2 class="section-headline">
          <span
            class="reveal headline-word headline-word-1 font-display font-bold tracking-tight text-black"
            style="--reveal-delay: 80ms;"
            data-t-es="Nuestros"
            data-t-en="Our"
          >Nuestros</span>
          <span
            class="reveal headline-word headline-word-2 font-hero-elmatia text-[#F3A2A7]"
            style="--reveal-delay: 220ms;"
            data-t-es="Valores"
            data-t-en="Values"
          >Valores</span>
        </h2>
        <p
          class="reveal mx-auto mt-6 max-w-xl text-sm text-black/60 sm:text-base"
          style="--reveal-delay: 360ms;"
          data-t-es="Los principios que guían cada decisión y cada tratamiento."
          data-t-en="The principles that guide every decision and treatment."
        >Los principios que guían cada decisión y cada tratamiento.</p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3 lg:gap-8">
        {values.map((v, i) => (
          <article
            class:list={[
              'about-card reveal group',
              v.accent === 'pink' && 'accent-pink',
              v.accent === 'mint' && 'accent-mint',
              v.accent === 'tan' && 'accent-tan'
            ]}
            style={`--reveal-delay: ${280 + i * 130}ms;`}
          >
            <span class="about-card-mark">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={iconPaths[v.icon]}/>
              </svg>
            </span>
            <h3 class="about-card-title" data-t-es={v.title.es} data-t-en={v.title.en}>{v.title.es}</h3>
            <p class="about-card-text" data-t-es={v.text.es} data-t-en={v.text.en}>{v.text.es}</p>
            <span class="about-card-underline"></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MÉTODO -->
  <section class="about-method relative overflow-hidden bg-gradient-to-b from-white via-[#FDFAFA] to-white py-20 text-black lg:py-24">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-12 left-1/4 h-72 w-72 rounded-full bg-[#F3A2A7]/8 blur-3xl"></div>
      <div class="absolute -bottom-16 right-1/3 h-72 w-72 rounded-full bg-[#AABFA8]/8 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center lg:mb-16">
        <span class="reveal mb-6 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-[#B76B71]">
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
          <span data-t-es="Cómo trabajamos" data-t-en="How we work">Cómo trabajamos</span>
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
        </span>
        <h2 class="section-headline">
          <span
            class="reveal headline-word headline-word-1 font-display font-bold tracking-tight text-black"
            style="--reveal-delay: 80ms;"
            data-t-es="El Método"
            data-t-en="The"
          >El Método</span>
          <span
            class="reveal headline-word headline-word-2 font-hero-elmatia text-[#F3A2A7]"
            style="--reveal-delay: 220ms;"
            data-t-es="Renasci"
            data-t-en="Renasci Method"
          >Renasci</span>
        </h2>
        <p
          class="reveal mx-auto mt-6 max-w-xl text-sm text-black/60 sm:text-base"
          style="--reveal-delay: 360ms;"
          data-t-es="Tres pilares que aseguran tu mejor versión en cada visita."
          data-t-en="Three pillars that ensure your best self at every visit."
        >Tres pilares que aseguran tu mejor versión en cada visita.</p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3 lg:gap-8">
        {method.map((m, i) => (
          <article
            class:list={[
              'about-card reveal group',
              m.accent === 'pink' && 'accent-pink',
              m.accent === 'mint' && 'accent-mint',
              m.accent === 'tan' && 'accent-tan'
            ]}
            style={`--reveal-delay: ${280 + i * 130}ms;`}
          >
            <span class="about-card-mark">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={iconPaths[m.icon]}/>
              </svg>
            </span>
            <h3 class="about-card-title" data-t-es={m.title.es} data-t-en={m.title.en}>{m.title.es}</h3>
            <p class="about-card-text" data-t-es={m.text.es} data-t-en={m.text.en}>{m.text.es}</p>
            <span class="about-card-underline"></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <TransformCTA />
</BaseLayout>

<script>
  type Lang = 'es' | 'en';

  function getAboutLang(): Lang {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang as Lang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang as Lang;
    const managerLang = (window as any).i18nManager?.getCurrentLanguage?.();
    if (managerLang === 'en' || managerLang === 'es') return managerLang as Lang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  }

  function applyAboutLang() {
    const lang = getAboutLang();
    document.querySelectorAll('[data-t-es]').forEach((el) => {
      const node = el as HTMLElement;
      const es = node.getAttribute('data-t-es') || '';
      const en = node.getAttribute('data-t-en') || es;
      node.textContent = lang === 'en' ? en : es;
    });
  }

  document.addEventListener('DOMContentLoaded', applyAboutLang);
  document.addEventListener('astro:page-load', applyAboutLang);
  window.addEventListener('languageChanged', applyAboutLang);

  function initAboutReveal() {
    const targets = document.querySelectorAll(
      '.about-hero .reveal, .about-history .reveal, .about-values .reveal, .about-method .reveal'
    );
    if (!targets.length) return;
    const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      targets.forEach((t) => t.classList.add('is-visible'));
      return;
    }
    document.querySelectorAll('.about-hero .reveal').forEach((t) => t.classList.add('is-visible'));
    const scrollTargets = document.querySelectorAll('.about-history .reveal, .about-values .reveal, .about-method .reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
    scrollTargets.forEach((t) => io.observe(t));
  }
  document.addEventListener('DOMContentLoaded', initAboutReveal);
  document.addEventListener('astro:page-load', initAboutReveal);

  function initAboutCounters() {
    const counters = document.querySelectorAll('#nuestra-historia .counter');
    if (!counters.length) return;
    const animateCounter = (el: Element) => {
      const node = el as HTMLElement;
      const target = parseInt(node.getAttribute('data-target') || '0', 10);
      const startAttr = node.getAttribute('data-start');
      const start = startAttr ? parseInt(startAttr, 10) : Math.floor(target * 0.85);
      const duration = 1800;
      const startTime = performance.now();
      const step = (now: number) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 3);
        const value = Math.floor(start + (target - start) * ease);
        node.textContent = value.toLocaleString();
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          counters.forEach((c) => animateCounter(c));
          io.disconnect();
        }
      });
    }, { threshold: 0.3 });
    const section = document.querySelector('#nuestra-historia .stats-grid');
    if (section) io.observe(section);
  }
  document.addEventListener('DOMContentLoaded', initAboutCounters);
  document.addEventListener('astro:page-load', initAboutCounters);
</script>

<style>
  /* ===================================================================
   * Shared editorial reveal motion
   * =================================================================== */
  .about-hero .reveal,
  .about-history .reveal,
  .about-values .reveal,
  .about-method .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 800ms cubic-bezier(0.2, 0.7, 0.2, 1) var(--reveal-delay, 0ms),
      transform 800ms cubic-bezier(0.2, 0.7, 0.2, 1) var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }
  .about-hero .reveal.is-visible,
  .about-history .reveal.is-visible,
  .about-values .reveal.is-visible,
  .about-method .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  /* ===================================================================
   * HERO
   * =================================================================== */
  .about-hero .hero-orb {
    animation: about-hero-float 9s ease-in-out infinite;
  }
  .about-hero .hero-orb-delayed {
    animation: about-hero-float 9s ease-in-out infinite 2.5s;
  }
  @keyframes about-hero-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-12px, -16px) scale(1.05); }
  }

  .about-hero .hero-headline {
    display: block;
    line-height: 0.92;
  }
  .about-hero .hero-word {
    display: block;
  }
  .about-hero .hero-word-1 {
