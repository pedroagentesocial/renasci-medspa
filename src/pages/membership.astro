</style>
<script>
  function applyMembershipLang(){
    const params = new URLSearchParams(window.location.search)
    const urlLang = params.get('lang')
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language')
    const manager = (window as any).i18nManager as { getCurrentLanguage?: () => string } | undefined
    const lang = urlLang === 'en' || urlLang === 'es' ? urlLang : (storedLang === 'en' ? 'en' : (manager?.getCurrentLanguage?.() || document.documentElement.lang || 'es'))
    const nodes = Array.from(document.querySelectorAll('[data-t-es]'))
    nodes.forEach((n) => { const es = n.getAttribute('data-t-es')||''; const en = n.getAttribute('data-t-en')||es; n.textContent = (lang==='en')? en : es })
  }
  document.addEventListener('DOMContentLoaded', applyMembershipLang)
  document.addEventListener('astro:page-load', applyMembershipLang)
  window.addEventListener('languageChanged', (event) => { const detail = (event as any).detail as { language?: string } | undefined; const lang = detail?.language || 'es'; const nodes = Array.from(document.querySelectorAll('[data-t-es]')); nodes.forEach((n) => { const es = n.getAttribute('data-t-es')||''; const en = n.getAttribute('data-t-en')||es; n.textContent = (lang==='en')? en : es }) })
</script>
