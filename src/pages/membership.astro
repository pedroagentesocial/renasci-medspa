<script>
  // Animaciones de entrada
  function initAnimations() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, observerOptions);

    // Observar elementos animables
    document.querySelectorAll('.benefit-card, .testimonial-card, .plan-card, .plan-card-featured, .contact-info-item').forEach(el => {
      observer.observe(el);
    });
  }

  // Contadores animados
   function initCounters() {
     const counters = document.querySelectorAll('.counter');
     const counterObserver = new IntersectionObserver((entries) => {
       entries.forEach(entry => {
         if (entry.isIntersecting) {
           const counter = entry.target;
           const targetAttr = counter.getAttribute('data-target');
           if (!targetAttr) return;
           
           const target = parseInt(targetAttr);
           let current = 0;
           const increment = target / 50;
           
           const updateCounter = () => {
             if (current < target) {
               current += increment;
               counter.textContent = Math.ceil(current).toString();
               requestAnimationFrame(updateCounter);
             } else {
               counter.textContent = target.toString();
             }
           };
           
           updateCounter();
           counterObserver.unobserve(counter);
         }
       });
     }, { threshold: 0.5 });

     counters.forEach(counter => counterObserver.observe(counter));
   }

  // Efecto ripple para botones
   function initRippleEffect() {
     document.querySelectorAll('.ripple-effect').forEach(button => {
       button.addEventListener('click', function(e: MouseEvent) {
         const ripple = document.createElement('span');
         const rect = this.getBoundingClientRect();
         const size = Math.max(rect.width, rect.height);
         const x = e.clientX - rect.left - size / 2;
         const y = e.clientY - rect.top - size / 2;
         
         ripple.style.width = size + 'px';
         ripple.style.height = size + 'px';
         ripple.style.left = x + 'px';
         ripple.style.top = y + 'px';
         ripple.classList.add('ripple');
         
         this.appendChild(ripple);
         
         setTimeout(() => {
           ripple.remove();
         }, 600);
       });
     });
   }

  // Validación de formulario
   function initFormValidation() {
     const form = document.getElementById('membershipForm');
     if (!form) return;

     const inputs = form.querySelectorAll('.form-input');
     
     inputs.forEach(input => {
        input.addEventListener('blur', validateField as EventListener);
        input.addEventListener('input', clearValidation as EventListener);
      });

     form.addEventListener('submit', handleFormSubmit as EventListener);
   }

   function validateField(e: Event) {
     const field = e.target as HTMLInputElement | HTMLSelectElement;
     const value = field.value.trim();
     const validation = field.parentNode?.querySelector('.form-validation') as HTMLElement;
     
     let isValid = true;
     let message = '';

     if (field.hasAttribute('required') && !value) {
       isValid = false;
       message = 'Este campo es requerido';
     } else if (field.type === 'email' && value && !isValidEmail(value)) {
       isValid = false;
       message = 'Por favor ingresa un email válido';
     } else if (field.type === 'tel' && value && !isValidPhone(value)) {
       isValid = false;
       message = 'Por favor ingresa un teléfono válido';
     }

     if (isValid) {
       field.classList.remove('border-red-500');
       field.classList.add('border-green-500');
       validation?.classList.add('hidden');
     } else {
       field.classList.remove('border-green-500');
       field.classList.add('border-red-500');
       if (validation) {
         validation.textContent = message;
         validation.classList.remove('hidden');
       }
     }

     return isValid;
   }

   function clearValidation(e: Event) {
     const field = e.target as HTMLInputElement | HTMLSelectElement;
     const validation = field.parentNode?.querySelector('.form-validation') as HTMLElement;
     
     field.classList.remove('border-red-500', 'border-green-500');
     validation?.classList.add('hidden');
   }

   function isValidEmail(email: string) {
     return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
   }

   function isValidPhone(phone: string) {
     return /^[\+]?[1-9][\d]{0,15}$/.test(phone.replace(/[\s\-\(\)]/g, ''));
   }

   async function handleFormSubmit(e: Event) {
     e.preventDefault();
     
     const form = e.target as HTMLFormElement;
     const inputs = form.querySelectorAll('.form-input[required]') as NodeListOf<HTMLInputElement>;
     const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
     const submitText = submitBtn?.querySelector('.submit-text') as HTMLElement;
     const loadingText = submitBtn?.querySelector('.loading-text') as HTMLElement;
     
     let isFormValid = true;
     
     // Validar todos los campos requeridos
      inputs.forEach(input => {
        const mockEvent = { target: input } as unknown as Event;
        if (!validateField(mockEvent)) {
          isFormValid = false;
        }
      });

     if (!isFormValid) {
       return;
     }

     // Mostrar estado de carga
     if (submitBtn) {
       submitBtn.disabled = true;
       submitText?.classList.add('hidden');
       loadingText?.classList.remove('hidden');
     }

     try {
       // Simular envío del formulario
       await new Promise(resolve => setTimeout(resolve, 2000));
       
       // Mostrar mensaje de éxito
       form.innerHTML = `
         <div class="text-center py-8">
           <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
             <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
             </svg>
           </div>
           <h3 class="text-2xl font-bold text-text mb-2">¡Solicitud Enviada!</h3>
           <p class="text-graytxt mb-4">Nos pondremos en contacto contigo dentro de las próximas 24 horas para agendar tu consulta gratuita.</p>
           <p class="text-sm text-graytxt">También puedes llamarnos directamente al <a href="tel:+1234567890" class="text-primary font-semibold">(385) 555-0123</a></p>
         </div>
       `;
     } catch (error) {
       // Restaurar estado del botón en caso de error
       if (submitBtn) {
         submitBtn.disabled = false;
         submitText?.classList.remove('hidden');
         loadingText?.classList.add('hidden');
       }
       
       alert('Hubo un error al enviar el formulario. Por favor intenta de nuevo.');
     }
   }

  // Efecto typing para el hero
   function initTypingEffect() {
     const typingElements = document.querySelectorAll('.typing-text, .typing-text-delayed');
     
     typingElements.forEach((element, index) => {
       const text = element.textContent || '';
       element.textContent = '';
       (element as HTMLElement).style.borderRight = '3px solid #8B5CF6';
       
       setTimeout(() => {
         let i = 0;
         const typeInterval = setInterval(() => {
           element.textContent += text.charAt(i);
           i++;
           
           if (i >= text.length) {
             clearInterval(typeInterval);
             setTimeout(() => {
               (element as HTMLElement).style.borderRight = 'none';
             }, 500);
           }
         }, 100);
       }, index * 1000);
     });
   }

  // Inicializar todo cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    initAnimations();
    initCounters();
    initRippleEffect();
    initTypingEffect();
  });
</script>

<style>
  /* Animaciones personalizadas */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes ripple {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }

  /* Clases de animación */
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out;
  }

  .animate-fade-in-up-delayed {
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  .animate-fade-in-up-more-delayed {
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .animate-fade-in-up-most-delayed {
    animation: fadeInUp 0.8s ease-out 0.6s both;
  }

  .floating-element {
    animation: float 6s ease-in-out infinite;
  }

  .floating-element-delayed {
    animation: float 6s ease-in-out infinite 3s;
  }

  /* Efectos hover y transiciones */
  .benefit-card:hover .benefit-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .testimonial-card:hover {
    transform: translateY(-5px);
  }

  .plan-card:hover {
    transform: translateY(-10px) scale(1.02);
  }

  .plan-card-featured:hover {
    transform: translateY(-10px) scale(1.12);
  }

  /* Efecto ripple */
  .ripple-effect {
    position: relative;
    overflow: hidden;
  }

  .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    transform: scale(0);
    animation: ripple 0.6s linear;
    pointer-events: none;
  }

  /* Animaciones de entrada */
  .benefit-card,
  .testimonial-card,
  .plan-card,
  .plan-card-featured,
  .contact-info-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease-out;
  }

  .benefit-card.animate-in,
  .testimonial-card.animate-in,
  .plan-card.animate-in,
  .plan-card-featured.animate-in,
  .contact-info-item.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Efectos de formulario */
  .form-input:focus {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(139, 92, 246, 0.1);
  }

  .form-group {
    position: relative;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 3rem;
    }
    
    .plan-card-featured {
      transform: none !important;
    }
    
    .plan-card-featured:hover {
      transform: translateY(-5px) !important;
    }
  }

  /* Mejoras de accesibilidad */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
<script>
  function applyMembershipLang(){
    const params = new URLSearchParams(window.location.search)
    const urlLang = params.get('lang')
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language')
    const lang = urlLang === 'en' || urlLang === 'es' ? urlLang : (storedLang === 'en' ? 'en' : (window.i18nManager?.getCurrentLanguage?.() || document.documentElement.lang || 'es'))
    const nodes = Array.from(document.querySelectorAll('[data-t-es]'))
    nodes.forEach((n) => { const es = n.getAttribute('data-t-es')||''; const en = n.getAttribute('data-t-en')||es; n.textContent = (lang==='en')? en : es })
  }
  document.addEventListener('DOMContentLoaded', applyMembershipLang)
  window.addEventListener('languageChanged', (e) => { const lang = e.detail?.language || 'es'; const nodes = Array.from(document.querySelectorAll('[data-t-es]')); nodes.forEach((n) => { const es = n.getAttribute('data-t-es')||''; const en = n.getAttribute('data-t-en')||es; n.textContent = (lang==='en')? en : es }) })
</script>
