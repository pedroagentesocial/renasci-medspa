  </section>
  <TestimonialsSection />

  <!-- FAQ Mejorado con Animaciones -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <div class="flex items-center justify-center mb-4">
            <div class="flex-1 h-[2px] bg-gray-200"></div>
            <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8M8 12h8" />
              </svg>
            </span>
            <div class="flex-1 h-[2px] bg-gray-200"></div>
          </div>
          <h2 class="font-display font-bold text-4xl md:text-5xl text-text mb-6">
            <span data-t-es="Preguntas" data-t-en="Frequently">Preguntas</span> <span class="text-[#F3A2A7]" data-t-es="Frecuentes" data-t-en="Asked Questions">Frecuentes</span>
          </h2>
          <p class="text-xl text-graytxt" data-t-es="Todo lo que necesitas saber sobre nuestras membresías" data-t-en="Everything you need to know about our memberships">
            Todo lo que necesitas saber sobre nuestras membresías
