---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQItem from '../components/FAQItem.astro';
import SimpleContactForm from '../components/SimpleContactForm.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import TransformCTA from '../components/TransformCTA.astro';
---

<BaseLayout 
  title="Membresías - Renasci Medical Spa"
  description="Descubre nuestras membresías Signature Glow y Signature Elite con precios exclusivos, beneficios wellness e inyecciones mensuales incluidas."
>
  <!-- Hero Section Editorial -->
  <section class="membership-hero relative flex min-h-screen items-center justify-center overflow-hidden">
    <div
      class="absolute inset-0 h-full w-full bg-cover"
      style="background-image:url('/img/services/hero-membership.png'); background-position: 30% 20%;"
      aria-label="Renasci Membership"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/35 via-black/45 to-black/75"></div>

    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="hero-orb absolute -top-24 -left-16 h-80 w-80 rounded-full bg-[#F3A2A7]/15 blur-3xl"></div>
      <div class="hero-orb-delayed absolute -bottom-24 right-1/4 h-96 w-96 rounded-full bg-[#AABFA8]/15 blur-3xl"></div>
      <div class="hero-orb absolute top-1/3 right-10 h-48 w-48 rounded-full bg-white/8 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center text-white">
      <span class="reveal mb-7 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-white/85">
        <span class="h-px w-10 bg-white/45"></span>
        <span data-t-es="Membresías Signature" data-t-en="Signature Memberships">Membresías Signature</span>
        <span class="h-px w-10 bg-white/45"></span>
      </span>

      <h1 class="hero-headline">
        <span
          class="reveal hero-word hero-word-1 font-display font-bold tracking-tight"
          style="--reveal-delay: 80ms;"
          data-t-es="Renueva"
          data-t-en="Renew"
        >Renueva</span>
        <span
          class="reveal hero-word hero-word-2 font-hero-elmatia text-[#F3A2A7]"
          style="--reveal-delay: 240ms;"
          data-t-es="tu Glow"
          data-t-en="your Glow"
        >tu Glow</span>
        <span
          class="reveal hero-word hero-word-3 font-display font-bold tracking-tight text-white/90"
          style="--reveal-delay: 380ms;"
          data-t-es="cada mes"
          data-t-en="every month"
        >cada mes</span>
      </h1>

      <p
        class="reveal mx-auto mt-8 max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg md:text-xl"
        style="--reveal-delay: 500ms;"
        data-t-es="Beneficios premium todo el año, atención prioritaria y precios preferenciales pensados para ti."
        data-t-en="Year-round premium benefits, priority access and preferred pricing made for you."
      >Beneficios premium todo el año, atención prioritaria y precios preferenciales pensados para ti.</p>

      <div class="reveal mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4" style="--reveal-delay: 620ms;">
        <a
          href="#planes"
          class="hero-cta-primary group inline-flex items-center gap-2 rounded-full bg-[#F3A2A7] px-8 py-4 font-semibold text-white shadow-[0_18px_36px_-12px_rgba(243,162,167,0.7)] transition-all duration-300 hover:gap-3 hover:opacity-95 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7] focus-visible:ring-offset-2 focus-visible:ring-offset-black"
        >
          <span data-t-es="Ver planes" data-t-en="See plans">Ver planes</span>
          <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="tel:+13856092840"
          class="hero-cta-secondary group inline-flex items-center gap-2 rounded-full border border-white/40 bg-white/5 px-8 py-4 font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white hover:bg-white/15 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
          </svg>
          <span data-t-es="Hablar con un especialista" data-t-en="Talk to a specialist">Hablar con un especialista</span>
        </a>
      </div>

      <div
        class="reveal mt-10 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 text-xs text-white/70 sm:text-sm"
        style="--reveal-delay: 740ms;"
      >
        <span class="hero-trust-item">
          <svg class="h-3.5 w-3.5 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
          <span data-t-es="Sin permanencia" data-t-en="No commitment">Sin permanencia</span>
        </span>
        <span class="text-white/30">·</span>
        <span class="hero-trust-item">
          <svg class="h-3.5 w-3.5 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
          <span data-t-es="Renovable mensual" data-t-en="Monthly renewal">Renovable mensual</span>
        </span>
        <span class="text-white/30">·</span>
        <span class="hero-trust-item">
          <svg class="h-3.5 w-3.5 text-[#F3A2A7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
          <span data-t-es="Cancela cuando quieras" data-t-en="Cancel anytime">Cancela cuando quieras</span>
        </span>
      </div>
    </div>

    <a href="#planes" class="hero-scroll group absolute bottom-8 left-1/2 -translate-x-1/2 text-white/70 hover:text-white transition-colors" aria-label="Scroll to plans">
      <span class="block text-[10px] font-semibold uppercase tracking-[0.42em] mb-2 text-center" data-t-es="Explorar" data-t-en="Explore">Explorar</span>
      <span class="hero-scroll-arrow mx-auto block h-10 w-[2px] bg-gradient-to-b from-white/0 via-white/70 to-white/0"></span>
    </a>
  </section>

  <!-- Sección Elige tu Plan -->
  <section id="planes" class="plans-section relative overflow-hidden bg-white py-20 text-black lg:py-28">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 left-1/4 h-72 w-72 rounded-full bg-[#F3A2A7]/12 blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-[#1DD1A1]/10 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center lg:mb-20">
        <span class="reveal mb-6 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-[#B76B71]">
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
          <span data-t-es="Tu plan a medida" data-t-en="Your plan, your way">Tu plan a medida</span>
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
        </span>
        <h2 class="plans-headline">
          <span
            class="reveal headline-word headline-word-1 font-display font-bold tracking-tight text-black"
            style="--reveal-delay: 80ms;"
            data-t-es="Elige tu"
            data-t-en="Choose your"
          >Elige tu</span>
          <span
            class="reveal headline-word headline-word-2 font-hero-elmatia text-[#F3A2A7]"
            style="--reveal-delay: 220ms;"
            data-t-es="Membresía"
            data-t-en="Membership"
          >Membresía</span>
        </h2>
        <p
          class="reveal mx-auto mt-7 max-w-xl text-sm text-black/65 sm:text-base lg:text-lg"
          style="--reveal-delay: 360ms;"
          data-t-es="Dos niveles diseñados para mantener tu glow todo el año."
          data-t-en="Two tiers designed to keep your glow year-round."
        >Dos niveles diseñados para mantener tu glow todo el año.</p>
      </div>

      <div class="tiers-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
        <article
          class="tier-card-v2 reveal"
          style="--tier-color: #1DD1A1; --tier-color-soft: #1DD1A11f; --tier-color-bg: #1DD1A10d; --tier-shadow: rgba(29,209,161,0.3); --reveal-delay: 280ms;"
        >
          <div class="tier-glow"></div>
          <div class="tier-card-inner">
            <div class="tier-head">
              <span class="tier-mark">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
                </svg>
              </span>
              <span class="tier-eyebrow" data-t-es="Para empezar tu rutina" data-t-en="To start your routine">Para empezar tu rutina</span>
              <h3 class="tier-name">Signature <span class="tier-name-accent">Glow</span></h3>
              <p class="tier-desc" data-t-es="Precios exclusivos y wellness para mantener tu glow todo el año." data-t-en="Exclusive pricing and wellness to keep glowing year-round.">
                Precios exclusivos y wellness para mantener tu glow todo el año.
              </p>
            </div>

            <div class="tier-price-block">
              <span class="tier-price">$99</span>
              <span class="tier-period" data-t-es="/mes" data-t-en="/mo">/mes</span>
            </div>

            <div class="tier-divider">
              <span class="tier-divider-label" data-t-es="Incluye" data-t-en="Includes">Incluye</span>
            </div>

            <ul class="tier-features">
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Botox / Tox por unidad" data-t-en="Botox / Tox per unit">Botox / Tox por unidad</span>
                <span class="tier-feature-value">$12</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Faciales médicos" data-t-en="Medical facials">Faciales médicos</span>
                <span class="tier-feature-value">15% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Dermal fillers" data-t-en="Dermal fillers">Dermal fillers</span>
                <span class="tier-feature-value">$60 OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="IV Therapy" data-t-en="IV Therapy">IV Therapy</span>
                <span class="tier-feature-value">10% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Péptidos" data-t-en="Peptides">Péptidos</span>
                <span class="tier-feature-value">10% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Wellness Performance Shots" data-t-en="Wellness Performance Shots">Wellness Performance Shots</span>
                <span class="tier-feature-value">10% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Priority booking & promociones" data-t-en="Priority booking & promotions">Priority booking & promociones</span>
                <span class="tier-feature-value tier-feature-mark">
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
              </li>
            </ul>

            <a href="#contacto" class="tier-cta group">
              <span data-t-es="Unirme a Signature Glow" data-t-en="Join Signature Glow">Unirme a Signature Glow</span>
              <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <p class="tier-foot" data-t-es="Sin permanencia · Cancela cuando quieras" data-t-en="No commitment · Cancel anytime">Sin permanencia · Cancela cuando quieras</p>
          </div>
        </article>

        <article
          class="tier-card-v2 is-featured reveal"
          style="--tier-color: #F3A2A7; --tier-color-soft: #F3A2A726; --tier-color-bg: #F3A2A714; --tier-shadow: rgba(243,162,167,0.4); --reveal-delay: 420ms;"
        >
          <div class="tier-badge" data-t-es="Más Popular" data-t-en="Most Popular">Más Popular</div>
          <div class="tier-glow"></div>
          <div class="tier-card-inner">
            <div class="tier-head">
              <span class="tier-mark">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>
                </svg>
              </span>
              <span class="tier-eyebrow" data-t-es="Para resultados premium" data-t-en="For premium results">Para resultados premium</span>
              <h3 class="tier-name">Signature <span class="tier-name-accent">Elite</span></h3>
              <p class="tier-desc" data-t-es="Resultados estéticos elevados con beneficios avanzados." data-t-en="Elevated aesthetic results with advanced benefits.">
                Resultados estéticos elevados con beneficios avanzados.
              </p>
            </div>

            <div class="tier-price-block">
              <span class="tier-price">$189</span>
              <span class="tier-period" data-t-es="/mes" data-t-en="/mo">/mes</span>
            </div>

            <div class="tier-divider">
              <span class="tier-divider-label" data-t-es="Incluye" data-t-en="Includes">Incluye</span>
            </div>

            <ul class="tier-features">
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Botox / Tox por unidad" data-t-en="Botox / Tox per unit">Botox / Tox por unidad</span>
                <span class="tier-feature-value">$10</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Faciales médicos" data-t-en="Medical facials">Faciales médicos</span>
                <span class="tier-feature-value">20% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Dermal fillers" data-t-en="Dermal fillers">Dermal fillers</span>
                <span class="tier-feature-value">$150 OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="IV Therapy" data-t-en="IV Therapy">IV Therapy</span>
                <span class="tier-feature-value">20% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Péptidos" data-t-en="Peptides">Péptidos</span>
                <span class="tier-feature-value">15% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Wellness Performance Shots" data-t-en="Wellness Performance Shots">Wellness Performance Shots</span>
                <span class="tier-feature-value">20% OFF</span>
              </li>
              <li class="tier-feature">
                <span class="tier-feature-label" data-t-es="Priority booking & promociones" data-t-en="Priority booking & promotions">Priority booking & promociones</span>
                <span class="tier-feature-value tier-feature-mark">
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
              </li>
              <li class="tier-feature tier-feature-bonus">
                <span class="tier-feature-label" data-t-es="Evaluación médica cada 6 meses" data-t-en="Medical evaluation every 6 months">Evaluación médica cada 6 meses</span>
                <span class="tier-feature-value tier-feature-bonus-value" data-t-es="Bonus" data-t-en="Bonus">Bonus</span>
              </li>
            </ul>

            <a href="#contacto" class="tier-cta group">
              <span data-t-es="Unirme a Signature Elite" data-t-en="Join Signature Elite">Unirme a Signature Elite</span>
              <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <p class="tier-foot" data-t-es="Sin permanencia · Cancela cuando quieras" data-t-en="No commitment · Cancel anytime">Sin permanencia · Cancela cuando quieras</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <style>
    .plan-card .tier-card .text-graytxt{ color:#000 !important }
    .plan-card-featured .tier-card .text-graytxt{ color:#000 !important }
  </style>

  <!-- Comparativa Signature (editorial) -->
  <section class="compare-section relative overflow-hidden bg-white py-20 text-black lg:py-24">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute -top-16 right-1/4 h-64 w-64 rounded-full bg-[#1DD1A1]/8 blur-3xl"></div>
      <div class="absolute -bottom-20 left-1/4 h-72 w-72 rounded-full bg-[#F3A2A7]/12 blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center lg:mb-16">
        <span class="reveal mb-6 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-[#B76B71]">
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
          <span data-t-es="Compara tus beneficios" data-t-en="Compare your benefits">Compara tus beneficios</span>
          <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
        </span>
        <h2 class="compare-headline">
          <span
            class="reveal headline-word headline-word-1 font-display font-bold tracking-tight text-black"
            style="--reveal-delay: 80ms;"
            data-t-es="Beneficios"
            data-t-en="Benefits"
          >Beneficios</span>
          <span
            class="reveal headline-word headline-word-2 font-hero-elmatia text-[#F3A2A7]"
            style="--reveal-delay: 220ms;"
            data-t-es="lado a lado"
            data-t-en="side by side"
          >lado a lado</span>
        </h2>
        <p
          class="reveal mx-auto mt-6 max-w-xl text-sm text-black/60 sm:text-base"
          style="--reveal-delay: 360ms;"
          data-t-es="Visualiza rápido la diferencia entre Glow y Elite."
          data-t-en="See the Glow vs Elite difference at a glance."
        >Visualiza rápido la diferencia entre Glow y Elite.</p>
      </div>

      <div class="reveal compare-table mx-auto" style="--reveal-delay: 420ms;">
        <div class="compare-head" role="row">
          <div class="compare-cell compare-cell-feature" role="columnheader">
            <span class="compare-feature-eyebrow" data-t-es="Beneficio" data-t-en="Benefit">Beneficio</span>
          </div>
          <div class="compare-cell compare-cell-tier compare-glow" role="columnheader">
            <span class="compare-tier-mark">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
              </svg>
            </span>
            <span class="compare-tier-name">Signature <strong>Glow</strong></span>
            <span class="compare-tier-price">$99<small data-t-es="/mes" data-t-en="/mo">/mes</small></span>
          </div>
          <div class="compare-cell compare-cell-tier compare-elite" role="columnheader">
            <span class="compare-tier-pop" data-t-es="Más Popular" data-t-en="Most Popular">Más Popular</span>
            <span class="compare-tier-mark">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>
              </svg>
