---
import BaseLayout from '../layouts/BaseLayout.astro';
import TierCard from '../components/TierCard.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQItem from '../components/FAQItem.astro';
import SimpleContactForm from '../components/SimpleContactForm.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import TransformCTA from '../components/TransformCTA.astro';
---

<BaseLayout 
  title="Membresías - Renasci Medical Spa"
  description="Descubre nuestras membresías Signature Glow y Signature Elite con precios exclusivos, beneficios wellness e inyecciones mensuales incluidas."
>
  <!-- Hero Section Renovado -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Imagen de fondo -->
    <div 
      class="absolute inset-0 w-full h-full bg-cover bg-center"
      style="background-image:url('/img/services/hero-membership.png')"
      aria-label="Renasci Membership"
    ></div>
    
    <!-- Overlay para legibilidad -->
    <div class="absolute inset-0 bg-black/40"></div>
    
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="floating-element absolute top-20 left-10 w-32 h-32 bg-primary/10 rounded-full blur-xl"></div>
      <div class="floating-element-delayed absolute top-40 right-20 w-24 h-24 bg-secondary/15 rounded-full blur-lg"></div>
      <div class="floating-element absolute bottom-32 left-1/4 w-40 h-40 bg-primary/8 rounded-full blur-2xl"></div>
      <div class="floating-element-delayed absolute bottom-20 right-1/3 w-28 h-28 bg-secondary/12 rounded-full blur-xl"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 px-6 max-w-6xl mx-auto text-center">
      <div class="hero-content">
        <!-- Badge animado -->
        <div class="inline-flex items-center px-4 py-2 bg-[#F3A2A7]/10 backdrop-blur-sm rounded-full text-white font-semibold text-sm mb-8 border border-[#F3A2A7]/20 animate-fade-in-up" data-t-es="Membresías Exclusivas" data-t-en="Exclusive Memberships">
          <svg class="w-4 h-4 mr-2 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
          </svg>
          <span class="i18n-text">Membresías Exclusivas</span>
        </div>
        
        <!-- Título principal con efecto typing -->
        <h1 class="font-display font-bold text-5xl md:text-7xl lg:text-8xl text-white mb-6 leading-tight">
          <span class="typing-text" data-t-es="Transforma" data-t-en="Transform">Transforma</span><br>
          <span class="text-[#F3A2A7] typing-text-delayed" data-t-es="Tu Belleza" data-t-en="Your Beauty">Tu Belleza</span>
        </h1>
        
        <!-- Subtítulo -->
        <p class="text-xl md:text-2xl text-white mb-12 leading-relaxed max-w-4xl mx-auto" data-t-es="Únete a nuestra comunidad exclusiva y descubre una nueva dimensión de cuidado personal con beneficios únicos, tratamientos premium y atención personalizada." data-t-en="Join our exclusive community and discover a new dimension of self-care with unique benefits, premium treatments, and personalized attention.">
          Únete a nuestra comunidad exclusiva y descubre una nueva dimensión de cuidado personal con beneficios únicos, tratamientos premium y atención personalizada.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
          <CTAButton 
            href="#planes"
            variant="primary"
            className="px-8 py-4 text-lg font-semibold bg-[#F3A2A7] text-white hover:opacity-90 focus-visible:ring-[#F3A2A7]/50"
          >
            <span data-t-es="Ver Planes de Membresía" data-t-en="View Membership Plans">Ver Planes de Membresía</span>
          </CTAButton>
          
          <CTAButton 
            href="#contacto"
            variant="mint"
            className="px-8 py-4 text-lg font-semibold focus-visible:ring-[#AABFA8]/50"
          >
            <span data-t-es="Consulta Gratuita" data-t-en="Free Consultation">Consulta Gratuita</span>
          </CTAButton>
        </div>
        
        <!-- Stats animados -->
        <div class="hidden">
          <div class="text-center">
            <div class="counter text-3xl md:text-4xl font-bold text-primary mb-2" data-target="500">0</div>
            <div class="text-sm text-white">Miembros Activos</div>
          </div>
          <div class="text-center">
            <div class="counter text-3xl md:text-4xl font-bold text-primary mb-2" data-target="98">0</div>
            <div class="text-sm text-white">% Satisfacción</div>
          </div>
          <div class="text-center">
            <div class="counter text-3xl md:text-4xl font-bold text-primary mb-2" data-target="25">0</div>
            <div class="text-sm text-white">% Descuento Promedio</div>
          </div>
          <div class="text-center">
            <div class="counter text-3xl md:text-4xl font-bold text-primary mb-2" data-target="24">0</div>
            <div class="text-sm text-white">Soporte 24/7</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    
  </section>

  <!-- Sección Elige tu Plan Perfecto (MOVIDA AQUÍ) -->
  <section id="planes" class="py-20 bg-white text-black">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative text-center mb-16">
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-64 h-64 rounded-full bg-[#F3A2A7]/15 blur-3xl"></div>
        <div class="absolute -bottom-12 left-8 w-40 h-40 rounded-full bg-[#1DD1A1]/10 blur-2xl"></div>
        <div class="relative inline-flex flex-col items-center gap-4 px-8 py-8 sm:px-10 sm:py-10 bg-white/90 backdrop-blur border border-[#F3A2A7]/30 rounded-3xl shadow-[0_20px_50px_rgba(243,162,167,0.25)]">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-[0.2em] text-[#B76B71] bg-[#F3A2A7]/15 uppercase" data-t-es="Membresías Signature" data-t-en="Signature Memberships">Membresías Signature</span>
          <h2 class="font-display font-bold text-4xl md:text-5xl text-gray-900 tracking-tight" data-t-es="Elige tu Membresía Signature" data-t-en="Choose Your Signature Membership">Elige tu Membresía Signature</h2>
          <p class="text-lg md:text-xl text-black/70 max-w-3xl leading-relaxed" data-t-es="Beneficios exclusivos y precios preferenciales diseñados para mantener tu glow todo el año." data-t-en="Exclusive benefits and preferred pricing designed to keep your glow year‑round.">
            Beneficios exclusivos y precios preferenciales diseñados para mantener tu glow todo el año.
          </p>
          <div class="flex items-center gap-3 text-sm text-black/60">
            <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
            <span data-t-es="Dos niveles, un solo glow" data-t-en="Two tiers, one glow">Dos niveles, un solo glow</span>
            <span class="h-px w-10 bg-[#F3A2A7]/50"></span>
          </div>
        </div>
      </div>
      
      <!-- Mobile: Stack vertical con Glow al centro (order-2) -->
      <!-- Desktop: Grid de 3 columnas con Glow destacado -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
        <!-- Signature Glow -->
        <div class="order-1 lg:order-1 plan-card">
          <TierCard
              title="Signature Glow Membership"
              titleEn="Signature Glow Membership"
              price="$100"
              period="mes"
              periodEn="month"
              description="Precios exclusivos y beneficios wellness para mantener tu glow todo el año."
              descriptionEn="Exclusive pricing and wellness perks to keep you glowing year‑round."
              features={[
                "Botox / Tox: $12 por unidad",
                "15% OFF en faciales médicos",
                "15% OFF en dermal fillers",
                "Inyección mensual de vitamina B12 incluida",
                "10% OFF en IV Therapy",
                "10% OFF en tratamientos de péptidos",
                "Priority booking y promociones exclusivas",
                "Mantenimiento estético continuo personalizado"
              ]}
              featuresEn={[
                "Botox / Tox: $12 per unit",
                "15% OFF medical facials",
                "15% OFF dermal fillers",
                "Monthly vitamin B12 injection included",
                "10% OFF IV Therapy",
                "10% OFF peptide treatments",
                "Priority booking and exclusive promotions",
                "Personalized continuous aesthetic maintenance"
              ]}
              ctaText="Unirme a Signature Glow"
              ctaTextEn="Join Signature Glow"
              ctaHref="#contacto"
              class="h-full min-h-[30rem] bg-white text-black border-2 border-[#1DD1A1] hover:ring-2 hover:ring-[#1DD1A1]"
              variant="light"
              ctaClass="bg-[#1DD1A1] text-white hover:opacity-90 border-2 border-[#1DD1A1] focus-visible:ring-[#1DD1A1] focus-visible:ring-offset-white"
              titleClass="text-3xl md:text-4xl text-black"
              hoverBorderColor="#1DD1A1"
            />
        </div>

        <!-- Signature Elite -->
        <div class="order-2 lg:order-2 plan-card-featured">
          <TierCard
              title="Signature Elite Membership"
              titleEn="Signature Elite Membership"
              price="$189"
              period="mes"
              periodEn="month"
              description="Membresía premium con resultados estéticos elevados y beneficios avanzados."
              descriptionEn="Premium membership with elevated aesthetic results and advanced benefits."
              features={[
                "Botox / Tox: $10 por unidad",
                "$150 OFF en dermal fillers",
                "20% OFF en faciales médicos",
                "20% OFF en IV Therapy",
                "15% OFF en tratamientos de péptidos",
                "Inyección mensual de B12 o Fat Blaster incluida",
                "Evaluación médica cada 6 meses",
                "Priority booking y promociones exclusivas",
                "Mantenimiento estético continuo personalizado"
              ]}
              featuresEn={[
                "Botox / Tox: $10 per unit",
                "$150 OFF dermal fillers",
                "20% OFF medical facials",
                "20% OFF IV Therapy",
                "15% OFF peptide treatments",
                "Monthly B12 or Fat Blaster injection included",
                "Medical evaluation every 6 months",
                "Priority booking and exclusive promotions",
                "Personalized continuous aesthetic maintenance"
              ]}
              ctaText="Unirme a Signature Elite"
              ctaTextEn="Join Signature Elite"
              ctaHref="#contacto"
              highlight={false}
              badgeImportance="primary"
              class="h-full relative min-h-[30rem] bg-white text-black border-2 border-[#F3A2A7] hover:ring-2 hover:ring-[#F3A2A7]"
              variant="light"
              ctaClass="bg-[#F3A2A7] text-white hover:opacity-90 border-2 border-[#F3A2A7] focus-visible:ring-[#F3A2A7] focus-visible:ring-offset-white"
              titleClass="text-3xl md:text-4xl text-black"
              hoverBorderColor="#F3A2A7"
