              <td class="px-5 py-4 font-semibold text-gray-900" data-t-es="IV Therapy" data-t-en="IV Therapy">IV Therapy</td>
              <td class="px-5 py-4 text-gray-700">10% OFF</td>
              <td class="px-5 py-4 text-gray-700">20% OFF</td>
            </tr>
