        </p>

        <div class="reveal mt-7 flex flex-wrap items-center justify-center gap-3 lg:justify-start" style="--reveal-delay: 520ms;">
          <span class="tier-chip tier-glow group">
            <span class="tier-dot"></span>
            <span data-t-es="Signature Glow" data-t-en="Signature Glow">Signature Glow</span>
          </span>
          <span class="tier-chip tier-elite group">
            <span class="tier-dot"></span>
            <span data-t-es="Signature Elite" data-t-en="Signature Elite">Signature Elite</span>
          </span>
        </div>

        <div class="reveal mt-9" style="--reveal-delay: 620ms;">
          <a
            href="/membership"
            class="group inline-flex items-center gap-2 rounded-full bg-[#F3A2A7] px-7 py-3 font-semibold text-white shadow-[0_14px_28px_-12px_rgba(243,162,167,0.6)] transition-all duration-300 hover:gap-3 hover:opacity-95 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7] focus-visible:ring-offset-2"
          >
            <span data-i18n="membership.view_membership">Ver Beneficios y Planes</span>
