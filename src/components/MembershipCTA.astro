---
import CTAButton from './CTAButton.astro';
---

<section class="py-16 lg:py-20 bg-gradient-to-br from-[#FDF4F5] via-white to-[#F6FFFB]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-[#F3A2A7]/30 text-[#B76B71] text-xs font-semibold tracking-[0.2em] uppercase">
          <span data-i18n="membership.join_title_prefix">Membresías Signature</span>
        </div>
        <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-black mt-5 mb-5">
          <span data-i18n="membership.join_title_highlight">Glow constante con beneficios reales</span>
        </h2>
        <p class="text-lg md:text-xl text-black/70 mb-8 leading-relaxed">
          <span data-i18n="membership.join_subtitle">Precio preferencial, prioridad en agenda y un plan de mantenimiento estético pensado para ti.</span>
        </p>
        <div class="flex flex-wrap items-center gap-3 justify-center lg:justify-start mb-8">
          <span class="px-4 py-2 rounded-full bg-white text-black border border-[#F3A2A7]/30 text-sm font-semibold">Signature Glow</span>
          <span class="px-4 py-2 rounded-full bg-[#F3A2A7] text-white text-sm font-semibold">Signature Elite</span>
        </div>
        <CTAButton 
          href="/membership"
          variant="primary"
          className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200 bg-[#F3A2A7] text-white focus-visible:ring-[#F3A2A7]/50"
        >
          <span data-i18n="membership.view_membership">Ver Beneficios y Planes</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </CTAButton>
      </div>

      <div class="bg-white rounded-3xl border border-[#F3A2A7]/20 shadow-[0_24px_60px_rgba(243,162,167,0.18)] p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex gap-4">
            <span class="w-10 h-10 rounded-full bg-[#F3A2A7]/15 text-[#B76B71] flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-base text-black" data-i18n="membership.benefit_discounts_title">Tox desde $12 y $10</h3>
              <p class="text-black/60 text-sm" data-i18n="membership.benefit_discounts_text">Precios especiales por unidad en Glow y Elite.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="w-10 h-10 rounded-full bg-[#AABFA8]/20 text-[#6D8C7B] flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-base text-black" data-i18n="membership.benefit_priority_title">Faciales y fillers con descuento</h3>
              <p class="text-black/60 text-sm" data-i18n="membership.benefit_priority_text">Hasta 20% OFF y $150 OFF en Elite.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="w-10 h-10 rounded-full bg-[#F3A2A7]/15 text-[#B76B71] flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-base text-black" data-i18n="membership.benefit_special_title">IV Therapy y Peptides</h3>
              <p class="text-black/60 text-sm" data-i18n="membership.benefit_special_text">Descuentos especiales para bienestar continuo.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="w-10 h-10 rounded-full bg-[#AABFA8]/20 text-[#6D8C7B] flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-base text-black">B12 mensual incluida</h3>
              <p class="text-black/60 text-sm">Fat Blaster incluido en Signature Elite.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="w-10 h-10 rounded-full bg-[#F3A2A7]/15 text-[#B76B71] flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-base text-black">Priority booking</h3>
              <p class="text-black/60 text-sm">Citas preferentes y promociones exclusivas.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="w-10 h-10 rounded-full bg-[#AABFA8]/20 text-[#6D8C7B] flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-base text-black">Glow planificado</h3>
              <p class="text-black/60 text-sm">Mantenimiento estético continuo personalizado.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .icon-pink {
    filter: brightness(0) saturate(100%) invert(69%) sepia(22%) saturate(1624%) hue-rotate(309deg) brightness(96%) contrast(93%);
  }
</style>
