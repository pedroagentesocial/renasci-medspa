    <div class="absolute -top-24 -left-24 h-80 w-80 rounded-full bg-[#F3A2A7]/15 blur-3xl"></div>
    <div class="absolute -bottom-32 -right-16 h-96 w-96 rounded-full bg-[#AABFA8]/15 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr] lg:gap-16">
      <div class="text-center lg:text-left">
        <span class="reveal mb-6 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.42em] text-[#B76B71]">
          <span class="h-px w-8 bg-[#F3A2A7]/50"></span>
