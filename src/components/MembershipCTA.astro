          <span
            class="reveal headline-word headline-word-2 font-display font-bold tracking-tight text-black"
            style="--reveal-delay: 220ms;"
            data-t-es="constante"
            data-t-en="all year"
          >constante</span>
          <span
            class="reveal headline-word headline-word-3 font-display font-bold tracking-tight text-black/85"
            style="--reveal-delay: 320ms;"
