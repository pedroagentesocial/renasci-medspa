                    class="font-semibold text-[0.95rem] text-black leading-snug"
                    {...(b.i18nTitle ? { 'data-i18n': b.i18nTitle } : {})}
                    data-t-es={b.title.es}
                    data-t-en={b.title.en}
                    data-bnf-title
                  >{b.title.es}</h4>
                  <p
                    class="mt-1 text-sm text-black/60 leading-relaxed"
                    {...(b.i18nText ? { 'data-i18n': b.i18nText } : {})}
                    data-t-es={b.text.es}
                    data-t-en={b.text.en}
                    data-bnf-text
                  >{b.text.es}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-7 flex items-center gap-2 border-t border-black/[0.06] pt-5 text-xs text-black/55">
            <svg class="h-4 w-4 flex-shrink-0 text-[#6D8C7B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
            <span data-t-es="Renovable mensualmente · Cancelable cuando quieras" data-t-en="Renews monthly · Cancel anytime">Renovable mensualmente · Cancelable cuando quieras</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  type Lang = 'es' | 'en';

  const getMembershipLang = (): Lang => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang as Lang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang as Lang;
    const managerLang = (window as any).i18nManager?.getCurrentLanguage?.();
    if (managerLang === 'en' || managerLang === 'es') return managerLang as Lang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyMembershipLang = (lang: Lang) => {
    document.querySelectorAll('.membership-cta-v2 [data-t-es]').forEach((el) => {
      const node = el as HTMLElement;
      const es = node.getAttribute('data-t-es') || '';
      const en = node.getAttribute('data-t-en') || es;
      node.textContent = lang === 'en' ? en : es;
    });
  };

  const initMembershipLang = () => applyMembershipLang(getMembershipLang());
  document.addEventListener('DOMContentLoaded', initMembershipLang);
  document.addEventListener('astro:page-load', initMembershipLang);
  window.addEventListener('languageChanged', (e) => {
    const detail = (e as CustomEvent).detail as { language?: Lang } | undefined;
    const lang = detail?.language === 'en' || detail?.language === 'es' ? detail.language : getMembershipLang();
    applyMembershipLang(lang);
  });

  const initMembershipReveal = () => {
    const targets = document.querySelectorAll('.membership-cta-v2 .reveal');
    if (!targets.length) return;
    const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      targets.forEach((t) => t.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
    targets.forEach((t) => io.observe(t));
  };
  document.addEventListener('DOMContentLoaded', initMembershipReveal);
  document.addEventListener('astro:page-load', initMembershipReveal);
</script>

<style>
  .membership-cta-v2 .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 750ms cubic-bezier(0.2, 0.7, 0.2, 1) var(--reveal-delay, 0ms),
      transform 750ms cubic-bezier(0.2, 0.7, 0.2, 1) var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }
  .membership-cta-v2 .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  .membership-cta-v2 .membership-headline {
    display: block;
    line-height: 0.94;
  }
  .membership-cta-v2 .headline-word {
    display: block;
  }
  .membership-cta-v2 .headline-word-1 {
    font-size: clamp(3.75rem, 9.5vw, 7rem);
    line-height: 0.88;
    letter-spacing: -0.01em;
    margin-bottom: -0.18em;
  }
  .membership-cta-v2 .headline-word-2 {
    font-size: clamp(2rem, 4.6vw, 3.5rem);
    letter-spacing: -0.02em;
    margin-top: 0.08em;
  }
  .membership-cta-v2 .headline-word-3 {
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    letter-spacing: -0.01em;
    margin-top: 0.45em;
  }

