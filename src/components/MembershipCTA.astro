---
import CTAButton from './CTAButton.astro';
---

<section class="pt-6 md:pt-8 pb-8 lg:pb-12 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <div class="flex items-center justify-center mb-4">
        <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
          <img src="/icons/flor-renasci.svg" alt="Renasci" class="w-5 h-5 object-contain icon-pink" loading="lazy" />
        </span>
        <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-black mb-6">
        <span data-i18n="membership.join_title_prefix">Únete a Nuestra</span>
        <span class="text-black" data-i18n="membership.join_title_highlight">Membresía</span>
      </h2>
      <p class="text-lg md:text-xl text-black/80 mb-8 leading-relaxed">
        <span data-i18n="membership.join_subtitle">Accede a descuentos exclusivos, tratamientos prioritarios y beneficios especiales diseñados para nuestros miembros más valorados.</span>
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6">
          <div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <img src="/icons/dollar.png" alt="Descuentos" class="w-10 h-10 object-contain icon-pink" loading="lazy" />
          </div>
          <h3 class="font-semibold text-lg text-black mb-2"><span data-i18n="membership.benefit_discounts_title">Descuentos Exclusivos</span></h3>
          <p class="text-black/70"><span data-i18n="membership.benefit_discounts_text">Descubre descuentos exclusivos en servicios seleccionados</span></p>
        </div>
        
        <div class="p-6">
          <div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <img src="/icons/lock.png" alt="Acceso prioritario" class="w-10 h-10 object-contain icon-pink" loading="lazy" />
          </div>
          <h3 class="font-semibold text-lg text-black mb-2"><span data-i18n="membership.benefit_priority_title">Acceso Prioritario</span></h3>
          <p class="text-black/70"><span data-i18n="membership.benefit_priority_text">Reserva tus citas con prioridad y flexibilidad</span></p>
        </div>
        
        <div class="p-6">
          <div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <img src="/icons/heart.png" alt="Beneficios especiales" class="w-10 h-10 object-contain icon-pink" loading="lazy" />
          </div>
          <h3 class="font-semibold text-lg text-black mb-2"><span data-i18n="membership.benefit_special_title">Beneficios Especiales</span></h3>
          <p class="text-black/70"><span data-i18n="membership.benefit_special_text">Tratamientos gratuitos y productos exclusivos</span></p>
        </div>
      </div>

      <CTAButton 
        href="/membership"
        variant="primary"
        className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200 bg-[#F3A2A7] text-white focus-visible:ring-[#F3A2A7]/50"
      >
        <span data-i18n="membership.view_membership">Conoce Nuestra Membresía</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </CTAButton>
    </div>
  </div>
</section>

<style>
  .icon-pink {
    filter: brightness(0) saturate(100%) invert(69%) sepia(22%) saturate(1624%) hue-rotate(309deg) brightness(96%) contrast(93%);
  }
</style>
