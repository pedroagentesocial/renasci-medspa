      <div class="reveal benefits-card relative" style="--reveal-delay: 280ms;">
        <div class="benefits-card-glow"></div>
        <div class="relative rounded-3xl border border-[#F3A2A7]/20 bg-white/90 p-6 shadow-[0_24px_60px_rgba(243,162,167,0.18)] backdrop-blur-sm sm:p-8">
          <div class="benefits-card-header mb-6 flex items-end justify-between gap-4 border-b border-black/[0.06] pb-5">
            <div>
              <span class="block text-[10px] font-semibold uppercase tracking-[0.32em] text-[#B76B71]" data-t-es="Tu plan incluye" data-t-en="Your plan includes">Tu plan incluye</span>
