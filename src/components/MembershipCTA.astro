  .membership-cta-v2 .tier-chip:hover {
    transform: translateY(-2px);
  }
  .membership-cta-v2 .tier-chip .tier-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
  }
  .membership-cta-v2 .tier-glow {
    background: #ffffff;
    color: #111;
    border: 1px solid rgba(243, 162, 167, 0.4);
