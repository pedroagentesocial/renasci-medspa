---
import ServicesShowcase from './ServicesShowcase.astro';
---

<section class="py-0 bg-white">
  <div class="max-w-none w-full px-0">
    <div class="space-y-0">
      <ServicesShowcase 
        title="Inyectables & Rellenos Dérmicos" 
        subtitle="Resultados naturales y prevención de arrugas"
        imageSrc="/img/services/Injection-general.jpg" 
        imageAlt="Sala de tratamiento Renasci"
        items={[
          { label: 'Neurotoxin Injections', href: '/services/neurotoxin-injections', icon: 'syringe' },
          { label: 'Botox Lip Flip', href: '/services/botox-lip-flip', icon: 'sparkle' },
          { label: 'Relleno de Labios', href: '/services/relleno-labios', icon: 'dropper' }
        ]}
        iconBgClass="bg-[#F3A2A7]"
        contentBgClass="bg-white"
        contentTextClass="text-black"
        titleKey="services.injectables_title"
        subtitleKey="services.injectables_subtitle"
      />

      <ServicesShowcase 
        title="Piel & PRP" 
        subtitle="PRP y renovación de la piel"
        imageSrc="/img/services/PRP-face.jpg" 
        imageAlt="Tratamientos de piel con PRP"
        items={[
          { label: 'PRP — Face + Neck', href: '/services/prp-face-neck', icon: 'dropper' },
          { label: 'PRP — Face + Neck + Décolleté', href: '/services/prp-face-neck-decollete', icon: 'dropper' },
          { label: 'PRP — Stretch Marks', href: '/services/prp-stretch-marks', icon: 'dropper' }
        ]}
        reverse={true}
        iconBgClass="bg-[#AABFA8]"
        contentBgClass="bg-white"
        contentTextClass="text-black"
        titleKey="services.skin_title"
        subtitleKey="services.skin_subtitle"
        
      />

      <ServicesShowcase 
        title="Body & Intimate"
        subtitle="Bienestar íntimo y recuperación"
        imageSrc="/img/services/Body-intimo-general.jpg.avif"
        imageAlt="Tratamientos corporales e íntimos"
        items={[
          { label: 'ChinBella', href: '/services/chinbella', icon: 'face' },
          { label: 'IV Drips', href: '/services/iv-drips', icon: 'dropper' },
          { label: 'IM Injections', href: '/services/im-injections', icon: 'syringe' }
        ]}
        iconBgClass="bg-[#C8A08C]"
        contentBgClass="bg-white"
        contentTextClass="text-black"
        titleKey="services.body_title"
        subtitleKey="services.body_subtitle"
      />
    </div>
  </div>
</section>
