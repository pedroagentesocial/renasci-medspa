---
export interface Props {
  title: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  highlight?: boolean;
  ctaText?: string;
  ctaHref?: string;
  class?: string;
}

const { 
  title,
  price,
  period = "mes",
  description,
  features,
  highlight = false,
  ctaText = "Elegir Plan",
  ctaHref = "#agendar",
  class: className = ''
} = Astro.props;
---

<div class={`tier-card group ${highlight ? 'tier-card--highlight' : ''} ${className}`}>
  <!-- Badge destacado -->
  {highlight && (
    <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
      <span class="bg-primary text-white px-6 py-2 rounded-full text-sm font-semibold shadow-lg">
        Más Popular
      </span>
    </div>
  )}
  
  <!-- Contenido de la tarjeta -->
  <div class="p-8 h-full flex flex-col">
    <!-- Header -->
    <div class="text-center mb-8">
      <h3 class="font-display font-bold text-2xl text-dark mb-2">
        {title}
      </h3>
      <p class="text-graytxt text-sm mb-6">
        {description}
      </p>
      
      <!-- Precio -->
      <div class="mb-6">
        <div class="flex items-baseline justify-center">
          <span class="text-4xl font-bold text-dark">
            {price}
          </span>
          <span class="text-graytxt text-lg ml-2">
            /{period}
          </span>
        </div>
      </div>
    </div>
    
    <!-- Features -->
    <div class="flex-1 mb-8">
      <ul class="space-y-4">
        {features.map((feature) => (
          <li class="flex items-start">
            <svg class="w-5 h-5 text-primary mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-dark text-sm leading-relaxed">
              {feature}
            </span>
          </li>
        ))}
      </ul>
    </div>
    
    <!-- CTA Button -->
    <div class="mt-auto">
      <a 
        href={ctaHref}
        class={`block w-full text-center py-4 px-6 rounded-lg font-semibold transition-all duration-300 ${
          highlight 
            ? 'bg-primary text-white hover:bg-primary/90 shadow-lg hover:shadow-xl transform hover:scale-105' 
            : 'bg-soft text-dark hover:bg-primary hover:text-white border-2 border-transparent hover:border-primary'
        }`}
      >
        {ctaText}
      </a>
    </div>
  </div>
</div>

<style>
  .tier-card {
    @apply relative bg-white rounded-xl shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-card;
  }
  
  .tier-card--highlight {
    @apply border-primary/30 shadow-lg;
    transform: scale(1.05);
  }
  
  .tier-card--highlight:hover {
    @apply shadow-xl;
    transform: scale(1.08);
  }
  
  .tier-card:not(.tier-card--highlight):hover {
    @apply -translate-y-2 shadow-card;
  }
</style>