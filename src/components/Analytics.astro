---
// Loads GA4, Google Ads conversion tracking, and GTM from env vars.
// Configure these in your Vercel project (Settings → Environment Variables):
//   PUBLIC_GA4_ID          → e.g. G-XXXXXXXXXX        (GA4 Measurement ID)
//   PUBLIC_GOOGLE_ADS_ID   → e.g. AW-1234567890       (Google Ads Conversion ID)
//   PUBLIC_GTM_ID          → e.g. GTM-XXXXXXX         (Google Tag Manager — optional)
//   PUBLIC_META_PIXEL_ID   → e.g. 1234567890123456    (Meta/Facebook Pixel — optional)
//
// Conversion events emitted across the site (capture in GA4 + Ads):
//   book_click             → "Agendar" / Boulevard widget triggers
//   contact_phone_click    → tel: link clicks
//   contact_email_click    → mailto: link clicks
//   contact_whatsapp_click → WhatsApp link clicks
//   contact_form_submit    → contact form successful submission

const GA4_ID = import.meta.env.PUBLIC_GA4_ID || 'G-QQBG46YQLQ';
const ADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID;
const GTM_ID = import.meta.env.PUBLIC_GTM_ID;
const META_PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID;
const analyticsEnabled = Boolean(GA4_ID || ADS_ID || GTM_ID || META_PIXEL_ID);
---

{analyticsEnabled && (
  <>
    {GTM_ID && (
      <script is:inline set:html={`
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start': new Date().getTime(),event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${GTM_ID}');
      `} />
    )}

    {(GA4_ID || ADS_ID) && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID || ADS_ID}`}></script>
    )}

    {(GA4_ID || ADS_ID) && (
      <script is:inline set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('consent', 'default', {
          'ad_storage': 'granted',
          'ad_user_data': 'granted',
          'ad_personalization': 'granted',
          'analytics_storage': 'granted'
        });
        ${GA4_ID ? `gtag('config', '${GA4_ID}', { 'anonymize_ip': true, 'send_page_view': true });` : ''}
        ${ADS_ID ? `gtag('config', '${ADS_ID}');` : ''}

        // Auto-tracking: phone, email, whatsapp, booking and form submission clicks
        document.addEventListener('DOMContentLoaded', function () {
          document.addEventListener('click', function (e) {
            var t = e.target;
            if (!t || !t.closest) return;
            var a = t.closest('a');
            if (!a) return;
            var href = (a.getAttribute('href') || '').toLowerCase();
            var booking = a.getAttribute('data-booking-trigger') === 'boulevard' || href.indexOf('joinblvd.com') !== -1;
            if (booking) {
              gtag('event', 'book_click', { event_category: 'engagement', value: 1 });
              ${ADS_ID ? `gtag('event', 'conversion', { send_to: '${ADS_ID}/BOOK_LABEL' });` : ''}
              return;
            }
            if (href.indexOf('tel:') === 0) {
              gtag('event', 'contact_phone_click', { event_category: 'engagement', value: 1 });
              ${ADS_ID ? `gtag('event', 'conversion', { send_to: '${ADS_ID}/CALL_LABEL' });` : ''}
              return;
            }
            if (href.indexOf('mailto:') === 0) {
              gtag('event', 'contact_email_click', { event_category: 'engagement', value: 1 });
              return;
            }
            if (href.indexOf('wa.me') !== -1 || href.indexOf('whatsapp') !== -1) {
              gtag('event', 'contact_whatsapp_click', { event_category: 'engagement', value: 1 });
              return;
            }
          }, { passive: true });

          document.addEventListener('submit', function (e) {
            var f = e.target;
            if (f && f.tagName === 'FORM') {
              gtag('event', 'contact_form_submit', { event_category: 'conversion', form_id: f.id || 'unknown' });
              ${ADS_ID ? `gtag('event', 'conversion', { send_to: '${ADS_ID}/FORM_LABEL' });` : ''}
            }
          }, { passive: true });
        });
      `} />
    )}

    {META_PIXEL_ID && (
      <script is:inline set:html={`
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window,document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '${META_PIXEL_ID}');
        fbq('track', 'PageView');
      `} />
    )}
  </>
)}

{GTM_ID && (
  <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`}></noscript>
)}
