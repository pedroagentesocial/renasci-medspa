---
const carouselItems = [
  { 
    title: { es: 'Inyecciones de Neurotoxina', en: 'Neurotoxin Injections' },
    href: '/services/neurotoxin-injections',
    image: '/img/services/neurotoxins.jpg',
    excerpt: { es: 'Suaviza líneas de expresión y arrugas dinámicas.', en: 'Smooth dynamic wrinkles and expression lines.' }
  },
  { 
    title: { es: 'Botox Lip Flip', en: 'Botox Lip Flip' },
    href: '/services/botox-lip-flip',
    image: '/img/services/Botox-Lip-Flip.jpg',
    excerpt: { es: 'Define el borde del labio superior con microinyecciones.', en: 'Defines upper lip border with micro-injections.' }
  },
  { 
    title: { es: 'Aumento Completo de Labios', en: 'Full Lip Augmentation' },
    href: '/services/full-lip-augmentation',
    image: '/img/services/Lip-filler-image.jpg',
    excerpt: { es: 'Volumen, hidratación y contorno natural de labios.', en: 'Natural lip volume, hydration and contour.' }
  },
  { 
    title: { es: 'Xeomin', en: 'Xeomin' },
    href: '/services/xeomin',
    image: '/img/services/Xeomin-botox.jpg.webp',
    excerpt: { es: 'Neuromodulador limpio para líneas del entrecejo y frente.', en: 'Purified neuromodulator for brow and forehead lines.' }
  },
  { 
    title: { es: 'Dysport', en: 'Dysport' },
    href: '/services/dysport',
    image: '/img/services/Dysport.webp',
    excerpt: { es: 'Cobertura amplia y rápida para líneas dinámicas.', en: 'Fast, wide-spread coverage for dynamic lines.' }
  },
  { 
    title: { es: 'ChinBella', en: 'ChinBella' },
    href: '/services/chinbella',
    image: '/img/services/Mini-Chin-Reduction.webp',
    excerpt: { es: 'Contorno mandibular y mentón más definido.', en: 'More defined jawline and chin contour.' }
  }
];

const items: any[] = carouselItems;

const labels = ['Más popular', 'Recomendado', 'Tendencia'];
---

<section class="bg-white text-black py-8 md:py-10">
  <div class="mx-auto max-w-7xl px-2 sm:px-4 lg:px-6">
    <div class="flex items-center justify-center mb-5">
      <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
      <span class="mx-4 inline-flex items-center justify-center w-8 h-8 rounded-full bg-[#F3A2A7] text-white">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3l2 5 5 2-5 2-2 5-2-5-5-2 5-2 2-5z" /></svg>
      </span>
      <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
    </div>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-black text-center mb-6"><span data-i18n="carousel.title">Servicios destacados del día</span></h2>

    <div id="carouselTrack" class="overflow-hidden relative" role="region" aria-live="polite" aria-label="Carrusel de servicios">
      <button id="carouselPrev" class="flex items-center justify-center absolute left-1 md:left-2 top-1/2 -translate-y-1/2 w-8 h-8 md:w-9 md:h-9 rounded-full bg-white/70 md:bg-white/80 text-black shadow hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50 z-10" aria-label="Anterior" title="Anterior">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button id="carouselNext" class="flex items-center justify-center absolute right-1 md:right-2 top-1/2 -translate-y-1/2 w-8 h-8 md:w-9 md:h-9 rounded-full bg-white/70 md:bg-white/80 text-black shadow hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50 z-10" aria-label="Siguiente" title="Siguiente">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
      <div class="mx-auto max-w-full px-2">
        <div id="carouselInner" class="flex transition-transform duration-700 ease-in-out will-change-transform">
        {items.map((svc: any, si: number) => (
          <div class="shrink-0 px-1">
            <div class="group bg-white rounded-2xl overflow-hidden ring-1 ring-black/5 shadow-[0_8px_24px_-8px_rgba(0,0,0,0.2)] hover:shadow-[0_16px_40px_-12px_rgba(0,0,0,0.25)] hover:ring-black/10 hover:-translate-y-[2px] transition-all duration-300 relative flex flex-col min-h-[300px] md:min-h-[360px] lg:min-h-[400px]">
              <a href={svc.href ?? (svc.slug ? `/services/${svc.slug}` : '#')} class="absolute inset-0 z-0" aria-label={typeof svc.title === 'string' ? svc.title : (svc.title?.es ?? svc.title?.en ?? 'Servicio')}></a>
              <div class="absolute top-2 right-2 z-10 inline-flex items-center gap-1 px-2 py-[3px] rounded-full bg-[#AABFA8] text-white text-[11px] font-semibold ring-1 ring-white/40">
                <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
                <span data-i18n={si % 3 === 0 ? 'carousel.label_popular' : si % 3 === 1 ? 'carousel.label_recommended' : 'carousel.label_trending'}>Más popular</span>
              </div>
              <div class="h-40 md:h-48 lg:h-56 overflow-hidden">
                <img src={(svc.image && svc.image.trim() !== '' ? svc.image : '/images/med-spa-room.jpg')} alt={(typeof svc.title === 'string' ? svc.title : (svc.title?.es ?? svc.title?.en ?? 'Servicio'))} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="p-3 md:p-4">
                <h3 class="font-semibold text-black text-sm">
                  <span 
                    class="carousel-title"
                    data-title-es={typeof svc.title === 'object' ? (svc.title.es ?? svc.title.en ?? 'Servicio') : (svc.title ?? 'Servicio')}
                    data-title-en={typeof svc.title === 'object' ? (svc.title.en ?? svc.title.es ?? 'Service') : (svc.title ?? 'Service')}
                  >
                    {typeof svc.title === 'object' ? (svc.title.es ?? svc.title.en ?? 'Servicio') : (svc.title ?? 'Servicio')}
                  </span>
                </h3>
                <p 
                  class="text-gray-600 text-sm mb-2 line-clamp-3 overflow-hidden carousel-desc"
                  data-excerpt-es={typeof svc.excerpt === 'object' ? svc.excerpt.es : (svc.excerpt ?? '')}
                  data-excerpt-en={typeof svc.excerpt === 'object' ? svc.excerpt.en : (svc.excerpt ?? '')}
                >{typeof svc.excerpt === 'object' ? svc.excerpt.es : (svc.excerpt ?? '')}</p>
                <a href={svc.href ?? (svc.slug ? `/services/${svc.slug}` : '#')} class="inline-flex items-center gap-1 text-[#F3A2A7] font-semibold text-sm hover:underline"><span data-i18n="carousel.view_more">Ver más</span><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12" /></svg></a>
        </div>
      </div>
      <div id="carouselDots" class="mt-3 flex justify-center gap-1.5 md:hidden"></div>
      <div id="carouselStatus" aria-live="polite" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;">Página 1</div>
    </div>
        ))}
      </div>
    </div>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('carouselTrack') as HTMLElement | null;
    const inner = document.getElementById('carouselInner') as HTMLElement | null;
    const dots = document.getElementById('carouselDots') as HTMLElement | null;
    const statusEl = document.getElementById('carouselStatus') as HTMLElement | null;
    if (!track || !inner) return;
    const slideCount = inner.children.length;
    let index = 0;
    let slideW = 0;
    let perView = 3;
    let maxIndex = 0;
    const sizeSlides = () => {
      const vw = track.clientWidth;
      perView = vw < 640 ? 1 : (vw < 1024 ? 2 : 3);
      slideW = Math.max(0, vw / perView);
      Array.from(inner.children).forEach((el) => { (el as HTMLElement).style.width = `${slideW}px`; });
      (inner as HTMLElement).style.width = `${slideW * slideCount}px`;
      maxIndex = Math.max(0, slideCount - perView);
      renderDots();
      updateDots();
    };
    const update = () => {
      inner.style.transform = `translateX(-${index * slideW}px)`;
      updateDots();
      if (statusEl) statusEl.textContent = `Página ${index + 1} de ${maxIndex + 1}`;
    };
    const step = () => {
      index = index + 1;
      if (index > maxIndex) index = 0;
      update();
    };
    sizeSlides();
    update();
  let timer = setInterval(step, 6000);
  let resumeTimeout: any = null;
  const resetAutoplay = () => { if (timer) clearInterval(timer); timer = setInterval(step, 6000); };
  const pauseAutoplay = () => { if (timer) { clearInterval(timer); timer = null; } if (resumeTimeout) { clearTimeout(resumeTimeout); resumeTimeout = null; } };
  const scheduleResume = (delay = 3000) => { if (resumeTimeout) clearTimeout(resumeTimeout); resumeTimeout = setTimeout(() => { resetAutoplay(); }, delay); };
  const prevBtn = document.getElementById('carouselPrev');
  const nextBtn = document.getElementById('carouselNext');
  function prev() {
    const maxIndex = Math.max(0, slideCount - perView);
    index = index - 1;
    if (index < 0) index = maxIndex;
    update();
    resetAutoplay();
  }
  function next() {
    step();
    resetAutoplay();
  }
  prevBtn?.addEventListener('click', prev);
  nextBtn?.addEventListener('click', next);

  track.addEventListener('mouseenter', () => { pauseAutoplay(); });
  track.addEventListener('mouseleave', () => { scheduleResume(2500); });
  track.addEventListener('focusin', () => { pauseAutoplay(); });
  track.addEventListener('focusout', () => { scheduleResume(2500); });
  track.addEventListener('touchstart', () => { pauseAutoplay(); }, { passive: true } as any);
  track.addEventListener('touchend', () => { scheduleResume(3000); }, { passive: true } as any);
  track.addEventListener('pointerdown', () => { pauseAutoplay(); });
  track.addEventListener('pointerup', () => { scheduleResume(3000); });
  track.addEventListener('keydown', (e: any) => {
    const k = (e as KeyboardEvent).key;
    if (k === 'ArrowLeft') { e.preventDefault(); prev(); }
    if (k === 'ArrowRight') { e.preventDefault(); next(); }
  });
  track.setAttribute('tabindex', '0');
  function renderDots() {
    if (!dots) return;
    const pages = maxIndex + 1;
    const currentChildren = Array.from(dots.children);
    if (currentChildren.length === pages) return;
    dots.innerHTML = '';
    for (let i = 0; i < pages; i++) {
      const b = document.createElement('button');
      b.setAttribute('type', 'button');
      b.setAttribute('aria-label', `Ir a página ${i + 1}`);
      b.className = 'w-2.5 h-2.5 rounded-full bg-black/20';
      b.addEventListener('click', () => { index = i; update(); resetAutoplay(); });
      dots.appendChild(b);
    }
  }
  function updateDots() {
    if (!dots) return;
    const children = Array.from(dots.children) as HTMLElement[];
    children.forEach((el, i) => {
      el.className = 'w-2.5 h-2.5 rounded-full ' + (i === index ? 'bg-[#F3A2A7]' : 'bg-black/20');
    });
  }
    window.addEventListener('resize', () => { sizeSlides(); index = 0; update(); });

    // Sincronizar descripciones con el idioma activo
    const applyDescLanguage = (lang) => {
      const nodes = Array.from(document.querySelectorAll('.carousel-desc'));
      nodes.forEach((node) => {
        const es = node.getAttribute('data-excerpt-es') || '';
        const en = node.getAttribute('data-excerpt-en') || '';
        node.textContent = lang === 'en' ? (en || es) : (es || en);
      });
    };
    const applyTitleLanguage = (lang) => {
      const nodes = Array.from(document.querySelectorAll('.carousel-title'));
      nodes.forEach((node) => {
        const es = node.getAttribute('data-title-es') || '';
        const en = node.getAttribute('data-title-en') || '';
        node.textContent = lang === 'en' ? (en || es) : (es || en);
      });
    };
    const currentLang = window.i18nManager?.getCurrentLanguage?.() || document.documentElement.lang || 'es';
    applyDescLanguage(currentLang);
    applyTitleLanguage(currentLang);
    window.addEventListener('languageChanged', (e) => {
      const l = e.detail?.language || 'es';
      applyDescLanguage(l);
      applyTitleLanguage(l);
    });
  });
</script>
