---
export interface Props {
  name: string;
  description: string;
  category?: string;
  price?: string;
  duration?: string;
  provider?: string;
  areaServed?: string;
  url?: string;
  image?: string;
  offers?: {
    price?: string;
    priceCurrency?: string;
    availability?: string;
  };
}

const {
  name,
  description,
  category = "Medical Spa Service",
  price,
  duration,
  provider = "Renasci Medical Spa",
  areaServed = "Utah, United States",
  url = "https://tu-dominio.com/",
  image = "https://tu-dominio.com/og-image.jpg",
  offers
} = Astro.props;

const schemaData = {
  "@context": "https://schema.org", <mcreference link="https://schema.org" index="0">0</mcreference>
  "@type": "Service",
  "name": name,
  "description": description,
  "category": category,
  "provider": {
    "@type": "MedicalBusiness",
    "name": provider,
    "url": url
  },
  "areaServed": {
    "@type": "Place",
    "name": areaServed
  },
  "url": url,
  "image": image,
  ...(duration && {
    "duration": duration
  }),
  ...(offers && {
    "offers": {
      "@type": "Offer",
      "price": offers.price,
      "priceCurrency": offers.priceCurrency || "USD",
      "availability": offers.availability || "https://schema.org/InStock",
      "validFrom": new Date().toISOString().split('T')[0]
    }
  }),
  "serviceType": category,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": `${name} - ${provider}`,
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": name,
          "description": description
        },
        ...(price && {
          "price": price,
          "priceCurrency": "USD"
        })
      }
    ]
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>