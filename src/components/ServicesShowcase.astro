---
export interface Item {
  label: string;
  href: string;
  icon?: 'syringe' | 'dropper' | 'sparkle' | 'face' | 'laser' | 'heart';
}

export interface Props {
  title: string;
  subtitle?: string;
  imageSrc: string;
  imageAlt: string;
  items: Item[];
  reverse?: boolean;
  iconBgClass?: string;
  contentBgClass?: string;
  contentTextClass?: string;
  titleKey?: string;
  subtitleKey?: string;
}

const {
  title,
  subtitle = '',
  imageSrc,
  imageAlt,
  items = [],
  reverse = false,
  iconBgClass = 'bg-black',
  contentBgClass = 'bg-text',
  contentTextClass = 'text-white',
  titleKey = '',
  subtitleKey = ''
} = Astro.props;
---

<div class={`grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch`}>
  <div class={`order-1 ${reverse ? 'lg:order-2' : 'lg:order-1'}`}>
    <img src={imageSrc} alt={imageAlt} class="w-full h-96 lg:h-[500px] object-cover" loading="lazy" />
  </div>

  <div class={`order-2 ${reverse ? 'lg:order-1' : 'lg:order-2'} ${contentBgClass} ${contentTextClass} p-8 flex flex-col justify-center items-center text-center shadow-xl`}>
    <h3 class="font-display font-bold text-2xl md:text-3xl lg:text-4xl mb-3">
      {titleKey ? <span data-i18n={titleKey}>{title}</span> : title}
    </h3>
    <div class={`mx-auto mb-4 h-[3px] w-16 md:w-24 ${iconBgClass} rounded-full`}></div>
    {subtitle && (
      <p class={`${contentTextClass === 'text-white' ? 'text-white/80' : 'text-black/70'} mb-6`}>
        {subtitleKey ? <span data-i18n={subtitleKey}>{subtitle}</span> : subtitle}
      </p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-0">
      {items.slice(0,3).map((item) => (
        <div class="group flex flex-col items-center gap-3 p-3">
          <a 
            href={item.href} 
            aria-label={item.label}
            class={`${iconBgClass} inline-flex items-center justify-center w-16 h-16 rounded-full text-white transition-all duration-200 hover:opacity-95 hover:scale-[1.06]`}
          >
            {item.icon === 'syringe' ? (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 2l4 4m-2-2l-7.5 7.5M14 6l4 4M3 21l6-6m-4 4l4-4" />
              </svg>
            ) : item.icon === 'dropper' ? (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-7 7m0 0l-3 6 6-3m-3-3l-4-4 4-4 4 4" />
              </svg>
            ) : item.icon === 'sparkle' ? (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3l2 5 5 2-5 2-2 5-2-5-5-2 5-2 2-5z" />
              </svg>
            ) : item.icon === 'face' ? (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <circle cx="12" cy="12" r="7" stroke-width="2" />
                <path stroke-width="2" d="M9 14c1.5 1 4.5 1 6 0" />
                <circle cx="9" cy="10" r="1" />
                <circle cx="15" cy="10" r="1" />
              </svg>
            ) : item.icon === 'laser' ? (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h12M15 12l6-3m-6 3l6 3" />
              </svg>
            ) : (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6l3 3-3 3-3-3 3-3zm0 6l3 3-3 3-3-3 3-3z" />
              </svg>
            )}
          </a>
          <span class="text-base md:text-lg font-semibold text-center">{item.label}</span>
      </div>
    ))}
  </div>
</div>
</div>
