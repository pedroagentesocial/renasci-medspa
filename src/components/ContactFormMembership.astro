---
import CTAButton from './CTAButton.astro';
---

<!-- Formulario de Contacto Interactivo -->
<section id="contacto" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="flex items-center justify-center mb-6">
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
          <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">•</span>
          <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-text mb-6">
          ¿Listo para <span class="text-[#F3A2A7]">Comenzar</span>?
        </h2>
        <p class="text-xl text-graytxt max-w-3xl mx-auto">
          Agenda tu consulta gratuita y descubre qué plan de membresía es perfecto para ti. Nuestro equipo te ayudará a crear un plan personalizado.
        </p>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Información de contacto -->
        <div class="space-y-8">
          <div class="contact-info-item flex items-start space-x-4 p-6 bg-[#F3A2A7]/5 rounded-2xl hover:bg-[#F3A2A7]/10 transition-all duration-300">
            <div class="w-12 h-12 bg-[#F3A2A7] rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-text mb-2">Llámanos</h3>
              <p class="text-graytxt mb-2">Habla directamente con nuestro equipo</p>
              <a href="tel:+13856092840" class="text-[#F3A2A7] font-semibold hover:opacity-80 transition-colors">385 609 2840</a>
            </div>
          </div>
          
          <div class="contact-info-item flex items-start space-x-4 p-6 bg-[#AABFA8]/5 rounded-2xl hover:bg-[#AABFA8]/10 transition-all duration-300">
            <div class="w-12 h-12 bg-[#AABFA8] rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-text mb-2">Visítanos</h3>
              <p class="text-graytxt mb-2">Ven a conocer nuestras instalaciones</p>
              <p class="text-[#F3A2A7] font-semibold">6770 S 900 E, Midvale, UT 84047</p>
            </div>
          </div>
          
          <div class="contact-info-item flex items-start space-x-4 p-6 bg-[#F3A2A7]/5 rounded-2xl hover:bg-[#F3A2A7]/10 transition-all duration-300">
            <div class="w-12 h-12 bg-[#F3A2A7] rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-text mb-2">Horarios</h3>
              <p class="text-graytxt mb-2">Lun - Vie: 9:00 AM - 7:00 PM</p>
              <p class="text-graytxt">Sáb - Dom: 10:00 AM - 6:00 PM</p>
            </div>
          </div>
        </div>
        
        <!-- Formulario -->
        <div class="bg-white rounded-3xl shadow-xl p-8 border border-gray-100">
          <form class="contact-form space-y-6" id="membershipForm">
            <div class="grid md:grid-cols-2 gap-4">
              <div class="form-group">
                <label class="block text-sm font-semibold text-text mb-2">Nombre completo</label>
                <input 
                  type="text" 
                  name="name"
                  class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#F3A2A7] focus:ring-2 focus:ring-[#F3A2A7]/20 outline-none transition-all duration-300"
                  placeholder="Tu nombre completo"
                  required
                />
                <div class="form-validation hidden text-red-500 text-sm mt-1"></div>
              </div>
              
              <div class="form-group">
                <label class="block text-sm font-semibold text-text mb-2">Teléfono</label>
                <input 
                  type="tel" 
                  name="phone"
                  class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#F3A2A7] focus:ring-2 focus:ring-[#F3A2A7]/20 outline-none transition-all duration-300"
                  placeholder="385 609 2840"
                  required
                />
                <div class="form-validation hidden text-red-500 text-sm mt-1"></div>
              </div>
            </div>
            
            <div class="form-group">
              <label class="block text-sm font-semibold text-text mb-2">Email</label>
              <input 
                type="email" 
                name="email"
                class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#F3A2A7] focus:ring-2 focus:ring-[#F3A2A7]/20 outline-none transition-all duration-300"
                placeholder="tu@email.com"
                required
              />
              <div class="form-validation hidden text-red-500 text-sm mt-1"></div>
            </div>
            
            <div class="form-group">
              <label class="block text-sm font-semibold text-text mb-2">Plan de interés</label>
              <select 
                name="plan"
                class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all duration-300"
                required
              >
                <option value="">Selecciona tu plan de interés</option>
                <option value="rack">Plan Rack - $99/mes</option>
                <option value="glow">Plan Glow - $199/mes (Recomendado)</option>
                <option value="elite">Plan Elite - $399/mes</option>
                <option value="consulta">Solo consulta informativa</option>
              </select>
              <div class="form-validation hidden text-red-500 text-sm mt-1"></div>
            </div>
            
            <div class="form-group">
              <label class="block text-sm font-semibold text-text mb-2">Mensaje (opcional)</label>
              <textarea 
                name="message"
                rows="4"
                class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#F3A2A7] focus:ring-2 focus:ring-[#F3A2A7]/20 outline-none transition-all duration-300 resize-none"
                placeholder="Cuéntanos sobre tus objetivos de belleza o cualquier pregunta específica..."
              ></textarea>
            </div>
            
            <div class="flex items-start gap-3">
              <input type="checkbox" id="consent-membership" name="consent" required class="mt-1 w-5 h-5 rounded border-2 border-[#F3A2A7] focus:ring-2 focus:ring-[#F3A2A7]" />
              <label for="consent-membership" class="text-sm text-graytxt">
                Acepto ser contactado y el tratamiento de mis datos de acuerdo a la <a href="/privacy" class="text-[#F3A2A7] hover:opacity-80 transition-colors">Política de Privacidad</a>.
              </label>
            </div>
            <p class="text-xs text-graytxt mt-2 text-center">Al ingresar tu número de teléfono, aceptas recibir mensajes de texto de nuestra parte. Pueden aplicar cargos por mensajes y datos. La frecuencia de mensajes puede variar. Responde AYUDA para más información. Puedes responder ALTO o CANCELAR para darte de baja. / By entering your phone number, you are agreeing to receive text messages from us. Message & data rates may apply. Message frequency may vary. Reply HELP for more information. You can reply STOP or UNSUBSCRIBE to opt-out.</p>
            
            <CTAButton 
              type="submit"
              variant="primary"
              className="w-full py-4 text-lg font-semibold ripple-effect focus-visible:ring-[#F3A2A7]/50"
            >
              <span class="submit-text">Solicitar Consulta Gratuita</span>
              <span class="loading-text hidden">Enviando...</span>
            </CTAButton>
            
            
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Efecto ripple para botones
  function initRippleEffect() {
    document.querySelectorAll('.ripple-effect').forEach(button => {
      button.addEventListener('click', function(e) {
        const ripple = document.createElement('span');
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;
        
        ripple.style.width = size + 'px';
        ripple.style.height = size + 'px';
        ripple.style.left = x + 'px';
        ripple.style.top = y + 'px';
        ripple.classList.add('ripple');
        
        this.appendChild(ripple);
        
        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    });
  }

  // Validación de formulario
  function initFormValidation() {
    const form = document.getElementById('membershipForm');
    if (!form) return;

    const inputs = form.querySelectorAll('.form-input');
    
    inputs.forEach(input => {
      input.addEventListener('blur', validateField);
      input.addEventListener('input', clearValidation);
    });

    form.addEventListener('submit', handleFormSubmit);
  }

  function validateField(e) {
    const field = e.target;
    const value = field.value.trim();
    const validation = field.parentNode?.querySelector('.form-validation');
    
    let isValid = true;
    let message = '';

    if (field.hasAttribute('required') && !value) {
      isValid = false;
      message = 'Este campo es requerido';
    } else if (field.type === 'email' && value && !isValidEmail(value)) {
      isValid = false;
      message = 'Por favor ingresa un email válido';
    } else if (field.type === 'tel' && value && !isValidPhone(value)) {
      isValid = false;
      message = 'Por favor ingresa un teléfono válido';
    }

    if (isValid) {
      field.classList.remove('border-red-500');
      field.classList.add('border-green-500');
      validation?.classList.add('hidden');
    } else {
      field.classList.remove('border-green-500');
      field.classList.add('border-red-500');
      if (validation) {
        validation.textContent = message;
        validation.classList.remove('hidden');
      }
    }

    return isValid;
  }

  function clearValidation(e) {
    const field = e.target;
    const validation = field.parentNode?.querySelector('.form-validation');
    
    field.classList.remove('border-red-500', 'border-green-500');
    validation?.classList.add('hidden');
  }

  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function isValidPhone(phone) {
    return /^[\+]?[1-9][\d]{0,15}$/.test(phone.replace(/[\s\-\(\)]/g, ''));
  }

  async function handleFormSubmit(e) {
    e.preventDefault();
    
    const form = e.target;
    const inputs = form.querySelectorAll('.form-input[required]');
    const submitBtn = form.querySelector('button[type="submit"]');
    const submitText = submitBtn?.querySelector('.submit-text');
    const loadingText = submitBtn?.querySelector('.loading-text');
    
    let isFormValid = true;
    
    // Validar todos los campos requeridos
    inputs.forEach(input => {
      const mockEvent = { target: input };
      if (!validateField(mockEvent)) {
        isFormValid = false;
      }
    });

    if (!isFormValid) {
      return;
    }

    // Mostrar estado de carga
    if (submitBtn) {
      submitBtn.disabled = true;
      submitText?.classList.add('hidden');
      loadingText?.classList.remove('hidden');
    }

    try {
      // Simular envío del formulario
      await new Promise(resolve => setTimeout(resolve, 2000));
      
      // Mostrar mensaje de éxito
      form.innerHTML = `
        <div class="text-center py-8">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-text mb-2">¡Solicitud Enviada!</h3>
          <p class="text-graytxt mb-4">Nos pondremos en contacto contigo dentro de las próximas 24 horas para agendar tu consulta gratuita.</p>
          <p class="text-sm text-graytxt">También puedes llamarnos directamente al <a href="tel:+13856092840" class="text-primary font-semibold">385 609 2840</a></p>
        </div>
      `;
    } catch (error) {
      console.error('Error al enviar formulario:', error);
      
      // Restaurar estado del botón
      if (submitBtn) {
        submitBtn.disabled = false;
        submitText?.classList.remove('hidden');
        loadingText?.classList.add('hidden');
      }
    }
  }

  // Animaciones para elementos de contacto
  function initContactAnimations() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, observerOptions);

    // Observar elementos animables
    document.querySelectorAll('.contact-info-item').forEach(el => {
      observer.observe(el);
    });
  }

  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    initRippleEffect();
    initFormValidation();
    initContactAnimations();
  });
</script>

<style>
  .contact-info-item {
    opacity: 0;
    transform: translateX(-30px);
    transition: all 0.6s ease-out;
  }

  .contact-info-item.animate-in {
    opacity: 1;
    transform: translateX(0);
  }

  .contact-info-item:nth-child(2) {
    transition-delay: 0.2s;
  }

  .contact-info-item:nth-child(3) {
    transition-delay: 0.4s;
  }

  .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    transform: scale(0);
    animation: ripple-animation 0.6s linear;
    pointer-events: none;
  }

  @keyframes ripple-animation {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }
</style>
