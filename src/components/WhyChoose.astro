---
// Componente para la sección "¿Por qué elegir Renasci?"
---

<!-- Sección de Beneficios con Iconos Animados -->
<section class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-display font-bold text-4xl md:text-5xl text-text mb-6">
        ¿Por qué elegir <span class="text-primary">Renasci</span>?
      </h2>
      <p class="text-xl text-graytxt max-w-3xl mx-auto">
        Más que un spa, somos tu partner en el journey hacia tu mejor versión
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Beneficio 1 -->
      <div class="benefit-card group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-primary/20">
        <div class="benefit-icon w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-all duration-300">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
          </svg>
        </div>
        <h3 class="font-bold text-xl text-text mb-4">Descuentos Exclusivos</h3>
        <p class="text-graytxt leading-relaxed">Hasta 30% de descuento en todos nuestros servicios y productos premium</p>
      </div>
      
      <!-- Beneficio 2 -->
      <div class="benefit-card group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-primary/20">
        <div class="benefit-icon w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-all duration-300">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-xl text-text mb-4">Acceso Prioritario</h3>
        <p class="text-graytxt leading-relaxed">Reserva tus citas con prioridad y accede a horarios exclusivos para miembros</p>
      </div>
      
      <!-- Beneficio 3 -->
      <div class="benefit-card group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-primary/20">
        <div class="benefit-icon w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-all duration-300">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-xl text-text mb-4">Atención Personalizada</h3>
        <p class="text-graytxt leading-relaxed">Plan de tratamiento personalizado y seguimiento continuo de tus resultados</p>
      </div>
      
      <!-- Beneficio 4 -->
      <div class="benefit-card group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-primary/20">
        <div class="benefit-icon w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-all duration-300">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-xl text-text mb-4">Productos Premium</h3>
        <p class="text-graytxt leading-relaxed">Kit completo de productos para el hogar y acceso a líneas exclusivas</p>
      </div>
      
      <!-- Beneficio 5 -->
      <div class="benefit-card group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-primary/20">
        <div class="benefit-icon w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-all duration-300">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-xl text-text mb-4">Comunidad Exclusiva</h3>
        <p class="text-graytxt leading-relaxed">Eventos especiales, workshops y acceso a nuestra comunidad VIP</p>
      </div>
      
      <!-- Beneficio 6 -->
      <div class="benefit-card group bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-primary/20">
        <div class="benefit-icon w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-all duration-300">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 109.75 9.75A9.75 9.75 0 0012 2.25z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-xl text-text mb-4">Soporte 24/7</h3>
        <p class="text-graytxt leading-relaxed">Atención personalizada cuando la necesites, con soporte dedicado para miembros</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Animaciones para las tarjetas de beneficios
  function initBenefitAnimations() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          // Añadir delay escalonado para cada tarjeta
          setTimeout(() => {
            entry.target.classList.add('animate-in');
          }, index * 100);
        }
      });
    }, observerOptions);

    // Observar elementos animables
    document.querySelectorAll('.benefit-card').forEach(el => {
      observer.observe(el);
    });
  }

  // Efecto de hover mejorado para iconos
  function initIconHoverEffects() {
    document.querySelectorAll('.benefit-icon').forEach(icon => {
      const card = icon.closest('.benefit-card');
      
      card.addEventListener('mouseenter', () => {
        icon.style.transform = 'scale(1.1) rotate(5deg)';
      });
      
      card.addEventListener('mouseleave', () => {
        icon.style.transform = 'scale(1) rotate(0deg)';
      });
    });
  }

  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    initBenefitAnimations();
    initIconHoverEffects();
  });
</script>

<style>
  .benefit-card {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease-out;
  }

  .benefit-card.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .benefit-icon {
    transition: transform 0.3s ease;
  }

  .benefit-card:hover .benefit-icon svg {
    transform: scale(1.1);
    transition: transform 0.3s ease;
  }

  /* Efecto de brillo sutil en hover */
  .benefit-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(var(--primary-rgb), 0.1), transparent);
    transition: left 0.5s;
  }

  .benefit-card:hover::before {
    left: 100%;
  }

  /* Animación de pulso para los iconos */
  @keyframes icon-pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  .benefit-card:hover .benefit-icon {
    animation: icon-pulse 2s ease-in-out infinite;
  }
</style>