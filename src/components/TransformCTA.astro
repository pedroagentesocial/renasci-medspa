---
import CTAButton from './CTAButton.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  phoneNumber?: string;
  phoneDisplay?: string;
}

const {
  title = "¿Listo para Transformarte?",
  subtitle = "Agenda tu consulta gratuita hoy y descubre cómo podemos ayudarte a alcanzar tus objetivos estéticos con tratamientos personalizados.",
  primaryButtonText = "Agendar Consulta Gratuita",
  primaryButtonHref = "/contact",
  phoneNumber = "+18019967427",
  phoneDisplay = "(801) 996-7427"
} = Astro.props;
---

<!-- Contact CTA Section -->
<section class="py-16 lg:py-24 bg-white text-black">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="flex items-center justify-center mb-6">
      <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
      <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
        </svg>
      </span>
      <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
    </div>
    <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl mb-6">
      <span class="text-[#F3A2A7]" data-i18n="transform.title">{title}</span>
    </h2>
    <p class="text-lg md:text-xl text-gray-700 mb-8 max-w-3xl mx-auto leading-relaxed">
      <span data-i18n="transform.subtitle">{subtitle}</span>
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <CTAButton 
        href={primaryButtonHref}
        variant="primary"
        className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200 !bg-[#F3A2A7] focus-visible:ring-[#F3A2A7]/50"
      >
        <span data-i18n="transform.primary_cta">{primaryButtonText}</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
      </CTAButton>
      
      <a 
        href={`tel:${phoneNumber}`}
        class="call-cta-button inline-flex items-center gap-3 px-8 py-4 bg-[#1DD1A1] text-white rounded-[48px] font-semibold text-lg transition-all duration-200 hover:opacity-90 hover:-translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1DD1A1]/50 animate-pulse-soft"
        aria-label="Llamar Renasci"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        {phoneDisplay}
      </a>
    </div>
  </div>
</section>

<script>
  // Ripple effect for call button
  document.addEventListener('DOMContentLoaded', function() {
    const callButton = document.querySelector('.call-cta-button');
    if (callButton) {
      callButton.addEventListener('click', function(e) {
        const ripple = document.createElement('span');
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;
        
        ripple.style.width = ripple.style.height = size + 'px';
        ripple.style.left = x + 'px';
        ripple.style.top = y + 'px';
        ripple.classList.add('ripple');
        
        this.appendChild(ripple);
        
        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    }
  });
</script>

<style>
  .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: scale(0);
    animation: ripple-animation 0.6s linear;
    pointer-events: none;
  }
  
  @keyframes ripple-animation {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }
</style>
