---
import CTAButton from './CTAButton.astro';

export interface Props {
  titleEs?: string;
  titleEn?: string;
  primaryButtonTextEs?: string;
  primaryButtonTextEn?: string;
  primaryButtonHref?: string;
  phoneDisplay?: string;
  imageSrc?: string;
  imageAltEs?: string;
  imageAltEn?: string;
}

const {
  titleEs = "¿Lista para transformar?",
  titleEn = "Ready to Transform?",
  primaryButtonTextEs = "Agendar",
  primaryButtonTextEn = "Book",
  primaryButtonHref = "/contact",
  phoneDisplay = "385 609 2840",
  imageSrc = "/img/services/transform.JPG",
  imageAltEs = "Consulta en Renasci",
  imageAltEn = "Renasci consultation"
} = Astro.props;
---

<section class="transform-cta py-0 text-black">
  <div class="w-full">
    <div class="grid lg:grid-cols-[60%_40%] gap-0 items-stretch">
      <div class="relative w-full h-full min-h-[360px] lg:min-h-[520px] bg-cover bg-center" style={`background-image: url(${imageSrc})`} aria-label={imageAltEs} data-aria-es={imageAltEs} data-aria-en={imageAltEn}></div>
      <div class="flex items-center justify-end">
        <div class="w-full text-right px-6 sm:px-8 lg:px-12 py-10 lg:py-14">
          <h2 class="font-display font-semibold text-2xl md:text-3xl lg:text-4xl mb-4 text-[#F3A2A7]">
            <span data-t-es={titleEs} data-t-en={titleEn}>{titleEs}</span>
          </h2>
          <div class="text-4xl md:text-5xl lg:text-6xl text-black font-semibold mb-8">{phoneDisplay}</div>
          <CTAButton 
            href={primaryButtonHref}
            variant="primary"
            className="inline-flex items-center gap-2 hover:gap-3 transition-all duration-200 !bg-[#F3A2A7] focus-visible:ring-[#F3A2A7]/50 !px-10 !py-4 !text-lg"
          >
            <span data-t-es={primaryButtonTextEs} data-t-en={primaryButtonTextEn}>{primaryButtonTextEs}</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </CTAButton>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const getTransformCtaLang = () => {
    const params = new URLSearchParams(window.location.search);
    const urlLang = params.get('lang');
    if (urlLang === 'en' || urlLang === 'es') return urlLang;
    const storedLang = localStorage.getItem('renasci-language') || localStorage.getItem('language');
    if (storedLang === 'en' || storedLang === 'es') return storedLang;
    const managerLang = window.i18nManager?.getCurrentLanguage?.();
    if (managerLang === 'en' || managerLang === 'es') return managerLang;
    return document.documentElement.lang === 'en' ? 'en' : 'es';
  };

  const applyTransformCtaLang = (lang) => {
    document.querySelectorAll('.transform-cta [data-t-es]').forEach((el) => {
      const es = el.getAttribute('data-t-es') || '';
      const en = el.getAttribute('data-t-en') || es;
      el.textContent = lang === 'en' ? en : es;
    });
    document.querySelectorAll('.transform-cta [data-aria-es]').forEach((el) => {
      const es = el.getAttribute('data-aria-es') || '';
      const en = el.getAttribute('data-aria-en') || es;
      el.setAttribute('aria-label', lang === 'en' ? en : es);
    });
  };

  const initTransformCtaLang = () => applyTransformCtaLang(getTransformCtaLang());
  document.addEventListener('DOMContentLoaded', initTransformCtaLang);
  document.addEventListener('astro:page-load', initTransformCtaLang);
  window.addEventListener('languageChanged', (e) => {
    const lang = e?.detail?.language || getTransformCtaLang();
    applyTransformCtaLang(lang);
  });
</script>
