---
export interface Props {
  question: string;
  answer: string;
  isOpen?: boolean;
  class?: string;
  questionKey?: string;
  answerKey?: string;
  questionEs?: string;
  questionEn?: string;
  answerEs?: string;
  answerEn?: string;
}

const { 
  question, 
  answer, 
  isOpen = false,
  class: className = '',
  questionKey = '',
  answerKey = '',
  questionEs = '',
  questionEn = '',
  answerEs = '',
  answerEn = ''
} = Astro.props;

// Generar ID único para accesibilidad
const faqId = `faq-${Math.random().toString(36).substr(2, 9)}`;
const hasBilingualQuestion = questionEs !== '' || questionEn !== '';
const hasBilingualAnswer = answerEs !== '' || answerEn !== '';
---

<div class={`faq-item border-b border-gray-100 ${className}`}>
  <button 
    class="faq-trigger w-full py-5 sm:py-6 flex items-center justify-between text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50 focus-visible:ring-offset-2 rounded-lg"
    aria-expanded={isOpen}
    aria-controls={`${faqId}-content`}
    data-faq-trigger
  >
    <h3 class="font-display font-semibold text-lg text-dark pr-4 leading-relaxed">
      {questionKey ? (
        <span data-i18n={questionKey}>{question}</span>
      ) : hasBilingualQuestion ? (
        <span data-t-es={questionEs || question} data-t-en={questionEn || questionEs || question}>{questionEs || question}</span>
      ) : (
        question
      )}
    </h3>
    
    <div class="faq-icon flex-shrink-0 w-7 h-7 sm:w-6 sm:h-6 text-[#F3A2A7] transition-transform duration-300">
      <svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          stroke-width="2" 
          d="M12 6v6m0 0v6m0-6h6m-6 0H6"
        ></path>
      </svg>
    </div>
  </button>
  
  <div 
    id={`${faqId}-content`}
    class="faq-content overflow-hidden transition-all duration-300 ease-in-out"
    style={isOpen ? 'max-height: 200px; opacity: 1;' : 'max-height: 0; opacity: 0;'}
    aria-hidden={!isOpen}
  >
    <div class="pb-6 pr-10">
      <p class="text-graytxt leading-relaxed">
        {answerKey ? (
          <span data-i18n={answerKey}>{answer}</span>
        ) : hasBilingualAnswer ? (
          <span data-t-es={answerEs || answer} data-t-en={answerEn || answerEs || answer}>{answerEs || answer}</span>
        ) : (
          answer
        )}
      </p>
    </div>
  </div>
</div>

<script>
  // FAQ Accordion functionality
  function setupFAQs() {
    const faqTriggers = document.querySelectorAll('[data-faq-trigger]');
    
    faqTriggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const content = trigger.nextElementSibling as HTMLElement | null;
        const icon = trigger.querySelector('.faq-icon svg') as SVGElement | null;
        if (!content || !icon) {
          return;
        }
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        
        // Cerrar todos los otros FAQs (opcional - para acordeón exclusivo)
        // faqTriggers.forEach(otherTrigger => {
        //   if (otherTrigger !== this) {
        //     const otherContent = otherTrigger.nextElementSibling;
        //     const otherIcon = otherTrigger.querySelector('.faq-icon svg');
        //     otherTrigger.setAttribute('aria-expanded', 'false');
        //     otherContent.setAttribute('aria-hidden', 'true');
        //     otherContent.style.maxHeight = '0';
        //     otherContent.style.opacity = '0';
        //     otherIcon.style.transform = 'rotate(0deg)';
        //   }
        // });
        
        if (isOpen) {
          trigger.setAttribute('aria-expanded', 'false');
          content.setAttribute('aria-hidden', 'true');
          content.style.maxHeight = '0';
          content.style.opacity = '0';
          icon.style.transform = 'rotate(0deg)';
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          content.setAttribute('aria-hidden', 'false');
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          icon.style.transform = 'rotate(45deg)';
        }
      });
    });
  }
  
  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', setupFAQs);
  
  // Re-inicializar si se cargan nuevos FAQs dinámicamente
  document.addEventListener('astro:page-load', setupFAQs);
</script>

<style>
  .faq-item:last-child {
    @apply border-b-0;
  }
  
  .faq-trigger:hover .faq-icon {
    color: #F3A2A7;
    opacity: 0.8;
  }
  
  .faq-content {
    transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
  }
</style>
