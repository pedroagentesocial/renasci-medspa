---
import CTAButton from './CTAButton.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

// Helper function to generate category URLs
function generateCategoryUrl(categoryGroup) {
  const replacements = { 'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u' };
  return `/services/category/${categoryGroup
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[áéíóú]/g, (match) => replacements[match] || match)}`;
}

const links = [
  { href: "/membership", label: "Membresía", key: "nav.membership" },
  { href: "/about", label: "Nosotros", key: "nav.about" },
  { href: "/contact", label: "Contacto", key: "nav.contact" },
  { href: "/services", label: "Servicios", key: "nav.services", mega: true }
];

const services = [
  { 
    group: "Inyecciones", 
    items: [
      { t: "Inyecciones de Neurotoxina Tox", href: "/services/tox-neurotoxina", price: "$12/unidad" },
      { t: "Tratamiento Botox No-Sweat (sudoración)", href: "/services/botox-no-sweat", price: "$850" },
      { t: "Botox Lip Flip (giro de labio)", href: "/services/botox-lip-flip", price: "$75" },
      { t: "Mini Aumento de Labios", href: "/services/mini-aumento-labios", price: "$375" },
      { t: "Aumento Completo de Labios", href: "/services/aumento-completo-labios", price: "$650" },
      { t: "Mega Aumento de Labios", href: "/services/mega-aumento-labios", price: "$850" }
    ]
  },
  { 
    group: "Inyecciones y Neurotoxinas", 
    items: [
      { t: "Xeomin", href: "/services/xeomin", price: "" },
      { t: "Dysport", href: "/services/dysport", price: "" },
      { t: "Botox para Adelgazar los Hombros", href: "/services/botox-hombros", price: "" },
      { t: "Baby Botox", href: "/services/baby-botox", price: "" },
      { t: "Botox para Migrañas", href: "/services/botox-migranas", price: "" }
    ]
  },
  { 
    group: "Skin & Laser", 
    items: [
      { t: "Microneedling + PRP", href: "/services/microneedling-prp", price: "" },
      { t: "Faciales PRF", href: "/services/facial-prp", price: "" },
      { t: "Restauración Capilar", href: "/services/capilar-prf", price: "" }
    ]
  },
  { 
    group: "Tratamientos con Sculptra y Rellenos", 
    items: [
      { t: "BananaBella (zona del bikini)", href: "/services/bananabella", price: "" },
      { t: "Estimulación de Colágeno con Sculptra", href: "/services/sculptra-colageno", price: "" },
      { t: "Mini Chin Up (reducción de papada)", href: "/services/mini-chin-up", price: "" },
      { t: "Doble Sculptra", href: "/services/doble-sculptra", price: "" },
      { t: "Brazilian Butt Lift", href: "/services/brazilian-butt-lift", price: "" },
      { t: "PRF-Ection (gel PRF)", href: "/services/prf-ection", price: "" }
    ]
  },
  { 
    group: "Contorno Facial y Corporal", 
    items: [
      { t: "Contorno Facial Personalizado", href: "/services/contorno-facial-personalizado", price: "" },
      { t: "Elevación de Pómulos (Cheekbone Pop)", href: "/services/cheekbone-pop", price: "" },
      { t: "Inyección Check Your Bags (ojeras/bolsas)", href: "/services/check-your-bags", price: "" },
      { t: "ChinBella (papada/doble mentón)", href: "/services/chinbella", price: "" },
      { t: "ThighBella (muslos)", href: "/services/thighbella", price: "" },
      { t: "BraBella (rollito de brasier)", href: "/services/brabella", price: "" }
    ]
  },
  { 
    group: "Tratamientos Especializados", 
    items: [
      { t: "Restauración Capilar con PRF", href: "/services/restauracion-capilar-prf", price: "" },
      { t: "O-Shot Terapia con Plaquetas", href: "/services/o-shot-terapia", price: "" },
      { t: "Inyecciones PuppetMaster (líneas faciales)", href: "/services/puppetmaster", price: "" },
      { t: "Lifting de Cuello Nefertiti", href: "/services/lifting-nefertiti", price: "" },
      { t: "Tratamiento Botox Lip Flip (giro de labio)", href: "/services/botox-lip-flip-especializado", price: "" }
    ]
  },
  { 
    group: "Body & Intimate", 
    items: [
      { t: "O-Shot", href: "/services/o-shot-prp", price: "" },
      { t: "Brazilian Butt Lift", href: "/services/bbl", price: "" }
    ]
  },
  { 
    group: "Terapias de Medicina Regenerativa", 
    items: [
      { t: "Semaglutide", href: "/services/semaglutide", price: "" },
      { t: "Ozempic", href: "/services/ozempic", price: "" },
      { t: "Ozonoterapia", href: "/services/ozonoterapia", price: "" },
      { t: "Exosomas", href: "/services/exosomas", price: "" },
      { t: "Terapia de Reemplazo Hormonal", href: "/services/terapia-reemplazo-hormonal", price: "" }
    ]
  },
  { 
    group: "Tratamientos de Cabello y Piel", 
    items: [
      { t: "Tratamiento de Restauración Capilar con PRP", href: "/services/restauracion-capilar-prp", price: "" },
      { t: "Tratamiento Microneedling", href: "/services/microneedling", price: "" },
      { t: "Microneedling con PRP", href: "/services/microneedling-prp", price: "" }
    ]
  },
  { 
    group: "Rellenos Faciales y Corporales", 
    items: [
      { t: "Relleno Dérmico", href: "/services/relleno-dermico", price: "" },
      { t: "Relleno de Labios", href: "/services/relleno-labios", price: "" },
      { t: "Relleno de Mejillas", href: "/services/relleno-mejillas", price: "" },
      { t: "Relleno para Debajo de los Ojos", href: "/services/relleno-debajo-ojos", price: "" },
      { t: "Relleno de Mandíbula", href: "/services/relleno-mandibula", price: "" },
      { t: "Relleno de Mano", href: "/services/relleno-mano", price: "" }
    ]
  },
  { 
    group: "Faciales Especializados", 
    items: [
      { t: "Faciales con PRP", href: "/services/faciales-prp", price: "" },
      { t: "Faciales con Células Madre", href: "/services/faciales-celulas-madre", price: "" }
    ]
  },
  { 
    group: "Tratamientos Avanzados", 
    items: [
      { t: "EZ Gel PRF", href: "/services/ez-gel-prf", price: "" },
      { t: "Disolvente de Grasa Kybella", href: "/services/kybella", price: "" },
      { t: "Inyección de Cortisona / Acné Quístico", href: "/services/cortisona-acne-quistico", price: "" },
      { t: "Inyecciones de PRP", href: "/services/inyecciones-prp", price: "" }
    ]
  },
  { 
    group: "Rejuvenecimiento Intimo", 
    items: [
      { t: "Rejuvenecimiento Vaginal con PRP", href: "/services/rejuvenecimiento-vaginal-prp", price: "" },
      { t: "Rejuvenecimiento Vaginal con Células Madre", href: "/services/rejuvenecimiento-vaginal-celulas-madre", price: "" }
    ]
  }
];
---

<header id="siteHeader" class="fixed top-0 inset-x-0 z-[100] transition-all duration-300 ease-out bg-white/20 backdrop-blur-xl border-b border-white/10 shadow-lg" data-scrolled="false">
  <nav class="mx-auto max-w-full px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <!-- Sección Izquierda: Menú Desktop + Mobile Button -->
    <div class="flex items-center">
      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-button"
        class="lg:hidden mobile-menu-btn p-2 text-white hover:text-white/80 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded mr-4"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <!-- Menú Desktop (Izquierda) -->
      <div class="hidden lg:flex items-center">
        <ul class="flex items-center gap-3 text-sm font-medium">
          {links.map((link) => (
            <li class="relative group">
              {link.mega ? (
                <>
                  <button 
                    class="nav-link flex items-center gap-1 text-white hover:text-white/80 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded px-2 py-1"
                    aria-expanded="false"
                    aria-haspopup="true"
                    data-mega-trigger
                  >
                    {link.label}
                    <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <!-- Mega Menu -->
                  <div class="mega-menu absolute top-full mt-2 bg-white rounded-lg shadow-2xl border border-gray-100 opacity-0 invisible translate-y-2 transition-all duration-300 ease-out group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 z-50 w-[95vw] sm:w-[85vw] md:w-[75vw] lg:w-[65vw] xl:w-[55vw] max-h-[75vh] overflow-y-auto scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-gray-100 relative before:content-[''] before:absolute before:-top-2 before:left-1/2 before:transform before:-translate-x-1/2 before:w-0 before:h-0 before:border-l-[10px] before:border-r-[10px] before:border-b-[10px] before:border-l-transparent before:border-r-transparent before:border-b-white before:drop-shadow-lg">
                <div class="p-4 md:p-6 lg:p-8">
                  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6">
                    {services.map((category) => (
                      <div class="min-w-0">
                        <h3 class="font-semibold text-[#E94594] mb-3 text-sm uppercase tracking-wide border-b border-[#E94594]/20 pb-2">{category.group}</h3>
                        <ul class="space-y-2">
                          {category.items.slice(0, 3).map((item) => (
                            <li>
                              <a 
                                href={item.href}
                                class="block text-gray-600 hover:text-[#E94594] hover:bg-[#E94594]/5 transition-all duration-200 text-sm hover:translate-x-1 transform py-2 px-3 rounded-md hover:scale-105 leading-tight"
                              >
                                <span class="line-clamp-2">{item.t}</span>
                              </a>
                            </li>
                          ))}
                          {category.items.length > 3 && (
                            <li class="pt-2 border-t border-gray-100 mt-3">
                              <a 
                                href={generateCategoryUrl(category.group)}
                                class="block text-[#E94594] hover:text-[#E94594]/80 hover:bg-[#E94594]/10 transition-all duration-200 text-sm font-medium py-2 px-3 rounded-md hover:scale-105 leading-tight text-center border border-[#E94594]/20 hover:border-[#E94594]/40"
                              >
                                Ver más ({category.items.length - 3} servicios)
                              </a>
                            </li>
                          )}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
              ) : (
                <a 
                  href={link.href}
                  class="nav-link text-white hover:text-white/80 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded px-2 py-1"
                >
                  {link.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Logo Centrado -->
    <div class="absolute left-1/2 transform -translate-x-1/2">
      <a href="/" class="flex items-center transition-transform duration-300 hover:scale-105">
        <img 
          id="brandLogo"
          src="/images/Renasci logo.png" 
          alt="Renasci Medical Spa" 
          class="h-12 w-auto transition-all duration-300 filter drop-shadow-lg"
        />
      </a>
    </div>

    <!-- Sección Derecha: Acciones -->
    <div class="flex items-center gap-3">
      <!-- Botón Llamar (Desktop) -->
      <a 
        href="tel:+13855550123"
        class="hidden md:flex items-center gap-2 bg-[#1DD1A1] text-white rounded-2xl px-3 md:px-4 py-2 md:py-2.5 font-semibold text-xs md:text-sm transition-all duration-200 hover:opacity-90 active:translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1DD1A1]/50 animate-pulseSoft overflow-hidden relative min-h-[44px]"
        aria-label="Llamar Renasci"
        id="call-button"
      >
        <svg class="w-3 md:w-4 h-3 md:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <span class="hidden lg:inline">(385) 555-0123</span>
        <span class="lg:hidden">Llamar</span>
      </a>

      <!-- CTA Agendar -->
      <div class="hidden md:inline-flex">
        <CTAButton 
          href="/contact"
          variant="primary"
          className="px-3 md:px-4 py-2 md:py-2.5 text-xs md:text-sm"
        >
          Agendar Ahora
        </CTAButton>
      </div>

      <!-- Redes Sociales -->
      <div class="hidden md:flex items-center gap-1 md:gap-2">
        <a 
          href="https://www.instagram.com/renascimedicalspa/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="social-link text-white hover:text-[#E94594] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded p-1 md:p-1.5"
          aria-label="Instagram"
        >
          <svg class="w-4 md:w-5 h-4 md:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a 
          href="https://facebook.com/renasci" 
          target="_blank" 
          rel="noopener noreferrer"
          class="social-link text-white hover:text-[#E94594] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded p-1 md:p-1.5"
          aria-label="Facebook"
        >
          <svg class="w-4 md:w-5 h-4 md:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>


    </div>
  </nav>

  <!-- Mobile Off-Canvas Menu -->
  <div 
    id="mobile-menu"
    class="lg:hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm opacity-0 invisible transition-all duration-300 ease-out"
    aria-hidden="true"
  >
    <div class="fixed right-0 top-0 h-full w-80 bg-white shadow-xl transform translate-x-full transition-transform duration-300 ease-out">
      <div class="flex flex-col h-full">
        <!-- Header -->
        <div class="flex items-center justify-between p-6 border-b border-gray-100">
          <img src="/images/Renasci logo.png" alt="Renasci Medical Spa" class="h-8 w-auto" />
          <button 
            id="mobile-menu-close"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded p-2"
            aria-label="Cerrar menú"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto p-6">
          <ul class="space-y-4">
            {links.map((link) => (
              <li>
                {link.mega ? (
                  <div class="space-y-2">
                    <button 
                      class="mobile-accordion-trigger flex items-center justify-between w-full text-left text-gray-900 font-medium py-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded"
                      aria-expanded="false"
                    >
                      {link.label}
                      <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                      </svg>
                    </button>
                    <div class="mobile-accordion-content hidden pl-4 space-y-3">
                      {services.map((category) => (
                        <div>
                          <h4 class="font-semibold text-gray-700 text-sm uppercase tracking-wide mb-2">{category.group}</h4>
                          <ul class="space-y-2">
                            {category.items.map((item) => (
                              <li>
                                <a 
                                  href={item.href}
                                  class="block text-gray-600 hover:text-[#E94594] hover:bg-[#E94594]/5 transition-all duration-200 text-sm py-2 px-2 rounded-md hover:scale-105"
                                >
                                  {item.t}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                ) : (
                  <a 
                    href={link.href}
                    class="block text-gray-900 font-medium py-2 hover:text-primary transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded"
                  >
                    {link.label}
                  </a>
                )}
              </li>
            ))}
          </ul>

          <!-- Mobile Social Links -->
          <div class="mt-8 pt-6 border-t border-gray-100">
            <h4 class="font-semibold text-gray-900 mb-4">Síguenos</h4>
            <div class="flex gap-4">
              <a 
                href="https://www.instagram.com/renascimedicalspa/" 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-primary transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded p-2"
                aria-label="Instagram"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987s11.987-5.367 11.987-11.987C24.004 5.367 18.637.001 12.017.001zM8.449 16.988c-1.297 0-2.448-.49-3.323-1.297C4.198 14.895 3.708 13.744 3.708 12.447s.49-2.448 1.418-3.323c.875-.807 2.026-1.297 3.323-1.297s2.448.49 3.323 1.297c.928.875 1.418 2.026 1.418 3.323s-.49 2.448-1.418 3.244c-.875.807-2.026 1.297-3.323 1.297zm7.83-9.781c-.315 0-.595-.122-.807-.315-.21-.21-.315-.49-.315-.807s.105-.595.315-.807c.21-.21.49-.315.807-.315s.595.105.807.315c.21.21.315.49.315.807s-.105.595-.315.807c-.21.193-.49.315-.807.315z"/>
                </svg>
              </a>
              <a 
                href="https://facebook.com/renasci" 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-primary transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded p-2"
                aria-label="Facebook"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            </div>
          </div>
        </nav>

        <!-- Sticky CTA Bottom -->
        <div class="p-6 border-t border-gray-100 bg-gray-50">
          <div class="space-y-3">
            <!-- Botón Llamar Mobile -->
            <a 
              href="tel:+13855550123"
              class="flex items-center justify-center gap-2 bg-[#1DD1A1] text-white rounded-2xl px-5 py-3 font-semibold transition-all duration-200 hover:opacity-90 active:translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1DD1A1]/50 animate-pulseSoft overflow-hidden relative min-h-[44px]"
              aria-label="Llamar Renasci"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              (385) 555-0123
            </a>
            <!-- CTA Agendar Mobile -->
            <div class="w-full">
              <CTAButton 
                href="/contact"
                variant="primary"
              >
                Agendar Ahora
              </CTAButton>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>

  // Navbar scroll behavior with logo switching
  function initNavbarScroll() {
    const header = document.getElementById('main-header') as HTMLElement | null;
    const logo = document.getElementById('navbar-logo') as HTMLImageElement | null;
    const navLinks = document.querySelectorAll('.nav-link');
    const socialLinks = document.querySelectorAll('.social-link');
    const mobileMenuButton = document.getElementById('mobile-menu-button');

    if (!header || !logo) return;

    function updateNavbarStyle() {
      const scrolled = window.scrollY > 24;
      
      // Update data attribute
      header.setAttribute('data-scrolled', scrolled.toString());
      
      if (scrolled) {
        // Scrolled state: solid white background, dark text, original logo
        header.classList.remove('bg-white/55', 'backdrop-blur-md');
        header.classList.add('bg-white', 'shadow-card');
        logo.style.filter = 'none';
        
        // Update nav links to dark
        navLinks?.forEach(link => {
          link.classList.remove('text-white', 'hover:text-white/80', 'focus-visible:ring-white/50');
          link.classList.add('text-gray-900', 'hover:text-primary', 'focus-visible:ring-primary/50');
        });
        
        // Update social links to dark with pink hover
        socialLinks?.forEach(link => {
          link.classList.remove('text-white', 'focus-visible:ring-white/50');
          link.classList.add('text-gray-600', 'focus-visible:ring-primary/50');
        });
        
        // Update mobile menu button
        if (mobileMenuButton) {
          mobileMenuButton.classList.remove('text-white', 'hover:text-white/80', 'focus-visible:ring-white/50');
          mobileMenuButton.classList.add('text-gray-900', 'hover:text-primary', 'focus-visible:ring-primary/50');
        }
      } else {
        // Initial state: translucent background with backdrop blur, white text, white logo
        header.classList.remove('bg-white', 'shadow-card');
        header.classList.add('bg-white/55', 'backdrop-blur-md');
        logo.style.filter = 'brightness(0) invert(1)';
        
        // Update nav links to white
        navLinks?.forEach(link => {
          link.classList.remove('text-gray-900', 'hover:text-primary', 'focus-visible:ring-primary/50');
          link.classList.add('text-white', 'hover:text-white/80', 'focus-visible:ring-white/50');
        });
        
        // Update social links to white with pink hover
        socialLinks?.forEach(link => {
          link.classList.remove('text-gray-600', 'focus-visible:ring-primary/50');
          link.classList.add('text-white', 'focus-visible:ring-white/50');
        });
        
        // Update mobile menu button
        if (mobileMenuButton) {
          mobileMenuButton.classList.remove('text-gray-900', 'hover:text-primary', 'focus-visible:ring-primary/50');
          mobileMenuButton.classList.add('text-white', 'hover:text-white/80', 'focus-visible:ring-white/50');
        }
      }
    }

    // Initial call
    updateNavbarStyle();
    
    // Listen to scroll events
    window.addEventListener('scroll', updateNavbarStyle, { passive: true });
  }

  // Call button ripple effect
  function initCallButtonRipple() {
    const callButtons = document.querySelectorAll('#call-button, a[href^="tel:"]');
    
    callButtons.forEach(button => {
      button.addEventListener('pointerdown', function(e: PointerEvent) {
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;
        
        const ripple = document.createElement('span');
        ripple.style.cssText = `
          position: absolute;
          width: ${size}px;
          height: ${size}px;
          left: ${x}px;
          top: ${y}px;
          background: rgba(255, 255, 255, 0.3);
          border-radius: 50%;
          transform: scale(0);
          animation: ripple 600ms ease-out;
          pointer-events: none;
        `;
        
        (this as HTMLElement).style.position = 'relative';
        (this as HTMLElement).style.overflow = 'hidden';
        this.appendChild(ripple);
        
        setTimeout(() => {
          ripple.remove();
        }, 600);
      });
    });
  }

  // Mobile menu functionality
  function initMobileMenu() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuPanel = mobileMenu?.querySelector('.fixed.right-0');

    function openMobileMenu() {
      if (mobileMenu && mobileMenuPanel) {
        mobileMenu.classList.remove('opacity-0', 'invisible');
        mobileMenuPanel.classList.remove('translate-x-full');
        mobileMenu.setAttribute('aria-hidden', 'false');
        mobileMenuButton?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeMobileMenu() {
      if (mobileMenu && mobileMenuPanel) {
        mobileMenu.classList.add('opacity-0', 'invisible');
        mobileMenuPanel.classList.add('translate-x-full');
        mobileMenu.setAttribute('aria-hidden', 'true');
        mobileMenuButton?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    }

    mobileMenuButton?.addEventListener('click', openMobileMenu);
    mobileMenuClose?.addEventListener('click', closeMobileMenu);
    
    // Close on backdrop click
    mobileMenu?.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMobileMenu();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !mobileMenu?.classList.contains('invisible')) {
        closeMobileMenu();
      }
    });

    // Mobile accordion functionality
    const accordionTriggers = document.querySelectorAll('.mobile-accordion-trigger');
    accordionTriggers.forEach(trigger => {
      trigger.addEventListener('click', function(this: HTMLElement) {
        const content = this.nextElementSibling;
        const icon = this.querySelector('svg');
        const isExpanded = this.getAttribute('aria-expanded') === 'true';

        if (isExpanded) {
          content?.classList.add('hidden');
          icon?.classList.remove('rotate-180');
          this.setAttribute('aria-expanded', 'false');
        } else {
          content?.classList.remove('hidden');
          icon?.classList.add('rotate-180');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  // Mega menu functionality
  function initMegaMenu() {
    const megaTriggers = document.querySelectorAll('[data-mega-trigger]');
    
    megaTriggers.forEach(trigger => {
      const megaMenu = trigger.nextElementSibling;
      let timeoutId;

      function showMegaMenu() {
        clearTimeout(timeoutId);
        megaMenu?.classList.remove('opacity-0', 'invisible', 'translate-y-2');
        trigger.setAttribute('aria-expanded', 'true');
      }

      function hideMegaMenu() {
        timeoutId = window.setTimeout(() => {
          megaMenu?.classList.add('opacity-0', 'invisible', 'translate-y-2');
          trigger.setAttribute('aria-expanded', 'false');
        }, 150);
      }

      trigger.addEventListener('mouseenter', showMegaMenu);
      trigger.addEventListener('mouseleave', hideMegaMenu);
      megaMenu?.addEventListener('mouseenter', showMegaMenu);
      megaMenu?.addEventListener('mouseleave', hideMegaMenu);

      // Keyboard support
      trigger.addEventListener('focus', showMegaMenu);
      trigger.addEventListener('blur', hideMegaMenu);

      // Close on Escape
      trigger.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') {
          hideMegaMenu();
          (trigger as HTMLElement).blur();
        }
      });
    });
  }

  // Initialize all functionality
  document.addEventListener('DOMContentLoaded', () => {
    initNavbarScroll();
    initCallButtonRipple();
    initMobileMenu();
    initMegaMenu();
  });
</script>

<style>
  /* Pulse animation for call button */
  @keyframes pulse-soft {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
    }
  }

  .animate-pulse-soft {
    animation: pulse-soft 2s infinite;
  }

  /* Ripple animation */
  @keyframes ripple {
    to {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Mega menu positioning */
  .mega-menu {
    left: 50%;
    transform: translateX(-50%);
  }

  /* Line clamp utility for text truncation */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Backdrop blur support */
  @supports (backdrop-filter: blur(12px)) {
    .supports-\[backdrop-filter\]\:bg-white\/55 {
      backdrop-filter: blur(12px);
    }
  }

  /* Navbar scroll states */
  #siteHeader[data-scrolled="false"] {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  #siteHeader[data-scrolled="true"] {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    transform: translateY(0);
  }

  #siteHeader[data-scrolled="false"] .nav-link {
    color: white;
  }

  #siteHeader[data-scrolled="true"] .nav-link {
    color: #1A1A1A;
  }

  #siteHeader[data-scrolled="false"] .mobile-menu-btn {
    color: white;
  }

  #siteHeader[data-scrolled="true"] .mobile-menu-btn {
    color: #1A1A1A;
  }



  /* Logo states */
  #siteHeader[data-scrolled="false"] #brandLogo {
    filter: brightness(0) invert(1);
  }

  #siteHeader[data-scrolled="true"] #brandLogo {
    filter: none;
  }

  /* Social icons states */
  #siteHeader[data-scrolled="false"] .social-link {
    color: white;
  }

  #siteHeader[data-scrolled="true"] .social-link {
    color: #1A1A1A;
  }

  .social-link:hover {
    color: #E94594 !important;
  }
</style>

<script>
  const header = document.getElementById('siteHeader');
  const logo = document.getElementById('brandLogo');
  
  function onScroll() {
    if (!header) return;
    const s = window.scrollY > 50;
    header.dataset.scrolled = s ? 'true' : 'false';
  }
  
  // Smooth scroll behavior
  function initSmoothScrolling() {
    if (!header) return;
    
    let ticking = false;
    
    function updateHeader() {
      onScroll();
      ticking = false;
    }
    
    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }
    
    window.addEventListener('scroll', requestTick, { passive: true });
  }
  
  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    onScroll();
    initSmoothScrolling();
  });
  
  // Fallback for immediate execution
  onScroll();
  initSmoothScrolling();
</script>
