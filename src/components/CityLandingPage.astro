---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from './JsonLd.astro';

export interface Props {
  city: string;            // "Salt Lake City"
  citySlug: string;        // "salt-lake-city"
  state?: string;          // "Utah"
  distanceLine?: string;   // "A 10 min de tu casa en Sandy"
  heroSubtitle?: string;
}

const {
  city,
  citySlug,
  state = 'Utah',
  distanceLine,
  heroSubtitle
} = Astro.props;

const pageUrl = `https://renascimedspa.com/medical-spa-${citySlug}`;
const title = `Medical Spa en ${city}, ${state} | Renasci — Botox, Rellenos, IV Therapy`;
const description = `Renasci Medical Spa atiende a ${city}, ${state} desde nuestra clínica en Midvale. Botox, rellenos dérmicos, Sculptra, IV therapy, IgniteRF, microneedling y más. Consulta gratuita.`;
const keywords = `medical spa ${city}, medspa ${city}, botox ${city}, rellenos ${city}, sculptra ${city}, IV therapy ${city}, ${city} ${state} medspa, Renasci Medical Spa ${city}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  '@id': pageUrl + '#business',
  name: `Renasci Medical Spa — atendiendo ${city}, ${state}`,
  parentOrganization: { '@id': 'https://renascimedspa.com/#business' },
  url: pageUrl,
  telephone: '+1-385-609-2840',
  email: 'orders@renascimedspa.com',
  priceRange: '$$',
  image: 'https://renascimedspa.com/og-image.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6770 S 900 E, Suite 100',
    addressLocality: 'Midvale',
    addressRegion: 'UT',
    postalCode: '84047',
    addressCountry: 'US'
  },
  areaServed: { '@type': 'City', name: city, containedInPlace: { '@type': 'State', name: state } },
  medicalSpecialty: 'CosmeticMedicine'
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://renascimedspa.com/' },
    { '@type': 'ListItem', position: 2, name: `Medical Spa en ${city}`, item: pageUrl }
  ]
};

const treatments = [
  { name: 'Botox & Neurotoxinas', slug: 'tox-neurotoxina', img: '/img/services/Neurotoxin.jpeg.webp' },
  { name: 'Rellenos Dérmicos', slug: 'relleno-labios', img: '/img/services/Lip-filler-image.jpg' },
  { name: 'Sculptra Colágeno', slug: 'sculptra-colageno', img: '/img/services/sculptra.jpg' },
  { name: 'IV Therapy', slug: 'iv-therapy', img: '/img/services/Drips.jpeg' },
  { name: 'IgniteRF', slug: 'igniterf', img: '/img/ignateRF.png' },
  { name: 'Microneedling & PRP', slug: 'microneedling', img: '/img/services/microneedling-face.jpg' },
  { name: 'BHRT — Terapia Hormonal', slug: 'biodentical-hormone-therapy', img: '/img/services/Hormone-her.jpg' },
  { name: 'Pérdida de Peso Médica', slug: 'medically-supervised-weight-loss', img: '/img/services/Semaglutide.jpg' }
];
---

<BaseLayout
  title={title}
  description={description}
  seoKeywords={keywords}
  seoImage="/og-image.jpg"
>
  <JsonLd schema={localBusinessSchema} />
  <JsonLd schema={breadcrumbSchema} />

  <section class="relative min-h-[70vh] flex items-center overflow-hidden bg-gradient-to-br from-[#F3A2A7]/15 via-white to-[#AABFA8]/15">
    <div class="container mx-auto px-6 py-20 lg:py-28 relative z-10">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.22em] text-[#F3A2A7] font-semibold mb-4">
          {city}, {state}
        </p>
        <h1 class="font-display font-bold text-4xl md:text-6xl leading-tight text-gray-900 mb-6">
          Medical Spa en <span class="text-[#F3A2A7]">{city}</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-700 leading-relaxed mb-8 max-w-2xl">
          {heroSubtitle || `Renasci Medical Spa atiende a ${city} y todo el valle de Salt Lake con tratamientos estéticos avanzados: Botox, rellenos dérmicos, Sculptra, IV Therapy, IgniteRF y más. Equipo bilingüe (español e inglés) y consulta inicial gratuita.`}
        </p>
        {distanceLine && (
          <p class="text-sm text-gray-500 mb-8">
            <span class="inline-block w-2 h-2 rounded-full bg-[#AABFA8] mr-2"></span>{distanceLine}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="inline-flex items-center justify-center bg-[#F3A2A7] text-white font-semibold px-7 py-3 rounded-full hover:brightness-105 transition">
            Agendar Consulta Gratuita
          </a>
          <a href="tel:+13856092840" class="inline-flex items-center justify-center gap-2 bg-[#AABFA8] text-white font-semibold px-7 py-3 rounded-full hover:brightness-105 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            (385) 609-2840
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-[#F3A2A7] font-semibold mb-3">Por qué Renasci</p>
          <h2 class="font-display font-bold text-3xl md:text-4xl text-gray-900 mb-6">
            La clínica estética más cercana a {city}
          </h2>
          <div class="prose prose-lg text-gray-700 leading-relaxed space-y-4">
            <p>
              Nuestra clínica en <strong>6770 S 900 E, Suite 100, Midvale, UT 84047</strong> recibe pacientes de {city} y de todo el Salt Lake Valley. Estamos a pocos minutos por la I-15 y la I-215, con estacionamiento gratuito.
            </p>
            <p>
              Equipo médico certificado por FDA, atención bilingüe en español e inglés, y planes de tratamiento personalizados con consulta inicial sin costo.
            </p>
            <ul class="space-y-2 not-prose">
              <li class="flex items-start gap-2"><span class="text-[#F3A2A7] font-bold">✓</span> Consulta inicial gratuita</li>
              <li class="flex items-start gap-2"><span class="text-[#F3A2A7] font-bold">✓</span> Tratamientos FDA-aprobados</li>
              <li class="flex items-start gap-2"><span class="text-[#F3A2A7] font-bold">✓</span> Atención en español e inglés</li>
              <li class="flex items-start gap-2"><span class="text-[#F3A2A7] font-bold">✓</span> Programa de membresía con descuentos</li>
            </ul>
          </div>
        </div>
        <div class="rounded-3xl overflow-hidden shadow-card">
          <iframe
            src={`https://www.google.com/maps?q=6770+S+900+E+Midvale+UT+84047&output=embed`}
            width="100%"
            height="450"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Renasci Medical Spa serving ${city}, Utah`}
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-xs uppercase tracking-[0.22em] text-[#F3A2A7] font-semibold mb-3">Tratamientos populares</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-gray-900">
          Tratamientos más buscados en {city}
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        {treatments.map((t) => (
          <a href={`/services/${t.slug}`} class="group rounded-2xl overflow-hidden bg-white shadow-card hover:shadow-xl transition">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={t.img} alt={`${t.name} en ${city}, ${state}`} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition" />
            </div>
            <div class="p-4">
              <h3 class="font-display font-semibold text-base text-gray-900 group-hover:text-[#F3A2A7] transition">{t.name}</h3>
              <p class="text-xs text-gray-500 mt-1">en {city}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gradient-to-br from-[#F3A2A7] to-[#AABFA8]">
    <div class="container mx-auto px-6 text-center text-white">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">¿Lista para empezar tu tratamiento?</h2>
      <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
        Agenda tu consulta gratuita y descubre cómo Renasci Medical Spa puede ayudarte a renovar tu piel y bienestar — atendiendo a {city} y todo Utah.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://www.joinblvd.com/b/3fdd50b8-7139-46c6-b272-20a94ddbbf3d/widget" data-booking-trigger="boulevard" class="inline-flex items-center justify-center bg-white text-[#F3A2A7] font-semibold px-7 py-3 rounded-full hover:brightness-95 transition">
          Agendar Online
        </a>
        <a href="tel:+13856092840" class="inline-flex items-center justify-center gap-2 bg-white/15 backdrop-blur-sm border-2 border-white text-white font-semibold px-7 py-3 rounded-full hover:bg-white/25 transition">
          (385) 609-2840
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
