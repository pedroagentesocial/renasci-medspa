---
export interface Props {
  href?: string;
  label?: string;
  variant?: 'primary' | 'ghost' | 'link' | 'call' | 'mint';
  className?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  onClick?: string;
}

const { 
  href = "#",
  label,
  variant = 'primary',
  className = '',
  target,
  rel,
  type = 'button',
  disabled = false,
  onClick
} = Astro.props;

// Clases base
const base = "inline-flex items-center justify-center px-6 py-3 rounded-[48px] font-semibold transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#F3A2A7]/50 min-h-[44px]";

// Variantes sólidas sin degradados
const variants = {
  primary: "bg-[#F3A2A7] text-white hover:opacity-90 active:translate-y-[1px] shadow-sm hover:shadow-md",
  call: "bg-[#1DD1A1] text-white hover:opacity-90 active:translate-y-[1px] shadow-sm hover:shadow-md",
  mint: "bg-[#AABFA8] text-white hover:opacity-90 active:translate-y-[1px] shadow-sm hover:shadow-md",
  ghost: "border-2 border-dark/15 text-dark bg-white hover:bg-soft hover:border-dark/25 hover:opacity-90 active:translate-y-[1px]",
  link: "relative text-dark bg-transparent hover:text-primary hover:opacity-90 active:translate-y-[1px] after:content-[''] after:absolute after:left-0 after:-bottom-0.5 after:h-[2px] after:bg-primary after:w-0 hover:after:w-full after:transition-all after:duration-200"
};

const allClasses = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a 
    href={href}
    class={allClasses}
    target={target}
    rel={rel}
  >
    {label || <slot />}
  </a>
) : (
  <button 
    type={type}
    class={allClasses}
    disabled={disabled}
    onclick={onClick}
  >
    {label || <slot />}
  </button>
)}
