---
export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  onClick?: string;
}

const { 
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  target,
  rel,
  type = 'button',
  disabled = false,
  onClick
} = Astro.props;

// Clases base según variante
const variantClasses = {
  primary: 'btn-primary',
  secondary: 'btn-secondary', 
  outline: 'border-2 border-primary text-primary hover:bg-primary hover:text-white bg-transparent'
};

// Clases de tamaño
const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg'
};

const baseClasses = 'inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed';

const allClasses = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;

// Si tiene href, renderizar como enlace
if (href) {
---
  <a 
    href={href}
    class={allClasses}
    target={target}
    rel={rel}
  >
    <slot />
  </a>
---
} else {
---
  <button 
    type={type}
    class={allClasses}
    disabled={disabled}
    onclick={onClick}
  >
    <slot />
  </button>
---
}