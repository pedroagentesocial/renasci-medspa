---
import CTAButton from './CTAButton.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { categoriasUnificadas } from '../data/services-unified.ts';

export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

// Helper function to generate category URLs
function generateCategoryUrl(categoryGroup) {
  const replacements = { 'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u' };
  return `/services/category/${categoryGroup
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[áéíóú]/g, (match) => replacements[match] || match)}`;
}

const links = [
  { href: "/membership", label: "Membresía", key: "nav.membership" },
  { href: "/about", label: "Nosotros", key: "nav.about" },
  { href: "/services", label: "Servicios", key: "nav.services", hasDropdown: true },
  { href: "/contact", label: "Contacto", key: "nav.contact" }
