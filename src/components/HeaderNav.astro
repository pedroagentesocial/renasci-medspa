---

<header id="siteHeader" class="fixed top-0 inset-x-0 z-[100] transition-all duration-300 ease-out bg-white/20 backdrop-blur-xl border-b border-white/10 shadow-lg" data-scrolled="false">
  <nav class="mx-auto max-w-full px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <!-- Sección Izquierda: Menú Desktop + Mobile Button -->
    <div class="flex items-center">
      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-button"
        class="lg:hidden mobile-menu-btn p-2 text-white hover:text-white/80 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded mr-4"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <!-- Menú Desktop (Izquierda) -->
      <div class="hidden lg:flex items-center">
        <ul class="flex items-center gap-3 text-sm font-medium">
          {links.map((link) => (
            <li class="relative group">
              {link.hasDropdown ? (
                <div class="services-dropdown-container">
                  <button 
                    class="services-dropdown-trigger nav-link text-white hover:text-white/80 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded px-2 py-1 flex items-center gap-1"
                    aria-expanded="false"
                    aria-haspopup="true"
                  >
                    {link.label}
                    <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  
                  <!-- Dropdown Menu -->
                  <div class="services-dropdown fixed top-full left-0 right-0 mt-2 opacity-0 invisible transform translate-y-2 transition-all duration-300 ease-out z-50">
                    <div class="dropdown-content bg-white/90 backdrop-blur-md shadow-2xl border-t border-white/20 overflow-hidden">
                      <div class="max-w-7xl mx-auto px-6 py-8 max-h-[500px] overflow-y-auto scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-gray-100">
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                          {categoriasUnificadas.map((categoria) => (
                            <div class="category-section">
                              <h3 class="text-sm font-bold text-gray-800 mb-3 border-b border-gray-200 pb-2 flex items-center gap-2">
                                <span class="text-pink-500">{categoria.nombre.es}</span>
                                <span class="text-xs text-gray-500">({categoria.servicios.length})</span>
                              </h3>
                              <ul class="space-y-2">
                                {categoria.servicios.slice(0, 3).map((servicio) => (
                                  <li>
                                    <a 
                                      href={servicio.href}
                                      class="group block px-3 py-2 text-sm text-black hover:bg-pink-50 rounded-lg transition-all duration-200 border border-transparent hover:border-pink-200"
                                    >
                                      <div class="flex items-start gap-2">
                                        {servicio.icon && (
                                          <span class="text-base flex-shrink-0 mt-0.5 text-black">{servicio.icon}</span>
                                        )}
                                        <div class="flex-1 min-w-0">
                                          <div class="font-medium truncate text-black">
                                            {servicio.title.es}
                                          </div>
                                        </div>
                                      </div>
                                    </a>
                                  </li>
                                ))}
                                {categoria.servicios.length > 3 && (
                                  <li>
                                    <a 
                                      href={`/services/${categoria.slug}`}
                                      class="group block px-3 py-2 text-sm text-pink-600 hover:bg-pink-50 hover:text-pink-700 rounded-lg transition-all duration-200 border border-pink-200 hover:border-pink-300 font-medium"
                                    >
                                      <div class="flex items-center justify-center gap-2">
                                        <span>Ver más</span>
                                        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                        </svg>
                                      </div>
                                    </a>
                                  </li>
                                )}
                              </ul>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ) : (
                <a 
                  href={link.href}
                  class="nav-link text-white hover:text-white/80 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded px-2 py-1"
                >
                  {link.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Logo Centrado -->
    <div class="absolute left-1/2 transform -translate-x-1/2">
      <a href="/" class="flex items-center transition-transform duration-300 hover:scale-105">
        <img 
          id="brandLogo"
          src="/images/Renasci logo.png" 
          alt="Renasci Medical Spa" 
          class="h-12 w-auto transition-all duration-300 filter drop-shadow-lg"
        />
      </a>
    </div>

    <!-- Sección Derecha: Acciones -->
    <div class="flex items-center gap-3">
      <!-- Botón Llamar (Desktop) -->
      <a 
        href="tel:+13855550123"
        class="hidden md:flex items-center gap-2 bg-[#1DD1A1] text-white rounded-2xl px-3 md:px-4 py-2 md:py-2.5 font-semibold text-xs md:text-sm transition-all duration-200 hover:opacity-90 active:translate-y-[1px] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1DD1A1]/50 animate-pulseSoft overflow-hidden relative min-h-[44px]"
        aria-label="Llamar Renasci"
        id="call-button"
      >
        <svg class="w-3 md:w-4 h-3 md:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <span class="hidden lg:inline">(385) 555-0123</span>
        <span class="lg:hidden">Llamar</span>
      </a>

      <!-- CTA Agendar -->
      <div class="hidden md:inline-flex">
        <CTAButton 
          href="/contact"
          variant="primary"
          className="px-3 md:px-4 py-2 md:py-2.5 text-xs md:text-sm"
        >
          Agendar Ahora
        </CTAButton>
      </div>

      <!-- Redes Sociales -->
      <div class="hidden md:flex items-center gap-1 md:gap-2">
        <a 
          href="https://instagram.com/renasci" 
          target="_blank" 
          rel="noopener noreferrer"
          class="social-link text-white hover:text-[#E94594] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded p-1 md:p-1.5"
          aria-label="Instagram"
        >
          <svg class="w-4 md:w-5 h-4 md:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a 
          href="https://facebook.com/renasci" 
          target="_blank" 
          rel="noopener noreferrer"
          class="social-link text-white hover:text-[#E94594] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded p-1 md:p-1.5"
          aria-label="Facebook"
        >
          <svg class="w-4 md:w-5 h-4 md:h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>


    </div>
  </nav>

  <!-- Mobile Off-Canvas Menu -->
  <div 
    id="mobile-menu"
    class="lg:hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm opacity-0 invisible transition-all duration-300 ease-out"
    aria-hidden="true"
  >
    <div class="fixed right-0 top-0 h-full w-80 bg-white shadow-xl transform translate-x-full transition-transform duration-300 ease-out">
      <div class="flex flex-col h-full">
        <!-- Header -->
        <div class="flex items-center justify-between p-6 border-b border-gray-100">
          <img src="/images/Renasci logo.png" alt="Renasci Medical Spa" class="h-8 w-auto" />
          <button 
            id="mobile-menu-close"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded p-2"
            aria-label="Cerrar menú"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto p-6">
          <ul class="space-y-4">
            {links.map((link) => (
              <li>
                <a 
                  href={link.href}
                  class="block text-gray-900 font-medium py-2 hover:text-primary transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>

          <!-- Mobile Social Links -->
          <div class="mt-8 pt-6 border-t border-gray-100">
            <h4 class="font-semibold text-gray-900 mb-4">Síguenos</h4>
            <div class="flex gap-4">
              <a 
                href="https://instagram.com/renasci" 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-primary transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 rounded p-2"
                aria-label="Instagram"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
