---

export interface Props {
  currentPath?: string;
}

const { currentPath: propPath } = Astro.props;
const currentPath = propPath ?? (Astro.url?.pathname ?? "/");
const schedulerUrl = (import.meta.env.PUBLIC_SCHEDULER_URL as string | undefined) ?? '';

function isActive(href: string) {
  try {
    const cp = String(currentPath || '/');
    const h = String(href || '');
    return cp === h || (h !== '/' && cp.startsWith(h + '/'));
  } catch { return false }
}

const serviceLinks = [
  { label: { es: 'Inyecciones de Neurotoxina', en: 'Neurotoxin Injections' }, href: '/services/neurotoxin-injections' },
  { label: { es: 'Rellenos Dérmicos', en: 'Dermal Fillers' }, href: '/services/dermal-fillers' },
  { label: { es: 'Tratamientos Faciales', en: 'Facial Treatments' }, href: '/services/facial-treatments' },
  { label: { es: 'Contorno Corporal', en: 'Body Contouring' }, href: '/services/body-contouring-treatments' },
  { label: { es: 'Bioestimuladores', en: 'Biostimulators' }, href: '/services/biostimulators' },
  { label: { es: 'Pérdida de Peso y Bienestar', en: 'Weight Loss & Wellness' }, href: '/services/medically-supervised-weight-loss' },
  { label: { es: 'Tratamientos Avanzados', en: 'Advanced Treatments' }, href: '/services/advanced-treatments' },
  { label: { es: 'Microneedling', en: 'Microneedling' }, href: '/services/microneedling' },
  { label: { es: 'Inyecciones PRP', en: 'PRP Injections' }, href: '/services/prp-injections' },
  { label: { es: 'Tratamiento con Células Madre', en: 'Stem Cells Treatment' }, href: '/services/stem-cells-treatment' },
  { label: { es: 'Terapia Hormonal Bioidéntica', en: 'Bioidentical Hormone Therapy' }, href: '/services/biodentical-hormone-therapy' },
  { label: { es: 'Terapia de Péptidos', en: 'Peptide Therapy' }, href: '/services/therapy-peptide' },
