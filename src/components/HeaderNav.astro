const currentPath = propPath ?? (Astro.url?.pathname ?? "/");
const schedulerUrl = (import.meta.env.PUBLIC_SCHEDULER_URL as string | undefined) ?? '';

// Helper function to generate category URLs
function generateCategoryUrl(categoryGroup: string) {
  const replacements: Record<string, string> = { 'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u' };
  return `/services/category/${categoryGroup
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[áéíóú]/g, (match: string) => replacements[match] || match)}`;
}

function isActive(href: string) {
  try {
    const cp = String(currentPath || '/');
    const h = String(href || '');
    return cp === h || (h !== '/' && cp.startsWith(h + '/'));
  } catch { return false }
}

