<script>
  // Navbar scroll behavior
  function initNavbarScroll() {
    const header = document.getElementById('siteHeader');
    const logo = document.getElementById('brandLogo');
    
    if (!header || !logo) return;
    
    let lastScrollY = window.scrollY;
    let ticking = false;
    
    function updateNavbar() {
      const scrollY = window.scrollY;
      const isScrolled = scrollY > 50;
      
      header.setAttribute('data-scrolled', isScrolled.toString());
      
      // Update logo filter based on scroll state
      if (isScrolled) {
        logo.style.filter = 'none';
      } else {
        logo.style.filter = 'brightness(0) invert(1)';
      }
      
      lastScrollY = scrollY;
      ticking = false;
    }
    
    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateNavbar);
        ticking = true;
      }
    }
    
    window.addEventListener('scroll', requestTick, { passive: true });
    
    // Initial call
    updateNavbar();
  }

  function initScheduler() {
    let u = (typeof schedulerUrl !== 'undefined' && schedulerUrl) 
      ? schedulerUrl 
      : 'https://link.msgsndr.com/widget/booking/ZIYe8XGFfENxqvZHGTBD';
    const m = document.getElementById('scheduler-modal');
    const f = document.getElementById('scheduler-frame') as HTMLIFrameElement | null;
    const b = document.getElementById('scheduler-backdrop');
    const c = document.getElementById('scheduler-close');
    if (!m || !f || !b || !c) return;
    async function resolveUrl() {
      if (u) return u;
      try {
        const res = await fetch('/scheduler.json', { cache: 'no-store' });
        if (res.ok) {
          const data = await res.json();
          if (data && typeof data.url === 'string' && data.url.trim() !== '') {
            u = data.url.trim();
          }
        }
      } catch {}
      return u;
    }
    function close() {
      m.classList.add('hidden');
      f.src = '';
      document.body.style.overflow = '';
    }
    function trigger() {
      m.classList.remove('hidden');
      if (f) {
        f.src = u;
      }
      document.body.style.overflow = 'hidden';
    }
    (window as any).__triggerScheduler = trigger;
    (window as any).__openScheduler = trigger;
    b.addEventListener('click', close);
    c.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { const k = (e as KeyboardEvent).key; if (k === 'Escape' && !m.classList.contains('hidden')) close(); });
  }

  // Call button ripple effect
  function initCallButtonRipple() {
    const callButton = document.getElementById('call-button');
    if (!callButton) return;
    
    callButton.addEventListener('click', function(e) {
      const ripple = document.createElement('span');
      const rect = this.getBoundingClientRect();
      const size = Math.max(rect.width, rect.height);
      const x = e.clientX - rect.left - size / 2;
      const y = e.clientY - rect.top - size / 2;
      
      ripple.style.width = ripple.style.height = size + 'px';
      ripple.style.left = x + 'px';
      ripple.style.top = y + 'px';
      ripple.classList.add('ripple');
      
      this.appendChild(ripple);
      
      setTimeout(() => {
        ripple.remove();
      }, 600);
    });
  }

  // Mobile menu functionality
  function initMobileMenu() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuPanel = document.getElementById('mobile-menu-panel');
    const headerEl = document.getElementById('siteHeader');

    function updateHeaderHeightVar() {
      const raw = headerEl ? headerEl.offsetHeight : 80;
      const adjusted = Math.max(0, raw - 12);
      document.documentElement.style.setProperty('--header-h', adjusted + 'px');
    }
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const accordionTriggers = document.querySelectorAll('.mobile-accordion-trigger');
    
    if (!mobileMenuButton || !mobileMenu || !mobileMenuClose) return;
    
    function openMobileMenu() {
      mobileMenu.classList.remove('opacity-0', 'invisible');
      mobileMenu.classList.add('opacity-100', 'visible');
      mobileMenu.style.opacity = '1';
      mobileMenu.style.visibility = 'visible';
      updateHeaderHeightVar();
      mobileMenuPanel?.classList.add('open');
      if (mobileMenuPanel) mobileMenuPanel.style.transform = 'translateX(0)';
      mobileMenu.setAttribute('aria-hidden', 'false');
      mobileMenuButton.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      document.body.classList.add('menu-open');
      const k1 = 'mobileMenuScrollTop', k2 = 'mobileMenuSelectedHref';
      setTimeout(() => {
        const st = parseInt(localStorage.getItem(k1) || '0', 10);
        if (mobileMenuPanel) mobileMenuPanel.scrollTop = st;
        const href = localStorage.getItem(k2);
        if (href && mobileMenuPanel) {
          const el = mobileMenuPanel.querySelector(`a[href="${href}"]`);
          if (el) (el as HTMLElement).scrollIntoView({ block: 'center' });
        } else if (mobileMenuPanel) {
          const active = mobileMenuPanel.querySelector('a.active-link') || mobileMenuPanel.querySelector(`a[href="${window.location.pathname}"]`);
          if (active) (active as HTMLElement).scrollIntoView({ block: 'center' });
        }
      }, 320);
    }

  function closeMobileMenu() {
    mobileMenu.classList.add('opacity-0', 'invisible');
    mobileMenu.classList.remove('opacity-100', 'visible');
    mobileMenu.style.opacity = '0';
    setTimeout(() => {
      mobileMenu.style.visibility = 'hidden';
    }, 250);
    mobileMenuPanel?.classList.remove('open');
    if (mobileMenuPanel) mobileMenuPanel.style.transform = 'translateX(-100%)';
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileMenuButton.setAttribute('aria-expanded', 'false');
    if (mobileMenuPanel) localStorage.setItem('mobileMenuScrollTop', String(mobileMenuPanel.scrollTop));
    document.body.style.overflow = '';
    document.body.classList.remove('menu-open');
  }

    // Keep menu aligned on resize
    window.addEventListener('resize', updateHeaderHeightVar);
    
    mobileMenuButton.addEventListener('click', openMobileMenu);
    mobileMenuClose.addEventListener('click', closeMobileMenu);
    
    // Close on backdrop click
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMobileMenu();
      }
    });
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      const key = (e as KeyboardEvent).key;
      if (key === 'Escape' && !mobileMenu.classList.contains('invisible')) {
        closeMobileMenu();
      }
    });
    
    // Accordion functionality
    accordionTriggers.forEach(trigger => {
      trigger.addEventListener('click', (evt) => {
        const t = evt.currentTarget as HTMLElement;
        const content = t.parentElement?.querySelector('.mobile-accordion-content') as HTMLElement | null;
        const isExpanded = t.getAttribute('aria-expanded') === 'true';
        
        // Close all other accordions
        accordionTriggers.forEach((otherTrigger) => {
          const ot = otherTrigger as HTMLElement;
          if (ot !== t) {
            ot.setAttribute('aria-expanded', 'false');
            const svgEl = ot.querySelector('svg') as SVGElement | null;
            if (svgEl) svgEl.style.transform = 'rotate(0deg)';
            const otherContent = ot.parentElement?.querySelector('.mobile-accordion-content') as HTMLElement | null;
            otherContent?.classList.add('hidden');
          }
        });
        
        // Toggle current accordion
        if (isExpanded) {
          t.setAttribute('aria-expanded', 'false');
          const svgEl = t.querySelector('svg') as SVGElement | null;
          if (svgEl) svgEl.style.transform = 'rotate(0deg)';
          content?.classList.add('hidden');
        } else {
          t.setAttribute('aria-expanded', 'true');
          const svgEl = t.querySelector('svg') as SVGElement | null;
          if (svgEl) svgEl.style.transform = 'rotate(180deg)';
          content?.classList.remove('hidden');
        }
      });
    });
  }

  // Services dropdown functionality
  function initServicesDropdown() {
    const dropdownTriggers = document.querySelectorAll('.services-dropdown-trigger');
    let timeoutId: ReturnType<typeof setTimeout> | undefined;
    
    dropdownTriggers.forEach(trigger => {
      const container = trigger.closest('.services-dropdown-container');
      const dropdown = container?.querySelector('.services-dropdown');
      if (!dropdown || !container) return;
      
      const showDropdown = () => {
        if (timeoutId) clearTimeout(timeoutId);
        container.classList.add('active');
        trigger.setAttribute('aria-expanded', 'true');
      };
      
      const hideDropdown = () => {
        timeoutId = setTimeout(() => {
          container.classList.remove('active');
          trigger.setAttribute('aria-expanded', 'false');
        }, 150);
      };
      
      // Mouse events
      container.addEventListener('mouseenter', showDropdown);
      container.addEventListener('mouseleave', hideDropdown);
      
      // Keyboard events
      trigger.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        if (key === 'Enter' || key === ' ') {
          e.preventDefault();
          const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
          if (isExpanded) {
            hideDropdown();
          } else {
            showDropdown();
          }
        }
        if (key === 'Escape') {
          hideDropdown();
        }
      });
    });
  }

  // Mega menu functionality
  function initMegaMenu() {
    const megaTriggers = document.querySelectorAll('[data-mega-trigger]');
    let timeoutId: ReturnType<typeof setTimeout> | undefined;
    
    megaTriggers.forEach(trigger => {
      const megaMenu = trigger.parentElement?.querySelector('.mega-menu');
      if (!megaMenu) return;
      
      const showMegaMenu = () => {
        clearTimeout(timeoutId);
        megaMenu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
        megaMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
        trigger.setAttribute('aria-expanded', 'true');
      };
      
      const hideMegaMenu = () => {
        timeoutId = setTimeout(() => {
          megaMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          megaMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          trigger.setAttribute('aria-expanded', 'false');
        }, 150);
      };
      
      trigger.addEventListener('mouseenter', showMegaMenu);
      trigger.addEventListener('mouseleave', hideMegaMenu);
      megaMenu.addEventListener('mouseenter', () => { if (timeoutId) clearTimeout(timeoutId); });
      megaMenu.addEventListener('mouseleave', hideMegaMenu);
      
      // Keyboard navigation
      trigger.addEventListener('focus', showMegaMenu);
      trigger.addEventListener('blur', hideMegaMenu);
    });
  }

  function initSidebarFilter() {
    const input = document.getElementById('services-filter') as HTMLInputElement | null;
    if (!input) return;
    const groupLis = Array.from(document.querySelectorAll('#mobile-menu-panel nav ul.space-y-3 > li')) as HTMLElement[];
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      groupLis.forEach(li => {
        const serviceList = li.querySelector('ul.space-y-2');
        if (!serviceList) return;
        let anyVisible = false;
        const items = Array.from(serviceList.querySelectorAll('li')) as HTMLElement[];
        items.forEach(item => {
          const a = item.querySelector('a');
          const txt = (a?.textContent || '').toLowerCase();
          const visible = q === '' || txt.includes(q);
          item.style.display = visible ? '' : 'none';
          if (visible) anyVisible = true;
        });
        li.style.display = (q !== '' && !anyVisible) ? 'none' : '';
      });
    });
  }

  function initSidebarActive() {
    const mobileMenuPanel = document.getElementById('mobile-menu-panel') as HTMLElement | null;
    const pathname = window.location.pathname.replace(/\/$/, '');
    const links = Array.from(document.querySelectorAll('#mobile-menu-panel nav ul.space-y-3 a[href]')) as HTMLAnchorElement[];
    links.forEach(a => {
      const href = (a.getAttribute('href') || '').replace(/\/$/, '');
      if (href && pathname === href) {
        a.classList.add('active-link');
      }
    });
    const linkNodes = Array.from(document.querySelectorAll('#mobile-menu-panel nav a[href^="/services/"]')) as HTMLAnchorElement[];
    linkNodes.forEach(a => {
      a.addEventListener('click', () => {
        if (mobileMenuPanel) localStorage.setItem('mobileMenuScrollTop', String(mobileMenuPanel.scrollTop));
        const href = a.getAttribute('href') || '';
        if (href) localStorage.setItem('mobileMenuSelectedHref', href);
      });
    });
    if (mobileMenuPanel) {
      let stId: number | undefined;
      mobileMenuPanel.addEventListener('scroll', () => {
        if (stId) window.clearTimeout(stId);
        stId = window.setTimeout(() => {
          localStorage.setItem('mobileMenuScrollTop', String(mobileMenuPanel.scrollTop));
        }, 150);
      }, { passive: true });
    }

  }

