      'Exosomas': 'Exosomes',
      'Terapia de Reemplazo Hormonal': 'Hormone Replacement Therapy',
      'Tratamiento de Restauración Capilar con PRP': 'Hair Restoration Treatment with PRP',
      'Tratamiento Microneedling': 'Microneedling Treatment',
      'Microneedling con PRP': 'Microneedling with PRP',
      'Relleno Dérmico': 'Dermal Filler',
      'Relleno de Labios': 'Lip Filler',
      'Inyecciones de Neurotoxina': 'Neurotoxin Injections',
      'Tratamiento Botox No‑Sweat (hiperhidrosis)': 'Botox No-Sweat Treatment (hyperhidrosis)',
      'Mini Aumento de Labios': 'Mini Lip Enhancement',
      'Aumento Completo de Labios': 'Full Lip Augmentation',
      'Mega Aumento de Labios': 'Mega Lip Augmentation',
      'Inyección No More Bags (ojeras/bolsas)': 'No More Bags Injection (under-eye bags)',
      'ThighBella (muslos)': 'ThighBella (thighs)',
      'RollBella (rollito de brasier)': 'RollBella (bra roll)',
      'BananaRoll (zona del bikini)': 'BananaRoll (bikini area)',
      
      'Mega Estimulación de Colágeno con Sculptra': 'Mega Collagen Stimulation with Sculptra',
      'Mini Reducción de Papada': 'Mini Chin Reduction',
      'Terapia Gel PRF de Renasci': 'Renasci PRF Gel Therapy',
      'Inyecciones Puppet Lines (líneas faciales)': 'Puppet Lines Injections (facial lines)',
      'Inyección B12 + Fat Blaster (Doble Efecto)': 'B12 Injection + Fat Blaster (Double Effect)',
      'Consulta de Medicina Alternativa (Obtén tu tarjeta)': 'Alternative Medicine Consultation (Get Carded)',
      'Inyecciones Fat Blaster': 'Fat Blaster Injections',
      'Inyección de Energía B12': 'B12 Energy Injection',
      'Pérdida de Peso Supervisada Médicamente': 'Medically Supervised Weight Loss'
    } as Record<string, string>;

    const enToEs = Object.fromEntries(Object.entries(esToEn).map(([es, en]) => [en, es])) as Record<string, string>;

    function apply(lang: string) {
      // Prefer explicit per-item labels
      const labels = document.querySelectorAll('#mobile-menu-panel .menu-item-label');
      labels.forEach((label) => {
        const el = label as HTMLElement;
        const es = el.getAttribute('data-label-es') || el.textContent || '';
        const en = el.getAttribute('data-label-en') || el.textContent || '';
        el.textContent = lang === 'en' ? (en || es) : (es || en);
      });
      // Fallback: map other texts (section headers etc.)
      const nodes = document.querySelectorAll('#mobile-menu-panel nav *');
      nodes.forEach((el) => {
        const node = el as HTMLElement;
        const txt = node.innerText?.trim();
        if (!txt) return;
        if (lang === 'en' && esToEn[txt]) node.innerText = esToEn[txt];
        if (lang === 'es' && enToEs[txt]) node.innerText = enToEs[txt];
      });
      const filterInput = document.getElementById('services-filter') as HTMLInputElement | null;
      if (filterInput) {
        filterInput.placeholder = lang === 'en' ? 'Filter services...' : 'Filtrar servicios...';
      }
    }

    const current = (window as any).i18nManager?.getCurrentLanguage?.() || document.documentElement.lang || 'es';
    apply(current);
    window.addEventListener('languageChanged', (e: any) => apply(e.detail?.language || 'es'));
  }

  // Initialize all functionality when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    initNavbarScroll();
    initCallButtonRipple();
    initMobileMenu();
    initServicesDropdown();
    initMegaMenu();
    initSidebarFilter();
    initSidebarActive();
    initSidebarLanguageSync();
    initScheduler();
  });
</script>

