---
export interface Props {
  service: {
    id: string;
    slug: string;
    title: { es: string; en: string };
    description: { es: string; en: string };
    excerpt: { es: string; en: string };
    category: string;
    categoryName: { es: string; en: string };
    precio: string;
    duracion?: string;
    image: string;
    benefits: string[];
    href: string;
  };
  lang?: 'es' | 'en';
  class?: string;
}

const { service, lang = 'es', class: className = '' } = Astro.props;

// Use unified data format
const title = service.title[lang];
const description = service.excerpt[lang];
const href = service.href;
const image = service.image;
---

<div class={`service-card group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-xl hover:scale-[1.02] transition-all duration-300 ${className}`} data-category={service.category}>
  <div class="aspect-[4/5] overflow-hidden">
    <img 
      src={image}
      alt={`${title} - ${description}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    >
  </div>
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      <h3 class="font-semibold text-dark font-poppins text-sm">{title}</h3>
    </div>
    <p class="text-gray-600 text-xs mb-3 font-dm-sans line-clamp-2">{description}</p>
    <a 
      href={href}
      class="inline-flex items-center text-primary font-semibold text-sm hover:underline focus-visible:ring-2 ring-primary/50 rounded"
    >
      Ver más →
    </a>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>