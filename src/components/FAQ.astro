---
import FAQItem from './FAQItem.astro';
---

<section class="pt-12 lg:pt-16 pb-16 lg:pb-24 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <div class="flex items-center justify-center mb-4">
        <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
        <span class="mx-4 inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#F3A2A7] text-white">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 9a2.25 2.25 0 1 1 3.9 1.5c-.54.57-1.26.93-1.83 1.28-.81.5-1.32 1.02-1.32 2.22" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 17h.01" />
          </svg>
        </span>
        <div class="flex-1 h-[2px] bg-[#F3A2A7]"></div>
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-[#F3A2A7] mb-6"><span data-i18n="faq.title">Preguntas Frecuentes</span></h2>
      <p class="text-lg md:text-xl text-graytxt mb-8"><span data-i18n="faq.subtitle">Resolvemos las dudas más comunes sobre tratamientos, reservas y membresías.</span></p>
    </div>

    <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-card p-2">
      <FAQItem 
        question="¿Cómo agendo una cita?" 
        answer="Puedes agendar directamente desde la página de contacto o llamarnos. Nuestro equipo confirmará tu horario ideal." 
        questionKey="faq.q1" 
        answerKey="faq.a1" 
        isOpen={true} 
      />
      <FAQItem question="¿Qué tratamientos son adecuados para mí?" answer="Realizamos una evaluación inicial para recomendarte el plan más adecuado según tus objetivos y perfil." questionKey="faq.q2" answerKey="faq.a2" />
      <FAQItem question="¿Ofrecen planes de membresía?" answer="Sí, contamos con una membresía con beneficios y accesos prioritarios. Puedes ver los detalles en la sección de Membresía." questionKey="faq.q3" answerKey="faq.a3" />
      <FAQItem question="¿Cuál es el tiempo de recuperación?" answer="Depende del tratamiento. La mayoría permite retomar actividades el mismo día, con cuidados simples que te indicaremos." questionKey="faq.q4" answerKey="faq.a4" />
      <FAQItem question="¿Aceptan consultas informativas?" answer="Sí, ofrecemos consultas para resolver dudas y diseñar tu plan personalizado." questionKey="faq.q5" answerKey="faq.a5" />
    </div>
  </div>
</section>
