---
import { t } from '../i18n/config';
import { dict } from '../i18n/dict';
import { getLocaleFromUrl } from '../i18n/config';

const currentLocale = getLocaleFromUrl(Astro.url);
---

<footer class="bg-logo/5 border-t border-logo/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 space-y-6 sm:space-y-0">
      <!-- Columna 1: Logo + About Us -->
      <div class="lg:col-span-2 space-y-6">
        <div>
          <img 
            src="/images/Renasci logo.png" 
            alt="Renasci Medical Spa" 
            class="h-10 w-auto mb-4"
            width="120"
            height="40"
            loading="lazy"
          />
          <p class="text-dark/70 leading-relaxed text-base md:text-lg">
            {currentLocale === "es" 
              ? "Renasci Medical Spa es tu destino para tratamientos estéticos avanzados. Renovamos tu piel con los mejores especialistas y tecnología de vanguardia."
              : "Renasci Medical Spa is your destination for advanced aesthetic treatments. We renew your skin with the best specialists and cutting-edge technology."
            }
          </p>
        </div>
        
        <!-- Certificaciones -->
        <div class="flex flex-wrap items-center gap-3 text-sm text-dark/60">
          <span class="bg-primary/10 text-primary px-3 py-1 rounded-full font-medium">
            {currentLocale === "es" ? "Certificado FDA" : "FDA Certified"}
          </span>
          <span class="bg-logo/20 text-logo px-3 py-1 rounded-full font-medium">
            {currentLocale === "es" ? "Licenciado" : "Licensed"}
          </span>
        </div>
      </div>

      <!-- Columna 2: Contact Us -->
      <div class="space-y-6">
        <h3 class="font-display font-bold text-xl md:text-2xl text-dark tracking-tight">
          {t(currentLocale, "footer.contact_title", dict)}
        </h3>
        
        <div class="space-y-4">
          <!-- Dirección -->
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <p class="text-dark font-medium">
                {currentLocale === "es" ? "Ubicación" : "Location"}
              </p>
              <p class="text-dark/70 text-sm leading-relaxed">
                123 Beauty Lane<br>
                Salt Lake City, UT 84101
              </p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <div>
              <a 
                href="tel:+1-801-555-0123" 
                class="text-dark hover:text-primary transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Llamar al teléfono principal" : "Call main phone number"}
              >
                +1 (801) 555-0123
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <div>
              <a 
                href="mailto:info@renasci.com" 
                class="text-dark hover:text-primary transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Enviar email" : "Send email"}
              >
                info@renasci.com
              </a>
            </div>
          </div>

          <!-- Horarios -->
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <p class="text-dark font-medium mb-1">
                {currentLocale === "es" ? "Horarios" : "Hours"}
              </p>
              <div class="text-dark/70 text-sm space-y-1 leading-relaxed">
                <p>{currentLocale === "es" ? "Lun - Vie: 9:00 AM - 7:00 PM" : "Mon - Fri: 9:00 AM - 7:00 PM"}</p>
                <p>{currentLocale === "es" ? "Sáb: 9:00 AM - 5:00 PM" : "Sat: 9:00 AM - 5:00 PM"}</p>
                <p>{currentLocale === "es" ? "Dom: Cerrado" : "Sun: Closed"}</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna 3: Find Us On (Redes Sociales) -->
      <div class="space-y-6">
        <h3 class="font-display font-bold text-xl md:text-2xl text-dark tracking-tight">
          {t(currentLocale, "footer.social_title", dict)}
        </h3>
        
        <div class="space-y-4">
          <p class="text-dark/70 text-base leading-relaxed">
            {currentLocale === "es" 
              ? "Síguenos en nuestras redes sociales para tips de belleza, promociones exclusivas y transformaciones increíbles."
              : "Follow us on social media for beauty tips, exclusive promotions and incredible transformations."
            }
          </p>
          
          <!-- Social Links -->
          <div class="flex flex-wrap gap-3">
            <!-- Instagram -->
            <a 
              href="https://instagram.com/renasci-medspa" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en Instagram" : "Follow on Instagram"}
            >
              <svg class="w-6 h-6 text-pink-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.62 5.367 11.987 11.988 11.987s11.987-5.367 11.987-11.987C24.004 5.367 18.637.001 12.017.001zM8.449 16.988c-1.297 0-2.448-.49-3.323-1.297C4.198 14.895 3.708 13.744 3.708 12.447s.49-2.448 1.418-3.323c.875-.807 2.026-1.297 3.323-1.297s2.448.49 3.323 1.297c.928.875 1.418 2.026 1.418 3.323s-.49 2.448-1.418 3.244c-.875.807-2.026 1.297-3.323 1.297zm7.83-9.781c-.315 0-.595-.122-.807-.315-.21-.21-.315-.49-.315-.807s.105-.595.315-.807c.21-.21.49-.315.807-.315s.595.105.807.315c.21.21.315.49.315.807s-.105.595-.315.807c-.21.193-.49.315-.807.315z"/>
                <path d="M12.017 7.075c-2.73 0-4.942 2.212-4.942 4.942s2.212 4.942 4.942 4.942 4.942-2.212 4.942-4.942-2.212-4.942-4.942-4.942z"/>
              </svg>
            </a>

            <!-- Facebook -->
            <a 
              href="https://facebook.com/renasci-medspa" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en Facebook" : "Follow on Facebook"}
            >
              <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>

            <!-- TikTok -->
            <a 
              href="https://tiktok.com/@renasci-medspa" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en TikTok" : "Follow on TikTok"}
            >
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-.88-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
              </svg>
            </a>

            <!-- YouTube -->
            <a 
              href="https://youtube.com/@renasci-medspa" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en YouTube" : "Follow on YouTube"}
            >
              <svg class="w-6 h-6 text-red-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          </div>

          <!-- Newsletter -->
          <div class="mt-6 p-4 bg-white rounded-lg border border-logo/20">
            <h4 class="font-semibold text-dark mb-2">
              {currentLocale === "es" ? "Newsletter" : "Newsletter"}
            </h4>
            <p class="text-sm text-dark/70 mb-3 leading-relaxed">
              {currentLocale === "es" 
                ? "Recibe tips de belleza y ofertas exclusivas"
                : "Get beauty tips and exclusive offers"
              }
            </p>
            <div class="flex">
              <input 
                type="email" 
                placeholder={currentLocale === "es" ? "Tu email" : "Your email"}
                class="flex-1 px-3 py-2 border border-gray-200 rounded-l-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary min-h-[44px]"
                aria-label={currentLocale === "es" ? "Ingresa tu email para el newsletter" : "Enter your email for newsletter"}
              />
              <button 
                type="submit"
                class="px-4 py-2 bg-primary text-white rounded-r-lg text-sm font-medium hover:bg-primary/90 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Suscribirse al newsletter" : "Subscribe to newsletter"}
              >
                {currentLocale === "es" ? "Enviar" : "Send"}
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-logo/20">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <div class="text-sm text-dark/60 text-center md:text-left">
          © 2024 Renasci Medical Spa. {currentLocale === "es" ? "Todos los derechos reservados." : "All rights reserved."}
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
          <a 
            href="/privacy" 
            class="text-dark/60 hover:text-primary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver política de privacidad" : "View privacy policy"}
          >
            {currentLocale === "es" ? "Privacidad" : "Privacy"}
          </a>
          <a 
            href="/terms" 
            class="text-dark/60 hover:text-primary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver términos de servicio" : "View terms of service"}
          >
            {currentLocale === "es" ? "Términos" : "Terms"}
          </a>
          <a 
            href="/sitemap.xml" 
            class="text-dark/60 hover:text-primary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver mapa del sitio" : "View sitemap"}
          >
            {currentLocale === "es" ? "Mapa del sitio" : "Sitemap"}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Enhanced focus styles for footer links */
  footer a:focus-visible {
    outline: 2px solid #E94594;
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Social icons hover effects */
  footer .social-icon:hover {
    transform: translateY(-2px);
  }
</style>