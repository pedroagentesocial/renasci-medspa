---
import { t } from '../i18n/config';
import { dict } from '../i18n/dict';
import { getLocaleFromUrl } from '../i18n/config';

const currentLocale = getLocaleFromUrl(Astro.url);
---

<footer class="bg-white border-t border-logo/10">
  <div class="h-[2px] w-screen bg-black relative left-1/2 -ml-[50vw]"></div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 space-y-6 sm:space-y-0">
      <!-- Columna 1: Logo + About Us -->
      <div class="lg:col-span-2 space-y-6">
        <div>
          <img 
            src="/images/Renasci logo.png" 
            alt="Renasci Medical Spa" 
            class="h-10 w-auto mb-4"
            width="120"
            height="40"
            loading="lazy"
          />
          <p class="text-dark/70 leading-relaxed text-base md:text-lg">
            <span data-i18n="footer.about_paragraph">Renasci Medical Spa es tu destino para tratamientos estéticos avanzados. Renovamos tu piel con los mejores especialistas y tecnología de vanguardia.</span>
          </p>
        </div>
        
        <!-- Certificaciones -->
        <div class="flex flex-wrap items-center gap-3 text-sm text-dark/60">
          <span class="bg-primary/10 text-primary px-3 py-1 rounded-full font-medium"><span data-i18n="footer.cert_fda">Certificado FDA</span></span>
          <span class="bg-logo/20 text-logo px-3 py-1 rounded-full font-medium"><span data-i18n="footer.cert_licensed">Licenciado</span></span>
        </div>
      </div>

      <!-- Columna 2: Contact Us -->
      <div class="space-y-6">
        <h3 class="font-display font-bold text-xl md:text-2xl text-dark tracking-tight"><span data-i18n="footer.contact_title">Contáctanos</span></h3>
        
        <div class="space-y-4">
          <!-- Dirección -->
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <p class="text-dark font-medium"><span data-i18n="footer.location_label">Ubicación</span></p>
              <p class="text-dark/70 text-sm leading-relaxed">
                123 Beauty Lane<br>
                Salt Lake City, UT 84101
              </p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <div>
              <a 
                href="tel:+1-801-555-0123" 
                class="text-dark hover:text-primary transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Llamar al teléfono principal" : "Call main phone number"}
              >
                +1 (801) 555-0123
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <div>
              <a 
                href="mailto:info@renasci.com" 
                class="text-dark hover:text-primary transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Enviar email" : "Send email"}
              >
                info@renasci.com
              </a>
            </div>
          </div>

          <!-- Horarios -->
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <p class="text-dark font-medium mb-1"><span data-i18n="footer.hours_label">Horarios</span></p>
              <div class="text-dark/70 text-sm space-y-1 leading-relaxed">
                <p><span data-i18n="footer.hours_mon_fri">Lun - Vie: 9:00 AM - 7:00 PM</span></p>
                <p><span data-i18n="footer.hours_sat">Sáb: 9:00 AM - 5:00 PM</span></p>
                <p><span data-i18n="footer.hours_sun">Dom: Cerrado</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna 3: Find Us On (Redes Sociales) -->
      <div class="space-y-6">
        <h3 class="font-display font-bold text-xl md:text-2xl text-dark tracking-tight"><span data-i18n="footer.social_title">Síguenos</span></h3>
        
        <div class="space-y-4">
          <p class="text-dark/70 text-base leading-relaxed"><span data-i18n="footer.follow_paragraph">Síguenos en nuestras redes sociales para tips de belleza, promociones exclusivas y transformaciones increíbles.</span></p>
          
          <!-- Social Links -->
          <div class="flex flex-wrap gap-3">
            <!-- Instagram -->
            <a 
              href="https://www.instagram.com/renascimedspa/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en Instagram" : "Follow on Instagram"}
            >
              <svg class="w-6 h-6 text-pink-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" ry="5" stroke-width="2" />
                <circle cx="12" cy="12" r="4" stroke-width="2" />
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
              </svg>
            </a>

            <!-- Facebook -->
            <a 
              href="https://www.facebook.com/profile.php?id=61580623082047" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm hover:shadow-md transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en Facebook" : "Follow on Facebook"}
            >
              <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>

            
          </div>

          
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-6 pt-4 border-t border-primary">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <div class="text-sm text-dark/60 text-center md:text-left">
          © 2025 Renasci Medical Spa. <span data-i18n="footer.copyright_suffix">Todos los derechos reservados.</span>
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
          <a 
            href="/privacy" 
            class="text-dark/60 hover:text-primary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver política de privacidad" : "View privacy policy"}
          >
            <span data-i18n="footer.privacy">Privacidad</span>
          </a>
          <a 
            href="/terms" 
            class="text-dark/60 hover:text-primary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver términos de servicio" : "View terms of service"}
          >
            <span data-i18n="footer.terms">Términos</span>
          </a>
          <a 
            href="/sitemap.xml" 
            class="text-dark/60 hover:text-primary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver mapa del sitio" : "View sitemap"}
          >
            <span data-i18n="footer.sitemap">Mapa del sitio</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Enhanced focus styles for footer links */
  footer a:focus-visible {
    outline: 2px solid #E94594;
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Social icons hover effects */
  footer .social-icon:hover {
    transform: translateY(-2px);
  }
</style>
