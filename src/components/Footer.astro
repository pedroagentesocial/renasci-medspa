---
import { t } from '../i18n/config';
import { dict } from '../i18n/dict';
import { getLocaleFromUrl } from '../i18n/config';
import ReviewCTA from './ReviewCTA.astro';

const currentLocale = getLocaleFromUrl(Astro.url);
---

<footer class="bg-[#AABFA8] border-t border-logo/10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 space-y-6 sm:space-y-0">
      <!-- Columna 1: Logo + About Us -->
      <div class="lg:col-span-2 space-y-6">
        <div>
          <img 
            src="/logo/Renasci-logo.png" 
            alt="Renasci Medical Spa" 
            class="h-14 md:h-16 w-auto mb-4 brightness-0 invert"
            width="160"
            height="64"
            loading="lazy"
          />
          <p class="text-white/80 leading-relaxed text-base md:text-lg">
            <span data-i18n="footer.about_paragraph">Renasci Medical Spa es tu destino para tratamientos estéticos avanzados. Renovamos tu piel con los mejores especialistas y tecnología de vanguardia.</span>
          </p>
        </div>
        
        <!-- Certificaciones -->
        <div class="flex flex-wrap items-center gap-3 text-sm text-white/80">
          <span class="bg-white/15 text-white px-3 py-1 rounded-full font-medium"><span data-i18n="footer.cert_fda">Certificado FDA</span></span>
          <span class="bg-white/15 text-white px-3 py-1 rounded-full font-medium"><span data-i18n="footer.cert_licensed">Licenciado</span></span>
        </div>
      </div>

      <!-- Columna 2: Contact Us -->
      <div class="space-y-6">
        <h3 class="font-display font-bold text-xl md:text-2xl text-white tracking-tight"><span data-i18n="footer.contact_title">Contáctanos</span></h3>
        
        <div class="space-y-4">
          <!-- Dirección -->
          <div class="flex items-start space-x-3">
            <svg class="w-7 h-7 text-white/90 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <p class="text-white font-medium"><span data-i18n="footer.location_label">Ubicación</span></p>
              <p class="text-white/80 text-sm leading-relaxed">
                6770 S 900 E, Suite 100<br>
                Midvale, UT 84047
              </p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-center space-x-3">
            <svg class="w-7 h-7 text-white/90 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <div>
              <a 
                href="tel:+13856092840" 
                class="text-white hover:text-white/80 transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Llamar al teléfono principal" : "Call main phone number"}
              >
                (385) 609-2840
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center space-x-3">
            <svg class="w-7 h-7 text-white/90 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <div>
              <a 
                href="mailto:orders@renascimedspa.com" 
                class="text-white hover:text-white/80 transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center"
                aria-label={currentLocale === "es" ? "Enviar email" : "Send email"}
              >
                orders@renascimedspa.com
              </a>
            </div>
          </div>

          <!-- Horarios -->
          <div class="flex items-start space-x-3">
            <svg class="w-7 h-7 text-white/90 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <p class="text-white font-medium mb-1"><span data-i18n="footer.hours_label">Horarios</span></p>
              <div class="text-white/80 text-sm space-y-1 leading-relaxed">
                <p><span data-i18n="footer.hours_mon_fri">Lun - Vie: 9:00 AM - 7:00 PM</span></p>
                <p><span data-i18n="footer.hours_sat">Sáb: 9:00 AM - 5:00 PM</span></p>
                <p><span data-i18n="footer.hours_sun">Dom: Cerrado</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna 3: Find Us On (Redes Sociales) -->
      <div class="space-y-6">
        <h3 class="font-display font-bold text-xl md:text-2xl text-white tracking-tight"><span data-i18n="footer.social_title">Síguenos</span></h3>
        
        <div class="space-y-4">
          <p class="text-white/80 text-base leading-relaxed"><span data-i18n="footer.follow_paragraph">Síguenos en nuestras redes sociales para tips de belleza, promociones exclusivas y transformaciones increíbles.</span></p>
          
          <!-- Social Links -->
          <div class="flex flex-wrap gap-3">
            <!-- Instagram -->
            <a 
              href="https://www.instagram.com/renascimedicalspa/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 flex items-center justify-center transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en Instagram" : "Follow on Instagram"}
            >
              <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 7.3a4.7 4.7 0 1 0 0 9.4 4.7 4.7 0 0 0 0-9.4Zm0 7.7a3 3 0 1 1 0-6 3 3 0 0 1 0 6Zm6-7.9a1.1 1.1 0 1 1-2.2 0 1.1 1.1 0 0 1 2.2 0ZM20.2 7c-.1-1.3-.3-2-1-2.7-.7-.7-1.4-.9-2.7-1C15.2 3 8.8 3 7.4 3.3c-1.3.1-2 .3-2.7 1-.7.7-.9 1.4-1 2.7-.3 1.4-.3 7.8 0 9.2.1 1.3.3 2 1 2.7.7.7 1.4.9 2.7 1 1.4.3 7.8.3 9.2 0 1.3-.1 2-.3 2.7-1 .7-.7.9-1.4 1-2.7.3-1.4.3-7.7 0-9.2ZM12 19.5c-2.8 0-5.5.2-6.4-.7-.9-.9-.7-3.6-.7-6.4 0-2.8-.2-5.5.7-6.4.9-.9 3.6-.7 6.4-.7 2.8 0 5.5-.2 6.4.7.9.9.7 3.6.7 6.4 0 2.8.2 5.5-.7 6.4-.9.9-3.6.7-6.4.7Z"/>
              </svg>
            </a>

            <!-- Facebook -->
            <a 
              href="https://www.facebook.com/profile.php?id=61580623082047" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-12 h-12 flex items-center justify-center transition-all duration-300 hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2"
              aria-label={currentLocale === "es" ? "Seguir en Facebook" : "Follow on Facebook"}
            >
              <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.1C24 5.4 18.6 0 12 0S0 5.4 0 12.1C0 18 4.4 23 10.1 24v-8.4H7.1v-3.5h3V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3H15.8c-1.5 0-2 .9-2 1.9v2.3h3.4l-.5 3.5h-2.9V24C19.6 23 24 18 24 12.1Z"/>
              </svg>
            </a>

            
          </div>

          
        </div>
      </div>
    </div>

    <!-- Review CTA inline -->
    <div class="mt-8 pt-6 border-t border-white/20">
      <div class="flex items-center gap-3 text-xs">
        <span class="text-white/70"
              data-t-es="¿Te atendimos? "
              data-t-en="Were you a patient? ">¿Te atendimos? </span>
        <ReviewCTA variant="inline" />
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-6 pt-4 border-t border-white/30">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <div class="text-sm text-white/70 text-center md:text-left">
          © 2025 Renasci Medical Spa. <span data-i18n="footer.copyright_suffix">Todos los derechos reservados.</span>
        </div>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
          <a 
            href="/privacy" 
            class="text-white/70 hover:text-white transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "View Privacy Policy" : "View Privacy Policy"}
          >
            <span data-i18n="footer.privacy">Privacy Policy</span>
          </a>
          <a 
            href="/terms" 
            class="text-white/70 hover:text-white transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver términos de servicio" : "View terms of service"}
          >
            <span data-i18n="footer.terms">Términos</span>
          </a>
          <a 
            href="/sitemap" 
            class="text-white/70 hover:text-white transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 rounded min-h-[44px] flex items-center px-2"
            aria-label={currentLocale === "es" ? "Ver mapa del sitio" : "View sitemap"}
          >
            <span data-i18n="footer.sitemap">Mapa del sitio</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Enhanced focus styles for footer links */
  footer a:focus-visible {
    outline: 2px solid #FFFFFF;
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Social icons hover effects */
  footer .social-icon:hover {
    transform: translateY(-2px);
  }
</style>
