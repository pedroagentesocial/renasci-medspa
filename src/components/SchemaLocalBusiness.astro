---
export interface Props {
  name?: string;
  description?: string;
  url?: string;
  telephone?: string;
  email?: string;
  address?: {
    streetAddress?: string;
    addressLocality?: string;
    addressRegion?: string;
    postalCode?: string;
    addressCountry?: string;
  };
  openingHours?: string[];
  sameAs?: string[];
  priceRange?: string;
  image?: string;
}

const {
  name = "Renasci Medical Spa",
  description = "Advanced aesthetic treatments and medical spa services in Utah. Specializing in Botox, dermal fillers, Sculptra, and skin rejuvenation treatments.",
  url = "https://tu-dominio.com/",
  telephone = "+1-000-000-0000",
  email = "info@renasci.com",
  address = {
    addressLocality: "Utah",
    addressRegion: "UT", 
    addressCountry: "US"
  },
  openingHours = [
    "Mo-Fr 09:00-18:00",
    "Sa 09:00-16:00"
  ],
  sameAs = [
    "https://www.instagram.com/renascimedicalspa/",
    "https://facebook.com/renasci-medspa", 
    "https://tiktok.com/@renasci-medspa"
  ],
  priceRange = "$$",
  image = "https://tu-dominio.com/og-image.jpg"
} = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "@id": url,
  "name": name,
  "description": description,
  "url": url,
  "telephone": telephone,
  "email": email,
  "image": image,
  "priceRange": priceRange,
  "address": {
    "@type": "PostalAddress",
    ...address
  },
  "openingHoursSpecification": openingHours.map(hours => {
    const [days, time] = hours.split(' ');
    const [startTime, endTime] = time.split('-');
    
    return {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": days.split('-').map(day => {
        const dayMap: Record<string, string> = {
          "Mo": "Monday",
          "Tu": "Tuesday", 
          "We": "Wednesday",
          "Th": "Thursday",
          "Fr": "Friday",
          "Sa": "Saturday",
          "Su": "Sunday"
        };
        return dayMap[day] || day;
      }),
      "opens": startTime,
      "closes": endTime
    };
  }),
  "sameAs": sameAs,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Medical Spa Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Botox Treatments",
          "description": "Professional Botox injections for wrinkle reduction"
        }
      },
      {
        "@type": "Offer", 
        "itemOffered": {
          "@type": "Service",
          "name": "Dermal Fillers",
          "description": "Hyaluronic acid fillers for facial enhancement"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service", 
          "name": "Sculptra",
          "description": "Collagen stimulating treatments for natural results"
        }
      }
    ]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "127",
    "bestRating": "5",
    "worstRating": "1"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>
