---
export interface Props {
  variant?: 'section' | 'card' | 'inline';
  title?: string;
  subtitle?: string;
}

const REVIEW_URL = 'https://g.page/r/CTkD-Yd93RJJEBM/review';

const {
  variant = 'section',
  title = '¿Tu experiencia fue buena? Cuéntale a Google',
  subtitle = 'Tu reseña en Google ayuda a otras personas a encontrarnos y nos motiva a seguir mejorando. Te toma menos de 1 minuto.'
} = Astro.props;
---

{variant === 'section' && (
  <section class="py-16 lg:py-20 bg-gradient-to-br from-[#F3A2A7]/10 via-white to-[#AABFA8]/10 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 left-10 text-9xl">★</div>
      <div class="absolute top-32 right-20 text-8xl">★</div>
      <div class="absolute bottom-20 left-1/4 text-7xl">★</div>
      <div class="absolute bottom-32 right-1/3 text-9xl">★</div>
    </div>

    <div class="container mx-auto px-6 relative">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-1 text-2xl text-[#F3A2A7] mb-5" aria-hidden="true">
          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
        </div>
        <p class="text-xs uppercase tracking-[0.22em] text-[#F3A2A7] font-semibold mb-3"
           data-t-es="Tu opinión cuenta"
           data-t-en="Your voice matters">Tu opinión cuenta</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-gray-900 mb-4"
            data-t-es={title}
            data-t-en="Had a great experience? Tell Google">{title}</h2>
        <p class="text-base md:text-lg text-gray-700 leading-relaxed mb-8 max-w-2xl mx-auto"
           data-t-es={subtitle}
           data-t-en="Your Google review helps others find us and motivates us to keep raising the bar. It takes less than 1 minute.">{subtitle}</p>

        <a
          href={REVIEW_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-review-trigger="google"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-[#F3A2A7] text-white font-semibold text-base md:text-lg hover:brightness-105 hover:-translate-y-[1px] transition-all duration-200 shadow-lg shadow-[#F3A2A7]/30"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
          </svg>
          <span data-t-es="Dejar reseña en Google"
                data-t-en="Leave a Google Review">Dejar reseña en Google</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>

        <p class="text-xs text-gray-500 mt-5"
           data-t-es="Se abre en una nueva pestaña en Google · Toma menos de 1 minuto"
           data-t-en="Opens in a new tab on Google · Takes under 1 minute">
          Se abre en una nueva pestaña en Google · Toma menos de 1 minuto
        </p>
      </div>
    </div>
  </section>
)}

{variant === 'card' && (
  <div class="bg-gradient-to-br from-[#F3A2A7] to-[#C69C87] text-white rounded-3xl p-7 lg:p-8">
    <div class="flex items-center gap-1 text-xl text-white/90 mb-3" aria-hidden="true">
      <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
    </div>
    <p class="text-xs uppercase tracking-[0.16em] text-white/80 font-semibold mb-2"
       data-t-es="¿Ya nos visitaste?"
       data-t-en="Already visited us?">¿Ya nos visitaste?</p>
    <h3 class="font-display font-bold text-2xl mb-2"
        data-t-es="Déjanos tu reseña"
        data-t-en="Leave us a review">Déjanos tu reseña</h3>
    <p class="text-sm text-white/90 mb-5"
       data-t-es="Tu reseña en Google ayuda a otras pacientes a encontrarnos."
       data-t-en="Your Google review helps other patients find us.">
      Tu reseña en Google ayuda a otras pacientes a encontrarnos.
    </p>
    <a
      href={REVIEW_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-review-trigger="google"
      class="inline-flex items-center gap-2 bg-white text-[#F3A2A7] font-semibold px-5 py-2.5 rounded-full hover:brightness-95 transition"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
      </svg>
      <span data-t-es="Dejar reseña" data-t-en="Leave a review">Dejar reseña</span>
    </a>
  </div>
)}

{variant === 'inline' && (
  <a
    href={REVIEW_URL}
    target="_blank"
    rel="noopener noreferrer"
    data-review-trigger="google"
    class="inline-flex items-center gap-1.5 text-white/85 hover:text-white text-sm transition"
    aria-label="Dejar reseña en Google"
  >
    <svg class="w-4 h-4 text-[#F3A2A7]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
    </svg>
    <span data-t-es="Reseña en Google" data-t-en="Google Review">Reseña en Google</span>
  </a>
)}
