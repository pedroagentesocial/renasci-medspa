---
import TierCard from './TierCard.astro';
---

<!-- Sección Elige tu Plan Perfecto -->
<section id="planes" class="py-20 bg-gradient-to-br from-primary/5 to-secondary/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-display font-bold text-4xl md:text-5xl text-text mb-6 tracking-tight">
        Elige tu Plan Perfecto
      </h2>
      <p class="text-xl text-graytxt max-w-3xl mx-auto leading-relaxed">
        Cada plan está diseñado para diferentes necesidades y presupuestos. 
        Todos incluyen beneficios exclusivos y atención personalizada.
      </p>
    </div>
    
    <!-- Mobile: Stack vertical con Glow al centro (order-2) -->
    <!-- Desktop: Grid de 3 columnas con Glow destacado -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <!-- Plan Rack -->
      <div class="order-1 lg:order-1 plan-card">
        <TierCard
            title="Rack"
            price="$99"
            period="/mes"
            description="Perfecto para comenzar tu journey de belleza con beneficios básicos"
            features={[
              "10% descuento en todos los servicios",
              "Consultas gratuitas ilimitadas", 
              "Acceso a promociones exclusivas",
              "1 facial básico gratis al mes",
              "Soporte por email",
              "Cancelación flexible"
            ]}
            ctaText="Comenzar Plan Rack"
            ctaHref="#contacto"
            class="h-full transform hover:scale-105 transition-all duration-300"
          />
      </div>
      
      <!-- Plan Glow (Destacado) - Centro en móvil con order-2 -->
      <div class="order-2 lg:order-2 plan-card-featured">
        <TierCard
            title="Glow"
            price="$199"
            period="/mes"
            description="Nuestro plan más popular con beneficios premium y tratamientos incluidos"
            features={[
              "20% descuento en todos los servicios",
              "2 tratamientos premium incluidos",
              "Consultas y seguimientos gratuitos",
              "Acceso prioritario a citas",
              "Productos para el hogar incluidos",
              "Soporte telefónico 24/7",
              "Invitaciones a eventos exclusivos",
              "Plan de tratamiento personalizado"
            ]}
            ctaText="Elegir Plan Glow"
            ctaHref="#contacto"
            highlight={true}
            class="h-full lg:scale-110 lg:z-10 relative transform hover:scale-115 transition-all duration-300 shadow-2xl"
          />
      </div>
      
      <!-- Plan Elite -->
      <div class="order-3 lg:order-3 plan-card">
        <TierCard
            title="Elite"
            price="$399"
            period="/mes"
            description="La experiencia más exclusiva con acceso VIP y tratamientos ilimitados"
            features={[
              "30% descuento en todos los servicios",
              "Tratamientos ilimitados básicos",
              "3 tratamientos premium incluidos",
              "Concierge personal dedicado",
              "Acceso VIP sin esperas",
              "Kit completo de productos premium",
              "Consultas en casa disponibles",
              "Acceso a tratamientos experimentales",
              "Garantía de satisfacción 100%"
            ]}
            ctaText="Experiencia Elite"
            ctaHref="#contacto"
            class="h-full transform hover:scale-105 transition-all duration-300"
          />
      </div>
    </div>
  </div>
</section>

<script>
  // Animaciones para las tarjetas de planes
  function initPlanAnimations() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, observerOptions);

    // Observar elementos animables
    document.querySelectorAll('.plan-card, .plan-card-featured').forEach(el => {
      observer.observe(el);
    });
  }

  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', initPlanAnimations);
</script>

<style>
  .plan-card, .plan-card-featured {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease-out;
  }

  .plan-card.animate-in, .plan-card-featured.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .plan-card-featured.animate-in {
    animation: glow-pulse 2s ease-in-out infinite alternate;
  }

  @keyframes glow-pulse {
    0% {
      box-shadow: 0 0 20px rgba(var(--primary-rgb), 0.3);
    }
    100% {
      box-shadow: 0 0 40px rgba(var(--primary-rgb), 0.5);
    }
  }
</style>