---
export interface Props {
  title: string;
  description: string;
  url?: string;
  image?: string;
  locale?: string;
  type?: string;
  siteName?: string;
  author?: string;
  keywords?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  url = "/",
  image = "/og-image.jpg",
  locale = "es",
  type = "website",
  siteName = "Renasci Medical Spa",
  author = "Renasci Medical Spa",
  keywords = "medical spa, tratamientos estéticos, belleza, Utah",
  canonicalUrl
} = Astro.props;

// Construct full URLs
const siteUrl = "https://tu-dominio.com";
const fullUrl = new URL(url, siteUrl).toString();
const fullImageUrl = new URL(image, siteUrl).toString();
const canonical = canonicalUrl ? new URL(canonicalUrl, siteUrl).toString() : fullUrl;
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={author} />
<meta name="robots" content="index, follow" />
<meta name="language" content={locale} />
<meta name="revisit-after" content="7 days" />

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={fullUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={fullUrl} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={fullImageUrl} />
<meta property="twitter:image:alt" content={title} />

<!-- Additional Meta Tags -->
<meta name="theme-color" content="#1DD1A1" />
<meta name="msapplication-TileColor" content="#1DD1A1" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content={siteName} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/icons/flor-renasci.svg?v=1" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Preconnect to external domains -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Alternate languages -->
{locale === 'es' && (
  <link rel="alternate" hreflang="en" href={fullUrl.replace('/es/', '/en/')} />
)}
{locale === 'en' && (
  <link rel="alternate" hreflang="es" href={fullUrl.replace('/en/', '/es/')} />
)}
<link rel="alternate" hreflang="x-default" href={fullUrl} />
