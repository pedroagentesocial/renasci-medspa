---
export interface Props {
  variant?: 'service' | 'tier' | 'testimonial' | 'blog';
  className?: string;
}

const { 
  variant = 'service',
  className = ""
} = Astro.props;
---

{variant === 'service' && (
  <div class={`animate-pulse bg-white rounded-2xl shadow-card overflow-hidden ${className}`}>
    <!-- Image skeleton -->
    <div class="bg-soft aspect-[4/5] rounded-t-2xl"></div>
    
    <!-- Content skeleton -->
    <div class="p-4 space-y-3">
      <!-- Title -->
      <div class="h-5 bg-soft rounded-lg w-3/4"></div>
      
      <!-- Description lines -->
      <div class="space-y-2">
        <div class="h-3 bg-soft rounded w-full"></div>
        <div class="h-3 bg-soft rounded w-2/3"></div>
      </div>
      
      <!-- Price -->
      <div class="h-4 bg-soft rounded w-1/3 mt-4"></div>
      
      <!-- Button -->
      <div class="h-10 bg-soft rounded-2xl w-full mt-4"></div>
    </div>
  </div>
)}

{variant === 'tier' && (
  <div class={`animate-pulse bg-white rounded-2xl shadow-card p-6 ${className}`}>
    <!-- Badge skeleton -->
    <div class="h-6 bg-soft rounded-full w-20 mb-4"></div>
    
    <!-- Title -->
    <div class="h-6 bg-soft rounded w-2/3 mb-2"></div>
    
    <!-- Price -->
    <div class="h-8 bg-soft rounded w-1/2 mb-4"></div>
    
    <!-- Description -->
    <div class="space-y-2 mb-6">
      <div class="h-3 bg-soft rounded w-full"></div>
      <div class="h-3 bg-soft rounded w-3/4"></div>
    </div>
    
    <!-- Features list -->
    <div class="space-y-3 mb-6">
      {Array.from({ length: 4 }).map(() => (
        <div class="flex items-center space-x-3">
          <div class="w-4 h-4 bg-soft rounded-full"></div>
          <div class="h-3 bg-soft rounded flex-1"></div>
        </div>
      ))}
    </div>
    
    <!-- Button -->
    <div class="h-12 bg-soft rounded-2xl w-full"></div>
  </div>
)}

{variant === 'testimonial' && (
  <div class={`animate-pulse bg-white rounded-2xl shadow-card p-6 ${className}`}>
    <!-- Quote -->
    <div class="space-y-2 mb-4">
      <div class="h-4 bg-soft rounded w-full"></div>
      <div class="h-4 bg-soft rounded w-5/6"></div>
      <div class="h-4 bg-soft rounded w-3/4"></div>
    </div>
    
    <!-- Author info -->
    <div class="flex items-center space-x-3 mt-6">
      <!-- Avatar -->
      <div class="w-12 h-12 bg-soft rounded-full"></div>
      
      <!-- Name and title -->
      <div class="space-y-1">
        <div class="h-4 bg-soft rounded w-24"></div>
        <div class="h-3 bg-soft rounded w-20"></div>
      </div>
    </div>
  </div>
)}

{variant === 'blog' && (
  <div class={`animate-pulse bg-white rounded-2xl shadow-card overflow-hidden ${className}`}>
    <!-- Image skeleton -->
    <div class="bg-soft aspect-[16/9] rounded-t-2xl"></div>
    
    <!-- Content skeleton -->
    <div class="p-4 space-y-3">
      <!-- Category -->
      <div class="h-3 bg-soft rounded w-16"></div>
      
      <!-- Title -->
      <div class="h-5 bg-soft rounded w-full"></div>
      <div class="h-5 bg-soft rounded w-3/4"></div>
      
      <!-- Excerpt -->
      <div class="space-y-2 mt-3">
        <div class="h-3 bg-soft rounded w-full"></div>
        <div class="h-3 bg-soft rounded w-5/6"></div>
      </div>
      
      <!-- Meta info -->
      <div class="flex items-center space-x-4 mt-4">
        <div class="h-3 bg-soft rounded w-16"></div>
        <div class="h-3 bg-soft rounded w-20"></div>
      </div>
    </div>
  </div>
)}

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  /* Shimmer effect for more elegant loading */
  .animate-pulse::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    animation: shimmer 1.5s infinite;
  }
  
  @keyframes shimmer {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }
  
  /* Ensure skeleton cards maintain proper positioning */
  .animate-pulse {
    position: relative;
    overflow: hidden;
  }
</style>