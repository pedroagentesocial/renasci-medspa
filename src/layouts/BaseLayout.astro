      "slogan": "Renueva tu Piel — Renew Your Skin",
      "url": "https://renascimedspa.com",
      "logo": "https://renascimedspa.com/logo/Renasci-logo.png",
      "image": [
        "https://renascimedspa.com/og-image.jpg",
        "https://renascimedspa.com/logo/Renasci-logo.png"
      ],
      "telephone": "+1-385-609-2840",
      "email": "orders@renascimedspa.com",
      "priceRange": "$$",
      "currenciesAccepted": "USD",
      "paymentAccepted": "Cash, Credit Card, Debit Card",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6770 S 900 E, Suite 100",
        "addressLocality": "Midvale",
        "addressRegion": "UT",
        "postalCode": "84047",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 40.6275,
        "longitude": -111.8635
      },
