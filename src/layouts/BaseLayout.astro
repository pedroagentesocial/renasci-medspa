      details: { title: "PRP Microneedling — Stretch Marks", p1: "Microneedling creates controlled micro‑channels; PRP overlays to intensify healing and remodeling of stretch marks.", p2: "Comfort‑focused technique tailored to area and pattern.", p3: "Series often recommended; optional boosters refine outcomes." },
      benefits: { title: "Treatment Benefits", subtitle: "Why choose PRP microneedling for stretch marks", items: [ { title: "Remodeling Support", text: "Collagen response to smooth texture." }, { title: "Appearance Improvement", text: "Reduces contrast and visibility." }, { title: "Comfort‑Focused", text: "Tailored parameters per area." } ] },
