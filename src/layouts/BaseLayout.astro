---
import HeaderNav from '../components/HeaderNav.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import LanguageToggle from '../components/LanguageToggle.astro';
import { getLocaleFromUrl } from '../i18n/config';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  currentPath?: string;
  seoTitle?: string;
  seoDescription?: string;
  seoImage?: string;
  seoKeywords?: string;
}

const currentLocale = getLocaleFromUrl(Astro.url);

const { 
  title = "Renasci Medical Spa - Renueva tu piel", 
  description = "Tratamientos estéticos avanzados en Renasci Medical Spa. Botox, rellenos, sculptra y más. Renueva tu piel con los mejores especialistas.",
  lang = currentLocale,
  currentPath = Astro.url.pathname,
  seoTitle = title,
  seoDescription = description,
  seoImage = "/og-image.jpg",
  seoKeywords = "medical spa, tratamientos estéticos, belleza, Utah, botox, rellenos"
} = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Component with comprehensive meta tags -->
    <SEO 
      title={seoTitle}
      description={seoDescription}
      url={Astro.url.pathname}
      image={seoImage}
      locale={lang}
      keywords={seoKeywords}
    />
    
    <!-- Google Fonts with display=swap for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preload critical resources -->
    <link rel="preload" href="/images/Renasci logo.png" as="image" type="image/png">
    
    <!-- Dynamic i18n script -->
    <script src="/src/scripts/i18n.js" type="module"></script>
  </head>
  <body>
    <HeaderNav currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
    <LanguageToggle />
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
  }
  
  body {
    margin: 0;
    padding: 0;
  }
</style>