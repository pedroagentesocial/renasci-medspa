                  p1: "Supports cellular energy and recovery to align with focus and vitality goals.",
                  p2: "Personalized dosing ensures comfort and consistency.",
                  p3: "Pairs with nutrition and rest for better synergy."
                },
                benefits: {
                  title: "Benefits",
                  subtitle: "Why consider NAD+",
                  items: [
                    { title: "Energy", text: "Cellular support." },
                    { title: "Focus", text: "Clarity and performance." },
                    { title: "Recovery", text: "Supports training goals." }
                  ]
                },
                process: {
                  title: "Process",
                  subtitle: "Consultation, plan, dosing and review",
                  steps: [
                    { title: "Consultation", text: "Goals and safety review." },
                    { title: "Plan", text: "Doses and route." },
                    { title: "Dosing", text: "Guided administration." },
                    { title: "Review", text: "Monitor and adjust." }
                  ]
                },
                faq: {
                  title: "Frequently Asked Questions",
                  subtitle: "Common questions about NAD+",
                  items: [
                    { q: "Is it safe?", a: "Used under supervision with monitoring." },
                    { q: "Energy?", a: "Supports cellular function." },
                    { q: "Combine?", a: "May pair with other therapies as indicated." }
                  ]
                }
              },
              footer: { contact_title: "Contact Us", hours_label: "Hours", privacy: "Privacy", terms: "Terms", sitemap: "Sitemap", social_title: "Follow Us", follow_paragraph: "Follow us on social media for beauty tips, exclusive promotions and amazing transformations.", hours_mon_fri: "Mon - Fri: 9:00 AM - 7:00 PM", hours_sat: "Sat: 9:00 AM - 5:00 PM", hours_sun: "Sun: Closed", about_paragraph: "Renasci Medical Spa is your destination for advanced aesthetic treatments. We renew your skin with top specialists and cutting‑edge technology.", cert_fda: "FDA Certified", cert_licensed: "Licensed", location_label: "Location", copyright_suffix: "All rights reserved." }
            }
          };
          this.translations = this.dict[this.currentLang] || {};
          document.documentElement.lang = this.currentLang;
          this.updateLanguageSwitcher();
          this.applyTranslations();
        }
        resolveInitialLang() {
          const urlLang = new URLSearchParams(window.location.search).get('lang');
          if (urlLang === 'en' || urlLang === 'es') return urlLang;
          const saved = localStorage.getItem('language') || localStorage.getItem('renasci-language');
          if (saved === 'en' || saved === 'es') return saved;
          const docLang = document.documentElement.lang;
          if (docLang === 'en' || docLang === 'es') return docLang;
          return 'es';
        }
        switchLanguage(lang) {
          this.currentLang = lang === 'en' ? 'en' : 'es';
          localStorage.setItem('language', this.currentLang);
          localStorage.setItem('renasci-language', this.currentLang);
          document.documentElement.lang = this.currentLang;
          this.updateLanguageSwitcher();
          this.translations = this.dict[this.currentLang] || {};
          this.applyTranslations();
          const evt = new CustomEvent('languageApplied', { detail: { language: this.currentLang } });
          window.dispatchEvent(evt);
        }
        async loadTranslations(lang) { this.translations = this.dict[lang] || {}; }
        getNested(obj, path) {
          try {
            return path.split('.').reduce((o, k) => (o ? o[k] : undefined), obj);
          } catch { return undefined }
        }
        applyTranslations() {
          const elements = document.querySelectorAll('[data-i18n]');
          elements.forEach((el) => {
            const key = el.getAttribute('data-i18n');
            let value = this.getNested(this.translations, key);
            if (typeof value === 'string') {
              if (el.hasAttribute('placeholder')) {
                el.setAttribute('placeholder', value);
              } else {
                el.innerHTML = value;
              }
            }
          });
          const titleEl = document.querySelector('title[data-i18n]');
          if (titleEl) {
            const key = titleEl.getAttribute('data-i18n');
            const value = this.getNested(this.translations, key);
            if (typeof value === 'string') titleEl.textContent = value;
          }
        }
        updateLanguageSwitcher() {
          const btn = document.querySelector('.language-switcher-button');
          if (btn) {
            const flag = btn.querySelector('.flag');
            const text = btn.querySelector('.lang-text');
            if (this.currentLang === 'es') {
              if (flag) flag.textContent = '🇪🇸';
              if (text) text.textContent = 'ES';
            } else {
              if (flag) flag.textContent = '🇺🇸';
              if (text) text.textContent = 'EN';
            }
          }
          const options = document.querySelectorAll('.lang-option');
          options.forEach((opt) => {
            const l = opt.getAttribute('data-lang');
            if (l === this.currentLang) opt.classList.add('active'); else opt.classList.remove('active');
          });
        }
        getCurrentLanguage() { return this.currentLang; }
      }
      let i18nManager;
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => { i18nManager = new I18nManager(); window.i18nManager = i18nManager; });
      } else {
        i18nManager = new I18nManager(); window.i18nManager = i18nManager;
      }
    </script>
    <SEO title={seoTitle} description={seoDescription} url={Astro.url.pathname} image={seoImage} locale={lang} keywords={seoKeywords} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Allura&family=Sacramento&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="/icons/flor-renasci.svg" />
  </head>
  <body data-path={currentPath}>
