      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "17:00" }
      ],
      "sameAs": [
        "https://www.instagram.com/renascimedicalspa/",
        "https://www.facebook.com/profile.php?id=61580623082047"
      ],
      "medicalSpecialty": ["CosmeticMedicine", "Dermatology", "PlasticSurgery"],
      "knowsLanguage": ["en", "es"],
      "areaServed": [
        { "@type": "City", "name": "Salt Lake City", "sameAs": "https://en.wikipedia.org/wiki/Salt_Lake_City" },
        { "@type": "City", "name": "Midvale", "sameAs": "https://en.wikipedia.org/wiki/Midvale,_Utah" },
        { "@type": "City", "name": "Sandy", "sameAs": "https://en.wikipedia.org/wiki/Sandy,_Utah" },
        { "@type": "City", "name": "Murray", "sameAs": "https://en.wikipedia.org/wiki/Murray,_Utah" },
        { "@type": "City", "name": "South Jordan", "sameAs": "https://en.wikipedia.org/wiki/South_Jordan,_Utah" },
        { "@type": "City", "name": "Draper", "sameAs": "https://en.wikipedia.org/wiki/Draper,_Utah" },
        { "@type": "City", "name": "West Jordan" },
        { "@type": "City", "name": "Cottonwood Heights" },
        { "@type": "City", "name": "Holladay" },
        { "@type": "City", "name": "Taylorsville" },
        { "@type": "State", "name": "Utah", "sameAs": "https://en.wikipedia.org/wiki/Utah" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Aesthetic & Wellness Treatments",
        "itemListElement": [
          { "@type": "OfferCatalog", "name": "Injectables & Neurotoxins", "url": "https://renascimedspa.com/services/injectables-treatments" },
          { "@type": "OfferCatalog", "name": "Dermal Fillers", "url": "https://renascimedspa.com/services/dermal-fillers" },
          { "@type": "OfferCatalog", "name": "Biostimulators (Sculptra)", "url": "https://renascimedspa.com/services/biostimulators" },
          { "@type": "OfferCatalog", "name": "Facial Treatments", "url": "https://renascimedspa.com/services/facial-treatments" },
          { "@type": "OfferCatalog", "name": "Body Contouring Treatments", "url": "https://renascimedspa.com/services/body-contouring-treatments" },
          { "@type": "OfferCatalog", "name": "Microneedling & PRP", "url": "https://renascimedspa.com/services/microneedling" },
          { "@type": "OfferCatalog", "name": "IV Therapy", "url": "https://renascimedspa.com/services/iv-therapy" },
          { "@type": "OfferCatalog", "name": "IgniteRF Skin Tightening", "url": "https://renascimedspa.com/services/igniterf" },
          { "@type": "OfferCatalog", "name": "Bioidentical Hormone Replacement Therapy (BHRT)", "url": "https://renascimedspa.com/services/biodentical-hormone-therapy" },
          { "@type": "OfferCatalog", "name": "Peptide Therapy", "url": "https://renascimedspa.com/services/therapy-peptide" },
          { "@type": "OfferCatalog", "name": "Medically Supervised Weight Loss", "url": "https://renascimedspa.com/services/medically-supervised-weight-loss" },
          { "@type": "OfferCatalog", "name": "Stem Cells & Regenerative Treatments", "url": "https://renascimedspa.com/services/stem-cells-treatment" }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "27",
        "bestRating": "5",
        "worstRating": "1"
      }
    })} />

    {currentPath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Dónde está ubicado Renasci Medical Spa en Utah?",
            "acceptedAnswer": { "@type": "Answer", "text": "Renasci Medical Spa está en 6770 S 900 E, Suite 100, Midvale, UT 84047. Atendemos clientes de Salt Lake City, Sandy, Murray, South Jordan, Draper y todo el valle de Salt Lake." }
          },
          {
            "@type": "Question",
            "name": "¿Cuál es el horario de atención?",
            "acceptedAnswer": { "@type": "Answer", "text": "Lunes a viernes de 9:00 AM a 7:00 PM, sábados de 9:00 AM a 5:00 PM. Domingos cerrado." }
          },
          {
            "@type": "Question",
            "name": "¿Cómo agendo una cita en Renasci Medical Spa?",
            "acceptedAnswer": { "@type": "Answer", "text": "Puedes agendar llamando al (385) 609-2840, escribiendo a orders@renascimedspa.com, o reservando online en nuestra página de contacto. Confirmamos tu cita en menos de 24 horas." }
          },
          {
            "@type": "Question",
            "name": "¿Qué tratamientos ofrecen?",
            "acceptedAnswer": { "@type": "Answer", "text": "Ofrecemos Botox, Dysport, Xeomin, rellenos dérmicos, Sculptra, Microneedling, PRP, IV Therapy, IgniteRF, terapia hormonal bioidéntica (BHRT), terapia con péptidos y programas médicamente supervisados de pérdida de peso." }
          },
          {
            "@type": "Question",
            "name": "¿La consulta inicial es gratuita?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. Ofrecemos una consulta inicial gratuita para evaluar tus objetivos y diseñar un plan personalizado de tratamiento." }
          },
          {
            "@type": "Question",
            "name": "¿Atienden en español e inglés?",
            "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nuestro equipo te atiende en español e inglés con la misma calidad y atención profesional." }
          }
        ]
      })} />
    )}

    <!-- JSON-LD: WebSite schema with SearchAction -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://renascimedspa.com/#website",
      "name": "Renasci Medical Spa",
      "alternateName": "Renasci Medspa Utah",
      "url": "https://renascimedspa.com",
      "publisher": { "@id": "https://renascimedspa.com/#business" },
      "inLanguage": ["es-US", "en-US"],
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://renascimedspa.com/services?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://www.googletagmanager.com">
    <link rel="dns-prefetch" href="https://www.google-analytics.com">
    {currentPath === '/' && (
      <link rel="preload" as="image" href="/img/services/hero-index.jpeg?v=2" fetchpriority="high" />
    )}
    {currentPath.startsWith('/services') && (
      <link rel="preload" as="image" href="/img/services/hero-services.jpg" fetchpriority="high" />
    )}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Allura&family=Sacramento&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" sizes="any" href="/icons/flor-renasci.svg?v=3" />
    <link rel="shortcut icon" href="/icons/flor-renasci.svg?v=3" type="image/svg+xml" />
    <link rel="mask-icon" href="/icons/flor-renasci.svg?v=3" color="#F3A2A7" />
    <Analytics />
  </head>
  <body data-path={currentPath}>
    <HeaderNav />
    <main>
      <slot />
    </main>
    <Footer />
    <LanguageToggle />
  </body>
</html>

<style is:global>
  html { font-family: system-ui, sans-serif; }
  body { margin: 0; padding: 0; }
  @font-face {
    font-family: 'Elmatia';
    src: url('../styles/fonts/Elmatia.ttf') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Safia March';
    src: local('Safia March'), local('Safira March'), url('../styles/fonts/Safira March Personal Use Only.ttf') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: block;
  }
  .font-hero-elmatia { font-family: 'Safia March', 'Elmatia', cursive; font-weight: 400; letter-spacing: -0.02em; }
  .font-hero-allura { font-family: 'Allura', cursive; font-weight: 400; letter-spacing: -0.03em; }
  .font-hero-sacramento { font-family: 'Sacramento', cursive; font-weight: 400; letter-spacing: -0.02em; }
  body[data-path^="/services"] main > section.bg-black.text-white.text-center:first-of-type { position: relative; }
  body[data-path^="/services"] main > section.bg-black.text-white.text-center:first-of-type::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('/img/services/hero-services.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  body[data-path^="/services"] main > section.bg-black.text-white.text-center:first-of-type::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 0;
  }
  body[data-path^="/services"] main > section.bg-black.text-white.text-center:first-of-type > * { position: relative; z-index: 1; }
</style>
