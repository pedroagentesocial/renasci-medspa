---
import HeaderNav from '../components/HeaderNav.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import LanguageToggle from '../components/LanguageToggle.astro';
import Analytics from '../components/Analytics.astro';
import { getLocaleFromUrl } from '../i18n/config';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  currentPath?: string;
  seoTitle?: string;
  seoDescription?: string;
  seoImage?: string;
  seoKeywords?: string;
}

const currentLocale = getLocaleFromUrl(Astro.url);
const {
  title = 'Renasci Medical Spa Utah | Botox, Rellenos y Tratamientos Estéticos en Salt Lake City',
  description = 'Medical Spa en Midvale, Utah atendiendo Salt Lake City, Sandy, Murray, South Jordan y Draper. Botox, rellenos dérmicos, Sculptra, IV Therapy, IgniteRF, PRP, microneedling, BHRT y pérdida de peso. Consulta gratuita.',
  lang = currentLocale,
  currentPath = Astro.url.pathname,
  seoTitle = title,
  seoDescription = description,
  seoImage = '/og-image.jpg',
  seoKeywords = 'medical spa Utah, medspa Salt Lake City, botox Utah, botox Salt Lake City, rellenos dérmicos Utah, sculptra Utah, medical spa Midvale, medical spa Sandy Utah, IV therapy Utah, IgniteRF, PRP Utah, microneedling Utah, BHRT Utah, pérdida de peso Utah, Renasci Medical Spa'
} = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        try {
          var urlLang = new URLSearchParams(location.search).get('lang');
          var stored = localStorage.getItem('renasci-language') || localStorage.getItem('language');
          var nav = (navigator.language || '').toLowerCase();
          var lang = (urlLang === 'en' || urlLang === 'es') ? urlLang
                   : (stored === 'en' || stored === 'es') ? stored
                   : nav.indexOf('en') === 0 ? 'en'
                   : 'es';
          document.documentElement.lang = lang;
          document.documentElement.setAttribute('data-lang', lang);
        } catch (e) {}
      })();
    </script>
    <script>
      import { dict } from '../i18n/runtime-dict';
      class I18nManager {
        constructor() {
          this.currentLang = this.resolveInitialLang();
          this.dict = dict;
          this.translations = this.dict[this.currentLang] || {};
          document.documentElement.lang = this.currentLang;
          this.updateLanguageSwitcher();
          this.applyTranslations();
        }
        resolveInitialLang() {
          const urlLang = new URLSearchParams(window.location.search).get('lang');
          if (urlLang === 'en' || urlLang === 'es') return urlLang;
          const saved = localStorage.getItem('renasci-language') || localStorage.getItem('language');
          if (saved === 'en' || saved === 'es') return saved;
          const docLang = document.documentElement.lang;
          if (docLang === 'en' || docLang === 'es') return docLang;
          const nav = (navigator.language || '').toLowerCase();
          if (nav.startsWith('en')) return 'en';
          return 'es';
        }
        switchLanguage(lang) {
          this.currentLang = lang === 'en' ? 'en' : 'es';
          localStorage.setItem('renasci-language', this.currentLang);
          localStorage.setItem('language', this.currentLang);
          document.documentElement.lang = this.currentLang;
          this.updateLanguageSwitcher();
          this.translations = this.dict[this.currentLang] || {};
          this.applyTranslations();
          const evt = new CustomEvent('languageApplied', { detail: { language: this.currentLang } });
          window.dispatchEvent(evt);
          const legacy = new CustomEvent('languageChanged', { detail: { language: this.currentLang } });
          window.dispatchEvent(legacy);
        }
        async loadTranslations(lang) { this.translations = this.dict[lang] || {}; }
        getNested(obj, path) {
          try {
            return path.split('.').reduce((o, k) => (o ? o[k] : undefined), obj);
          } catch { return undefined }
        }
        applyTranslations() {
          const lang = this.currentLang;
          document.querySelectorAll('[data-i18n]').forEach((el) => {
            const key = el.getAttribute('data-i18n');
            const value = this.getNested(this.translations, key);
            if (typeof value !== 'string') return;
            if (el.hasAttribute('placeholder')) el.setAttribute('placeholder', value);
            else el.innerHTML = value;
          });
          const titleEl = document.querySelector('title[data-i18n]');
          if (titleEl) {
            const key = titleEl.getAttribute('data-i18n');
            const value = this.getNested(this.translations, key);
            if (typeof value === 'string') titleEl.textContent = value;
          }
          document.querySelectorAll('[data-t-es]').forEach((el) => {
            const es = el.getAttribute('data-t-es') || '';
            const en = el.getAttribute('data-t-en') || es;
            el.textContent = lang === 'en' ? en : es;
          });
          document.querySelectorAll('[data-alt-es]').forEach((el) => {
            const es = el.getAttribute('data-alt-es') || '';
            const en = el.getAttribute('data-alt-en') || es;
            el.setAttribute('alt', lang === 'en' ? en : es);
          });
          document.querySelectorAll('[data-ph-es]').forEach((el) => {
            const es = el.getAttribute('data-ph-es') || '';
            const en = el.getAttribute('data-ph-en') || es;
            el.setAttribute('placeholder', lang === 'en' ? en : es);
          });
        }
        updateLanguageSwitcher() {
          const btn = document.querySelector('.language-switcher-button');
          if (btn) {
            const flag = btn.querySelector('.flag');
            const text = btn.querySelector('.lang-text');
            if (this.currentLang === 'es') {
              if (flag) flag.textContent = '🇪🇸';
              if (text) text.textContent = 'ES';
            } else {
              if (flag) flag.textContent = '🇺🇸';
              if (text) text.textContent = 'EN';
            }
          }
          const options = document.querySelectorAll('.lang-option');
          options.forEach((opt) => {
            const l = opt.getAttribute('data-lang');
            if (l === this.currentLang) opt.classList.add('active'); else opt.classList.remove('active');
          });
        }
        getCurrentLanguage() { return this.currentLang; }
      }
      let i18nManager;
      const bootI18n = () => {
        if (!i18nManager) {
          i18nManager = new I18nManager();
          window.i18nManager = i18nManager;
        } else {
          i18nManager.applyTranslations();
          i18nManager.updateLanguageSwitcher();
          document.documentElement.lang = i18nManager.getCurrentLanguage();
        }
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootI18n);
      } else {
        bootI18n();
      }
      document.addEventListener('astro:page-load', bootI18n);
    </script>
    <SEO title={seoTitle} description={seoDescription} url={Astro.url.pathname} image={seoImage} locale={lang} keywords={seoKeywords} />

    <!-- JSON-LD: MedicalBusiness schema for Google rich results -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["MedicalBusiness", "MedicalClinic", "LocalBusiness"],
      "@id": "https://renascimedspa.com/#business",
      "name": "Renasci Medical Spa",
